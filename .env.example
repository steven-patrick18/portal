# Copy to .env and fill in real values.  NEVER commit .env to git.

# ── Server ─────────────────────────────────────────────
NODE_ENV=production
PORT=6672
DB_PATH=./data/portal.db

# Generate a strong random secret on the VPS (32+ bytes):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=change-me-in-production-32-bytes-minimum

# ── Company defaults ─────────────────────────────────
# Fallbacks when nothing is set in Settings → Company & Logo. Once you save
# branding in the UI, the DB values win.
COMPANY_NAME=Portal Garments Pvt Ltd
COMPANY_GSTIN=
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
# COMPANY_STATE drives intra-state vs inter-state GST (CGST+SGST vs IGST)
COMPANY_STATE=

# ── SMS Gateway (Capcom Android phone) ──────────────
# All SMS goes through your Android-phone gateway. No DLT, no sender ID.
# Configure these via the UI: Settings → SMS Settings (preferred), or here.
# SMS_PROVIDER=gateway
# SMS_GATEWAY_URL=https://api.sms-gate.app/3rdparty/v1
# SMS_GATEWAY_USERNAME=
# SMS_GATEWAY_PASSWORD=

# ── GST defaults ─────────────────────────────────────
DEFAULT_GST_RATE=5
