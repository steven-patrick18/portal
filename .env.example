# Copy to .env and fill in real values.  NEVER commit .env to git.

# ── Server ─────────────────────────────────────────────
NODE_ENV=production
PORT=6672
DB_PATH=./data/portal.db

# Generate a strong random secret on the VPS (32+ bytes):
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=change-me-in-production-32-bytes-minimum

# ── Company defaults ─────────────────────────────────
# These act as fallbacks when nothing is set in Settings → Company & Logo.
# Once you save branding in the UI, the DB values win.
COMPANY_NAME=Portal Garments Pvt Ltd
COMPANY_GSTIN=
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
# COMPANY_STATE drives intra-state vs inter-state GST (CGST+SGST vs IGST)
COMPANY_STATE=

# ── MSG91 (SMS / WhatsApp notifications) ─────────────
# Leave MSG91_ENABLED=false to keep the app in stub mode (no real sending).
MSG91_AUTH_KEY=
MSG91_SENDER_ID=PORTAL
MSG91_DLT_TEMPLATE_PAYMENT=
MSG91_DLT_TEMPLATE_OUTSTANDING=
MSG91_WHATSAPP_TEMPLATE=
MSG91_ENABLED=false

# ── GST defaults ─────────────────────────────────────
DEFAULT_GST_RATE=5
