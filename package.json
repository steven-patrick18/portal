{
  "name": "portal",
  "version": "0.1.0",
  "private": true,
  "description": "Garment Manufacturing ERP - Phase 1",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node --test test/*.test.js",
    "seed-demo": "node src/db/seedDemo.js",
    "reset-db": "node -e \"require('fs').existsSync('./data/portal.db') && require('fs').rmSync('./data/portal.db'); require('fs').existsSync('./data/portal.db-wal') && require('fs').rmSync('./data/portal.db-wal'); require('fs').existsSync('./data/portal.db-shm') && require('fs').rmSync('./data/portal.db-shm'); console.log('DB reset.')\""
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-rate-limit": "^8.4.1",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "supertest": "^7.2.2"
  },
