<%- include('../partials/header') %>
<h4>New Admin Fund</h4>
<form method="post" action="/admin-funds" class="card p-3" style="max-width:560px">
  <div class="mb-3">
    <label class="form-label">Admin *</label>
    <select name="user_id" class="form-select" required>
      <option value="">-- choose --</option>
      <% candidates.forEach(c => { %>
        <option value="<%= c.id %>"><%= c.name %> · <%= c.role %> · <%= c.email %></option>
      <% }) %>
    </select>
    <div class="form-text">Only active admin/owner accounts without an existing fund are listed.</div>
  </div>
  <div class="mb-3">
    <label class="form-label">Opening Balance</label>
    <input name="opening_balance" type="number" step="0.01" class="form-control" value="0">
    <div class="form-text">Whatever cash you've already handed over. Future top-ups go through the Top-up button.</div>
  </div>
  <div class="mb-3">
    <label class="form-label">Notes</label>
    <textarea name="notes" class="form-control" rows="2" placeholder="e.g. petty cash for finishing-section daily expenses"></textarea>
  </div>
  <div class="d-flex gap-2">
    <button class="btn btn-primary">Create Fund</button>
    <a href="/admin-funds" class="btn btn-secondary">Cancel</a>
  </div>
</form>
<%- include('../partials/footer') %>
