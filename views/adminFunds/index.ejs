<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-wallet2"></i> Admin Funds</h4>
    <small class="text-muted">Cash floats for designated admins. Balance updates live from top-ups − expenses debited.</small>
  </div>
  <% if (canManage) { %>
    <a href="/admin-funds/new" class="btn btn-sm btn-primary"><i class="bi bi-plus"></i> New Fund</a>
  <% } %>
</div>

<% if (canManage) { %>
<div class="row g-3 mb-3">
  <div class="col-md-3 col-6"><div class="kpi-card kpi-denim">
    <i class="bi bi-people-fill kpi-icon"></i>
    <div class="kpi-label">Funds</div><div class="kpi-value"><%= totals.funds %></div>
  </div></div>
  <div class="col-md-3 col-6"><div class="kpi-card kpi-marigold">
    <i class="bi bi-arrow-up-circle kpi-icon"></i>
    <div class="kpi-label">Topped-up (lifetime)</div><div class="kpi-value"><%= fmtINR(totals.topups + totals.opening) %></div>
  </div></div>
  <div class="col-md-3 col-6"><div class="kpi-card kpi-coral">
    <i class="bi bi-arrow-down-circle kpi-icon"></i>
    <div class="kpi-label">Expenses debited</div><div class="kpi-value"><%= fmtINR(totals.expenses) %></div>
  </div></div>
  <div class="col-md-3 col-6"><div class="kpi-card kpi-emerald">
    <i class="bi bi-cash-stack kpi-icon"></i>
    <div class="kpi-label">Live balance (all funds)</div><div class="kpi-value"><%= fmtINR(totals.balance) %></div>
  </div></div>
</div>
<% } %>

<div class="card"><div class="table-responsive">
<table class="table table-sm m-0 align-middle">
<thead><tr>
  <th>Admin</th><th>Role</th>
  <th class="text-end">Opening</th>
  <th class="text-end">Topped-up</th>
  <th class="text-end">Expenses</th>
  <th class="text-end">Balance</th>
  <th class="text-center">Active</th>
  <th></th>
</tr></thead>
<tbody>
<% funds.forEach(f => { %>
<tr class="<%= !f.active ? 'text-muted' : '' %>">
  <td>
    <a href="/admin-funds/<%= f.id %>" class="text-decoration-none">
      <strong><%= f.user_name %></strong>
    </a>
    <div class="small text-muted"><%= f.email %></div>
  </td>
  <td><span class="badge bg-light text-dark"><%= f.role %></span></td>
  <td class="text-end"><%= fmtINR(f.opening_balance) %></td>
  <td class="text-end" style="color: var(--marigold-600)"><%= fmtINR(f.topups_total) %></td>
  <td class="text-end" style="color: var(--coral-600)"><%= fmtINR(f.expenses_total) %></td>
  <td class="text-end fw-bold <%= f.balance < 0 ? 'text-danger' : '' %>"><%= fmtINR(f.balance) %></td>
  <td class="text-center">
    <% if (f.active) { %><span class="badge bg-success">yes</span>
    <% } else { %><span class="badge bg-secondary">no</span><% } %>
  </td>
  <td><a href="/admin-funds/<%= f.id %>" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-right"></i></a></td>
</tr>
<% }) %>
<% if (funds.length === 0) { %>
  <tr><td colspan="8" class="text-muted text-center py-4">
    <% if (isLimited) { %>You don't have a fund assigned.<% } else { %>No funds yet. Click <strong>New Fund</strong> to assign one.<% } %>
  </td></tr>
<% } %>
</tbody></table></div></div>
<%- include('../partials/footer') %>
