<%- include('../partials/header') %>
<div class="login-card card shadow-sm">
  <div class="card-body p-4">
    <h4 class="mb-3 text-center"><%= companyName %></h4>
    <p class="text-muted text-center small">Sign in to your account</p>
    <form method="post" action="/login">
      <div class="mb-3">
        <label class="form-label">Email</label>
        <input name="email" type="email" class="form-control" required autofocus>
      </div>
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input name="password" type="password" class="form-control" required>
      </div>
      <button class="btn btn-primary w-100">Login</button>
    </form>
    <hr>
    <small class="text-muted d-block">Default seed users (password <code>admin123</code>):</small>
    <small class="text-muted">owner@portal.local · admin@portal.local · sales1@portal.local</small>
  </div>
</div>
<%- include('../partials/footer') %>
