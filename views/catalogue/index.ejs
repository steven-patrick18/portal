<%- include('../partials/header') %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700;900&family=Inter:wght@300;400;500;600&display=swap" media="print" onload="this.media='all'">
<link rel="stylesheet" href="/css/catalogue-premium.css">

<div class="cat-premium">
  <!-- Cover masthead -->
  <header class="d-flex justify-content-between align-items-end flex-wrap gap-3" style="padding: 2.5rem 0 1.5rem; border-bottom: 1px solid var(--line);">
    <div>
      <div class="eyebrow"><%= companyName %> · The Catalogue</div>
      <h1 class="editorial-display" style="margin: .4rem 0 0;">Collection</h1>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <% if (user && user.role === 'owner') { %>
        <a href="/catalogue/templates" class="btn-edit btn-edit-ghost">Templates · <%= templateCount %></a>
        <a href="/catalogue/settings" class="btn-edit btn-edit-ghost">AI Settings</a>
        <a href="/catalogue/new" class="btn-edit">+ New Item</a>
      <% } %>
    </div>
  </header>

  <% if (!items || items.length === 0) { %>
    <div style="padding: 6rem 0; text-align:center;">
      <div class="eyebrow" style="margin-bottom: 1rem;">— A blank canvas —</div>
      <h2 class="editorial-serif" style="font-size:2rem; margin:0 0 1rem;">No items yet.</h2>
      <p class="editorial-body" style="margin: 0 auto 2rem;">Upload a flat-lay shot of any garment. The AI dresses one of your model templates with it, in the scene you pick.</p>
      <% if (user && user.role === 'owner') { %>
        <% if (templateCount === 0) { %>
          <a href="/catalogue/templates" class="btn-edit">Set up model templates first</a>
        <% } else { %>
          <a href="/catalogue/new" class="btn-edit">Create the first item</a>
        <% } %>
      <% } %>
    </div>
  <% } else { %>
    <div style="padding: 0;">
      <% items.forEach((it, idx) => { %>
        <a href="/catalogue/<%= it.id %>" class="editorial-card <%= idx % 2 === 1 ? 'flip' : '' %>">
          <div class="editorial-card-hero" style="<%= it.hero ? `background-image:url('${it.hero}')` : '' %>"></div>
          <div class="editorial-card-text">
            <div class="eyebrow">№ <%= String(it.id).padStart(3, '0') %>
              <% if (it.status === 'generating') { %><span style="margin-left:.6rem; color: var(--accent)">· generating…</span>
              <% } else if (it.status === 'failed') { %><span style="margin-left:.6rem; color:#a02020">· failed</span>
              <% } %>
            </div>
            <h2><%= it.name %></h2>
            <% if (it.editorial_copy) { %>
              <p class="editorial-body"><%= it.editorial_copy %></p>
            <% } else if (it.description) { %>
              <p class="editorial-body" style="color: var(--muted)"><%= it.description %></p>
            <% } %>
            <div class="meta">
              <span><%= it.angle_count %> angle<%= it.angle_count===1?'':'s' %></span>
              <span class="dot">·</span>
              <span><%= (it.scene_key || 'pure_white').replace(/_/g,' ').replace(/\b\w/g, c => c.toUpperCase()) %></span>
              <span class="dot">·</span>
              <span>₹<%= (it.total_cost_inr||0).toFixed(0) %></span>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>

  <footer style="padding: 4rem 0 2rem; text-align:center;">
    <div class="eyebrow">— <%= companyName %> · <%= new Date().getFullYear() %> —</div>
  </footer>
</div>

<%- include('../partials/footer') %>
