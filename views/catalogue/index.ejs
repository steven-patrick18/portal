<%- include('../partials/header') %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Inter:wght@300;400;500;600&display=swap" media="print" onload="this.media='all'">
<link rel="stylesheet" href="/css/catalogue-premium.css">

<%
  // Roman numerals for the chapter index — keeps the layout feeling
  // like a printed edition rather than a CRUD list.
  function roman(num) {
    const lookup = [
      ['M',1000],['CM',900],['D',500],['CD',400],
      ['C',100],['XC',90],['L',50],['XL',40],
      ['X',10],['IX',9],['V',5],['IV',4],['I',1]
    ];
    let n = num, out = '';
    for (const [r, v] of lookup) { while (n >= v) { out += r; n -= v; } }
    return out;
  }
  const year = new Date().getFullYear();
  const yearRoman = roman(year);
%>

<div class="cat-cover">
  <!-- Editor's tools — pushed top-right, deliberately quiet. Only the
       owner sees these; viewers see a clean cover. -->
  <% if (user && user.role === 'owner') { %>
    <nav class="tools-strip">
      <a href="/catalogue/templates" class="tools-link">Templates · <%= templateCount %></a>
      <a href="/catalogue/settings"  class="tools-link">AI Settings</a>
      <a href="/catalogue/new"       class="tools-link tools-cta">+ New Item</a>
    </nav>
  <% } %>

  <!-- Cover spread -->
  <header class="cover">
    <div class="cover-eyebrow">Volume <%= roman(items.length || 1) %> · MMXXVI</div>
    <h1 class="cover-title">Collection</h1>
    <div class="cover-rule"></div>
    <div class="cover-credit">A <%= companyName %> Edition</div>
  </header>

  <% if (!items || items.length === 0) { %>
    <!-- Empty front-matter spread -->
    <section class="blank-spread">
      <div class="ornament">✦</div>
      <h2>The first impression is yet to be made.</h2>
      <p>Lay any garment flat. The atelier will dress one of your house models, frame the light, set the scene — and bind it into this volume.</p>
      <% if (user && user.role === 'owner') { %>
        <% if (templateCount === 0) { %>
          <a href="/catalogue/templates" class="blank-cta">Set up the house models</a>
        <% } else { %>
          <a href="/catalogue/new" class="blank-cta">Open the first chapter</a>
        <% } %>
      <% } %>
    </section>
  <% } else { %>
    <!-- Numbered chapters — alternating sides, generous whitespace -->
    <main>
      <% items.forEach((it, idx) => { %>
        <a href="/catalogue/<%= it.id %>" class="chapter">
          <div class="chapter-image" style="<%= it.hero ? `background-image:url('${it.hero}')` : '' %>"></div>
          <div class="chapter-text">
            <div class="chapter-numeral"><%= roman(idx + 1) %></div>
            <h2><%= it.name %></h2>
            <% if (it.editorial_copy) { %>
              <p class="blurb"><%= it.editorial_copy %></p>
            <% } else if (it.description) { %>
              <p class="blurb" style="color: var(--muted); font-style: normal;"><%= it.description %></p>
            <% } else { %>
              <p class="blurb" style="color: var(--muted);">— Awaiting its caption —</p>
            <% } %>
            <div class="meta">
              <% if (it.status === 'generating') { %>
                <span style="color: var(--accent);">In production</span>
              <% } else if (it.status === 'failed') { %>
                <span style="color:#a02020;">Returned for re-shoot</span>
              <% } else { %>
                <span><%= it.angle_count %> Plate<%= it.angle_count===1?'':'s' %></span>
              <% } %>
              <% if (it.scene_key && it.scene_key !== 'pure_white') { %>
                <span class="dot">·</span>
                <span><%= (it.scene_key || '').replace(/_/g,' ').replace(/\b\w/g, c => c.toUpperCase()) %></span>
              <% } %>
              <% if (it.cloth_type) { %>
                <span class="dot">·</span>
                <span><%= it.cloth_type === 'lower' ? 'Bottoms' : it.cloth_type === 'overall' ? 'Full' : 'Top' %></span>
              <% } %>
            </div>
          </div>
        </a>
      <% }) %>
    </main>
  <% } %>

  <!-- Colophon — typeset like a printed edition's imprint page -->
  <footer class="colophon">
    <div class="colophon-rule"></div>
    <div class="colophon-mark"><%= companyName %></div>
    <div class="colophon-line">Volume <%= roman(items.length || 1) %> · <%= yearRoman %></div>
    <div class="colophon-line">Set in Playfair · Bound at the atelier</div>
    <div class="colophon-line" style="margin-top: 1.4rem; opacity: 0.6;">© <%= year %> · All rights reserved</div>
  </footer>
</div>

<%- include('../partials/footer') %>
