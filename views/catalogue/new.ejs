<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0"><i class="bi bi-plus-square"></i> New Catalogue Item</h4>
  <a href="/catalogue" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

<% if (templateCount === 0) { %>
  <div class="alert alert-warning">
    <strong>⚠ No model templates active.</strong> You can create the item now, but you won't be able to generate AI angles
    until you upload at least one model template at <a href="/catalogue/templates">Model Templates</a>.
  </div>
<% } %>

<form method="post" action="/catalogue/new" enctype="multipart/form-data" class="card p-3" style="max-width:840px">
  <div class="row g-3">
    <div class="col-md-8">
      <label class="form-label">Item name <span class="text-danger">*</span></label>
      <input name="name" class="form-control" required placeholder="e.g. Floral Cotton Kurti — Pink, M">
      <div class="form-text small">Free-form. Not linked to your product master — purely for the catalogue.</div>
    </div>
    <div class="col-md-4">
      <label class="form-label">Notes (optional)</label>
      <input name="description" class="form-control" placeholder="size, fabric, etc.">
    </div>

    <div class="col-md-6">
      <label class="form-label"><strong>Front photo</strong> <span class="text-danger">*</span></label>
      <input name="front" type="file" accept="image/*" capture="environment" class="form-control" required>
      <div class="form-text small">Lay the garment flat, daylight, plain background. The AI works best with a clean, single-garment shot.</div>
    </div>
    <div class="col-md-6">
      <label class="form-label"><strong>Back photo</strong> <span class="text-muted small">(optional but recommended)</span></label>
      <input name="back" type="file" accept="image/*" capture="environment" class="form-control">
      <div class="form-text small">Reserved for future per-angle pairing. Phase B uses the front photo for try-on.</div>
    </div>

    <!-- Gender picker — feeds straight into the auto-generation step
         below. "Both" = use every active template (most common case). -->
    <div class="col-12">
      <label class="form-label"><strong>Render on which model?</strong></label>
      <div class="btn-group" role="group">
        <input type="radio" class="btn-check" name="gender" id="ng-all"    value="all" checked>
        <label class="btn btn-outline-primary" for="ng-all">Both</label>
        <input type="radio" class="btn-check" name="gender" id="ng-female" value="female">
        <label class="btn btn-outline-primary" for="ng-female">Female</label>
        <input type="radio" class="btn-check" name="gender" id="ng-male"   value="male">
        <label class="btn btn-outline-primary" for="ng-male">Male</label>
      </div>
      <div class="form-text small">You can change this later on the item page and re-generate.</div>
    </div>

    <!-- Auto-generate toggle. Default ON so the most common path (upload
         → click button → see results) is one round-trip; OFF lets owner
         upload the photos now and generate later when fal.ai balance is
         healthy or templates change. -->
    <div class="col-12">
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="auto_generate" name="auto_generate" value="1" <%= templateCount > 0 ? 'checked' : '' %> <%= templateCount === 0 ? 'disabled' : '' %>>
        <label class="form-check-label" for="auto_generate">
          <strong>Generate AI angles immediately after upload</strong>
          <span class="text-muted small">— costs ~₹2.50 per matching template (e.g. 4 angles ≈ ₹11)</span>
        </label>
      </div>
    </div>
  </div>

  <div class="mt-3">
    <button class="btn btn-primary"><i class="bi bi-cloud-arrow-up"></i> Create &amp; Upload</button>
    <a href="/catalogue" class="btn btn-secondary">Cancel</a>
  </div>
</form>
<%- include('../partials/footer') %>
