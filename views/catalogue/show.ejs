<%- include('../partials/header') %>
<link rel="stylesheet" href="/css/catalogue-premium.css">

<div class="cat-premium">
  <!-- Top crumb + actions strip -->
  <div class="d-flex justify-content-between align-items-center" style="padding: 1.5rem 0; border-bottom: 1px solid var(--line);">
    <a href="/catalogue" class="eyebrow" style="text-decoration:none;">← The Catalogue</a>
    <div class="d-flex gap-2 flex-wrap">
      <% if (item.status === 'ready' && angles.length) { %>
        <a href="/catalogue/<%= item.id %>/pdf" class="btn-edit btn-edit-ghost">Download PDF</a>
      <% } %>
      <% if (user && user.role === 'owner') { %>
        <form method="post" action="/catalogue/<%= item.id %>/delete" class="m-0" onsubmit="return confirm('Delete this item and all generated photos?');">
          <button type="submit" class="btn-edit btn-edit-ghost" style="border-color:#a02020; color:#a02020;">Delete</button>
        </form>
      <% } %>
    </div>
  </div>

  <!-- Magazine cover spread -->
  <section class="spread-cover">
    <div class="spread-hero" style="<%= hero ? `background-image:url('${hero}')` : '' %>"></div>
    <div>
      <div class="eyebrow">№ <%= String(item.id).padStart(3, '0') %>
        <% if (item.status === 'ready')      { %><span style="margin-left:.6rem">· Ready</span>
        <% } else if (item.status === 'generating') { %><span style="margin-left:.6rem; color: var(--accent)">· Generating…</span>
        <% } else if (item.status === 'failed') { %><span style="margin-left:.6rem; color:#a02020">· Failed</span>
        <% } %>
      </div>
      <h1 class="editorial-display"><%= item.name %></h1>
      <% if (item.editorial_copy) { %>
        <p class="editorial-body"><%= item.editorial_copy %></p>
      <% } else if (item.description) { %>
        <p class="editorial-body" style="color: var(--muted); font-style: normal;"><%= item.description %></p>
      <% } %>
      <% if (user && user.role === 'owner') { %>
        <div class="meta" style="margin-top: 1.4rem; font-size:0.7rem; letter-spacing:0.16em; color: var(--muted); text-transform: uppercase;">
          <a href="#" id="btn-regen-copy" style="color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--ink);">✦ Regenerate copy</a>
          <span style="margin: 0 .8rem; opacity:.4">·</span>
          <span><%= angles.length %> angle<%= angles.length===1?'':'s' %></span>
          <span style="margin: 0 .8rem; opacity:.4">·</span>
          <span>₹<%= (item.total_cost_inr||0).toFixed(0) %></span>
        </div>
      <% } %>
    </div>
  </section>

  <!-- Generation panel — shown only to owner, integrated into the editorial flow -->
  <% if (user && user.role === 'owner') { %>
    <section style="padding: 3rem 0; border-bottom: 1px solid var(--line);" id="gen-card">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
        <div>
          <div class="eyebrow">Direction</div>
          <h2 class="editorial-serif" style="font-size:1.5rem; margin: 0.4rem 0 1rem;">Render this piece on the runway</h2>
          <div class="d-flex gap-2 flex-wrap" id="gender-picker" data-counts='<%- JSON.stringify(counts) %>'>
            <label class="scene-chip"><input type="radio" name="gender" value="all" checked>Both <span style="opacity:.5; margin-left:.4rem"><%= counts.all %></span></label>
            <label class="scene-chip"><input type="radio" name="gender" value="female">Female <span style="opacity:.5; margin-left:.4rem"><%= counts.female %></span></label>
            <label class="scene-chip"><input type="radio" name="gender" value="male">Male <span style="opacity:.5; margin-left:.4rem"><%= counts.male %></span></label>
          </div>
          <div class="meta" style="margin-top: .9rem; font-size:0.7rem;">
            <span class="eyebrow"><span id="gen-summary"></span></span>
          </div>
        </div>
        <button id="btn-gen" class="btn-edit"<%= counts.all === 0 ? ' disabled' : '' %>>Generate angles</button>
      </div>
      <div id="gen-progress" style="display:none; margin-top: 2rem;">
        <div style="height:1px; background: rgba(0,0,0,0.1); position: relative;">
          <div id="bar" style="position:absolute; top:0; left:0; height:1px; background: var(--ink); width:0; transition: width .3s ease;"></div>
        </div>
        <div class="d-flex justify-content-between" style="margin-top:.6rem; font-size:.7rem; letter-spacing:.16em; text-transform:uppercase; color: var(--muted);">
          <span id="status-text">Starting</span>
          <span id="cost-text">₹0.00</span>
        </div>
      </div>
      <% if (job && job.error) { %>
        <p style="margin-top: 2rem; padding: 1rem 1.4rem; background: #fdf6f6; color:#7a1d1d; font-size:0.9rem;">⚠ <%= job.error %></p>
      <% } %>
    </section>
  <% } %>

  <!-- Cinematic gallery — alternating sides, big and quiet -->
  <% if (angles.length > 0) { %>
    <section class="editorial-gallery" id="angle-gallery">
      <% angles.forEach((a, idx) => { %>
        <div class="frame">
          <a href="<%= a.file_path %>" target="_blank">
            <img src="<%= a.file_path %>" alt="<%= a.variant %>" loading="lazy">
          </a>
          <div class="caption-block">
            <div class="eyebrow">Plate <%= String(idx + 1).padStart(2, '0') %></div>
            <h3><%= a.variant || 'Angle' %></h3>
            <p class="editorial-body" style="font-size: 1rem;"><%= item.editorial_copy || item.description || item.name %></p>
            <div class="price">₹<%= (a.cost_inr||0).toFixed(2) %></div>
          </div>
        </div>
      <% }) %>
    </section>
  <% } %>

  <!-- Source photos appear at the END as a quiet appendix -->
  <% if (originals.length > 0) { %>
    <section style="padding: 4rem 0 2rem; border-top: 1px solid var(--line);">
      <div class="eyebrow" style="margin-bottom: 1rem;">— Appendix · Source —</div>
      <div class="d-flex gap-3 flex-wrap">
        <% originals.forEach(o => { %>
          <div style="flex: 0 0 180px;">
            <img src="<%= o.file_path %>" style="width:100%; aspect-ratio:1/1; object-fit:cover; background:#ececea;">
            <div class="eyebrow" style="margin-top:.5rem; font-size:0.65rem;"><%= o.kind === 'original_front' ? 'Front · As supplied' : 'Back · As supplied' %></div>
          </div>
        <% }) %>
        <% if (cutout) { %>
          <div style="flex: 0 0 180px;">
            <img src="<%= cutout.file_path %>" style="width:100%; aspect-ratio:1/1; object-fit:cover; background: repeating-conic-gradient(#eee 0% 25%, #fff 0% 50%) 50%/16px 16px;">
            <div class="eyebrow" style="margin-top:.5rem; font-size:0.65rem;">Cutout · BG removed</div>
          </div>
        <% } %>
      </div>
    </section>
  <% } %>

  <footer style="padding: 3rem 0 1.5rem; text-align:center;">
    <div class="eyebrow">— <%= companyName %> —</div>
  </footer>
</div>

<script>
(function () {
  // Gender summary (drives both the live count + the cost estimate).
  const picker = document.getElementById('gender-picker');
  const summary = document.getElementById('gen-summary');
  if (picker) {
    const counts = JSON.parse(picker.dataset.counts || '{}');
    function refreshGen() {
      const sel = picker.querySelector('input[name="gender"]:checked')?.value || 'all';
      const n = counts[sel] || 0;
      // Each angle now: 1 try-on (~₹2.50) + optional iclight relight (~₹3.30 if scene != pure_white). +1 BG-remove (~₹0.85).
      const isRelight = '<%= item.scene_key %>' !== 'pure_white';
      const perAngle = 2.50 + (isRelight ? 3.30 : 0);
      const total = 0.85 + n * perAngle;
      summary.textContent = `${n} plate${n===1?'':'s'} · ~₹${total.toFixed(2)}`;
      const btn = document.getElementById('btn-gen');
      if (btn) btn.disabled = (n === 0);
    }
    picker.addEventListener('change', refreshGen);
    refreshGen();
  }

  // Generate flow — same async polling as before, simpler styled progress bar.
  const btn = document.getElementById('btn-gen');
  if (btn) {
    const progress = document.getElementById('gen-progress');
    const bar = document.getElementById('bar');
    const statusText = document.getElementById('status-text');
    const costText = document.getElementById('cost-text');
    let polling = false;

    async function startGen() {
      btn.disabled = true;
      progress.style.display = '';
      statusText.textContent = 'Starting';
      bar.style.width = '5%';
      const gender = (document.querySelector('#gender-picker input[name="gender"]:checked') || {}).value || 'all';
      try {
        const r = await fetch('/catalogue/<%= item.id %>/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'gender=' + encodeURIComponent(gender),
        });
        const d = await r.json();
        if (!d.ok) {
          statusText.textContent = '⚠ ' + (d.error || 'failed to start');
          btn.disabled = false; return;
        }
        poll();
      } catch (e) {
        statusText.textContent = '⚠ ' + e.message;
        btn.disabled = false;
      }
    }

    async function poll() {
      if (polling) return; polling = true;
      while (polling) {
        try {
          const r = await fetch('/catalogue/<%= item.id %>/status');
          const d = await r.json();
          const job = d.job;
          if (job) {
            const total = job.total_steps || 0;
            const done  = job.completed_steps || 0;
            const pct   = total ? Math.round((done / total) * 100) : 5;
            bar.style.width = pct + '%';
            statusText.textContent = job.status === 'running'
              ? `Plate ${done} of ${total}`
              : (job.status === 'queued' ? 'Queued' : job.status);
            costText.textContent = `₹${(job.cost_inr || 0).toFixed(2)}`;
            if (job.status === 'done' || job.status === 'failed' || job.status === 'partial') {
              polling = false;
              btn.disabled = false;
              statusText.textContent = job.status === 'done' ? '✓ Complete' : (job.status === 'partial' ? 'Stopped: ' + (job.error || '') : '⚠ ' + (job.error || ''));
              if (job.status === 'done' || job.status === 'partial') setTimeout(() => location.reload(), 800);
              return;
            }
          }
        } catch (e) {}
        await new Promise(r => setTimeout(r, 2000));
      }
    }
    btn.addEventListener('click', startGen);
    <% if (job && (job.status === 'running' || job.status === 'queued')) { %>
      progress.style.display = '';
      btn.disabled = true;
      poll();
    <% } %>
  }

  // Regenerate editorial copy
  const regen = document.getElementById('btn-regen-copy');
  if (regen) {
    regen.addEventListener('click', async (e) => {
      e.preventDefault();
      regen.textContent = '✦ Regenerating…';
      try {
        const r = await fetch('/catalogue/<%= item.id %>/copy/regenerate', { method: 'POST' });
        const d = await r.json();
        if (d.ok) location.reload();
        else regen.textContent = '⚠ ' + (d.error || 'failed');
      } catch (err) { regen.textContent = '⚠ ' + err.message; }
    });
  }
})();
</script>
<%- include('../partials/footer') %>
