<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="m-0"><i class="bi bi-people"></i> Model Templates</h4>
    <small class="text-muted">Reference photos of the model(s) for virtual try-on. AI-generate a default set, or upload your own.</small>
  </div>
  <a href="/catalogue" class="btn btn-outline-secondary btn-sm">← Back</a>
</div>

<!-- Generate AI defaults — text-to-image via FLUX schnell.
     Three pose sets, each 8 templates (4F + 4M), ~₹2.50 each. The
     pipeline picks the right set based on the item's cloth_type, so
     for jeans you get walking / hands-in-pockets / side-stance poses,
     not the standard hands-on-hips ones. -->
<div class="card mb-3" style="max-width:920px">
  <div class="card-body">
    <strong>🪄 Generate AI default models</strong>
    <div class="small text-muted mb-3">
      Three pose sets — each tailored to a garment type. Run whichever you need;
      the catalogue pipeline picks the right set automatically based on each item's
      cloth-type. ~₹2.50 per set.
    </div>
    <div class="row g-2">
      <div class="col-md-4">
        <div class="border rounded p-2 h-100">
          <div class="fw-semibold">👕 Tops · Kurtis · Blouses</div>
          <div class="small text-muted mb-2">Hands on hips, torso facing camera. 4 female + 4 male.</div>
          <button class="btn btn-sm btn-primary w-100 btn-seed" data-pose-focus="upper">Generate Top-set</button>
        </div>
      </div>
      <div class="col-md-4">
        <div class="border rounded p-2 h-100">
          <div class="fw-semibold">👖 Jeans · Trousers · Skirts</div>
          <div class="small text-muted mb-2">Walking, hands in pockets, side stance. 4 female + 4 male.</div>
          <button class="btn btn-sm btn-primary w-100 btn-seed" data-pose-focus="lower">Generate Bottom-set</button>
        </div>
      </div>
      <div class="col-md-4">
        <div class="border rounded p-2 h-100">
          <div class="fw-semibold">👗 Dresses · Sarees</div>
          <div class="small text-muted mb-2">Open-stance silhouette, arms away from body. 4 female only.</div>
          <button class="btn btn-sm btn-primary w-100 btn-seed" data-pose-focus="overall">Generate Full-set</button>
        </div>
      </div>
    </div>
    <div id="seed-progress" class="mt-3" style="display:none">
      <div class="progress" style="height:8px"><div id="seed-bar" class="progress-bar" style="width:0%"></div></div>
      <div class="d-flex justify-content-between small mt-1">
        <span id="seed-status">Starting…</span>
        <span id="seed-cost" class="text-muted">₹0.00</span>
      </div>
    </div>
  </div>
</div>

<!-- Manual upload — for owner who wants to add a custom real-photo model. -->
<details class="mb-3" <%= templates.length === 0 ? 'open' : '' %>>
  <summary class="btn btn-outline-secondary btn-sm">+ Upload your own template (optional)</summary>
  <form method="post" action="/catalogue/templates" enctype="multipart/form-data" class="card p-3 mt-2" style="max-width:920px">
    <div class="row g-3">
      <div class="col-md-3">
        <label class="form-label">Name</label>
        <input name="name" class="form-control" required placeholder="e.g. Model 1 – front">
      </div>
      <div class="col-md-2">
        <label class="form-label">Gender</label>
        <select name="gender" class="form-select">
          <option value="female">Female</option>
          <option value="male">Male</option>
          <option value="unisex">Unisex</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Best for</label>
        <select name="pose_focus" class="form-select">
          <option value="unisex">Any (default)</option>
          <option value="upper">Tops</option>
          <option value="lower">Bottoms</option>
          <option value="overall">Dresses / Sarees</option>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Pose</label>
        <input name="pose_label" class="form-control" placeholder="front / side">
      </div>
      <div class="col-md-3">
        <label class="form-label">Image</label>
        <input name="image" type="file" accept="image/*" class="form-control" required>
      </div>
    </div>
    <div class="mt-3">
      <button class="btn btn-primary"><i class="bi bi-plus"></i> Add template</button>
    </div>
  </form>
</details>

<div class="card">
  <div class="card-header">
    <strong><%= templates.length %></strong> template<%= templates.length===1?'':'s' %> ·
    <strong><%= templates.filter(t=>t.active===1).length %></strong> active ·
    <span class="text-muted small">
      by gender:
      <%= templates.filter(t=>t.gender==='female' && t.active).length %> female,
      <%= templates.filter(t=>t.gender==='male' && t.active).length %> male
      ·
      by garment:
      <%= templates.filter(t=>(t.pose_focus||'unisex')==='upper' && t.active).length %> top,
      <%= templates.filter(t=>(t.pose_focus||'unisex')==='lower' && t.active).length %> bottom,
      <%= templates.filter(t=>(t.pose_focus||'unisex')==='overall' && t.active).length %> full,
      <%= templates.filter(t=>(t.pose_focus||'unisex')==='unisex' && t.active).length %> unisex
    </span>
  </div>
  <div class="card-body">
    <% if (templates.length === 0) { %>
      <div class="text-muted text-center py-4">
        No templates yet. Click <strong>Generate AI Defaults</strong> above for a one-click starter set,
        or upload your own.
      </div>
    <% } else { %>
      <div class="row g-3">
        <% templates.forEach(t => { %>
          <div class="col-6 col-md-4 col-lg-3">
            <div class="card h-100">
              <img src="<%= t.file_path %>" class="card-img-top" style="aspect-ratio:1/1; object-fit:cover; opacity:<%= t.active ? '1' : '.4' %>">
              <div class="card-body py-2 px-2">
                <div class="fw-semibold text-truncate"><%= t.name %></div>
                <div class="small text-muted">
                  <% var g = t.gender || 'unisex'; var pf = t.pose_focus || 'unisex'; %>
                  <span class="badge" style="background: <%= g==='female' ? '#ec4899' : g==='male' ? '#3b82f6' : '#6b7280' %>"><%= g %></span>
                  <% if (pf !== 'unisex') { %>
                    <span class="badge" style="background: <%= pf==='upper' ? '#10b981' : pf==='lower' ? '#f59e0b' : '#8b5cf6' %>"><%= pf==='upper' ? 'top' : pf==='lower' ? 'bottom' : 'full' %></span>
                  <% } %>
                  <%= t.pose_label ? '· ' + t.pose_label : '' %>
                  <%= t.variant === 'ai-default' ? '· 🤖 AI' : '' %>
                </div>
                <div class="d-flex gap-1 mt-2">
                  <form method="post" action="/catalogue/templates/<%= t.id %>/toggle" class="m-0 flex-fill">
                    <button class="btn btn-sm btn-outline-<%= t.active ? 'secondary' : 'success' %> w-100"><%= t.active ? 'Disable' : 'Enable' %></button>
                  </form>
                  <form method="post" action="/catalogue/templates/<%= t.id %>/delete" class="m-0" onsubmit="return confirm('Delete this template?');">
                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                  </form>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</div>

<script>
(function () {
  const btn = document.getElementById('btn-seed');
  const wrap = document.getElementById('seed-progress');
  const bar = document.getElementById('seed-bar');
  const status = document.getElementById('seed-status');
  const cost = document.getElementById('seed-cost');

  let polling = false;

  async function poll() {
    if (polling) return; polling = true;
    while (polling) {
      try {
        const r = await fetch('/catalogue/templates/seed/status').then(r => r.json());
        const total = r.total || 8;
        const done = r.done || 0;
        bar.style.width = Math.round((done / total) * 100) + '%';
        status.textContent = r.running
          ? `Generating ${done} / ${total}…`
          : (r.error ? `⚠ ${done} / ${total} done · ${r.error}` : `✅ Done — ${done} / ${total} created.`);
        cost.textContent = `₹${(r.costInr || 0).toFixed(2)}`;
        if (!r.running && (done >= total || r.error)) {
          polling = false;
          // Reload after a beat so the new templates appear in the grid.
          setTimeout(() => location.reload(), 1200);
          return;
        }
      } catch (e) { /* ignore */ }
      await new Promise(r => setTimeout(r, 1500));
    }
  }

  // Three buttons (one per pose-focus set) all go through the same
  // seed endpoint with a different `pose_focus` body param.
  document.querySelectorAll('.btn-seed').forEach(btn => {
    btn.addEventListener('click', async () => {
      const focus = btn.dataset.poseFocus || 'upper';
      const labels = { upper: 'top-set (4F + 4M)', lower: 'bottom-set (4F + 4M)', overall: 'full-set (4F)' };
      if (!confirm(`Generate the ${labels[focus]}? Costs ~₹2.50 of fal.ai credit. Existing templates are kept.`)) return;
      document.querySelectorAll('.btn-seed').forEach(b => b.disabled = true);
      wrap.style.display = '';
      status.textContent = 'Starting ' + focus + '-set…';
      try {
        const r = await fetch('/catalogue/templates/seed', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: 'pose_focus=' + encodeURIComponent(focus),
        });
        const d = await r.json();
        if (!d.ok) {
          status.textContent = '⚠ ' + (d.error || 'failed');
          document.querySelectorAll('.btn-seed').forEach(b => b.disabled = false);
          return;
        }
        poll();
      } catch (e) {
        status.textContent = '⚠ ' + e.message;
        document.querySelectorAll('.btn-seed').forEach(b => b.disabled = false);
      }
    });
  });

  // If a seed run is already in progress (e.g. user reloaded), resume polling.
  fetch('/catalogue/templates/seed/status').then(r => r.json()).then(r => {
    if (r.running) {
      document.querySelectorAll('.btn-seed').forEach(b => b.disabled = true);
      wrap.style.display = ''; poll();
    }
  }).catch(() => {});
})();
</script>
<%- include('../partials/footer') %>
