<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-person-check-fill text-gradient"></i> Assign Dealers to Salespersons</h4>
    <small class="text-muted">Bulk-update which salesperson owns each dealer</small>
  </div>
  <a href="/dealers" class="btn btn-sm btn-outline-secondary">← All Dealers</a>
</div>

<div class="card mb-3">
  <div class="card-header"><i class="bi bi-funnel"></i> Filter View</div>
  <div class="p-3 d-flex gap-2 flex-wrap">
    <a href="?sp=all" class="btn btn-sm <%= filter==='all'?'btn-primary':'btn-outline-secondary' %>">All Dealers (<%= dealers.length %>)</a>
    <a href="?sp=unassigned" class="btn btn-sm <%= filter==='unassigned'?'btn-primary':'btn-outline-secondary' %>"><i class="bi bi-exclamation-circle"></i> Unassigned (<%= unassignedCount %>)</a>
    <% salespersons.forEach(sp => { %>
      <a href="?sp=<%= sp.id %>" class="btn btn-sm <%= String(filter)===String(sp.id)?'btn-primary':'btn-outline-secondary' %>"><%= sp.name %> (<%= countMap[sp.id] || 0 %>)</a>
    <% }) %>
  </div>
</div>

<form method="post" action="/dealers/assign">
  <div class="card">
    <div class="card-header d-flex flex-wrap align-items-center gap-2">
      <span><i class="bi bi-people-fill"></i> Dealers — <%= dealers.length %> shown</span>
      <div class="ms-auto d-flex align-items-center gap-2 flex-wrap">
        <label class="form-label m-0 small">Reassign selected to:</label>
        <select name="salesperson_id" class="form-select form-select-sm" style="width: auto">
          <option value="">— Unassign —</option>
          <% salespersons.forEach(sp => { %><option value="<%= sp.id %>"><%= sp.name %></option><% }) %>
        </select>
        <button class="btn btn-sm btn-success" data-confirm="Reassign selected dealers? This will change ownership."><i class="bi bi-arrow-left-right"></i> Apply to Selected</button>
      </div>
    </div>
    <div class="table-responsive">
      <table class="table table-sm m-0">
        <thead><tr>
          <th style="width:40px"><input type="checkbox" id="check-all" class="form-check-input"></th>
          <th>Code</th><th>Dealer</th><th>City</th><th>Phone</th>
          <th>Currently Assigned To</th>
          <th class="text-end">Outstanding</th>
        </tr></thead>
        <tbody>
          <% dealers.forEach(d => { %>
            <tr>
              <td><input type="checkbox" name="dealer_ids" value="<%= d.id %>" class="form-check-input dealer-check"></td>
              <td><%= d.code %></td>
              <td><a href="/dealers/<%= d.id %>"><%= d.name %></a></td>
              <td><%= d.city || '-' %></td>
              <td><%= d.phone || '-' %></td>
              <td>
                <% if (d.sp_name) { %>
                  <span class="badge" style="background: var(--grad-marigold)"><i class="bi bi-person-fill"></i> <%= d.sp_name %></span>
                <% } else { %>
                  <span class="badge bg-secondary"><i class="bi bi-question-circle"></i> Unassigned</span>
                <% } %>
              </td>
              <td class="text-end <%= d.outstanding > 0 ? 'fw-bold' : 'text-muted' %>" style="<%= d.outstanding > 0 ? 'color: var(--coral-600)' : '' %>"><%= fmtINR(d.outstanding) %></td>
            </tr>
          <% }) %>
          <% if (dealers.length === 0) { %><tr><td colspan="7" class="text-muted text-center py-4">No dealers match this filter</td></tr><% } %>
        </tbody>
      </table>
    </div>
    <div class="card-footer small text-muted">
      <i class="bi bi-info-circle"></i> Tip: filter by "Unassigned" then bulk-assign to a salesperson in one click.
      <span id="selected-count" class="ms-2"></span>
    </div>
  </div>
</form>

<script>
const checkAll = document.getElementById('check-all');
const checks = document.querySelectorAll('.dealer-check');
const counter = document.getElementById('selected-count');
function refreshCount() {
  const n = Array.from(checks).filter(c => c.checked).length;
  counter.textContent = n > 0 ? '· ' + n + ' selected' : '';
}
checkAll.addEventListener('change', () => { checks.forEach(c => c.checked = checkAll.checked); refreshCount(); });
checks.forEach(c => c.addEventListener('change', refreshCount));
</script>
<%- include('../partials/footer') %>
