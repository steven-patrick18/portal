<%- include('../partials/header') %>
<h4><%= d ? 'Edit Dealer' : 'New Dealer' %></h4>
<form method="post" action="<%= d ? '/dealers/' + d.id : '/dealers' %>" class="card p-3">
<div class="row g-3">
<div class="col-md-3"><label class="form-label">Code</label><input name="code" class="form-control" value="<%= d ? d.code : '' %>" <%= d ? 'readonly' : 'placeholder="auto"' %>></div>
<div class="col-md-5"><label class="form-label">Name *</label><input name="name" class="form-control" required value="<%= d ? d.name : '' %>"></div>
<div class="col-md-4"><label class="form-label">Contact Person</label><input name="contact_person" class="form-control" value="<%= d ? (d.contact_person||'') : '' %>"></div>
<div class="col-md-3"><label class="form-label">Phone</label><input name="phone" class="form-control" value="<%= d ? (d.phone||'') : '' %>"></div>
<div class="col-md-4"><label class="form-label">Email</label><input name="email" type="email" class="form-control" value="<%= d ? (d.email||'') : '' %>"></div>
<div class="col-md-5"><label class="form-label">GSTIN</label><input name="gstin" class="form-control" value="<%= d ? (d.gstin||'') : '' %>"></div>
<div class="col-md-12"><label class="form-label">Address</label><textarea name="address" class="form-control" rows="2"><%= d ? (d.address||'') : '' %></textarea></div>
<div class="col-md-4"><label class="form-label">City</label><input name="city" class="form-control" value="<%= d ? (d.city||'') : '' %>"></div>
<div class="col-md-4"><label class="form-label">State</label><input name="state" class="form-control" value="<%= d ? (d.state||'') : '' %>"></div>
<div class="col-md-4"><label class="form-label">Pincode</label><input name="pincode" class="form-control" value="<%= d ? (d.pincode||'') : '' %>"></div>
<div class="col-md-3"><label class="form-label">Credit Limit (₹)</label><input name="credit_limit" type="number" step="0.01" class="form-control" value="<%= d ? d.credit_limit : 0 %>"></div>
<div class="col-md-3"><label class="form-label">Opening Balance (₹)</label><input name="opening_balance" type="number" step="0.01" class="form-control" value="<%= d ? d.opening_balance : 0 %>"></div>
<div class="col-md-4"><label class="form-label">Salesperson</label>
<select name="salesperson_id" class="form-select"><option value="">-- none --</option>
<% sp.forEach(s => { %><option value="<%= s.id %>" <%= d && d.salesperson_id===s.id ? 'selected' : '' %>><%= s.name %></option><% }) %>
</select></div>
<% if (d) { %><div class="col-md-2"><div class="form-check form-switch mt-4"><input class="form-check-input" type="checkbox" name="active" value="1" <%= d.active?'checked':'' %>><label class="form-check-label">Active</label></div></div><% } %>
</div>
<div class="mt-3"><button class="btn btn-primary">Save</button> <a href="/dealers" class="btn btn-secondary">Cancel</a></div>
</form>
<%- include('../partials/footer') %>
