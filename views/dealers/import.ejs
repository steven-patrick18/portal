<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0">Import Dealers (CSV)</h4>
  <a href="/dealers" class="btn btn-sm btn-secondary">← Back to Dealers</a>
</div>

<div class="card mb-3" style="max-width:760px">
  <div class="card-body">
    <p class="text-muted mb-2">Upload a CSV exported from this page. Rows are matched by <code>code</code>:</p>
    <ul class="text-muted small">
      <li><strong>Existing code</strong> → fields are updated</li>
      <li><strong>Blank or new code</strong> → a new dealer is inserted (auto-numbered if blank)</li>
      <li><strong>Code missing from CSV</strong> → optionally deactivated (checkbox below)</li>
    </ul>
    <form method="post" action="/dealers/import" enctype="multipart/form-data" onsubmit="return checkReplace(this);">
      <div class="mb-3">
        <label class="form-label">CSV file</label>
        <input type="file" name="file" accept=".csv,text/csv" required class="form-control">
      </div>
      <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" id="deactMiss" name="deactivate_missing" value="1">
        <label class="form-check-label" for="deactMiss">Deactivate active dealers whose code is NOT in this CSV</label>
      </div>

      <div class="card mb-3" style="border-color:#dc3545">
        <div class="card-header bg-danger text-white py-2"><i class="bi bi-exclamation-triangle-fill"></i> Danger zone — replace all</div>
        <div class="card-body py-3">
          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="replaceAll" name="replace_all" value="1">
            <label class="form-check-label" for="replaceAll"><strong>Replace ALL existing dealers with this CSV</strong></label>
          </div>
          <div class="small text-muted mb-3">
            Wipes every dealer first, then imports the file as the fresh master list.
            Dealers with no transactions are <strong>permanently deleted</strong>;
            dealers that already have invoices / payments / orders are <strong>kept as inactive</strong>
            (renamed with an <code>_old_*</code> code suffix) so the history isn't broken.
            Use this for "I uploaded twice, let me start over" situations.
          </div>
          <div class="alert alert-warning py-2 mb-2 small">
            <strong>Step 2 — type the confirmation phrase:</strong> If you ticked the box above, you must type the exact phrase <code>REPLACE ALL</code> (capital letters) into the field below or the import will be rejected.
          </div>
          <label class="form-label small fw-bold text-danger mb-1">Confirmation phrase</label>
          <input name="replace_confirm" class="form-control form-control-sm" placeholder="Type: REPLACE ALL" autocomplete="off">
        </div>
      </div>

      <button class="btn btn-primary">Import</button>
      <a href="/dealers/export.csv" class="btn btn-outline-secondary">Download current as CSV</a>
    </form>
    <script>
      function checkReplace(form) {
        if (form.replace_all && form.replace_all.checked) {
          const v = (form.replace_confirm && form.replace_confirm.value || '').trim();
          if (v !== 'REPLACE ALL') { alert('Type REPLACE ALL (caps) to confirm wiping every dealer.'); return false; }
          return confirm('This will WIPE EVERY existing dealer (hard-delete if no transactions, kept as inactive otherwise) and then re-import from the CSV. Continue?');
        }
        return true;
      }
    </script>
  </div>
</div>

<div class="card" style="max-width:760px">
  <div class="card-header">CSV columns</div>
  <div class="card-body small">
    <code>code, name, contact_person, phone, email, address, city, state, pincode, gstin, credit_limit, opening_balance, salesperson_email, active</code>
    <ul class="mt-2 text-muted">
      <li><code>name</code> is required</li>
      <li><code>credit_limit</code>, <code>opening_balance</code> — numbers (no ₹ or commas)</li>
      <li><code>salesperson_email</code> — must match a user's email exactly, or leave blank for unassigned</li>
      <li><code>active</code> — 1 or 0 (defaults to 1)</li>
    </ul>
  </div>
</div>
<%- include('../partials/footer') %>
