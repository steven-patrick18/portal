<%- include('../partials/header') %>
<%
  // Build a sortable column header that preserves the current filters.
  function sortHead(key, label, thClass) {
    const base = [];
    if (q) base.push('q=' + encodeURIComponent(q));
    if (filter && filter !== 'all') base.push('filter=' + encodeURIComponent(filter));
    if (typeof spFilter !== 'undefined' && spFilter) base.push('sp=' + spFilter);
    if (typeof officeFilter !== 'undefined' && officeFilter !== null) base.push('office=' + officeFilter);
    const active = (sort === key);
    const nextDir = (active && dir === 'asc') ? 'desc' : 'asc';
    const href = '?' + base.concat(['sort=' + key, 'dir=' + nextDir]).join('&');
    const arrow = active ? (dir === 'asc' ? ' ▲' : ' ▼') : ' <span class="text-muted" style="opacity:.4">↕</span>';
    return '<th class="' + (thClass || '') + '"><a href="' + href + '" class="text-decoration-none text-reset">' + label + arrow + '</a></th>';
  }
%>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2 d-print-none">
  <h4 class="m-0">Dealers / Customers</h4>
  <div class="d-flex gap-2 flex-wrap">
    <% if (!isLimited && (user.role === 'admin' || user.role === 'owner')) { %>
      <div class="btn-group btn-group-sm">
        <a class="btn btn-outline-secondary <%= filter==='all'?'active':'' %>" href="?filter=all<%= spFilter ? '&sp=' + spFilter : '' %>">All</a>
        <a class="btn btn-outline-secondary <%= filter==='mine'?'active':'' %>" href="?filter=mine">My Dealers</a>
      </div>
      <form class="d-flex gap-1 align-items-center" method="get">
        <% if (q)     { %><input type="hidden" name="q" value="<%= q %>"><% } %>
        <% if (filter && filter !== 'all') { %><input type="hidden" name="filter" value="<%= filter %>"><% } %>
        <% if (officeFilter) { %><input type="hidden" name="office" value="<%= officeFilter %>"><% } %>
        <% if (sort) { %><input type="hidden" name="sort" value="<%= sort %>"><input type="hidden" name="dir" value="<%= dir %>"><% } %>
        <select name="sp" class="form-select form-select-sm" onchange="this.form.submit()" title="Filter by assigned salesperson">
          <option value="">All salespersons</option>
          <% salespersons.forEach(s => { %>
            <option value="<%= s.id %>" <%= spFilter === s.id ? 'selected' : '' %>><%= s.name %></option>
          <% }) %>
        </select>
      </form>
      <% if (offices && offices.length) { %>
      <form class="d-flex gap-1 align-items-center" method="get">
        <% if (q)     { %><input type="hidden" name="q" value="<%= q %>"><% } %>
        <% if (filter && filter !== 'all') { %><input type="hidden" name="filter" value="<%= filter %>"><% } %>
        <% if (spFilter) { %><input type="hidden" name="sp" value="<%= spFilter %>"><% } %>
        <% if (sort) { %><input type="hidden" name="sort" value="<%= sort %>"><input type="hidden" name="dir" value="<%= dir %>"><% } %>
        <select name="office" class="form-select form-select-sm" onchange="this.form.submit()" title="Filter by dealer's tagged office">
          <option value="">All offices</option>
          <% offices.forEach(o => { %>
            <option value="<%= o.id %>" <%= officeFilter === o.id ? 'selected' : '' %>>
              <% if (o.type === 'factory')   { %>🏭<% } %>
              <% if (o.type === 'office')    { %>🏢<% } %>
              <% if (o.type === 'warehouse') { %>📦<% } %>
              <%= o.name %><% if (o.city) { %> · <%= o.city %><% } %>
            </option>
          <% }) %>
        </select>
      </form>
      <% } %>
    <% } %>
    <form><input name="q" value="<%= q %>" class="form-control form-control-sm" style="width:200px" placeholder="Search code/name/phone"></form>
    <button onclick="window.print()" class="btn btn-outline-secondary btn-sm" title="Print this dealer list"><i class="bi bi-printer"></i> Print</button>
    <% if (user.role === 'owner') { %>
      <a href="/dealers/duplicates" class="btn btn-outline-warning btn-sm" title="Find duplicate dealers (same phone or name)"><i class="bi bi-files"></i> Duplicates</a>
      <a href="/dealers/export.csv" class="btn btn-outline-secondary btn-sm" title="Download all dealers as CSV"><i class="bi bi-download"></i> Export</a>
      <a href="/dealers/import" class="btn btn-outline-secondary btn-sm" title="Upload CSV to update or insert dealers"><i class="bi bi-upload"></i> Import</a>
    <% } %>
    <a href="/dealers/new" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New</a>
  </div>
</div>
<% if (isLimited) { %>
  <div class="alert alert-info py-2 small mb-3"><i class="bi bi-info-circle"></i> You see only dealers assigned to you. Contact admin to get more dealers assigned.</div>
<% } %>

<!-- ── Print zone: everything inside is what shows when the user prints.
     Outside .print-zone is hidden via the global @media print rules. -->
<div class="print-zone">
  <div class="print-only mb-3">
    <div style="font-size:16pt;font-weight:800;border-bottom:2px solid #000;padding-bottom:4px;margin-bottom:6px">
      <%= companyName %> · Dealer List
    </div>
    <div style="font-size:10pt;color:#444">
      <% if (officeName) { %><strong>Office:</strong> <%= officeName %> · <% } %>
      <% if (spName) { %><strong>Salesperson:</strong> <%= spName %> · <% } %>
      <% if (filter === 'mine') { %><strong>Filter:</strong> My dealers · <% } %>
      <% if (q) { %><strong>Search:</strong> "<%= q %>" · <% } %>
      <strong>Total:</strong> <%= items.length %> dealer<%= items.length===1?'':'s' %>
      · Generated <%= fmtDateTime(new Date().toISOString().replace('T',' ').slice(0,19)) %>
    </div>
  </div>

  <div class="card"><div class="table-responsive">
  <table class="table table-sm m-0"><thead><tr>
    <%- sortHead('code', 'Code') %>
    <%- sortHead('name', 'Name') %>
    <%- sortHead('city', 'City') %>
    <%- sortHead('office', 'Office') %>
    <%- sortHead('phone', 'Phone') %>
    <%- sortHead('salesperson', 'Salesperson') %>
    <%- sortHead('credit', 'Credit Limit', 'text-end') %>
    <%- sortHead('outstanding', 'Outstanding', 'text-end') %>
    <th class="d-print-none"></th>
  </tr></thead><tbody>
  <% items.forEach(d => { %>
  <tr><td><%= d.code %></td><td><a href="/dealers/<%= d.id %>"><%= d.name %></a>
    <% if (d.cscore && d.cscore.score != null) { %><span class="badge bg-<%= d.cscore.color %> ms-1" title="Credit score <%= d.cscore.score %>/100 — <%= d.cscore.label %>" style="font-size:.62rem;vertical-align:middle"><%= d.cscore.grade %></span><% } %></td>
  <td><%= d.city||'-' %></td>
  <td><% if (d.office_name) { %><span class="badge bg-secondary-subtle text-dark" style="font-weight:500">🏢 <%= d.office_name %></span><% } else { %><span class="text-muted small">—</span><% } %></td>
  <td><%= d.phone||'-' %></td><td><%= d.sp_name||'-' %></td>
  <td class="text-end"><%= fmtINR(d.credit_limit) %></td>
  <td class="text-end <%= d.outstanding > d.credit_limit && d.credit_limit > 0 ? 'text-danger fw-bold' : '' %>"><%= fmtINR(d.outstanding) %></td>
  <td class="d-print-none"><a href="/dealers/<%= d.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a></td>
  </tr>
  <% }) %>
  <% if (items.length===0) { %><tr><td colspan="9" class="text-muted text-center">No dealers</td></tr><% } %>
  </tbody></table></div></div>
</div>
<%- include('../partials/footer') %>
