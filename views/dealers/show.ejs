<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div><h4 class="m-0">
       <%= d.name %> <small class="text-muted">(<%= d.code %>)</small>
       <% if (credit && credit.score != null) { %><span class="badge bg-<%= credit.color %> ms-2" title="Credit score — <%= credit.label %>" style="font-size:.7rem;vertical-align:middle">Credit <%= credit.grade %> · <%= credit.score %></span><% } %>
       <% if (!d.active) { %><span class="badge bg-warning text-dark ms-2" style="font-size:.6rem">INACTIVE</span><% } %>
     </h4>
       <small class="text-muted"><%= d.city||'' %> · <%= d.phone||'-' %> · Salesperson: <%= d.sp_name||'-' %></small></div>
  <div>
    <a href="/dealers/<%= d.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
    <a href="/sales-orders/new?dealer_id=<%= d.id %>" class="btn btn-sm btn-primary">New Order</a>
    <a href="/payments/new?dealer_id=<%= d.id %>" class="btn btn-sm btn-success">Receive Payment</a>
    <a href="/notifications/send?dealer_id=<%= d.id %>" class="btn btn-sm btn-outline-info">Send Notification</a>
    <% if (user.role === 'owner') { %>
      <form method="post" action="/dealers/<%= d.id %>/delete" class="d-inline m-0"
            onsubmit="return confirm('Delete dealer <%= d.code %>? If they have invoices/payments/orders the dealer will be deactivated instead (history preserved).');">
        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Delete</button>
      </form>
    <% } %>
  </div>
</div>

<% if (!d.active) { %>
  <!-- Inactive dealer banner — without this, an owner re-assigning a
       deactivated old dealer wouldn't understand why the assignment
       doesn't show up on lists / reports. -->
  <div class="alert alert-warning d-flex justify-content-between align-items-center py-2 mb-3">
    <div>
      <i class="bi bi-exclamation-triangle-fill"></i>
      <strong>This dealer is deactivated.</strong>
      They are hidden from active lists (Dealers, Route Plan), excluded from active KPIs,
      and from the salesperson report's primary list (shown under "deactivated" instead).
      Reactivate to bring them back into the working catalogue.
    </div>
    <% if (['owner','admin'].includes(user.role)) { %>
      <form method="post" action="/dealers/<%= d.id %>/reactivate" class="m-0">
        <button class="btn btn-sm btn-warning"><i class="bi bi-arrow-counterclockwise"></i> Reactivate</button>
      </form>
    <% } %>
  </div>
<% } %>

<!-- Shop location — populated from the most-recent visit's GPS, used to
     plot the dealer as a 🏪 store icon on /visits/map. -->
<div class="card p-2 mb-3 d-flex flex-row align-items-center gap-2 flex-wrap" style="background:linear-gradient(135deg,#f0f9ff,#fff)">
  <% if (d.last_visit_lat && d.last_visit_lng) { %>
    <i class="bi bi-shop text-info" style="font-size:1.4rem"></i>
    <div class="flex-grow-1">
      <div class="small"><strong>Shop located</strong> at
        <code style="font-size:.75rem"><%= Number(d.last_visit_lat).toFixed(5) %>, <%= Number(d.last_visit_lng).toFixed(5) %></code>
        <% if (d.last_visit_at) { %><span class="text-muted">· captured <%= fmtDateTime(d.last_visit_at) %></span><% } %>
      </div>
      <div class="small text-muted">Set automatically by the most-recent visit. Shows as a 🏪 icon on the Visit Map's Stores layer.</div>
    </div>
    <a href="https://www.google.com/maps?q=<%= d.last_visit_lat %>,<%= d.last_visit_lng %>" target="_blank" class="btn btn-sm btn-outline-info">
      <i class="bi bi-map"></i> Open in Google Maps
    </a>
    <a href="/visits/map/recent?sp=<%= d.salesperson_id || '' %>" class="btn btn-sm btn-outline-secondary">
      <i class="bi bi-geo-alt"></i> Show on map
    </a>
    <% if (['owner','admin'].includes(user.role)) { %>
      <form method="post" action="/dealers/<%= d.id %>/clear-location" class="m-0"
            onsubmit="return confirm('Clear stored shop location for <%= d.code %>? Next visit will set a new pin.');">
        <button class="btn btn-sm btn-outline-danger" title="Wipe coords so next visit re-anchors the pin">
          <i class="bi bi-x-circle"></i> Clear
        </button>
      </form>
    <% } %>
  <% } else { %>
    <i class="bi bi-geo text-muted" style="font-size:1.4rem"></i>
    <div class="flex-grow-1">
      <div class="small"><strong>Shop not yet located.</strong></div>
      <div class="small text-muted">The first time a salesperson logs a visit to this dealer with GPS, the shop's location will be saved and pinned on the map.</div>
    </div>
    <a href="/visits/new?dealer_id=<%= d.id %>" class="btn btn-sm btn-outline-primary">
      <i class="bi bi-camera"></i> Log first visit
    </a>
  <% } %>
</div>

<div class="row g-3 mb-3">
  <div class="col-md-2 col-6"><div class="kpi-card kpi-indigo">
    <i class="bi bi-flag kpi-icon"></i>
    <div class="kpi-label">Opening Bal</div><div class="kpi-value" style="font-size:1.15rem"><%= fmtINR(d.opening_balance||0) %></div>
  </div></div>
  <div class="col-md-2 col-6"><a class="card-link" href="/invoices?dealer_id=<%= d.id %>"><div class="kpi-card kpi-denim">
    <i class="bi bi-receipt kpi-icon"></i>
    <div class="kpi-label">Total Billed</div><div class="kpi-value" style="font-size:1.15rem"><%= fmtINR(billed) %></div>
    <i class="bi bi-arrow-right kpi-arrow"></i>
  </div></a></div>
  <div class="col-md-2 col-6"><a class="card-link" href="/payments?dealer_id=<%= d.id %>"><div class="kpi-card kpi-emerald">
    <i class="bi bi-cash-coin kpi-icon"></i>
    <div class="kpi-label">Total Paid</div><div class="kpi-value" style="font-size:1.15rem"><%= fmtINR(paid) %></div>
    <i class="bi bi-arrow-right kpi-arrow"></i>
  </div></a></div>
  <div class="col-md-2 col-6"><a class="card-link" href="/returns?dealer_id=<%= d.id %>"><div class="kpi-card kpi-teal">
    <i class="bi bi-arrow-return-left kpi-icon"></i>
    <div class="kpi-label">Returns Credit</div><div class="kpi-value" style="font-size:1.15rem"><%= fmtINR(returned||0) %></div>
    <i class="bi bi-arrow-right kpi-arrow"></i>
  </div></a></div>
  <div class="col-md-4 col-12"><div class="kpi-card <%= outstanding > d.credit_limit && d.credit_limit > 0 ? 'kpi-coral' : 'kpi-marigold' %>">
    <i class="bi bi-exclamation-octagon kpi-icon"></i>
    <div class="kpi-label">Outstanding (opening + billed − paid − returns)</div>
    <div class="kpi-value"><%= fmtINR(outstanding) %></div>
  </div></div>
</div>

<!-- Credit standing: score + limit + suggested -->
<% if (credit) { %>
<div class="card mb-3"><div class="card-body py-2">
  <div class="d-flex flex-wrap align-items-center gap-4">
    <div>
      <div class="small text-muted">Credit score</div>
      <% if (credit.score != null) { %>
        <span class="badge bg-<%= credit.color %>" style="font-size:1rem"><%= credit.grade %> · <%= credit.score %>/100</span>
        <span class="small text-muted"><%= credit.label %></span>
      <% } else { %><span class="text-muted">No history yet</span><% } %>
    </div>
    <div class="vr d-none d-md-block"></div>
    <div><div class="small text-muted">Credit limit</div><strong><%= d.credit_limit > 0 ? fmtINR(d.credit_limit) : 'Not set' %></strong></div>
    <div>
      <div class="small text-muted">Suggested limit</div>
      <strong class="text-<%= credit.color %>"><%= credit.suggested > 0 ? fmtINR(credit.suggested) : '—' %></strong>
      <% if (credit.suggested > 0 && ['owner','admin','accountant'].includes(user.role)) { %>
        <a href="/dealers/<%= d.id %>/edit" class="small ms-1">apply</a>
      <% } %>
    </div>
    <% if (credit.factors && credit.factors.length) { %>
      <div class="flex-grow-1 small text-muted text-md-end"><i class="bi bi-info-circle"></i> <%= credit.factors.join(' · ') %></div>
    <% } %>
  </div>
</div></div>
<% } %>

<div class="row g-3">
<div class="col-md-7"><div class="card"><div class="card-header">Invoices</div><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>Inv #</th><th>Date</th><th class="text-end">Total</th><th class="text-end">Paid</th><th>Status</th></tr></thead><tbody>
<% invoices.forEach(i => { %>
<tr><td><a href="/invoices/<%= i.id %>"><%= i.invoice_no %></a></td><td><%= fmtDate(i.invoice_date) %></td>
<td class="text-end"><%= fmtINR(i.total) %></td><td class="text-end"><%= fmtINR(i.paid_amount) %></td>
<td><span class="badge bg-<%= i.status==='paid'?'success':i.status==='partial'?'warning':'secondary' %>"><%= i.status %></span></td></tr>
<% }) %>
<% if (invoices.length===0) { %><tr><td colspan="5" class="text-muted text-center">No invoices</td></tr><% } %>
</tbody></table></div></div></div>

<div class="col-md-5"><div class="card"><div class="card-header">Payments</div><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>Pmt #</th><th>Date</th><th>Mode</th><th class="text-end">Amount</th><th>Status</th></tr></thead><tbody>
<% payments.forEach(p => { %>
<tr><td><a href="/payments/<%= p.id %>"><%= p.payment_no %></a></td><td><%= fmtDate(p.payment_date) %></td>
<td><%= p.mode||'-' %></td><td class="text-end"><%= fmtINR(p.amount) %></td>
<td><span class="badge bg-<%= p.status==='verified'?'success':p.status==='rejected'?'danger':'warning' %>"><%= p.status %></span></td></tr>
<% }) %>
<% if (payments.length===0) { %><tr><td colspan="5" class="text-muted text-center">No payments</td></tr><% } %>
</tbody></table></div></div></div>
</div>

<% if (returnsList && returnsList.length) { %>
<div class="card mt-3"><div class="card-header d-flex justify-content-between">
  <span>Returns / Credit Notes</span>
  <a href="/returns/new?dealer_id=<%= d.id %>" class="small">+ New return</a>
</div><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>RET #</th><th>Date</th><th>Against Invoice</th><th>Reason</th><th class="text-end">Amount</th><th>Status</th></tr></thead><tbody>
<% returnsList.forEach(rt => { %>
<tr>
  <td><a href="/returns/<%= rt.id %>"><%= rt.return_no %></a></td>
  <td><%= fmtDate(rt.return_date) %></td>
  <td><% if (rt.invoice_no) { %><a href="/invoices/<%= rt.invoice_id %>"><%= rt.invoice_no %></a><% } else { %>—<% } %></td>
  <td><%= rt.reason || '-' %></td>
  <td class="text-end"><%= fmtINR(rt.total_amount) %></td>
  <td><span class="badge bg-<%= rt.status==='restocked'||rt.status==='approved'?'success':rt.status==='rejected'?'danger':'warning' %>"><%= rt.status %></span></td>
</tr>
<% }) %>
</tbody></table></div></div>
<% } %>
<%- include('../partials/footer') %>
