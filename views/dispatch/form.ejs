<%- include('../partials/header') %>
<h4><%= dispatch ? 'Edit Dispatch ' + dispatch.dispatch_no : 'New Dispatch' %></h4>
<form method="post" action="<%= dispatch ? '/dispatch/' + dispatch.id : '/dispatch' %>" class="card p-3" style="max-width:720px">
<div class="row g-3">
<div class="col-md-12"><label class="form-label">Invoice *</label>
<% if (invoice) { %>
<% if (!dispatch) { %><input type="hidden" name="invoice_id" value="<%= invoice.id %>"><% } %>
<input class="form-control" value="<%= invoice.invoice_no %> · <%= invoice.dealer_name %> · ₹<%= invoice.total.toFixed(2) %>" readonly>
<% } else { %>
<select name="invoice_id" class="form-select" required><option value="">-- select --</option>
<% invoices.forEach(i => { %><option value="<%= i.id %>"><%= i.invoice_no %> · <%= i.dealer_name %> · ₹<%= i.total.toFixed(2) %></option><% }) %>
</select>
<% } %>
</div>
<div class="col-md-4"><label class="form-label">Dispatch Date</label><input type="date" name="dispatch_date" class="form-control" required value="<%= dispatch ? dispatch.dispatch_date : new Date().toISOString().slice(0,10) %>"></div>
<div class="col-md-4"><label class="form-label">Transport</label><input name="transport_name" class="form-control" value="<%= dispatch ? (dispatch.transport_name||'') : '' %>"></div>
<div class="col-md-4"><label class="form-label">Vehicle No</label><input name="vehicle_no" class="form-control" value="<%= dispatch ? (dispatch.vehicle_no||'') : '' %>"></div>
<div class="col-md-4"><label class="form-label">LR No</label><input name="lr_no" class="form-control" value="<%= dispatch ? (dispatch.lr_no||'') : '' %>"></div>
<div class="col-md-4"><label class="form-label">Freight (₹)</label><input type="number" step="0.01" name="freight" class="form-control" value="<%= dispatch ? dispatch.freight : 0 %>"></div>
<div class="col-md-12"><label class="form-label">Notes</label><textarea name="notes" class="form-control" rows="2"><%= dispatch ? (dispatch.notes||'') : '' %></textarea></div>
</div>
<div class="mt-3"><button class="btn btn-primary"><%= dispatch ? 'Save Changes' : 'Save' %></button> <a href="/dispatch" class="btn btn-secondary">Cancel</a></div>
</form>
<%- include('../partials/footer') %>
