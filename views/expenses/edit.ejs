<%- include('../partials/header') %>
<h4>Edit Expense</h4>
<form method="post" action="/expenses/<%= e.id %>" class="card p-3" style="max-width:680px">
<div class="row g-2">
<div class="col-md-6"><label class="form-label">Date</label><input type="date" name="expense_date" class="form-control" required value="<%= e.expense_date %>"></div>
<div class="col-md-6"><label class="form-label">Amount</label><input type="number" step="0.01" name="amount" class="form-control" required value="<%= e.amount %>"></div>
<div class="col-md-12"><label class="form-label">Category</label>
<select name="category_id" class="form-select"><option value="">-- none --</option>
<% cats.forEach(c => { %><option value="<%= c.id %>" <%= e.category_id===c.id?'selected':'' %>><%= c.name %></option><% }) %></select></div>
<div class="col-md-12"><label class="form-label">Description</label><input name="description" class="form-control" value="<%= e.description||'' %>"></div>
<div class="col-md-6"><label class="form-label">Paid To</label><input name="paid_to" class="form-control" value="<%= e.paid_to||'' %>"></div>
<div class="col-md-6"><label class="form-label">Mode</label><input name="payment_mode" class="form-control" placeholder="Cash/UPI/..." value="<%= e.payment_mode||'' %>"></div>
<div class="col-md-12"><label class="form-label">Reference</label><input name="reference_no" class="form-control" value="<%= e.reference_no||'' %>"></div>
</div>
<div class="mt-3"><button class="btn btn-primary">Save Changes</button> <a href="/expenses" class="btn btn-secondary">Cancel</a></div>
</form>
<%- include('../partials/footer') %>
