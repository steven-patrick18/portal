<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0">Manufacturing Expenses</h4>
  <form class="d-flex gap-2"><input type="month" name="month" value="<%= month %>" class="form-control form-control-sm"><button class="btn btn-sm btn-outline-primary">Filter</button></form>
</div>

<div class="row g-3">
<div class="col-md-5">
<div class="card p-3 mb-3"><div class="kpi-label">Total <%= month %></div><div class="kpi-value"><%= fmtINR(total) %></div></div>
<div class="card mb-3"><div class="card-header">New Expense</div>
<form method="post" class="card-body">
<div class="row g-2">
<div class="col-6"><label class="form-label">Date</label><input type="date" name="expense_date" class="form-control" required value="<%= new Date().toISOString().slice(0,10) %>"></div>
<div class="col-6"><label class="form-label">Amount</label><input type="number" step="0.01" name="amount" class="form-control" required></div>
<div class="col-12"><label class="form-label">Category</label>
<select name="category_id" class="form-select"><option value="">-- none --</option>
<% cats.forEach(c => { %><option value="<%= c.id %>"><%= c.name %></option><% }) %></select></div>
<div class="col-12"><label class="form-label">Description</label><input name="description" class="form-control"></div>
<div class="col-6"><label class="form-label">Paid To</label><input name="paid_to" class="form-control"></div>
<div class="col-6"><label class="form-label">Mode</label><input name="payment_mode" class="form-control" placeholder="Cash/UPI/..."></div>
<div class="col-12"><label class="form-label">Reference</label><input name="reference_no" class="form-control"></div>
</div>
<button class="btn btn-primary mt-3 w-100">Save Expense</button>
</form></div>

<form method="post" action="/expenses/category" class="card p-3"><label class="form-label small">Add Category</label>
<div class="input-group"><input name="name" class="form-control form-control-sm" required><button class="btn btn-sm btn-outline-secondary">+</button></div></form>
</div>

<div class="col-md-7">
<div class="card"><div class="card-header"><%= month %> Expenses</div>
<div class="table-responsive"><table class="table table-sm m-0">
<thead><tr><th>Date</th><th>Category</th><th>Description</th><th>Paid To</th><th class="text-end">Amount</th><th></th></tr></thead><tbody>
<% items.forEach(e => { %>
<tr><td><%= fmtDate(e.expense_date) %></td><td><%= e.category_name||'-' %></td><td><%= e.description||'-' %></td><td><%= e.paid_to||'-' %></td><td class="text-end"><%= fmtINR(e.amount) %></td>
<td><form method="post" action="/expenses/<%= e.id %>/delete" data-confirm="Delete?" class="m-0"><button class="btn btn-sm btn-outline-danger">×</button></form></td></tr>
<% }) %>
<% if (items.length===0) { %><tr><td colspan="6" class="text-muted text-center">No expenses for this month</td></tr><% } %>
</tbody></table></div></div>
</div>
</div>
<%- include('../partials/footer') %>
