<%- include('../partials/header') %>
<h4><%= f ? 'Edit' : 'New' %> Fabric Cost Calculation</h4>
<small class="text-muted d-block mb-3">Enter how many meters went on the cutting table and how many pieces came out. The system computes per-piece cost (factoring wastage).</small>

<form method="post" action="<%= f ? '/fabric-cost/' + f.id : '/fabric-cost' %>" class="card p-3" style="max-width:820px">
  <div class="row g-3">
    <div class="col-md-6">
      <label class="form-label">Product *</label>
      <select name="product_id" id="product-sel" class="form-select" required>
        <option value="">-- select --</option>
        <% products.forEach(p => { %>
          <option value="<%= p.id %>" <%= f && f.product_id === p.id ? 'selected' : '' %>><%= p.code %> · <%= p.name %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-6">
      <label class="form-label">Fabric (Raw Material) *</label>
      <select name="raw_material_id" id="material-sel" class="form-select" required>
        <option value="">-- select --</option>
        <% materials.forEach(m => { %>
          <option value="<%= m.id %>" data-rate="<%= m.cost_per_unit %>" data-unit="<%= m.unit %>" <%= f && f.raw_material_id === m.id ? 'selected' : '' %>><%= m.code %> · <%= m.name %> (<%= m.unit %> @ ₹<%= m.cost_per_unit %>)</option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-3">
      <label class="form-label">Calc Date</label>
      <input type="date" name="calc_date" class="form-control" value="<%= f ? f.calc_date : todayLocal() %>">
    </div>
    <div class="col-md-3">
      <label class="form-label">Meters on Cutting Table *</label>
      <input id="inp-meters" name="fabric_used_meters" type="number" step="0.01" min="0.01" class="form-control" value="<%= f ? f.fabric_used_meters : '' %>" required placeholder="e.g. 60">
    </div>
    <div class="col-md-3">
      <label class="form-label">Pieces Cut *</label>
      <input id="inp-pieces" name="pieces_cut" type="number" min="1" class="form-control" value="<%= f ? f.pieces_cut : '' %>" required placeholder="e.g. 40">
    </div>
    <div class="col-md-3">
      <label class="form-label">Wastage % <small class="text-muted">(scrap)</small></label>
      <input id="inp-wastage" name="wastage_percent" type="number" step="0.1" min="0" max="50" class="form-control" value="<%= f ? f.wastage_percent : 0 %>" placeholder="0">
    </div>
    <div class="col-md-12">
      <label class="form-label">Notes</label>
      <textarea name="notes" class="form-control" rows="2"><%= f ? (f.notes || '') : '' %></textarea>
    </div>
  </div>

  <h6 class="section-title mt-3">Live Calculation</h6>
  <div class="row g-2 mb-3">
    <div class="col-md-3 col-6">
      <div class="kpi-card kpi-denim" style="padding:.85rem 1rem !important">
        <div class="kpi-label" style="font-size:.65rem">Fabric / Piece</div>
        <div class="kpi-value" style="font-size:1.2rem"><span id="calc-fpp">0.000</span> <span id="calc-unit">m</span></div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="kpi-card kpi-marigold" style="padding:.85rem 1rem !important">
        <div class="kpi-label" style="font-size:.65rem">Total Fabric Cost</div>
        <div class="kpi-value" style="font-size:1.2rem">₹<span id="calc-total">0</span></div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="kpi-card kpi-rose" style="padding:.85rem 1rem !important">
        <div class="kpi-label" style="font-size:.65rem">Cost / Piece (with wastage)</div>
        <div class="kpi-value" style="font-size:1.2rem">₹<span id="calc-cpp">0</span></div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="kpi-card kpi-emerald" style="padding:.85rem 1rem !important">
        <div class="kpi-label" style="font-size:.65rem">Pieces / Meter</div>
        <div class="kpi-value" style="font-size:1.2rem"><span id="calc-eff">0.00</span></div>
      </div>
    </div>
  </div>

  <div>
    <button class="btn btn-primary"><i class="bi bi-check-lg"></i> Save</button>
    <a href="/fabric-cost" class="btn btn-secondary">Cancel</a>
  </div>
</form>

<script>
const inpMeters = document.getElementById('inp-meters');
const inpPieces = document.getElementById('inp-pieces');
const inpWastage = document.getElementById('inp-wastage');
const matSel = document.getElementById('material-sel');
const fpp = document.getElementById('calc-fpp');
const cpp = document.getElementById('calc-cpp');
const total = document.getElementById('calc-total');
const eff = document.getElementById('calc-eff');
const unit = document.getElementById('calc-unit');

function fmtINR(n) {
  if (!isFinite(n)) return '0';
  return Number(n).toLocaleString('en-IN', { maximumFractionDigits: 2, minimumFractionDigits: 2 });
}

function recalc() {
  const m = parseFloat(inpMeters.value || 0);
  const p = parseInt(inpPieces.value || 0);
  const w = parseFloat(inpWastage.value || 0);
  const opt = matSel.options[matSel.selectedIndex];
  const rate = opt ? parseFloat(opt.dataset.rate || 0) : 0;
  const u = opt ? (opt.dataset.unit || 'm') : 'm';
  unit.textContent = u;
  const fabricPerPiece = p > 0 ? m / p : 0;
  const totalCost = m * rate;
  // The wastage is informational; cost-per-piece already reflects all fabric used (including wastage)
  // because total fabric on table / pieces produced = real per-piece consumption.
  // We display a wastage-adjusted theoretical cost-per-piece if user wants to plan ahead:
  const costPerPiece = fabricPerPiece * rate;
  const piecesPerMeter = m > 0 ? p / m : 0;
  fpp.textContent = fabricPerPiece.toFixed(3);
  total.textContent = fmtINR(totalCost);
  cpp.textContent = fmtINR(costPerPiece);
  eff.textContent = piecesPerMeter.toFixed(2);
}
[inpMeters, inpPieces, inpWastage, matSel].forEach(el => el && el.addEventListener('input', recalc));
matSel && matSel.addEventListener('change', recalc);
recalc();
</script>
<%- include('../partials/footer') %>
