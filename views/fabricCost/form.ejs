<%- include('../partials/header') %>
<h4>New Fabric Cost Calculation</h4>
<form method="post" class="card p-3" style="max-width:720px">
<div class="row g-3">
<div class="col-md-6"><label class="form-label">Product *</label>
<select name="product_id" class="form-select" required><option value="">-- select --</option>
<% products.forEach(p => { %><option value="<%= p.id %>"><%= p.code %> · <%= p.name %></option><% }) %>
</select></div>
<div class="col-md-6"><label class="form-label">Fabric (Raw Material) *</label>
<select name="raw_material_id" class="form-select" required><option value="">-- select --</option>
<% materials.forEach(m => { %><option value="<%= m.id %>"><%= m.code %> · <%= m.name %> (<%= m.unit %>)</option><% }) %>
</select></div>
<div class="col-md-6"><label class="form-label">Fabric Used (mtr/units) *</label><input name="fabric_used_meters" type="number" step="0.01" class="form-control" required></div>
<div class="col-md-6"><label class="form-label">Pieces Cut *</label><input name="pieces_cut" type="number" class="form-control" required></div>
<div class="col-md-12"><label class="form-label">Notes</label><textarea name="notes" class="form-control" rows="2"></textarea></div>
</div>
<div class="mt-3"><button class="btn btn-primary">Calculate & Save</button> <a href="/fabric-cost" class="btn btn-secondary">Cancel</a></div>
</form>
<%- include('../partials/footer') %>
