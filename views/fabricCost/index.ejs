<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3"><h4 class="m-0">Fabric Cost Calculation</h4><a href="/fabric-cost/new" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New</a></div>
<div class="alert alert-info small">Track how much fabric was used and pieces cut, to compute fabric cost per piece and cutting efficiency.</div>
<div class="card"><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>Date</th><th>Product</th><th>Material</th><th class="text-end">Fabric Used</th><th class="text-end">Pieces Cut</th><th class="text-end">Pcs/Mtr</th><th class="text-end">Cost/Piece</th><th>Notes</th></tr></thead><tbody>
<% items.forEach(i => { %>
<tr><td><%= fmtDate(i.calc_date) %></td><td><%= i.product_code %> · <%= i.product_name %></td><td><%= i.material_name %></td>
<td class="text-end"><%= i.fabric_used_meters %> <%= i.unit %></td><td class="text-end"><%= i.pieces_cut %></td>
<td class="text-end"><%= (i.efficiency_percent/100).toFixed(2) %></td>
<td class="text-end"><%= fmtINR(i.fabric_cost_per_piece) %></td><td><%= i.notes||'-' %></td></tr>
<% }) %>
<% if (items.length===0) { %><tr><td colspan="8" class="text-muted text-center">No calculations yet</td></tr><% } %>
</tbody></table></div></div>
<%- include('../partials/footer') %>
