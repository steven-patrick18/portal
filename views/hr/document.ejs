<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2 d-print-none">
  <div>
    <h4 class="m-0"><i class="bi bi-file-earmark-text"></i> <%= d.title %></h4>
    <small class="text-muted">
      <a href="/hr/employees/<%= d.employee_id %>"><%= d.emp_name %></a> · <%= d.emp_code %> · <%= docLabel %>
      <% if (d.doc_no) { %> · <strong><%= d.doc_no %></strong><% } %>
    </small>
  </div>
  <div class="d-flex gap-2 align-items-center flex-wrap">
    <span class="badge fs-6 bg-<%= d.status==='filed'?'success':d.status==='issued'?'primary':'secondary' %>"><%= d.status %></span>
    <button onclick="window.print()" class="btn btn-sm btn-outline-secondary"><i class="bi bi-printer"></i> Print</button>
    <% if (d.status === 'draft') { %>
      <form method="post" action="/hr/documents/<%= d.id %>/issue" class="m-0" data-confirm="Issue this document? It will get a document number and can no longer be edited.">
        <button class="btn btn-sm btn-success"><i class="bi bi-check2-circle"></i> Issue</button>
      </form>
    <% } %>
    <% if (['owner','admin'].includes(user.role)) { %>
      <form method="post" action="/hr/documents/<%= d.id %>/delete" class="m-0" data-confirm="Delete this document permanently?">
        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
      </form>
    <% } %>
  </div>
</div>

<!-- ── Draft editor ───────────────────────────────────────────── -->
<% if (d.status === 'draft') { %>
  <div class="alert alert-warning py-2 small d-print-none">
    <i class="bi bi-pencil-square"></i> <strong>Draft.</strong> Review and edit the wording below, fill any <code>__________</code> blanks, then click <strong>Issue</strong>.
    The wording follows standard Indian HR norms — <strong>have it vetted by your labour-law advisor / CA once</strong> before relying on it.
  </div>
  <form method="post" action="/hr/documents/<%= d.id %>" class="card p-3 mb-3 d-print-none">
    <div class="mb-2">
      <label class="form-label small mb-0">Title</label>
      <input name="title" value="<%= d.title %>" class="form-control form-control-sm">
    </div>
    <div class="mb-2">
      <label class="form-label small mb-0">Body — type directly, use the toolbar to format. (<code>&lt;/&gt; HTML</code> for advanced edits.)</label>
      <%- include('../partials/richEditor', { reName: 'body_html', reHtml: d.body_html, reRows: 18 }) %>
    </div>
    <div class="mb-2">
      <label class="form-label small mb-0">Internal note (not printed)</label>
      <input name="notes" value="<%= d.notes || '' %>" class="form-control form-control-sm">
    </div>
    <div><button class="btn btn-primary btn-sm"><i class="bi bi-save"></i> Save Draft</button></div>
  </form>
  <div class="card-header small text-muted d-print-none">Live preview ↓</div>
<% } %>

<!-- ── Issued: signed-copy upload ─────────────────────────────── -->
<% if (d.status !== 'draft') { %>
  <div class="card p-3 mb-3 d-print-none">
    <div class="row g-2 align-items-end">
      <div class="col-md-7">
        <strong>Signed &amp; stamped copy</strong>
        <% if (d.signed_doc_path) { %>
          <div class="small"><a href="<%= d.signed_doc_path %>" target="_blank"><i class="bi bi-file-earmark-check"></i> view filed copy</a></div>
        <% } else { %>
          <div class="small text-muted">Print, get it signed + company stamp, scan, and upload here.</div>
        <% } %>
      </div>
      <div class="col-md-5">
        <form method="post" action="/hr/documents/<%= d.id %>/upload" enctype="multipart/form-data" class="d-flex gap-1">
          <input type="file" name="signed_doc" accept="image/*,application/pdf" class="form-control form-control-sm" required>
          <button class="btn btn-outline-primary btn-sm"><i class="bi bi-cloud-upload"></i> Upload</button>
        </form>
      </div>
    </div>
  </div>
<% } %>

<!-- ════════════ PRINTABLE LETTER ════════════ -->
<div class="print-zone">
  <div class="card p-4" id="doc-paper" style="max-width:820px; margin:0 auto">
    <!-- Letterhead (also prints) -->
    <table style="width:100%; border-collapse:collapse; border-bottom:2px solid #000; margin-bottom:14px">
      <tr>
        <% if (brand && brand.logo) { %>
          <td style="width:90px; vertical-align:middle; padding-bottom:8px"><img src="<%= brand.logo %>" alt="logo" style="max-height:70px; max-width:84px; object-fit:contain"></td>
        <% } %>
        <td style="vertical-align:middle; padding-bottom:8px">
          <div style="font-size:19pt; font-weight:800"><%= companyName %></div>
          <div style="font-size:9pt; color:#333">
            <% if (brand && brand.address) { %><%= brand.address %><br><% } %>
            <% if (brand && brand.phone)  { %>Ph: <%= brand.phone %><% } %>
            <% if (brand && brand.email)  { %> · <%= brand.email %><% } %>
            <% if (brand && brand.gstin)  { %> · GSTIN: <%= brand.gstin %><% } %>
          </div>
        </td>
      </tr>
    </table>

    <!-- Body (frozen HTML) -->
    <div style="font-size:11pt; line-height:1.55"><%- d.body_html %></div>

    <!-- Signature blocks -->
    <table style="width:100%; border-collapse:collapse; margin-top:46px; font-size:9.5pt">
      <tr>
        <td style="width:50%; text-align:left; vertical-align:bottom">
          <div style="border-top:1px solid #000; padding-top:4px; width:230px">
            Employee — <%= d.emp_name %><br><span style="font-size:8pt; color:#555">Signature &amp; Date</span>
          </div>
        </td>
        <td style="width:50%; text-align:right; vertical-align:bottom">
          <div style="border-top:1px solid #000; padding-top:4px; width:230px; margin-left:auto">
            For <%= companyName %><br><span style="font-size:8pt; color:#555">Authorised Signatory &amp; Seal</span>
          </div>
        </td>
      </tr>
    </table>

    <div style="font-size:7.5pt; color:#888; text-align:center; margin-top:12px">
      <% if (d.doc_no) { %><%= d.doc_no %> · <% } %><% if (d.issued_date) { %>Issued <%= fmtDate(d.issued_date + ' 00:00:00') %> · <% } %><%= companyName %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
