<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2 d-print-none">
  <div>
    <h4 class="m-0"><i class="bi bi-folder2-open"></i> Documents Register</h4>
    <small class="text-muted">Every issued / filed HR document across all employees — audit-ready, printable.</small>
  </div>
  <div class="d-flex gap-2 align-items-center flex-wrap">
    <form class="d-flex gap-2 align-items-center flex-wrap">
      <label class="small text-muted m-0">From</label>
      <input type="date" name="from" value="<%= from %>" class="form-control form-control-sm">
      <label class="small text-muted m-0">To</label>
      <input type="date" name="to" value="<%= to %>" class="form-control form-control-sm">
      <select name="type" class="form-select form-select-sm">
        <option value="all" <%= docType==='all'?'selected':'' %>>All types</option>
        <% docTypes.forEach(t => { %><option value="<%= t.key %>" <%= docType===t.key?'selected':'' %>><%= t.label %></option><% }) %>
      </select>
      <button class="btn btn-sm btn-outline-primary">Filter</button>
    </form>
    <button onclick="window.print()" class="btn btn-sm btn-outline-secondary"><i class="bi bi-printer"></i> Print</button>
  </div>
</div>

<%- include('../partials/printHead', { printTitle: 'Documents Register', printSubtitle: from + ' → ' + to + (docType !== 'all' ? ' · ' + labelFor(docType) : '') }) %>

<div class="card"><div class="card-header d-flex justify-content-between">
  <span><i class="bi bi-table"></i> <%= rows.length %> document<%= rows.length===1?'':'s' %></span>
</div>
<div class="table-responsive"><table class="table table-sm m-0 align-middle">
  <thead><tr><th>Doc No.</th><th>Type</th><th>Employee</th><th>Issued</th><th>Status</th><th class="d-print-none">Signed copy</th><th class="d-print-none"></th></tr></thead>
  <tbody>
    <% rows.forEach(d => { %>
      <tr>
        <td><strong><%= d.doc_no || '—' %></strong></td>
        <td><%= labelFor(d.doc_type) %></td>
        <td><a href="/hr/employees/<%= d.employee_id %>" class="d-print-none"><%= d.emp_name %></a><span class="print-only"><%= d.emp_name %></span> <span class="small text-muted"><%= d.emp_code %></span></td>
        <td class="small"><%= d.issued_date ? fmtDate(d.issued_date + ' 00:00:00') : '—' %></td>
        <td><span class="badge bg-<%= d.status==='filed'?'success':'primary' %>"><%= d.status %></span></td>
        <td class="d-print-none"><% if (d.signed_doc_path) { %><a href="<%= d.signed_doc_path %>" target="_blank" class="small"><i class="bi bi-file-earmark-check"></i> view</a><% } else { %><span class="text-muted small">—</span><% } %></td>
        <td class="d-print-none"><a href="/hr/documents/<%= d.id %>" class="btn btn-sm btn-outline-secondary py-0"><i class="bi bi-arrow-right"></i></a></td>
      </tr>
    <% }) %>
    <% if (rows.length === 0) { %><tr><td colspan="7" class="text-muted text-center py-3">No issued documents in this range.</td></tr><% } %>
  </tbody>
</table></div>
<div class="card-footer small text-muted py-1">Drafts are excluded — only issued / filed documents appear here. "Filed" means the signed &amp; stamped copy has been uploaded.</div>
</div>
<%- include('../partials/footer') %>
