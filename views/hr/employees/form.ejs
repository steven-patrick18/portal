<%- include('../../partials/header') %>
<h4><%= e ? 'Edit ' + e.name : 'New Employee' %></h4>
<form method="post" action="<%= e ? '/hr/employees/' + e.id : '/hr/employees' %>" class="card p-3">
<div class="row g-3">
<div class="col-md-3"><label class="form-label">Code</label><input name="code" class="form-control" value="<%= e ? e.code : '' %>" <%= e ? 'readonly' : 'placeholder="auto"' %>></div>
<div class="col-md-5"><label class="form-label">Name *</label><input name="name" class="form-control" required value="<%= e ? e.name : '' %>"></div>
<div class="col-md-4"><label class="form-label">Phone</label><input name="phone" class="form-control" value="<%= e ? (e.phone||'') : '' %>"></div>

<div class="col-md-4"><label class="form-label">Email</label><input name="email" type="email" class="form-control" value="<%= e ? (e.email||'') : '' %>"></div>
<div class="col-md-3"><label class="form-label">Department</label>
  <select name="department" class="form-select">
    <option value="">-- none --</option>
    <% ['sales','production','admin','accounts','field','store','other'].forEach(d => { %>
      <option value="<%= d %>" <%= e && e.department===d?'selected':'' %>><%= d %></option>
    <% }) %>
  </select>
</div>
<div class="col-md-5"><label class="form-label">Designation</label><input name="designation" class="form-control" value="<%= e ? (e.designation||'') : '' %>"></div>

<div class="col-md-3"><label class="form-label">Employee Type *</label>
  <select name="employee_type" class="form-select" required>
    <option value="salary" <%= !e || e.employee_type==='salary'?'selected':'' %>>Salary (monthly)</option>
    <option value="contract" <%= e && e.employee_type==='contract'?'selected':'' %>>Contract (per-piece)</option>
  </select>
</div>
<div class="col-md-3"><label class="form-label">Base Salary (₹/month)</label><input type="number" step="0.01" min="0" name="base_salary" class="form-control" value="<%= e ? e.base_salary : 0 %>"></div>
<div class="col-md-3"><label class="form-label">Per-Piece Rate (₹)</label><input type="number" step="0.01" min="0" name="per_piece_rate" class="form-control" value="<%= e ? e.per_piece_rate : 0 %>"></div>
<div class="col-md-3"><label class="form-label">KM Rate (₹/km)</label><input type="number" step="0.01" min="0" name="km_rate" class="form-control" value="<%= e ? e.km_rate : 0 %>"></div>

<!-- Optional salary breakup components. Leave empty → letters auto-calc
     Basic 50% / HRA 40% of basic / Special. Add rows to override. -->
<div class="col-12">
  <% let _comps = [];
     try { if (e && e.salary_components) _comps = JSON.parse(e.salary_components) || []; } catch (_) {}
     if (!Array.isArray(_comps)) _comps = []; %>
  <div class="card bg-light p-2">
    <div class="d-flex justify-content-between align-items-center mb-1">
      <label class="form-label small m-0"><i class="bi bi-cash-stack"></i> Salary Components <span class="text-muted">(optional — leave empty to auto-calculate Basic / HRA / Special on letters)</span></label>
      <button type="button" class="btn btn-sm btn-outline-secondary" id="comp-add">+ Add component</button>
    </div>
    <div id="comp-rows">
      <% _comps.forEach(c => { %>
        <div class="row g-1 mb-1 comp-row">
          <div class="col-md-5"><input name="comp_name" class="form-control form-control-sm" placeholder="Component (e.g. Conveyance)" value="<%= c.name || '' %>"></div>
          <div class="col-md-3"><input name="comp_amount" type="number" step="0.01" min="0" class="form-control form-control-sm" placeholder="₹ / month" value="<%= c.amount || '' %>"></div>
          <div class="col-md-1"><button type="button" class="btn btn-sm btn-outline-danger comp-del">×</button></div>
        </div>
      <% }) %>
    </div>
    <small class="text-muted">If you add components, the gross becomes their sum and that exact breakup prints on the Appointment / Offer / Salary Certificate.</small>
  </div>
</div>

<div class="col-md-3"><label class="form-label">Joining Date</label><input type="date" name="joining_date" class="form-control" value="<%= e ? (e.joining_date||'') : new Date().toISOString().slice(0,10) %>"></div>
<% if (e) { %><div class="col-md-3"><label class="form-label">Exit Date</label><input type="date" name="exit_date" class="form-control" value="<%= e.exit_date||'' %>"></div><% } %>

<div class="col-md-12"><label class="form-label">Address</label><textarea name="address" class="form-control" rows="2"><%= e ? (e.address||'') : '' %></textarea></div>

<!-- HR-document fields: feed offer/appointment letters + probation tracking -->
<div class="col-md-4"><label class="form-label">Father's / Guardian's Name</label><input name="father_name" class="form-control" value="<%= e ? (e.father_name||'') : '' %>"></div>
<div class="col-md-2"><label class="form-label">Date of Birth</label><input type="date" name="dob" class="form-control" value="<%= e ? (e.dob||'') : '' %>"></div>
<div class="col-md-2"><label class="form-label">Probation (months)</label><input type="number" min="0" name="probation_months" class="form-control" value="<%= e ? (e.probation_months != null ? e.probation_months : 3) : 3 %>"></div>
<div class="col-md-2"><label class="form-label">Notice (days)</label><input type="number" min="0" name="notice_period_days" class="form-control" value="<%= e ? (e.notice_period_days != null ? e.notice_period_days : 30) : 30 %>"></div>
<div class="col-md-2"><label class="form-label">Confirmation Date</label><input type="date" name="confirmation_date" class="form-control" value="<%= e ? (e.confirmation_date||'') : '' %>"></div>
<div class="col-md-6"><label class="form-label">Reporting To</label><input name="reporting_to" class="form-control" value="<%= e ? (e.reporting_to||'') : '' %>" placeholder="e.g. Production Manager / Mr. Arvind Mehta"></div>

<div class="col-md-4"><label class="form-label">Bank Name</label><input name="bank_name" class="form-control" value="<%= e ? (e.bank_name||'') : '' %>"></div>
<div class="col-md-4"><label class="form-label">Account No</label><input name="account_no" class="form-control" value="<%= e ? (e.account_no||'') : '' %>"></div>
<div class="col-md-2"><label class="form-label">IFSC</label><input name="ifsc" class="form-control" value="<%= e ? (e.ifsc||'') : '' %>"></div>
<div class="col-md-2"><label class="form-label">PAN</label><input name="pan" class="form-control" value="<%= e ? (e.pan||'') : '' %>"></div>

<div class="col-md-6"><label class="form-label">Linked User Account</label>
  <select name="user_id" class="form-select">
    <option value="">-- none --</option>
    <% users.forEach(u => { %><option value="<%= u.id %>" <%= e && e.user_id===u.id?'selected':'' %>><%= u.name %> · <%= u.email %></option><% }) %>
  </select>
</div>
<div class="col-md-6"><label class="form-label">Notes</label><input name="notes" class="form-control" value="<%= e ? (e.notes||'') : '' %>"></div>

<% if (e) { %>
<div class="col-md-2"><div class="form-check form-switch mt-4"><input class="form-check-input" type="checkbox" name="active" value="1" <%= e.active?'checked':'' %>><label class="form-check-label">Active</label></div></div>
<% } %>
</div>
<div class="mt-3"><button class="btn btn-primary">Save</button> <a href="/hr/employees" class="btn btn-secondary">Cancel</a></div>
</form>
<script>
(function () {
  const rows = document.getElementById('comp-rows');
  const tpl = '<div class="row g-1 mb-1 comp-row">' +
    '<div class="col-md-5"><input name="comp_name" class="form-control form-control-sm" placeholder="Component (e.g. Conveyance)"></div>' +
    '<div class="col-md-3"><input name="comp_amount" type="number" step="0.01" min="0" class="form-control form-control-sm" placeholder="₹ / month"></div>' +
    '<div class="col-md-1"><button type="button" class="btn btn-sm btn-outline-danger comp-del">×</button></div></div>';
  document.getElementById('comp-add')?.addEventListener('click', () => {
    rows.insertAdjacentHTML('beforeend', tpl);
  });
  rows?.addEventListener('click', (e) => {
    if (e.target.classList.contains('comp-del')) e.target.closest('.comp-row').remove();
  });
})();
</script>
<%- include('../../partials/footer') %>
