<%- include('../../partials/header') %>
<style>
  .emp-dp { width:34px; height:34px; border-radius:50%; object-fit:cover; border:1px solid var(--hairline,#e5e7eb); flex:0 0 auto; background:#f1f3f5; }
  .emp-dp-ph { width:34px; height:34px; border-radius:50%; flex:0 0 auto; background:#e9ecef; color:#6c757d; font-weight:700; font-size:.8rem; display:inline-flex; align-items:center; justify-content:center; }
  .emp-dp-ph::before { content: attr(data-init); }  /* via CSS so it stays out of Excel/print text */
</style>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <h4 class="m-0">Employees <span id="emp-count" class="text-muted" style="font-size:.8rem;font-weight:400"></span></h4>
  <div class="d-flex gap-2 flex-wrap">
    <input type="search" id="emp-search" class="form-control form-control-sm" style="min-width:230px" placeholder="🔍 Search name, code, dept, designation, phone…">
    <select onchange="location.href='/hr/employees?filter='+this.value" class="form-select form-select-sm" style="width:auto">
      <% ['active','inactive','all'].forEach(f => { %><option value="<%= f %>" <%= filter===f?'selected':'' %>><%= f %></option><% }) %>
    </select>
    <a href="/hr/employees/new" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New Employee</a>
  </div>
</div>
<div class="card"><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>Code</th><th>Name</th><th>Type</th><th>Department</th><th>Designation</th><th class="text-end">Base / Rate</th><th>Phone</th><th>Joined</th><th></th><th></th></tr></thead><tbody>
<% items.forEach(e => { %>
<tr data-search="<%= ((e.code||'') + ' ' + (e.name||'') + ' ' + (e.department||'') + ' ' + (e.designation||'') + ' ' + (e.phone||'') + ' ' + (e.employee_type||'')).toLowerCase() %>">
  <td><%= e.code %></td>
  <td>
    <div class="d-flex align-items-center gap-2">
      <% if (e.photo_path) { %>
        <img src="<%= e.photo_path %>" alt="" class="emp-dp">
      <% } else { %>
        <span class="emp-dp-ph" data-init="<%= (e.name||'?').trim().charAt(0).toUpperCase() %>"></span>
      <% } %>
      <span><a href="/hr/employees/<%= e.id %>"><%= e.name %></a><% if (!e.active) { %> <span class="badge bg-secondary">inactive</span><% } %></span>
    </div>
  </td>
  <td><span class="badge bg-<%= e.employee_type==='salary'?'primary':'info' %>"><%= e.employee_type %></span></td>
  <td><%= e.department||'-' %></td>
  <td><%= e.designation||'-' %></td>
  <td class="text-end"><% if (e.employee_type==='salary') { %><%= fmtINR(e.base_salary) %>/mo<% } else { %>₹<%= e.per_piece_rate %>/pc<% } %></td>
  <td><%= e.phone||'-' %></td>
  <td><%= e.joining_date ? fmtDate(e.joining_date) : '-' %></td>
  <td><a href="/hr/employees/<%= e.id %>/edit" class="btn btn-sm btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a></td>
  <td></td>
</tr>
<% }) %>
<% if (items.length===0) { %><tr><td colspan="10" class="text-muted text-center">No employees</td></tr><% } %>
<tr id="emp-noresult" style="display:none"><td colspan="10" class="text-muted text-center py-3">No employees match your search.</td></tr>
</tbody></table></div></div>
<script>
(function(){
  var q = document.getElementById('emp-search');
  if (!q) return;
  var rows = Array.prototype.slice.call(document.querySelectorAll('tbody tr[data-search]'));
  var count = document.getElementById('emp-count');
  var noRow = document.getElementById('emp-noresult');
  function apply(){
    var s = (q.value || '').trim().toLowerCase();
    var shown = 0;
    rows.forEach(function(r){ var hit = !s || r.dataset.search.indexOf(s) >= 0; r.style.display = hit ? '' : 'none'; if (hit) shown++; });
    if (count) count.textContent = s ? ('(' + shown + ' of ' + rows.length + ')') : ('(' + rows.length + ')');
    if (noRow) noRow.style.display = (shown === 0 && rows.length) ? '' : 'none';
  }
  q.addEventListener('input', apply); apply();
})();
</script>
<%- include('../../partials/footer') %>
