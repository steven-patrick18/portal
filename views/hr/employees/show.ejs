<%- include('../../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="m-0"><%= e.name %> <small class="text-muted">· <%= e.code %></small></h4>
    <small class="text-muted"><%= e.designation||'-' %><% if (e.department) { %> · <%= e.department %><% } %> · <%= e.employee_type %><% if (!e.active) { %> · <span class="badge bg-secondary">inactive</span><% } %></small>
  </div>
  <a href="/hr/employees/<%= e.id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
</div>

<div class="row g-3 mb-3">
  <div class="col-md-3 col-6"><div class="kpi-card kpi-denim">
    <i class="bi bi-cash-stack kpi-icon"></i>
    <div class="kpi-label"><%= e.employee_type==='salary' ? 'Base Salary' : 'Per-Piece Rate' %></div>
    <div class="kpi-value"><% if (e.employee_type==='salary') { %><%= fmtINR(e.base_salary) %><small style="font-size:.5em">/mo</small><% } else { %>₹<%= e.per_piece_rate %><small style="font-size:.5em">/pc</small><% } %></div>
  </div></div>
  <div class="col-md-3 col-6"><div class="kpi-card kpi-emerald">
    <i class="bi bi-calendar-check-fill kpi-icon"></i>
    <div class="kpi-label">Present (<%= period %>)</div>
    <div class="kpi-value"><%= attendance.find(a=>a.status==='present')?.n || 0 %></div>
  </div></div>
  <div class="col-md-3 col-6"><a class="card-link" href="/hr/advances"><div class="kpi-card kpi-coral">
    <i class="bi bi-cash-coin kpi-icon"></i>
    <div class="kpi-label">Advance Balance</div>
    <div class="kpi-value"><%= fmtINR(advanceBalance) %></div>
  </div></a></div>
  <div class="col-md-3 col-6"><div class="kpi-card kpi-marigold">
    <i class="bi bi-signpost-split-fill kpi-icon"></i>
    <div class="kpi-label">KM Rate</div>
    <div class="kpi-value">₹<%= e.km_rate %><small style="font-size:.5em">/km</small></div>
  </div></div>
</div>

<!-- ── Live photo + KYC + police verification row ─────────────────── -->
<div class="row g-3 mb-3">

  <!-- Live photo -->
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-header"><i class="bi bi-person-bounding-box"></i> Employee Photo (live)</div>
      <div class="card-body text-center">
        <% if (e.photo_path) { %>
          <a href="<%= e.photo_path %>" target="_blank">
            <img src="<%= e.photo_path %>" alt="Employee photo" class="img-fluid rounded shadow-sm mb-2" style="max-height:220px;object-fit:cover">
          </a>
        <% } else { %>
          <div class="text-muted py-4">
            <i class="bi bi-camera" style="font-size:2.5rem"></i>
            <div class="small mt-2">No photo on file</div>
          </div>
        <% } %>
        <form method="post" action="/hr/employees/<%= e.id %>/photo" enctype="multipart/form-data" class="d-flex flex-column gap-2 mt-2">
          <!-- capture="user" forces the front camera; phone shutter opens
               directly instead of the gallery picker. Desktop users get a
               file picker if their machine has no camera. -->
          <input type="file" name="photo" accept="image/*" capture="user" class="form-control form-control-sm" required>
          <button class="btn btn-primary btn-sm"><i class="bi bi-cloud-upload"></i> Capture & Save</button>
        </form>
      </div>
    </div>
  </div>

  <!-- KYC docs -->
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-header"><i class="bi bi-file-earmark-text-fill"></i> KYC Documents</div>
      <div class="card-body small">
        <form method="post" action="/hr/employees/<%= e.id %>/kyc" enctype="multipart/form-data">
          <div class="mb-2">
            <label class="form-label small mb-0">Aadhaar No.</label>
            <input name="aadhaar_no" value="<%= e.aadhaar_no || '' %>" maxlength="14" class="form-control form-control-sm" placeholder="XXXX XXXX XXXX">
            <div class="d-flex justify-content-between align-items-center mt-1">
              <input type="file" name="aadhaar_doc" accept="image/*,application/pdf" class="form-control form-control-sm">
              <% if (e.aadhaar_doc_path) { %><a href="<%= e.aadhaar_doc_path %>" target="_blank" class="ms-2 small"><i class="bi bi-file-earmark-check"></i> view</a><% } %>
            </div>
          </div>
          <div class="mb-2">
            <label class="form-label small mb-0">PAN</label>
            <input name="pan" value="<%= e.pan || '' %>" maxlength="10" class="form-control form-control-sm" placeholder="AAAAA9999A" style="text-transform:uppercase">
            <div class="d-flex justify-content-between align-items-center mt-1">
              <input type="file" name="pan_doc" accept="image/*,application/pdf" class="form-control form-control-sm">
              <% if (e.pan_doc_path) { %><a href="<%= e.pan_doc_path %>" target="_blank" class="ms-2 small"><i class="bi bi-file-earmark-check"></i> view</a><% } %>
            </div>
          </div>
          <div class="mb-2">
            <label class="form-label small mb-0">Driving Licence No.</label>
            <input name="dl_no" value="<%= e.dl_no || '' %>" maxlength="20" class="form-control form-control-sm" placeholder="optional">
            <div class="d-flex justify-content-between align-items-center mt-1">
              <input type="file" name="dl_doc" accept="image/*,application/pdf" class="form-control form-control-sm">
              <% if (e.dl_doc_path) { %><a href="<%= e.dl_doc_path %>" target="_blank" class="ms-2 small"><i class="bi bi-file-earmark-check"></i> view</a><% } %>
            </div>
          </div>
          <button class="btn btn-primary btn-sm w-100"><i class="bi bi-cloud-upload"></i> Save KYC</button>
        </form>
        <div class="text-muted small mt-2" style="font-size:.7rem">
          PDF or image, ≤ 10 MB each. Leave file blank to keep the existing doc.
        </div>
      </div>
    </div>
  </div>

  <!-- Police verification -->
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-shield-check"></i> Police Verification</span>
        <%
          const pvs = e.police_verif_status || 'not_done';
          const pvBadge = pvs==='verified' ? 'success'
                         : pvs==='pending' ? 'warning text-dark'
                         : pvs==='not_required' ? 'secondary'
                         : 'danger';
        %>
        <span class="badge bg-<%= pvBadge %>"><%= pvs.replace('_',' ') %></span>
      </div>
      <div class="card-body small">
        <form method="post" action="/hr/employees/<%= e.id %>/police-verif" enctype="multipart/form-data">
          <div class="mb-2">
            <label class="form-label small mb-0">Status</label>
            <select name="police_verif_status" class="form-select form-select-sm">
              <% ['not_done','pending','verified','not_required'].forEach(s => { %>
                <option value="<%= s %>" <%= pvs===s?'selected':'' %>><%= s.replace('_',' ') %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-2">
            <label class="form-label small mb-0">Verification Date</label>
            <input type="date" name="police_verif_date" value="<%= e.police_verif_date || '' %>" class="form-control form-control-sm">
          </div>
          <div class="mb-2">
            <label class="form-label small mb-0">Notes (station, ref no., etc.)</label>
            <input name="police_verif_notes" value="<%= e.police_verif_notes || '' %>" maxlength="300" class="form-control form-control-sm">
          </div>
          <div class="mb-2">
            <label class="form-label small mb-0">Verification document</label>
            <input type="file" name="police_verif_doc" accept="image/*,application/pdf" class="form-control form-control-sm">
            <% if (e.police_verif_doc_path) { %>
              <div class="mt-1"><a href="<%= e.police_verif_doc_path %>" target="_blank" class="small"><i class="bi bi-file-earmark-check"></i> view current doc</a></div>
            <% } %>
          </div>
          <button class="btn btn-primary btn-sm w-100"><i class="bi bi-shield-lock"></i> Save Verification</button>
        </form>
      </div>
    </div>
  </div>

</div>

<div class="row g-3">
  <div class="col-md-6">
    <div class="card mb-3"><div class="card-header">Personal & Bank</div>
    <div class="card-body small">
      <div><strong>Phone:</strong> <%= e.phone||'-' %></div>
      <div><strong>Email:</strong> <%= e.email||'-' %></div>
      <div><strong>Address:</strong> <%= e.address||'-' %></div>
      <hr>
      <div><strong>Bank:</strong> <%= e.bank_name||'-' %></div>
      <div><strong>A/C:</strong> <%= e.account_no||'-' %> · IFSC: <%= e.ifsc||'-' %></div>
      <div><strong>PAN:</strong> <%= e.pan||'-' %></div>
      <% if (e.aadhaar_no) { %><div><strong>Aadhaar:</strong> <%= e.aadhaar_no %></div><% } %>
      <% if (e.dl_no) { %><div><strong>Driving Licence:</strong> <%= e.dl_no %></div><% } %>
      <% if (e.user_name) { %><div><strong>User Login:</strong> <%= e.user_name %> (<%= e.user_email %>)</div><% } %>
    </div></div>

    <% if (advances && advances.length) { %>
    <div class="card mb-3"><div class="card-header d-flex justify-content-between"><span>Advances</span><a href="/hr/advances" class="small">manage →</a></div>
    <div class="table-responsive"><table class="table table-sm m-0">
    <thead><tr><th>Date</th><th class="text-end">Amount</th><th class="text-end">Balance</th><th>Status</th></tr></thead><tbody>
    <% advances.forEach(a => { %>
      <tr><td><%= fmtDate(a.advance_date) %></td><td class="text-end"><%= fmtINR(a.amount) %></td>
      <td class="text-end"><%= fmtINR(a.balance) %></td>
      <td><span class="badge bg-<%= a.status==='cleared'?'success':a.status==='partial'?'warning':'secondary' %>"><%= a.status %></span></td></tr>
    <% }) %>
    </tbody></table></div></div>
    <% } %>
  </div>

  <div class="col-md-6">
    <% if (recentSalary && recentSalary.length) { %>
    <div class="card mb-3"><div class="card-header">Recent Salary Slips</div>
    <div class="table-responsive"><table class="table table-sm m-0">
    <thead><tr><th>Period</th><th class="text-end">Gross</th><th class="text-end">Net</th><th>Status</th></tr></thead><tbody>
    <% recentSalary.forEach(s => { %>
      <tr><td><a href="/hr/payroll/<%= s.id %>"><%= s.period %></a></td>
      <td class="text-end"><%= fmtINR(s.gross) %></td>
      <td class="text-end"><%= fmtINR(s.net_paid) %></td>
      <td><span class="badge bg-<%= s.status==='paid'?'success':'secondary' %>"><%= s.status %></span></td></tr>
    <% }) %>
    </tbody></table></div></div>
    <% } %>

    <% if (recentPieces && recentPieces.length) { %>
    <div class="card mb-3"><div class="card-header">Recent Per-Piece Work</div>
    <div class="table-responsive"><table class="table table-sm m-0">
    <thead><tr><th>Date</th><th class="text-end">Pcs</th><th class="text-end">Rate</th><th class="text-end">Total</th></tr></thead><tbody>
    <% recentPieces.forEach(p => { %>
      <tr><td><%= fmtDate(p.work_date) %></td><td class="text-end"><%= p.qty_pieces %></td>
      <td class="text-end">₹<%= p.rate_per_piece %></td><td class="text-end"><%= fmtINR(p.total_amount) %></td></tr>
    <% }) %>
    </tbody></table></div></div>
    <% } %>

    <% if (recentKm && recentKm.length) { %>
    <div class="card mb-3"><div class="card-header">Recent KM Log</div>
    <div class="table-responsive"><table class="table table-sm m-0">
    <thead><tr><th>Date</th><th class="text-end">KM</th><th>Dealer</th><th class="text-end">Amount</th></tr></thead><tbody>
    <% recentKm.forEach(k => { %>
      <tr><td><%= fmtDate(k.log_date) %></td><td class="text-end"><%= k.km %></td>
      <td><%= k.dealer_name||'-' %></td><td class="text-end"><%= fmtINR(k.amount) %></td></tr>
    <% }) %>
    </tbody></table></div></div>
    <% } %>
  </div>
</div>

<!-- ── HR Documents ───────────────────────────────────────────── -->
<div class="card mt-3">
  <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <span><i class="bi bi-file-earmark-text-fill"></i> Documents &amp; Letters</span>
    <form method="post" action="/hr/employees/<%= e.id %>/documents" class="d-flex gap-1 align-items-center">
      <select name="doc_type" class="form-select form-select-sm" style="min-width:230px" required>
        <option value="">— generate a document —</option>
        <% let _g = null; docTypes.forEach(t => { %>
          <% if (t.group !== _g) { _g = t.group; %><optgroup label="<%= t.group %>"></optgroup><% } %>
          <option value="<%= t.key %>"><%= t.label %></option>
        <% }) %>
      </select>
      <button class="btn btn-sm btn-primary"><i class="bi bi-magic"></i> Generate</button>
    </form>
  </div>
  <div class="table-responsive">
    <table class="table table-sm m-0 align-middle">
      <thead><tr><th>Document</th><th>No.</th><th>Status</th><th>Issued</th><th>Signed copy</th><th></th></tr></thead>
      <tbody>
        <% (documents || []).forEach(d => { %>
          <tr>
            <td><a href="/hr/documents/<%= d.id %>"><%= d.title %></a></td>
            <td><%= d.doc_no || '—' %></td>
            <td><span class="badge bg-<%= d.status==='filed'?'success':d.status==='issued'?'primary':'secondary' %>"><%= d.status %></span></td>
            <td class="small"><%= d.issued_date ? fmtDate(d.issued_date + ' 00:00:00') : '—' %></td>
            <td><% if (d.signed_doc_path) { %><a href="<%= d.signed_doc_path %>" target="_blank" class="small"><i class="bi bi-file-earmark-check"></i> view</a><% } else { %><span class="text-muted small">—</span><% } %></td>
            <td><a href="/hr/documents/<%= d.id %>" class="btn btn-sm btn-outline-secondary py-0"><i class="bi bi-arrow-right"></i></a></td>
          </tr>
        <% }) %>
        <% if (!documents || documents.length === 0) { %>
          <tr><td colspan="6" class="text-muted text-center py-3">No documents yet. Pick a type above to generate the first one.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <div class="card-footer small text-muted py-1">
    Generate → review/edit → Issue (assigns a number &amp; freezes it) → Print → sign + stamp → upload the signed copy.
    Company-wide rules live in the <a href="/hr/handbook">Policy Handbook</a>.
  </div>
</div>
<%- include('../../partials/footer') %>
