<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0">Incentives</h4>
  <form class="d-flex gap-2"><input type="month" name="period" value="<%= period %>" class="form-control form-control-sm"><button class="btn btn-sm btn-outline-primary">Filter</button></form>
</div>
<div class="row g-3">
<div class="col-md-5">
<div class="kpi-card kpi-emerald mb-3" style="padding:1rem 1.2rem !important">
  <i class="bi bi-gift-fill kpi-icon"></i>
  <div class="kpi-label">Total · <%= period %></div>
  <div class="kpi-value"><%= fmtINR(total) %></div>
</div>
<div class="card"><div class="card-header">Add Incentive</div>
<form method="post" action="/hr/incentives" class="card-body">
<div class="row g-2">
<div class="col-12"><label class="form-label">Employee *</label>
  <select name="employee_id" class="form-select" required>
    <option value="">-- select --</option>
    <% employees.forEach(e => { %><option value="<%= e.id %>"><%= e.code %> · <%= e.name %></option><% }) %>
  </select>
</div>
<div class="col-6"><label class="form-label">Period</label><input type="month" name="period" class="form-control" required value="<%= period %>"></div>
<div class="col-6"><label class="form-label">Amount (₹)</label><input type="number" step="0.01" min="0.01" name="amount" class="form-control" required></div>
<div class="col-12"><label class="form-label">Reason</label><input name="reason" class="form-control" placeholder="e.g. Top sales bonus"></div>
</div>
<button class="btn btn-primary mt-3 w-100">Save</button>
</form></div>
<div class="alert alert-info small mt-2">Incentives auto-flow into the salary slip for that period. They become locked once the slip is marked paid.</div>
</div>

<div class="col-md-7">
<div class="card"><div class="card-header"><%= period %> · <%= items.length %> incentive<%= items.length===1?'':'s' %></div>
<div class="table-responsive"><table class="table table-sm m-0">
<thead><tr><th>Employee</th><th>Reason</th><th class="text-end">Amount</th><th>Status</th><th></th></tr></thead><tbody>
<% items.forEach(i => { %>
<tr><td><a href="/hr/employees/<%= i.employee_id %>"><%= i.emp_name %></a></td>
<td><%= i.reason||'-' %></td>
<td class="text-end"><%= fmtINR(i.amount) %></td>
<td><% if (i.applied_to_salary_id) { %><a href="/hr/payroll/<%= i.applied_to_salary_id %>"><span class="badge bg-success">applied</span></a><% } else { %><span class="badge bg-secondary">pending</span><% } %></td>
<td><% if (!i.applied_to_salary_id) { %><form method="post" action="/hr/incentives/<%= i.id %>/delete" data-confirm="Delete?" class="m-0"><button class="btn btn-sm btn-outline-danger">×</button></form><% } %></td>
</tr>
<% }) %>
<% if (items.length===0) { %><tr><td colspan="5" class="text-muted text-center">No incentives this period</td></tr><% } %>
</tbody></table></div></div>
</div>
</div>
<%- include('../partials/footer') %>
