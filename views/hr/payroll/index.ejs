<%- include('../../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
  <h4 class="m-0">Payroll</h4>
  <div class="d-flex gap-2">
    <form class="d-flex gap-2"><input type="month" name="period" value="<%= period %>" class="form-control form-control-sm"><button class="btn btn-sm btn-outline-primary">Filter</button></form>
    <button onclick="window.print()" class="btn btn-sm btn-outline-secondary" title="Print the salary register for this period — includes a signature column for cash disbursal"><i class="bi bi-printer"></i> Print Register</button>
  </div>
</div>

<!-- ── Printed salary register (letterhead + signature column) ───── -->
<div class="print-only">
  <table style="width:100%; border-collapse:collapse; border-bottom:2px solid #000; margin-bottom:8px">
    <tr>
      <% if (brand && brand.logo) { %>
        <td style="width:80px; vertical-align:middle; padding-bottom:6px"><img src="<%= brand.logo %>" alt="logo" style="max-height:60px; max-width:74px; object-fit:contain"></td>
      <% } %>
      <td style="vertical-align:middle; padding-bottom:6px">
        <div style="font-size:17pt; font-weight:800"><%= companyName %></div>
        <div style="font-size:9pt; color:#333"><% if (brand && brand.address) { %><%= brand.address %><% } %></div>
      </td>
      <td style="text-align:right; vertical-align:middle; white-space:nowrap">
        <div style="font-size:12pt; font-weight:700">SALARY REGISTER · <%= period %></div>
        <div style="font-size:8.5pt; color:#444"><%= items.length %> employee<%= items.length===1?'':'s' %> · Net <%= fmtINR(totals.net) %> · Generated <%= fmtDateTime(new Date().toISOString().replace('T',' ').slice(0,19)) %></div>
      </td>
    </tr>
  </table>
  <table style="width:100%; border-collapse:collapse; font-size:9pt">
    <thead>
      <tr>
        <th style="border:1px solid #000; padding:4px 6px; text-align:left">#</th>
        <th style="border:1px solid #000; padding:4px 6px; text-align:left">Employee</th>
        <th style="border:1px solid #000; padding:4px 6px; text-align:right">Base</th>
        <th style="border:1px solid #000; padding:4px 6px; text-align:right">Pieces</th>
        <th style="border:1px solid #000; padding:4px 6px; text-align:right">Incentive</th>
        <th style="border:1px solid #000; padding:4px 6px; text-align:right">KM</th>
        <th style="border:1px solid #000; padding:4px 6px; text-align:right">Advance −</th>
        <th style="border:1px solid #000; padding:4px 6px; text-align:right">Net Pay</th>
        <th style="border:1px solid #000; padding:4px 6px; width:110px">Signature</th>
      </tr>
    </thead>
    <tbody>
      <% items.forEach((s, idx) => { %>
      <tr>
        <td style="border:1px solid #000; padding:4px 6px"><%= idx + 1 %></td>
        <td style="border:1px solid #000; padding:4px 6px"><%= s.emp_name %> <span style="font-size:7.5pt; color:#555">(<%= s.code %>)</span></td>
        <td style="border:1px solid #000; padding:4px 6px; text-align:right"><%= fmtINR(s.base_amount).replace('₹','') %></td>
        <td style="border:1px solid #000; padding:4px 6px; text-align:right"><%= fmtINR(s.piece_amount).replace('₹','') %></td>
        <td style="border:1px solid #000; padding:4px 6px; text-align:right"><%= fmtINR(s.incentive_amount).replace('₹','') %></td>
        <td style="border:1px solid #000; padding:4px 6px; text-align:right"><%= fmtINR(s.km_amount).replace('₹','') %></td>
        <td style="border:1px solid #000; padding:4px 6px; text-align:right"><%= fmtINR(s.advance_deducted).replace('₹','') %></td>
        <td style="border:1px solid #000; padding:4px 6px; text-align:right; font-weight:700"><%= fmtINR(s.net_paid).replace('₹','') %></td>
        <td style="border:1px solid #000; padding:4px 6px"></td>
      </tr>
      <% }) %>
      <tr>
        <td colspan="7" style="border:1.5px solid #000; padding:5px 6px; font-weight:800; text-align:right">TOTAL</td>
        <td style="border:1.5px solid #000; padding:5px 6px; text-align:right; font-weight:800"><%= fmtINR(totals.net).replace('₹','') %></td>
        <td style="border:1.5px solid #000"></td>
      </tr>
    </tbody>
  </table>
  <table style="width:100%; margin-top:40px; font-size:9.5pt">
    <tr>
      <td style="width:50%; text-align:center"><div style="border-top:1px solid #000; padding-top:4px; width:200px; margin:0 auto">HR</div></td>
      <td style="width:50%; text-align:center"><div style="border-top:1px solid #000; padding-top:4px; width:200px; margin:0 auto">Authorised Signatory<br><span style="font-size:8pt; color:#444">for <%= companyName %></span></div></td>
    </tr>
  </table>
</div>

<div class="row g-3 mb-3 d-print-none">
  <div class="col-md-3 col-6"><div class="kpi-card kpi-denim">
    <i class="bi bi-people-fill kpi-icon"></i>
    <div class="kpi-label">Slips Generated</div><div class="kpi-value"><%= items.length %> / <%= empCount %></div>
  </div></div>
  <div class="col-md-3 col-6"><div class="kpi-card kpi-marigold">
    <i class="bi bi-cash-stack kpi-icon"></i>
    <div class="kpi-label">Gross Total</div><div class="kpi-value"><%= fmtINR(totals.gross) %></div>
  </div></div>
  <div class="col-md-3 col-6"><div class="kpi-card kpi-emerald">
    <i class="bi bi-check2-circle kpi-icon"></i>
    <div class="kpi-label">Net to Pay</div><div class="kpi-value"><%= fmtINR(totals.net) %></div>
  </div></div>
  <div class="col-md-3 col-6"><div class="kpi-card kpi-coral">
    <i class="bi bi-receipt-cutoff kpi-icon"></i>
    <div class="kpi-label">Period</div><div class="kpi-value" style="font-size:1.6rem"><%= period %></div>
  </div></div>
</div>

<!-- ── Selective generation: pick employees, generate only those ──── -->
<% if (pendingEmployees && pendingEmployees.length) { %>
<div class="card mb-3 d-print-none">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span><i class="bi bi-person-plus-fill"></i> Generate Slips for <%= period %> <span class="badge bg-warning text-dark"><%= pendingEmployees.length %> without slip</span></span>
    <small class="text-muted">Pulls attendance, per-piece work, KM log, and incentives. Pick who to generate — single or multiple.</small>
  </div>
  <form method="post" action="/hr/payroll/generate" class="card-body">
    <input type="hidden" name="period" value="<%= period %>">
    <div class="d-flex gap-2 align-items-center mb-2 flex-wrap">
      <button type="button" class="btn btn-sm btn-outline-secondary" id="gen-select-all">Select all</button>
      <button type="button" class="btn btn-sm btn-outline-secondary" id="gen-select-none">Clear</button>
      <span class="small text-muted" id="gen-count">0 selected</span>
      <button class="btn btn-success btn-sm ms-auto" data-confirm="Generate salary slips for the selected employees?"><i class="bi bi-magic"></i> Generate Selected</button>
    </div>
    <div class="row g-1" style="max-height:260px; overflow-y:auto">
      <% pendingEmployees.forEach(e => { %>
        <div class="col-md-3 col-sm-4 col-6">
          <label class="d-flex align-items-center gap-2 small border rounded px-2 py-1" style="cursor:pointer">
            <input type="checkbox" name="employee_ids" value="<%= e.id %>" class="form-check-input m-0 gen-emp-cb">
            <span class="text-truncate" title="<%= e.name %> · <%= e.code %>">
              <%= e.name %>
              <span class="text-muted" style="font-size:.68rem"><%= e.employee_type === 'salary' ? '💼' : '🧵' %></span>
            </span>
          </label>
        </div>
      <% }) %>
    </div>
  </form>
</div>
<% } else { %>
<div class="alert alert-success py-2 small mb-3 d-print-none">
  <i class="bi bi-check-circle-fill"></i> Every active employee already has a slip for <%= period %>.
</div>
<% } %>

<!-- ── Slips table with per-row + bulk delete ─────────────────────── -->
<form method="post" action="/hr/payroll/delete-selected" id="bulk-del-form" class="d-print-none">
<input type="hidden" name="period" value="<%= period %>">
<div class="card"><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr>
  <th style="width:28px"><input type="checkbox" id="del-select-all" class="form-check-input" title="Select all draft slips"></th>
  <th>Employee</th><th>Type</th><th class="text-end">Base</th><th class="text-end">Pieces</th><th class="text-end">Incentive</th><th class="text-end">KM</th><th class="text-end">Advance</th><th class="text-end">Gross</th><th class="text-end">Net</th><th>Status</th><th></th>
</tr></thead><tbody>
<% items.forEach(s => { %>
<tr>
  <td>
    <% if (s.status !== 'paid') { %>
      <input type="checkbox" name="slip_ids" value="<%= s.id %>" class="form-check-input del-cb">
    <% } %>
  </td>
  <td><a href="/hr/payroll/<%= s.id %>"><%= s.emp_name %></a><div class="small text-muted"><%= s.code %></div></td>
  <td><span class="badge bg-<%= s.employee_type==='salary'?'primary':'info' %>"><%= s.employee_type %></span></td>
  <td class="text-end"><%= fmtINR(s.base_amount) %></td>
  <td class="text-end"><%= fmtINR(s.piece_amount) %></td>
  <td class="text-end"><%= fmtINR(s.incentive_amount) %></td>
  <td class="text-end"><%= fmtINR(s.km_amount) %></td>
  <td class="text-end text-danger">− <%= fmtINR(s.advance_deducted) %></td>
  <td class="text-end"><%= fmtINR(s.gross) %></td>
  <td class="text-end"><strong><%= fmtINR(s.net_paid) %></strong></td>
  <td><span class="badge bg-<%= s.status==='paid'?'success':'secondary' %>"><%= s.status %></span></td>
  <td>
    <% if (s.status !== 'paid') { %>
      <button type="button" class="btn btn-sm btn-outline-danger py-0 single-del" data-id="<%= s.id %>" data-name="<%= s.emp_name %>" title="Delete this draft slip">×</button>
    <% } %>
  </td>
</tr>
<% }) %>
<% if (items.length===0) { %><tr><td colspan="12" class="text-muted text-center">No slips generated yet for <%= period %></td></tr><% } %>
</tbody></table></div>
<% if (items.some(s => s.status !== 'paid')) { %>
<div class="card-footer d-flex gap-2 align-items-center py-2">
  <span class="small text-muted" id="del-count">0 selected</span>
  <button class="btn btn-sm btn-outline-danger ms-auto" data-confirm="Delete the selected DRAFT slips? Paid slips are skipped automatically."><i class="bi bi-trash"></i> Delete Selected</button>
</div>
<% } %>
</div>
</form>

<!-- Hidden single-delete form (posts to the existing /:id/delete route) -->
<form method="post" id="single-del-form" class="d-none"></form>

<script>
(function () {
  // ── Generation picker counters ─────────────────────────
  const genCbs = Array.from(document.querySelectorAll('.gen-emp-cb'));
  const genCount = document.getElementById('gen-count');
  function refreshGenCount() {
    if (genCount) genCount.textContent = genCbs.filter(c => c.checked).length + ' selected';
  }
  genCbs.forEach(c => c.addEventListener('change', refreshGenCount));
  document.getElementById('gen-select-all')?.addEventListener('click', () => { genCbs.forEach(c => c.checked = true); refreshGenCount(); });
  document.getElementById('gen-select-none')?.addEventListener('click', () => { genCbs.forEach(c => c.checked = false); refreshGenCount(); });

  // ── Bulk delete counters + select-all ──────────────────
  const delCbs = Array.from(document.querySelectorAll('.del-cb'));
  const delCount = document.getElementById('del-count');
  function refreshDelCount() {
    if (delCount) delCount.textContent = delCbs.filter(c => c.checked).length + ' selected';
  }
  delCbs.forEach(c => c.addEventListener('change', refreshDelCount));
  document.getElementById('del-select-all')?.addEventListener('change', function () {
    delCbs.forEach(c => c.checked = this.checked); refreshDelCount();
  });

  // ── Single-row delete (uses the existing per-slip route) ──
  document.querySelectorAll('.single-del').forEach(btn => {
    btn.addEventListener('click', () => {
      if (!confirm('Delete draft slip for ' + btn.dataset.name + '?')) return;
      const f = document.getElementById('single-del-form');
      f.action = '/hr/payroll/' + btn.dataset.id + '/delete';
      f.submit();
    });
  });
})();
</script>
<%- include('../../partials/footer') %>
