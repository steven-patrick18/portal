<%- include('../../partials/header') %>
<% const sc = { new:'secondary', reviewed:'info', shortlisted:'primary', rejected:'danger', hired:'success', archived:'light' };
   const d16 = s => String(s||'').slice(0,16); %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-person-badge"></i> <%= a.name %>
      <span class="badge bg-<%= sc[a.status]||'secondary' %>"><%= a.status %></span></h4>
    <small class="text-muted"><a href="/hr/recruitment">← Applicant Portal</a> · <%= a.role_applied || a.job_title || 'Candidate' %><% if (a.location) { %> · <%= a.location %><% } %></small>
  </div>
  <div class="d-flex gap-2">
    <% if (a.email) { %><button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#candEmail"><i class="bi bi-envelope"></i> Send Email</button><% } %>
    <% if (emp) { %>
      <a href="/hr/employees/<%= emp.id %>" class="btn btn-sm btn-success"><i class="bi bi-person-check-fill"></i> Employee <%= emp.code %></a>
    <% } else { %>
      <form method="post" action="/hr/recruitment/<%= a.id %>/hire" data-confirm="Hire this candidate and create an employee record?" class="d-inline">
        <button class="btn btn-sm btn-success"><i class="bi bi-person-plus-fill"></i> Pass → Hire (create employee)</button>
      </form>
    <% } %>
  </div>
</div>

<div class="row g-3">
  <!-- Left: profile + status + notes -->
  <div class="col-lg-5">
    <div class="card mb-3"><div class="card-header bg-white d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-person-lines-fill"></i> Candidate</span>
        <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#editCand"><i class="bi bi-pencil"></i> Edit</button>
      </div>
      <div class="card-body">
        <table class="table table-sm m-0"><tbody>
          <tr><th class="text-muted" style="width:110px">Role</th><td><%= a.role_applied || a.job_title || '-' %></td></tr>
          <tr><th class="text-muted">Phone</th><td><% if (a.phone) { %><a href="tel:<%= a.phone %>"><%= a.phone %></a>
            <a href="https://wa.me/91<%= a.phone.replace(/[^0-9]/g,'').slice(-10) %>" target="_blank" class="ms-1"><i class="bi bi-whatsapp text-success"></i></a><% } else { %>-<% } %></td></tr>
          <tr><th class="text-muted">Email</th><td><%= a.email || '-' %></td></tr>
          <tr><th class="text-muted">City</th><td><%= a.location || '-' %></td></tr>
          <tr><th class="text-muted">Applied</th><td><%= d16(a.created_at) %></td></tr>
          <tr><th class="text-muted">CV</th><td><% if (a.cv_path) { %><a href="<%= a.cv_path %>" target="_blank" class="btn btn-sm btn-outline-primary py-0"><i class="bi bi-file-earmark-arrow-down"></i> Download CV</a><% } else { %><span class="text-muted">not attached</span><% } %></td></tr>
        </tbody></table>
      </div>
    </div>

    <div class="card mb-3"><div class="card-header bg-white fw-semibold"><i class="bi bi-flag"></i> Stage</div>
      <div class="card-body d-flex flex-wrap gap-2">
        <% ['reviewed','shortlisted','rejected'].forEach(s => { %>
          <form method="post" action="/hr/recruitment/<%= a.id %>/status" class="d-inline">
            <input type="hidden" name="status" value="<%= s %>">
            <button class="btn btn-sm btn-<%= a.status===s ? sc[s] : 'outline-'+sc[s] %>"><%= s %></button>
          </form>
        <% }) %>
        <% if (a.status==='hired') { %><span class="badge bg-success align-self-center">hired ✓</span><% } %>
      </div>
    </div>

    <div class="card"><div class="card-header bg-white fw-semibold"><i class="bi bi-journal-text"></i> Notes</div>
      <form method="post" action="/hr/recruitment/<%= a.id %>/notes" class="card-body">
        <textarea name="notes" rows="4" class="form-control" placeholder="Interview notes, salary expectation, follow-up…"><%= a.notes || '' %></textarea>
        <button class="btn btn-sm btn-primary mt-2">Save notes</button>
      </form>
    </div>
  </div>

  <!-- Right: email history -->
  <div class="col-lg-7">
    <%
      // Merge sent (email_log) + received (email_inbox) into one chronological thread.
      var thread = [];
      emails.forEach(function(e){ thread.push({ dir:'out', subject:e.subject, body:e.body, at:e.created_at, status:e.status, error:e.error, meta:e.template_key }); });
      (received||[]).forEach(function(e){ thread.push({ dir:'in', subject:e.subject, body:e.body, at:e.received_at, who:(e.from_name||a.name) }); });
      thread.sort(function(x,y){ return String(x.at||'').localeCompare(String(y.at||'')); });
    %>
    <div class="card"><div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
      <span class="fw-semibold"><i class="bi bi-envelope-paper"></i> Email thread</span>
      <div class="d-flex gap-2">
        <% if (a.email) { %><form method="post" action="/hr/recruitment/<%= a.id %>/sync-replies" class="d-inline"><button class="btn btn-sm btn-outline-secondary" <%= imapReady ? '' : 'disabled title="Set up IMAP in Settings → Email"' %>><i class="bi bi-arrow-repeat"></i> Sync replies</button></form><% } %>
        <% if (a.email) { %><button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#candEmail"><i class="bi bi-send"></i> Send Email</button><% } %>
      </div>
    </div>
    <div class="list-group list-group-flush">
      <% thread.forEach(function(m){ %>
        <div class="list-group-item <%= m.dir==='in' ? 'bg-success-subtle' : '' %>">
          <div class="d-flex justify-content-between align-items-start">
            <strong class="small"><%= m.dir==='in' ? '↩ ' : '' %><%= m.subject %></strong>
            <% if (m.dir==='out') { %><span class="badge bg-<%= m.status==='sent'?'success':'danger' %>"><%= m.status %></span>
            <% } else { %><span class="badge bg-success">reply</span><% } %>
          </div>
          <div class="small text-muted"><%= m.dir==='out' ? 'You → candidate' : ('← ' + (m.who||'Candidate')) %> · <%= d16(m.at) %><% if (m.meta) { %> · <%= m.meta %><% } %></div>
          <% if (m.error) { %><div class="small text-danger"><%= m.error %></div><% } %>
          <% if (m.body) { %><div class="small mt-1" style="white-space:pre-wrap;max-height:160px;overflow:auto"><%= m.body %></div><% } %>
        </div>
      <% }) %>
      <% if (!thread.length) { %><div class="list-group-item text-muted text-center py-4">No emails yet.<% if (!emailReady) { %> Set up email in <a href="/settings/email">Settings → Email</a>.<% } %></div><% } %>
    </div></div>
    <p class="small text-muted mt-2"><i class="bi bi-info-circle"></i> Click <strong>Sync replies</strong> to pull the candidate's replies from your <strong>hr@sharvexports.com</strong> mailbox into this thread.<% if (!imapReady) { %> First add IMAP in <a href="/settings/email">Settings → Email</a>.<% } %></p>
  </div>
</div>

<!-- Send email modal -->
<% if (a.email) { %>
<div class="modal fade" id="candEmail"><div class="modal-dialog modal-lg"><div class="modal-content">
  <form method="post" action="/hr/recruitment/<%= a.id %>/email">
    <div class="modal-header"><h5 class="modal-title"><i class="bi bi-envelope"></i> Email <%= a.name %></h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <% if (!emailReady) { %><div class="alert alert-warning small">Email isn't set up. Add your mailbox in <a href="/settings/email">Settings → Email</a> first.</div><% } %>
      <div class="mb-2 small text-muted">To: <strong><%= a.email %></strong></div>
      <input type="hidden" name="template_key" id="ce-tkey">
      <label class="form-label">Quick template <span class="text-muted">(<%= emailTemplates.length %> available — click one to fill)</span></label>
      <div class="d-flex flex-wrap gap-1 mb-2">
        <% emailTemplates.forEach(t => { %><button type="button" class="btn btn-sm btn-outline-secondary" onclick="ceFill('<%= t.tkey %>')"><%= t.label %></button><% }) %>
        <% if (!emailTemplates.length) { %><span class="small text-danger">No templates loaded — type the subject &amp; message below.</span><% } %>
      </div>
      <label class="form-label">Subject</label>
      <input name="subject" id="ce-subject" class="form-control mb-2" required>
      <label class="form-label">Message</label>
      <textarea name="body" id="ce-body" rows="10" class="form-control" required></textarea>
      <div class="form-text">Edit before sending. Fill in <code>{date}</code> / <code>{time}</code> / <code>{place}</code> where needed.</div>
    </div>
    <div class="modal-footer"><button class="btn btn-primary" <%= emailReady ? '' : 'disabled' %>><i class="bi bi-send"></i> Send email</button></div>
  </form>
</div></div></div>
<script>
  var CE_TPLS = <%- JSON.stringify(emailTemplates || []) %>;
  var CE_VARS = { name: "<%= (a.name||'').replace(/"/g,'\\"') %>", role: "<%= (a.role_applied||a.job_title||'').replace(/"/g,'\\"') %>", company: "<%= (company||'').replace(/"/g,'\\"') %>", sender: "<%= (senderName||'').replace(/"/g,'\\"') %>" };
  function ceFill(key){
    document.getElementById('ce-tkey').value = key;
    var t = CE_TPLS.filter(function(x){ return x.tkey === key; })[0];
    if (!t) return;
    function rep(s){ return String(s||'').replace(/\{(\w+)\}/g, function(m,k){ return CE_VARS[k] != null ? CE_VARS[k] : m; }); }
    document.getElementById('ce-subject').value = rep(t.subject);
    document.getElementById('ce-body').value = rep(t.body);
  }
</script>
<% } %>

<!-- Edit candidate details (e.g. add a missing email) -->
<div class="modal fade" id="editCand"><div class="modal-dialog"><div class="modal-content">
  <form method="post" action="/hr/recruitment/<%= a.id %>/edit">
    <div class="modal-header"><h5 class="modal-title">Edit candidate</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <div class="row g-2">
        <div class="col-12"><label class="form-label">Name *</label><input name="name" class="form-control" required value="<%= a.name || '' %>"></div>
        <div class="col-md-6"><label class="form-label">Phone</label><input name="phone" class="form-control" value="<%= a.phone || '' %>"></div>
        <div class="col-md-6"><label class="form-label">Email</label><input name="email" type="email" class="form-control" value="<%= a.email || '' %>" placeholder="name@example.com"></div>
        <div class="col-md-6"><label class="form-label">City</label><input name="location" class="form-control" value="<%= a.location || '' %>"></div>
        <div class="col-md-6"><label class="form-label">Role</label><input name="role_applied" class="form-control" value="<%= a.role_applied || a.job_title || '' %>"></div>
      </div>
      <div class="form-text mt-2">Add the email here to enable sending emails to this candidate.</div>
    </div>
    <div class="modal-footer"><button class="btn btn-primary">Save</button></div>
  </form>
</div></div></div>
<%- include('../../partials/footer') %>
