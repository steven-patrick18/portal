<%- include('../partials/header') %>
<h4>Edit Invoice <%= inv.invoice_no %></h4>
<div class="alert alert-info small">Line items are locked for audit. You can adjust the date, discount, or notes — totals + GST will recompute automatically.</div>
<form method="post" action="/invoices/<%= inv.id %>" class="card p-3" style="max-width:680px">
  <div class="row g-3">
    <div class="col-md-6"><label class="form-label">Invoice Date</label><input type="date" name="invoice_date" class="form-control" required value="<%= inv.invoice_date %>"></div>
    <div class="col-md-6"><label class="form-label">Status</label><input class="form-control" value="<%= inv.status %>" readonly></div>
    <div class="col-md-6"><label class="form-label">Subtotal (locked)</label><input class="form-control" value="₹<%= inv.subtotal.toFixed(2) %>" readonly></div>
    <div class="col-md-6"><label class="form-label">Discount (₹)</label><input type="number" step="0.01" min="0" max="<%= inv.subtotal %>" name="discount_amount" class="form-control" value="<%= inv.discount_amount || 0 %>"></div>
    <div class="col-md-12"><label class="form-label">Notes</label><textarea name="notes" class="form-control" rows="3"><%= inv.notes||'' %></textarea></div>
  </div>
  <div class="mt-3"><button class="btn btn-primary">Save Changes</button> <a href="/invoices/<%= inv.id %>" class="btn btn-secondary">Cancel</a></div>
</form>
<%- include('../partials/footer') %>
