<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="m-0">Invoices</h4>
    <% if (dealerName) { %><small class="text-muted">Filtered to dealer: <strong><%= dealerName %></strong> · <a href="/invoices?status=<%= status %>" class="text-decoration-none">clear ✕</a></small><% } %>
  </div>
  <div class="d-flex gap-2">
    <div class="btn-group btn-group-sm">
      <a class="btn btn-outline-secondary <%= status==='all'?'active':'' %>" href="?status=all<%= dealerId?'&dealer_id='+dealerId:'' %>">All</a>
      <a class="btn btn-outline-secondary <%= status==='unpaid'?'active':'' %>" href="?status=unpaid<%= dealerId?'&dealer_id='+dealerId:'' %>">Unpaid</a>
      <a class="btn btn-outline-secondary <%= status==='partial'?'active':'' %>" href="?status=partial<%= dealerId?'&dealer_id='+dealerId:'' %>">Partial</a>
      <a class="btn btn-outline-secondary <%= status==='paid'?'active':'' %>" href="?status=paid<%= dealerId?'&dealer_id='+dealerId:'' %>">Paid</a>
    </div>
    <button onclick="window.print()" class="btn btn-outline-secondary btn-sm" title="Print this list"><i class="bi bi-printer"></i> Print</button>
    <a href="/invoices/new" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New</a>
  </div>
</div>

<div class="print-zone">
<div class="print-only mb-3">
  <div style="font-size:16pt;font-weight:800;border-bottom:2px solid #000;padding-bottom:4px;margin-bottom:6px"><%= companyName %> · Invoices</div>
  <div style="font-size:10pt;color:#444">
    <strong>Status:</strong> <%= status %>
    <% if (dealerName) { %> · <strong>Dealer:</strong> <%= dealerName %><% } %>
    · <strong>Total:</strong> <%= invoices.length %> invoice<%= invoices.length===1?'':'s' %>
    · Generated <%= fmtDateTime(new Date().toISOString().replace('T',' ').slice(0,19)) %>
  </div>
</div>

<div class="card"><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>Inv #</th><th>Date</th><th>Dealer</th><th>Salesperson</th><th class="text-end">Total</th><th class="text-end">Paid</th><th class="text-end">Balance</th><th>Status</th></tr></thead><tbody>
<% invoices.forEach(i => { %>
<tr><td><a href="/invoices/<%= i.id %>"><%= i.invoice_no %></a></td><td><%= fmtDate(i.invoice_date) %></td>
<td><%= i.dealer_name %></td><td><%= i.sp_name||'-' %></td>
<td class="text-end"><%= fmtINR(i.total) %></td><td class="text-end"><%= fmtINR(i.paid_amount) %></td>
<td class="text-end fw-bold"><%= fmtINR(i.total - i.paid_amount) %></td>
<td><span class="badge bg-<%= i.status==='paid'?'success':i.status==='partial'?'warning':i.status==='cancelled'?'danger':'secondary' %>"><%= i.status %></span></td></tr>
<% }) %>
<% if (invoices.length===0) { %><tr><td colspan="8" class="text-muted text-center">No invoices</td></tr><% } %>
</tbody></table></div></div>
</div><!-- /.print-zone -->
<%- include('../partials/footer') %>
