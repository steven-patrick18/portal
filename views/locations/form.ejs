<%- include('../partials/header') %>
<% const editing = loc && loc.id; %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0"><i class="bi bi-building"></i> <%= editing ? 'Edit ' + loc.name : 'New Office / Location' %></h4>
  <a href="/locations" class="btn btn-sm btn-outline-secondary">← All locations</a>
</div>

<form method="post" action="<%= editing ? '/locations/' + loc.id : '/locations' %>" class="card p-3" style="max-width:880px">
  <div class="row g-3">
    <div class="col-md-7">
      <label class="form-label">Name *</label>
      <input name="name" class="form-control" required maxlength="120"
             value="<%= editing ? loc.name : '' %>"
             placeholder="e.g. Muzaffarpur Regional Office">
    </div>
    <div class="col-md-5">
      <label class="form-label">Type *</label>
      <select name="type" class="form-select" required>
        <% types.forEach(t => { %>
          <option value="<%= t %>" <%= editing && loc.type === t ? 'selected' : '' %>>
            <% if (t === 'factory')   { %>🏭 Factory (production)<% } %>
            <% if (t === 'office')    { %>🏢 Office (sales / admin)<% } %>
            <% if (t === 'warehouse') { %>📦 Warehouse (stock-holding)<% } %>
          </option>
        <% }) %>
      </select>
      <div class="form-text small">Office = no stock. Warehouse = future inventory split. Factory = production happens here.</div>
    </div>

    <div class="col-md-4">
      <label class="form-label">City</label>
      <input name="city" class="form-control" value="<%= editing ? (loc.city || '') : '' %>" placeholder="Muzaffarpur">
    </div>
    <div class="col-md-4">
      <label class="form-label">State</label>
      <input name="state" class="form-control" value="<%= editing ? (loc.state || '') : '' %>" placeholder="Bihar">
    </div>
    <div class="col-md-4">
      <label class="form-label">Phone</label>
      <input name="phone" class="form-control" value="<%= editing ? (loc.phone || '') : '' %>" placeholder="9876543210">
    </div>

    <div class="col-md-12">
      <label class="form-label">Address</label>
      <textarea name="address" class="form-control" rows="2" placeholder="Street, area, landmark, pincode"><%= editing ? (loc.address || '') : '' %></textarea>
    </div>

    <div class="col-md-4">
      <label class="form-label">GPS Latitude</label>
      <input name="lat" type="number" step="0.000001" class="form-control"
             value="<%= editing && loc.lat ? loc.lat : '' %>" placeholder="26.1227">
    </div>
    <div class="col-md-4">
      <label class="form-label">GPS Longitude</label>
      <input name="lng" type="number" step="0.000001" class="form-control"
             value="<%= editing && loc.lng ? loc.lng : '' %>" placeholder="85.3906">
    </div>
    <div class="col-md-4 d-flex align-items-end">
      <button type="button" class="btn btn-outline-secondary btn-sm" onclick="useMyLocation()">
        <i class="bi bi-geo-alt"></i> Use my current GPS
      </button>
    </div>
    <div class="col-12 small text-muted" style="margin-top:-4px">
      Tip: open Google Maps on your phone at the office, drop a pin, and paste the coords here. Or open this page in the browser at the office and click "Use my current GPS".
    </div>

    <div class="col-md-6">
      <label class="form-label">GSTIN</label>
      <input name="gstin" class="form-control" value="<%= editing ? (loc.gstin || '') : '' %>" placeholder="10ABCDE1234F1Z5">
      <div class="form-text small">Optional. Only set if this office is registered in a different state from head office (for inter-state GST).</div>
    </div>
    <% if (editing) { %>
      <div class="col-md-6">
        <label class="form-label d-block">Active</label>
        <div class="form-check form-switch mt-2">
          <input class="form-check-input" type="checkbox" name="active" value="1" <%= loc.active ? 'checked' : '' %>>
          <label class="form-check-label small text-muted">Uncheck to hide from dropdowns without deleting history</label>
        </div>
      </div>
    <% } else { %>
      <input type="hidden" name="active" value="1">
    <% } %>
  </div>

  <div class="mt-3">
    <button class="btn btn-primary"><i class="bi bi-save"></i> <%= editing ? 'Save Changes' : 'Create Location' %></button>
    <a href="/locations" class="btn btn-secondary">Cancel</a>
  </div>
</form>

<script>
function useMyLocation() {
  if (!navigator.geolocation) { alert('Browser does not support geolocation.'); return; }
  navigator.geolocation.getCurrentPosition(
    p => {
      document.querySelector('input[name="lat"]').value = p.coords.latitude.toFixed(6);
      document.querySelector('input[name="lng"]').value = p.coords.longitude.toFixed(6);
    },
    err => alert('Could not read GPS: ' + err.message),
    { enableHighAccuracy: true, timeout: 10000 }
  );
}
</script>
<%- include('../partials/footer') %>
