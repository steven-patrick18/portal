<%- include('../partials/header') %>
<h5 class="mb-3"><i class="bi bi-phone"></i> My Salesperson App</h5>
<div class="row g-2 mb-3">
  <div class="col-6"><div class="card kpi-card success p-2"><div class="kpi-label small">Today Sales</div><div class="kpi-value" style="font-size:1.2rem"><%= fmtINR(todaySales) %></div></div></div>
  <div class="col-6"><div class="card kpi-card success p-2"><div class="kpi-label small">Today Collection</div><div class="kpi-value" style="font-size:1.2rem"><%= fmtINR(todayCol) %></div></div></div>
  <div class="col-6"><div class="card kpi-card p-2"><div class="kpi-label small">Month Sales</div><div class="kpi-value" style="font-size:1.2rem"><%= fmtINR(monthSales) %></div></div></div>
  <div class="col-6"><div class="card kpi-card p-2"><div class="kpi-label small">Month Collection</div><div class="kpi-value" style="font-size:1.2rem"><%= fmtINR(monthCol) %></div></div></div>
  <div class="col-6"><div class="card kpi-card warning p-2"><div class="kpi-label small">My Dealers</div><div class="kpi-value" style="font-size:1.2rem"><%= myDealers %></div></div></div>
  <div class="col-6"><div class="card kpi-card warning p-2"><div class="kpi-label small">My Outstanding</div><div class="kpi-value" style="font-size:1.2rem"><%= fmtINR(myOutstanding) %></div></div></div>
</div>
<div class="d-grid gap-2 mb-5">
  <a href="/mobile/dealers" class="btn btn-outline-primary"><i class="bi bi-people"></i> My Dealers</a>
  <a href="/sales-orders/new" class="btn btn-primary"><i class="bi bi-plus-circle"></i> New Sales Order</a>
  <a href="/payments/new" class="btn btn-success"><i class="bi bi-cash-coin"></i> Record Payment</a>
  <a href="/mobile/payments" class="btn btn-outline-secondary"><i class="bi bi-clock-history"></i> My Recent Payments</a>
</div>
<div class="mobile-bottom-nav">
  <a href="/mobile" class="active"><i class="bi bi-house"></i><div>Home</div></a>
  <a href="/mobile/dealers"><i class="bi bi-people"></i><div>Dealers</div></a>
  <a href="/sales-orders/new"><i class="bi bi-plus-circle"></i><div>Order</div></a>
  <a href="/payments/new"><i class="bi bi-cash-coin"></i><div>Pay</div></a>
  <a href="/users/me"><i class="bi bi-person"></i><div>Me</div></a>
</div>
<%- include('../partials/footer') %>
