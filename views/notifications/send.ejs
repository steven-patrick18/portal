<%- include('../partials/header') %>
<h4>Send Notification</h4>
<div class="alert alert-light border small" style="max-width:680px">
  <i class="bi bi-info-circle"></i> SMS goes via Fast2SMS (DLT), so you can only send an <strong>approved template</strong> — not free text. Dealer-level templates (e.g. <em>Outstanding reminder</em>) work best here; invoice/dispatch alerts fire automatically.
</div>
<form method="post" action="/notifications/send" class="card p-3" style="max-width:680px">
  <div class="mb-3"><label class="form-label">Dealer</label>
    <select name="dealer_id" class="form-select" required>
      <% dealers.forEach(d => { %><option value="<%= d.id %>" <%= preDealer && parseInt(preDealer)===d.id ? 'selected' : '' %>><%= d.name %> · <%= d.phone %></option><% }) %>
    </select>
  </div>
  <div class="mb-3"><label class="form-label">Template</label>
    <select name="template_id" id="tplSel" class="form-select" required>
      <option value="">— pick a template —</option>
      <% templates.forEach(t => { %><option value="<%= t.id %>" data-body="<%= t.body %>" <%= !t.dlt_template_id ? 'data-noid="1"' : '' %>><%= t.label %> (<%= t.event %>)<%= !t.dlt_template_id ? ' — no DLT ID set' : '' %></option><% }) %>
    </select>
    <div class="form-text">The message uses this template's wording; dealer name &amp; outstanding are filled automatically.</div>
  </div>
  <div class="mb-3" id="preview" style="display:none">
    <label class="form-label">Preview</label>
    <div class="border rounded p-2 small bg-light" id="previewBody"></div>
  </div>
  <button class="btn btn-primary">Send</button> <a href="/notifications" class="btn btn-secondary">Cancel</a>
</form>
<script>
(function(){
  var sel=document.getElementById('tplSel'), pv=document.getElementById('preview'), body=document.getElementById('previewBody');
  sel.addEventListener('change', function(){
    var o=sel.options[sel.selectedIndex], txt=o.getAttribute('data-body');
    if(txt){ body.textContent=txt; pv.style.display=''; } else { pv.style.display='none'; }
  });
})();
</script>
<%- include('../partials/footer') %>
