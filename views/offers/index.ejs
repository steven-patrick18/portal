<%- include('../partials/header') %>
<% const KL = { yearly:'Whole-year', seasonal:'Seasonal', festival:'Festival' };
   const kb = { yearly:'primary', seasonal:'info', festival:'warning' }; %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-gift-fill text-danger"></i> Dealer Offers</h4>
    <small class="text-muted">Reward dealers with gifts &amp; trips when their <strong>cleared payment</strong> in the offer window reaches a tier. Whole-year · seasonal · festival campaigns.</small>
  </div>
</div>

<div class="row g-3">
  <div class="<%= canManage ? 'col-lg-8' : 'col-12' %>">
    <% if (!list.length) { %>
      <div class="card p-4 text-center text-muted">No offers yet.<% if (canManage) { %> Create one on the right — e.g. "Diwali Dhamaka" or "Annual Loyalty".<% } %></div>
    <% } %>
    <% list.forEach(s => { %>
      <div class="card mb-2">
        <div class="card-body py-2">
          <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
              <a href="/offers/<%= s.id %>" class="fw-semibold text-decoration-none fs-6"><%= s.name %></a>
              <span class="badge bg-<%= kb[s.kind]||'secondary' %>-subtle text-<%= kb[s.kind]||'secondary' %>-emphasis border border-<%= kb[s.kind]||'secondary' %>-subtle"><%= KL[s.kind]||s.kind %></span>
              <% if (s.running) { %><span class="badge bg-success">running</span><% } else if (!s.active) { %><span class="badge bg-secondary">off</span><% } else { %><span class="badge bg-light text-dark border">scheduled/ended</span><% } %>
              <div class="small text-muted">
                <i class="bi bi-calendar-range"></i>
                <%= s.from_date ? fmtDate(s.from_date+' 00:00:00') : 'any' %> → <%= s.to_date ? fmtDate(s.to_date+' 00:00:00') : 'any' %>
                · <%= s.tierCount %> reward tier<%= s.tierCount===1?'':'s' %>
              </div>
            </div>
            <div class="text-end small">
              <div><span class="badge bg-primary"><%= s.eligible %></span> eligible</div>
              <div class="mt-1"><span class="badge bg-success"><%= s.delivered %></span> delivered · <span class="badge bg-warning text-dark"><%= s.pending %></span> pending</div>
            </div>
          </div>
          <a href="/offers/<%= s.id %>" class="btn btn-sm btn-outline-primary mt-2"><i class="bi bi-people"></i> Eligible dealers &amp; delivery</a>
        </div>
      </div>
    <% }) %>
  </div>

  <% if (canManage) { %>
  <div class="col-lg-4">
    <form method="post" action="/offers" class="card p-3">
      <h6 class="mb-2"><i class="bi bi-plus-circle"></i> New offer campaign</h6>
      <div class="mb-2"><label class="form-label small mb-0">Name</label><input name="name" class="form-control form-control-sm" required placeholder="e.g. Diwali Dhamaka 2026"></div>
      <div class="mb-2"><label class="form-label small mb-0">Type</label>
        <select name="kind" class="form-select form-select-sm">
          <option value="seasonal">Seasonal</option>
          <option value="festival">Festival</option>
          <option value="yearly">Whole-year</option>
        </select></div>
      <div class="row g-2">
        <div class="col-6"><label class="form-label small mb-0">From</label><input type="date" name="from_date" class="form-control form-control-sm"></div>
        <div class="col-6"><label class="form-label small mb-0">To</label><input type="date" name="to_date" class="form-control form-control-sm"></div>
      </div>
      <div class="mt-2"><label class="form-label small mb-0">Note (optional)</label><input name="note" class="form-control form-control-sm" placeholder="terms, remarks"></div>
      <div class="mt-3"><button class="btn btn-sm btn-primary">Create &amp; add rewards</button></div>
      <div class="form-text mt-2">Rewards are earned on <strong>cleared payment</strong> in the window. You add the reward tiers (₹ → gift) on the next screen.</div>
    </form>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
