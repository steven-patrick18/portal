<%- include('../partials/header') %>
<% const KL = { yearly:'Whole-year', seasonal:'Seasonal', festival:'Festival' };
   const running = (!s.from_date || s.from_date <= today) && (!s.to_date || s.to_date >= today) && s.active; %>
<div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-gift-fill text-danger"></i> <%= s.name %>
      <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle"><%= KL[s.kind]||s.kind %></span>
      <% if (running) { %><span class="badge bg-success">running</span><% } else if (!s.active) { %><span class="badge bg-secondary">off</span><% } else { %><span class="badge bg-light text-dark border">not in window</span><% } %>
    </h4>
    <small class="text-muted"><a href="/offers">← Offers</a> · Window: <%= s.from_date ? fmtDate(s.from_date+' 00:00:00') : 'any' %> → <%= s.to_date ? fmtDate(s.to_date+' 00:00:00') : 'any' %> · reward on <strong>cleared payment</strong> in this window
      <% if (s.filter_kind && s.filter_kind !== 'all') { %> · <span class="badge bg-secondary-subtle text-secondary-emphasis border"><i class="bi bi-funnel"></i> <%= filterLabels[s.filter_kind] %><%= s.filter_kind==='inactive' && s.filter_days ? ' ('+s.filter_days+'d)' : '' %></span><% } %>
      <% if (s.ontime_days) { %> <span class="badge bg-success-subtle text-success-emphasis border">⏱ on-time only — paid within <%= s.ontime_days %> days of invoice</span><% } %>
    </small>
  </div>
  <% if (canManage) { %>
  <div class="d-flex gap-2">
    <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#editOffer"><i class="bi bi-pencil"></i> Edit</button>
    <form method="post" action="/offers/<%= s.id %>/toggle" class="d-inline"><button class="btn btn-sm btn-outline-<%= s.active?'warning':'success' %>"><%= s.active?'Turn off':'Turn on' %></button></form>
    <form method="post" action="/offers/<%= s.id %>/delete" class="d-inline" data-confirm="Delete this offer, its tiers and delivery records?"><button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>
  </div>
  <% } %>
</div>

<% if (canManage) { %>
<div class="collapse mb-3" id="editOffer">
  <form method="post" action="/offers" class="card p-3">
    <input type="hidden" name="id" value="<%= s.id %>">
    <div class="row g-2">
      <div class="col-md-4"><label class="form-label small mb-0">Name</label><input name="name" class="form-control form-control-sm" value="<%= s.name %>" required></div>
      <div class="col-md-2"><label class="form-label small mb-0">Type</label>
        <select name="kind" class="form-select form-select-sm">
          <% ['seasonal','festival','yearly'].forEach(k => { %><option value="<%= k %>" <%= s.kind===k?'selected':'' %>><%= KL[k] %></option><% }) %>
        </select></div>
      <div class="col-md-2"><label class="form-label small mb-0">From</label><input type="date" name="from_date" class="form-control form-control-sm" value="<%= s.from_date||'' %>"></div>
      <div class="col-md-2"><label class="form-label small mb-0">To</label><input type="date" name="to_date" class="form-control form-control-sm" value="<%= s.to_date||'' %>"></div>
      <div class="col-md-2 d-flex align-items-end"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="active" value="1" <%= s.active?'checked':'' %>><label class="form-check-label small">Active</label></div></div>
      <div class="col-md-4"><label class="form-label small mb-0">Applies to</label>
        <select name="filter_kind" id="ef-filter" class="form-select form-select-sm" onchange="efFilterUI()">
          <option value="all" <%= s.filter_kind==='all'?'selected':'' %>>All dealers</option>
          <option value="new" <%= s.filter_kind==='new'?'selected':'' %>>New dealers (joined on/after From)</option>
          <option value="inactive" <%= s.filter_kind==='inactive'?'selected':'' %>>Inactive dealers</option>
          <option value="selected" <%= s.filter_kind==='selected'?'selected':'' %>>Selected dealers</option>
        </select></div>
      <div class="col-md-4" id="ef-days" style="display:none"><label class="form-label small mb-0">No payment in the … days before From</label>
        <input name="filter_days" type="number" min="1" class="form-control form-control-sm" value="<%= s.filter_days || 90 %>"></div>
      <div class="col-md-4"><label class="form-label small mb-0">On-time: count payments within … days of invoice</label>
        <input name="ontime_days" type="number" min="0" class="form-control form-control-sm" value="<%= s.ontime_days || '' %>" placeholder="blank = all payments"></div>
      <div class="col-12" id="ef-dealers" style="display:none">
        <label class="form-label small mb-0">Pick the dealers (Ctrl/⌘-click for many) — <%= selectedIds.length %> selected</label>
        <select name="dealer_ids" class="form-select form-select-sm" multiple size="8">
          <% allDealers.forEach(d => { %><option value="<%= d.id %>" <%= selectedIds.includes(d.id)?'selected':'' %>><%= d.name %> (<%= d.code %>)<%= d.city ? ' · ' + d.city : '' %></option><% }) %>
        </select>
      </div>
      <div class="col-12"><label class="form-label small mb-0">Note</label><input name="note" class="form-control form-control-sm" value="<%= s.note||'' %>"></div>
    </div>
    <div class="mt-2"><button class="btn btn-sm btn-primary">Save</button></div>
  </form>
</div>
<script>
function efFilterUI(){
  var v = document.getElementById('ef-filter').value;
  document.getElementById('ef-days').style.display = v==='inactive' ? '' : 'none';
  document.getElementById('ef-dealers').style.display = v==='selected' ? '' : 'none';
}
efFilterUI();
</script>
<% } %>

<div class="row g-3">
  <!-- Reward tiers -->
  <div class="col-lg-4">
    <div class="card"><div class="card-header bg-white fw-semibold"><i class="bi bi-trophy"></i> Reward tiers</div>
      <div class="card-body py-2">
        <% if (!tiers.length) { %><div class="text-muted text-center py-2">No rewards yet — add below.</div><% } %>
        <% tiers.forEach(t => { const imgs = (()=>{try{return JSON.parse(t.images_json||'[]')||[]}catch(e){return[]}})(); %>
          <div class="d-flex gap-2 align-items-start border-bottom py-2">
            <div class="flex-grow-1" style="min-width:0">
              <div><span class="fw-semibold"><%= fmtINR(t.min_amount) %></span> → <span class="badge bg-primary"><%= t.reward %></span></div>
              <% if (imgs.length) { %>
                <div class="d-flex gap-1 mt-1 flex-wrap">
                  <% imgs.forEach(im => { %>
                    <div style="position:relative">
                      <a href="<%= im %>" target="_blank"><img src="<%= im %>" style="width:48px;height:48px;object-fit:cover;border-radius:6px;border:1px solid #e5e7eb"></a>
                      <% if (canManage) { %><form method="post" action="/offers/tier/<%= t.id %>/photo/delete" style="position:absolute;top:-7px;right:-7px;margin:0"><input type="hidden" name="path" value="<%= im %>"><button class="btn btn-danger p-0 d-flex align-items-center justify-content-center" style="width:17px;height:17px;font-size:11px;border-radius:50%" title="Remove photo">×</button></form><% } %>
                    </div>
                  <% }) %>
                </div>
              <% } %>
              <% if (canManage && imgs.length < 4) { %>
                <form method="post" action="/offers/tier/<%= t.id %>/photos" enctype="multipart/form-data" class="mt-1 d-flex gap-1 align-items-center">
                  <input type="file" name="photos" accept="image/*" multiple class="form-control form-control-sm" style="max-width:170px">
                  <button class="btn btn-sm btn-outline-secondary py-0"><i class="bi bi-image"></i> add photo</button>
                </form>
              <% } %>
            </div>
            <% if (canManage) { %><form method="post" action="/offers/tier/<%= t.id %>/delete" data-confirm="Remove this reward tier?" class="m-0"><button class="btn btn-sm btn-outline-danger py-0">×</button></form><% } %>
          </div>
        <% }) %>
      </div>
      <% if (canManage) { %>
      <form method="post" action="/offers/<%= s.id %>/tier" enctype="multipart/form-data" class="card-body py-2 border-top">
        <div class="row g-1">
          <div class="col-5"><input name="min_amount" type="number" step="1000" class="form-control form-control-sm" placeholder="₹ reach" required></div>
          <div class="col-5"><input name="reward" class="form-control form-control-sm" placeholder="e.g. Dinner Set" required></div>
          <div class="col-2"><button class="btn btn-sm btn-primary w-100">+</button></div>
          <div class="col-12 mt-1"><input type="file" name="photos" accept="image/*" multiple class="form-control form-control-sm">
            <div class="form-text">Optional — up to 4 photos of the gift. e.g. 500000 → Steel Bottle · 5000000 → Thailand Trip · 10000000 → Car</div></div>
        </div>
      </form>
      <% } %>
    </div>
  </div>

  <!-- Eligible dealers + delivery -->
  <div class="col-lg-8">
    <div class="row g-2 mb-2">
      <div class="col"><div class="card text-center"><div class="card-body p-2"><div class="h5 m-0"><%= stats.eligible %></div><div class="small text-muted">eligible dealers</div></div></div></div>
      <div class="col"><div class="card text-center"><div class="card-body p-2"><div class="h5 m-0 text-success"><%= stats.delivered %></div><div class="small text-muted">delivered</div></div></div></div>
      <div class="col"><div class="card text-center"><div class="card-body p-2"><div class="h5 m-0 text-warning"><%= stats.pending %></div><div class="small text-muted">to give</div></div></div></div>
    </div>
    <div class="card"><div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
      <span class="fw-semibold"><i class="bi bi-people-fill"></i> Eligible dealers</span>
      <span class="d-flex align-items-center gap-2">
        <% if (canManage) { %>
          <% if (smsReady) { %>
            <form method="post" action="/offers/<%= s.id %>/notify" class="d-inline" data-confirm="SMS every eligible dealer not yet congratulated?">
              <button class="btn btn-sm btn-success"><i class="bi bi-chat-dots"></i> Send SMS to eligible</button>
            </form>
          <% } else { %>
            <a href="/settings/sms" class="btn btn-sm btn-outline-secondary" title="Add the DLT id to the 'Dealer offer' template and switch it on"><i class="bi bi-chat-dots"></i> SMS off — set up template</a>
          <% } %>
        <% } %>
        <span class="small text-muted">reached a reward tier in the window</span>
      </span>
    </div>
    <div class="table-responsive"><table class="table table-sm table-hover align-middle m-0">
      <thead><tr><th>Dealer</th><th class="text-end">Cleared payment</th><th>Reward earned</th><th>Status</th><% if (canManage) { %><th></th><% } %></tr></thead>
      <tbody>
        <% eligible.forEach(e => { %>
          <tr>
            <td><a href="/dealers/<%= e.id %>" class="text-decoration-none fw-semibold"><%= e.name %></a> <span class="text-muted small">(<%= e.code %>)</span><% if (e.sp_name) { %><div class="small text-muted"><i class="bi bi-person"></i> <%= e.sp_name %><% if (e.city) { %> · <%= e.city %><% } %></div><% } %></td>
            <td class="text-end fw-semibold"><%= fmtINR(e.collected) %><% if (e.nextTier) { %><div class="small text-muted">+<%= fmtINR(e.nextTier.min_amount - e.collected) %> → <%= e.nextTier.reward %></div><% } %></td>
            <td><span class="badge bg-primary"><%= e.reward %></span></td>
            <td>
              <% if (e.award) { %><span class="text-success"><i class="bi bi-check-circle-fill"></i> Delivered<% if (e.award.delivered_date) { %> <%= fmtDate(e.award.delivered_date+' 00:00:00') %><% } %></span><% if (e.award.reward && e.award.reward!==e.reward) { %><div class="small text-muted"><%= e.award.reward %></div><% } %>
              <% } else { %><span class="badge bg-warning text-dark">to give</span><% } %>
              <% if (e.notice) { %><div class="small text-info" title="Congratulation SMS sent for this reward"><i class="bi bi-chat-dots-fill"></i> SMS sent</div><% } %>
            </td>
            <% if (canManage) { %>
            <td class="text-end" style="white-space:nowrap">
              <% if (e.award) { %>
                <form method="post" action="/offers/<%= s.id %>/undeliver" class="d-inline" data-confirm="Mark this reward as not delivered?"><input type="hidden" name="dealer_id" value="<%= e.id %>"><button class="btn btn-sm btn-outline-secondary py-0">undo</button></form>
              <% } else { %>
                <form method="post" action="/offers/<%= s.id %>/deliver" class="d-inline" data-confirm="Mark <%= e.reward %> delivered to <%= e.name %>?">
                  <input type="hidden" name="dealer_id" value="<%= e.id %>">
                  <input type="hidden" name="tier_id" value="<%= e.tier.id %>">
                  <input type="hidden" name="reward" value="<%= e.reward %>">
                  <input type="hidden" name="amount" value="<%= e.collected %>">
                  <button class="btn btn-sm btn-success py-0"><i class="bi bi-check2"></i> Delivered</button>
                </form>
              <% } %>
            </td>
            <% } %>
          </tr>
        <% }) %>
        <% if (!eligible.length) { %><tr><td colspan="<%= canManage?5:4 %>" class="text-muted text-center py-4">No dealer has reached a reward tier yet<% if (!tiers.length) { %> — add reward tiers first<% } %>.</td></tr><% } %>
      </tbody>
    </table></div></div>
  </div>
</div>
<%- include('../partials/footer') %>
