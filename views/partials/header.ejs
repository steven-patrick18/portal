<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title><%= title %> · <%= companyName %></title>
<link rel="icon" href="data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🧵</text></svg>">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
<link rel="stylesheet" href="/css/app.css">
</head>
<body>
<%- include('navbar') %>
<div class="container-fluid">
  <div class="row">
    <% if (user) { %>
      <%- include('sidebar') %>
      <main class="col-md-9 col-lg-10 ms-sm-auto px-md-4 py-3">
    <% } else { %>
      <main class="col-12 px-md-4 py-3">
    <% } %>
    <% if (flash) { %>
      <div class="alert alert-<%= flash.type %> alert-dismissible fade show" role="alert">
        <%= flash.message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% } %>
