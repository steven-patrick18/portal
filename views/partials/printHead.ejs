<%
// Shared print letterhead for every report. Include with locals
// { printTitle, printSubtitle } — e.g. title 'Sales Report' and
// subtitle from + ' → ' + to.
// Renders ONLY when printing (.print-only). Pulls logo + company details
// from res.locals.brand so an emailed PDF carries the full identity.
const _pt = typeof printTitle !== 'undefined' ? printTitle : 'Report';
const _ps = typeof printSubtitle !== 'undefined' ? printSubtitle : '';
%>
<div class="print-only mb-3">
  <table style="width:100%; border-collapse:collapse; border-bottom:2px solid #000; margin-bottom:8px">
    <tr>
      <% if (brand && brand.logo) { %>
        <td style="width:80px; vertical-align:middle; padding-bottom:6px">
          <img src="<%= brand.logo %>" alt="logo" style="max-height:60px; max-width:74px; object-fit:contain">
        </td>
      <% } %>
      <td style="vertical-align:middle; padding-bottom:6px">
        <div style="font-size:16pt; font-weight:800; letter-spacing:.2px"><%= companyName %></div>
        <div style="font-size:8.5pt; color:#333">
          <% if (brand && brand.address) { %><%= brand.address %><% } %>
          <% if (brand && brand.phone)  { %> · Ph: <%= brand.phone %><% } %>
          <% if (brand && brand.gstin)  { %> · GSTIN: <%= brand.gstin %><% } %>
        </div>
      </td>
      <td style="text-align:right; vertical-align:middle; white-space:nowrap; padding-left:10px">
        <div style="font-size:12pt; font-weight:700"><%= _pt %></div>
        <div style="font-size:8.5pt; color:#444">
          <% if (_ps) { %><%= _ps %> · <% } %>Generated <%= fmtDateTime(new Date().toISOString().replace('T',' ').slice(0,19)) %>
        </div>
      </td>
    </tr>
  </table>
</div>
