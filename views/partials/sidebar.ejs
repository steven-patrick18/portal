<script>
(function () {
  // ── Accordion behaviour ─────────────────────────────────────────
  // Only ONE sidebar group stays open at a time. Opening a section
  // auto-collapses the others — clears the cluttered "all expanded"
  // look. On page load, the group containing the current page's link
  // is the one that's open; the others are closed.
  //
  // We do NOT restore per-section state from localStorage anymore —
  // navigating is the signal for which section matters right now.
  const groups = Array.from(document.querySelectorAll('.sidebar details.nav-group'));
  const activeGroup = groups.find(d => d.querySelector('.nav-link.active'));

  groups.forEach(d => {
    d.open = (d === activeGroup);    // open only the active section
    d.addEventListener('toggle', () => {
      if (d.open) {
        // Close every other group when this one opens.
        groups.forEach(other => { if (other !== d) other.open = false; });
      }
    });
  });

  // ── Mobile drawer behaviour (unchanged) ─────────────────────────
  const sidebar = document.getElementById('sidebarMenu');
  if (!sidebar) return;
  const isMobile = () => window.matchMedia('(max-width: 767.98px)').matches;

  function syncBackdrop() {
    document.body.classList.toggle('sidebar-open', isMobile() && sidebar.classList.contains('show'));
  }
  sidebar.addEventListener('shown.bs.collapse', syncBackdrop);
  sidebar.addEventListener('hidden.bs.collapse', syncBackdrop);
  sidebar.addEventListener('show.bs.collapse',  syncBackdrop);
  sidebar.addEventListener('hide.bs.collapse',  syncBackdrop);

  document.addEventListener('click', e => {
    if (!isMobile()) return;
    if (!sidebar.classList.contains('show')) return;
    if (sidebar.contains(e.target)) return;
    if (e.target.closest('.navbar-toggler')) return;
    bootstrap.Collapse.getOrCreateInstance(sidebar).hide();
  });

  sidebar.querySelectorAll('a.nav-link').forEach(a => {
    a.addEventListener('click', () => {
      if (isMobile()) bootstrap.Collapse.getOrCreateInstance(sidebar).hide();
    });
  });

  window.addEventListener('resize', () => {
    if (!isMobile() && sidebar.classList.contains('show')) {
      bootstrap.Collapse.getOrCreateInstance(sidebar).hide();
    }
    syncBackdrop();
  });

  // ── Wipe legacy per-section open/closed prefs ──────────────────
  // Previous version stored each section's state under sb:<name>.
  // Accordion mode supersedes that — purge so old "all open" state
  // doesn't fight us.
  try {
    Object.keys(localStorage).forEach(k => { if (k.startsWith('sb:')) localStorage.removeItem(k); });
  } catch (_) { /* localStorage disabled — no-op */ }
})();
</script>
