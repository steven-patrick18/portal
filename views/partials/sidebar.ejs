<%
  function has(feature) { return perms && perms[feature] && perms[feature] !== 'none'; }
  function activeIf(prefix) { return path === prefix || path.startsWith(prefix + '/') || path.startsWith(prefix + '?') ? 'active' : ''; }
%>
<nav class="col-md-3 col-lg-2 d-md-block sidebar collapse" id="sidebarMenu">
  <div class="position-sticky pt-3">
    <ul class="nav flex-column sidebar-nav">

      <li class="nav-item nav-top"><a class="nav-link <%= path === '/' ? 'active' : '' %>" href="/"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a></li>

      <!-- ── Sales — money in (orders → invoices → payments) ───── -->
