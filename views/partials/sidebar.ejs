<%
  function has(feature) { return perms && perms[feature] && perms[feature] !== 'none'; }
  function activeIf(prefix) { return path === prefix || path.startsWith(prefix + '/') || path.startsWith(prefix + '?') ? 'active' : ''; }
%>
<nav class="col-md-3 col-lg-2 d-md-block sidebar collapse" id="sidebarMenu">
  <div class="position-sticky pt-3">
    <ul class="nav flex-column sidebar-nav">

      <li class="nav-item nav-top"><a class="nav-link <%= path === '/' ? 'active' : '' %>" href="/"><i class="bi bi-speedometer2"></i><span>Dashboard</span></a></li>

      <% if (has('dealers') || has('sales') || has('payments') || has('dispatch') || has('visits')) { %>
      <li><details class="nav-group" data-section="sales">
        <summary><span class="nav-section-label"><span class="nav-section-emoji">💼</span> Sales</span><i class="bi bi-chevron-right chev"></i></summary>
        <ul class="nav-sub">
          <% if (has('dealers'))   { %><li><a class="nav-link <%= activeIf('/dealers') %>" href="/dealers"><i class="bi bi-people-fill"></i><span>Dealers</span></a></li><% } %>
          <% if (has('sales'))     { %>
            <li><a class="nav-link <%= activeIf('/sales-orders') %>" href="/sales-orders"><i class="bi bi-file-earmark-text-fill"></i><span>Sales Orders</span></a></li>
            <li><a class="nav-link <%= activeIf('/invoices') %>" href="/invoices"><i class="bi bi-receipt"></i><span>Invoices</span></a></li>
          <% } %>
          <% if (has('payments'))  { %><li><a class="nav-link <%= activeIf('/payments') %>" href="/payments"><i class="bi bi-credit-card-2-front"></i><span>Payments</span></a></li><% } %>
          <% if (has('visits'))    { %><li><a class="nav-link <%= activeIf('/visits') %>" href="/visits"><i class="bi bi-geo-alt-fill"></i><span>Field Visits</span></a></li><% } %>
          <% if (has('dispatch'))  { %>
            <li><a class="nav-link <%= activeIf('/dispatch') %>" href="/dispatch"><i class="bi bi-truck-front-fill"></i><span>Dispatch</span></a></li>
            <li><a class="nav-link <%= activeIf('/returns') %>" href="/returns"><i class="bi bi-arrow-return-left"></i><span>Returns</span></a></li>
          <% } %>
        </ul>
      </details></li>
      <% } %>

      <% if (has('products') || has('materials') || has('stock') || has('fabric_costs')) { %>
      <li><details class="nav-group" data-section="inventory">
        <summary><span class="nav-section-label"><span class="nav-section-emoji">📦</span> Inventory</span><i class="bi bi-chevron-right chev"></i></summary>
        <ul class="nav-sub">
          <% if (has('products'))     { %><li><a class="nav-link <%= activeIf('/products') %>" href="/products"><i class="bi bi-box-seam"></i><span>Products</span></a></li><% } %>
          <% if (has('materials'))    { %><li><a class="nav-link <%= activeIf('/raw-materials') %>" href="/raw-materials"><i class="bi bi-bricks"></i><span>Raw Materials</span></a></li><% } %>
          <% if (has('materials'))    { %><li><a class="nav-link <%= activeIf('/suppliers') %>" href="/suppliers"><i class="bi bi-truck"></i><span>Suppliers</span></a></li><% } %>
          <% if (has('stock'))        { %><li><a class="nav-link <%= activeIf('/stock') %>" href="/stock"><i class="bi bi-archive-fill"></i><span>Ready Stock</span></a></li><% } %>
          <% if (has('fabric_costs')) { %><li><a class="nav-link <%= activeIf('/fabric-cost') %>" href="/fabric-cost"><i class="bi bi-scissors"></i><span>Fabric Cost</span></a></li><% } %>
        </ul>
      </details></li>
      <% } %>

      <% if (has('production') || has('fabric_costs')) { %>
      <li><details class="nav-group" data-section="production">
        <summary><span class="nav-section-label"><span class="nav-section-emoji">🧵</span> Production</span><i class="bi bi-chevron-right chev"></i></summary>
        <ul class="nav-sub">
          <% if (has('production'))   { %><li><a class="nav-link <%= activeIf('/production') %>" href="/production"><i class="bi bi-gear-wide-connected"></i><span>Batches</span></a></li><% } %>
          <% if (has('fabric_costs')) { %><li><a class="nav-link <%= activeIf('/expenses') %>" href="/expenses"><i class="bi bi-cash-coin"></i><span>Mfg Expenses</span></a></li><% } %>
        </ul>
      </details></li>
      <% } %>

      <% if (has('purchasing')) { %>
      <li><details class="nav-group" data-section="purchasing">
        <summary><span class="nav-section-label"><span class="nav-section-emoji">🛒</span> Purchasing</span><i class="bi bi-chevron-right chev"></i></summary>
        <ul class="nav-sub">
          <li><a class="nav-link <%= path === '/purchasing' ? 'active' : '' %>" href="/purchasing"><i class="bi bi-cart3"></i><span>Dashboard</span></a></li>
          <li><a class="nav-link <%= activeIf('/purchasing/compare') %>" href="/purchasing/compare"><i class="bi bi-bar-chart-fill"></i><span>Compare Vendors</span></a></li>
          <li><a class="nav-link <%= activeIf('/purchasing/orders') %>" href="/purchasing/orders"><i class="bi bi-truck-front-fill"></i><span>Purchase Orders</span></a></li>
        </ul>
      </details></li>
      <% } %>

      <% if (has('hr')) { %>
      <li><details class="nav-group" data-section="hr">
        <summary><span class="nav-section-label"><span class="nav-section-emoji">👥</span> HR</span><i class="bi bi-chevron-right chev"></i></summary>
        <ul class="nav-sub">
          <li><a class="nav-link <%= path === '/hr' ? 'active' : '' %>" href="/hr"><i class="bi bi-speedometer"></i><span>Dashboard</span></a></li>
          <li><a class="nav-link <%= activeIf('/hr/employees') %>" href="/hr/employees"><i class="bi bi-person-badge-fill"></i><span>Employees</span></a></li>
          <li><a class="nav-link <%= activeIf('/hr/attendance') %>" href="/hr/attendance"><i class="bi bi-calendar-check-fill"></i><span>Attendance</span></a></li>
          <li><a class="nav-link <%= activeIf('/hr/pieces') %>" href="/hr/pieces"><i class="bi bi-grid-3x3-gap-fill"></i><span>Per-Piece Work</span></a></li>
          <li><a class="nav-link <%= activeIf('/hr/work-types') %>" href="/hr/work-types"><i class="bi bi-tools"></i><span>Work Types</span></a></li>
          <li><a class="nav-link <%= activeIf('/hr/km') %>" href="/hr/km"><i class="bi bi-signpost-split-fill"></i><span>Mileage / KM</span></a></li>
          <li><a class="nav-link <%= activeIf('/hr/advances') %>" href="/hr/advances"><i class="bi bi-cash-coin"></i><span>Advances</span></a></li>
          <li><a class="nav-link <%= activeIf('/hr/incentives') %>" href="/hr/incentives"><i class="bi bi-gift-fill"></i><span>Incentives</span></a></li>
          <li><a class="nav-link <%= activeIf('/hr/payroll') %>" href="/hr/payroll"><i class="bi bi-receipt-cutoff"></i><span>Payroll</span></a></li>
        </ul>
      </details></li>
      <% } %>

      <% if (has('reports') || has('activity')) { %>
      <li><details class="nav-group" data-section="reports">
        <summary><span class="nav-section-label"><span class="nav-section-emoji">📊</span> Reports</span><i class="bi bi-chevron-right chev"></i></summary>
        <ul class="nav-sub">
          <% if (has('reports'))  { %><li><a class="nav-link <%= activeIf('/reports') %>" href="/reports"><i class="bi bi-graph-up-arrow"></i><span>All Reports</span></a></li><% } %>
          <% if (has('activity')) { %><li><a class="nav-link <%= activeIf('/activity') %>" href="/activity"><i class="bi bi-clock-history"></i><span>Activity Log</span></a></li><% } %>
        </ul>
      </details></li>
      <% } %>

      <% if (has('training')) { %>
      <li class="nav-item nav-top"><a class="nav-link <%= activeIf('/training') %>" href="/training"><i class="bi bi-mortarboard-fill"></i><span>Training</span></a></li>
      <% } %>

      <% if (has('notifications')) { %>
      <li class="nav-item nav-top"><a class="nav-link <%= activeIf('/notifications') %>" href="/notifications"><i class="bi bi-bell-fill"></i><span>Notifications</span></a></li>
      <% } %>

      <li class="nav-item nav-top"><a class="nav-link <%= activeIf('/mobile') %>" href="/mobile"><i class="bi bi-phone-fill"></i><span>Mobile App</span></a></li>

      <% if (has('settings')) { %>
      <% var isOwner = user && user.role === 'owner'; %>
      <li><details class="nav-group" data-section="settings">
        <summary><span class="nav-section-label"><span class="nav-section-emoji">⚙️</span> Settings</span><i class="bi bi-chevron-right chev"></i></summary>
        <ul class="nav-sub">
          <% if (isOwner) { %><li><a class="nav-link <%= activeIf('/settings/branding') %>" href="/settings/branding"><i class="bi bi-palette-fill"></i><span>Company &amp; Logo</span></a></li><% } %>
          <li><a class="nav-link <%= path === '/users' || (path.startsWith('/users/') && !path.startsWith('/users/me')) ? 'active' : '' %>" href="/users"><i class="bi bi-shield-lock-fill"></i><span>Users</span></a></li>
          <li><a class="nav-link <%= activeIf('/settings/access') %>" href="/settings/access"><i class="bi bi-key-fill"></i><span>Access &amp; Roles</span></a></li>
          <li><a class="nav-link <%= activeIf('/dealers/assign') %>" href="/dealers/assign"><i class="bi bi-person-check-fill"></i><span>Assign Dealers</span></a></li>
          <li><a class="nav-link <%= activeIf('/settings/sms') %>" href="/settings/sms"><i class="bi bi-chat-square-dots-fill"></i><span>SMS Settings</span></a></li>
          <% if (isOwner) { %><li><a class="nav-link <%= activeIf('/settings/system') %>" href="/settings/system"><i class="bi bi-hdd-rack-fill"></i><span>System &amp; Updates</span></a></li><% } %>
          <li><a class="nav-link <%= activeIf('/settings/stages') %>" href="/settings/stages"><i class="bi bi-list-ol"></i><span>Production Stages</span></a></li>
          <li><a class="nav-link <%= activeIf('/payment-modes') %>" href="/payment-modes"><i class="bi bi-wallet2"></i><span>Payment Modes</span></a></li>
          <li><a class="nav-link <%= activeIf('/categories') %>" href="/categories"><i class="bi bi-tags-fill"></i><span>Categories</span></a></li>
          <li><a class="nav-link <%= activeIf('/import') %>" href="/import"><i class="bi bi-cloud-upload-fill"></i><span>Data Import</span></a></li>
        </ul>
      </details></li>
      <% } %>

    </ul>
  </div>
</nav>

<script>
(function () {
  // 1. Auto-open the section containing the active link.
  // 2. Otherwise, restore user's last open/closed state from localStorage.
  // 3. Save toggles back to localStorage.
  document.querySelectorAll('.sidebar details.nav-group').forEach(d => {
    const key = 'sb:' + d.dataset.section;
    const hasActive = !!d.querySelector('.nav-link.active');
    if (hasActive) {
      d.open = true;
    } else {
      const saved = localStorage.getItem(key);
      if (saved !== null) d.open = saved === '1';
    }
    d.addEventListener('toggle', () => localStorage.setItem(key, d.open ? '1' : '0'));
  });
})();
</script>
