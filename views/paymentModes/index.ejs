<%- include('../partials/header') %>
<h4>Payment Modes</h4>
<form method="post" action="/payment-modes" class="card p-3 mb-3" style="max-width:480px">
<div class="input-group"><input name="name" class="form-control" required placeholder="Mode name"><button class="btn btn-primary">Add</button></div>
</form>
<div class="card" style="max-width:560px"><ul class="list-group list-group-flush">
<% items.forEach(m => { %>
<li class="list-group-item d-flex gap-2 align-items-center">
  <form method="post" action="/payment-modes/<%= m.id %>" class="d-flex gap-2 align-items-center flex-grow-1 m-0">
    <input name="name" class="form-control form-control-sm flex-grow-1" required value="<%= m.name %>">
    <button class="btn btn-sm btn-outline-primary">Save</button>
  </form>
  <% if (!m.active) { %><span class="badge bg-secondary">inactive</span><% } %>
  <form method="post" action="/payment-modes/<%= m.id %>/toggle" class="m-0"><button class="btn btn-sm btn-outline-secondary"><%= m.active ? 'Disable' : 'Enable' %></button></form>
</li>
<% }) %>
</ul></div>
<%- include('../partials/footer') %>
