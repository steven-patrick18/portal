<%- include('../partials/header') %>
<h4>Payment Modes</h4>
<form method="post" class="card p-3 mb-3" style="max-width:480px">
<div class="input-group"><input name="name" class="form-control" required placeholder="Mode name"><button class="btn btn-primary">Add</button></div>
</form>
<div class="card" style="max-width:480px"><ul class="list-group list-group-flush">
<% items.forEach(m => { %>
<li class="list-group-item d-flex justify-content-between align-items-center">
<%= m.name %> <%= m.active ? '' : '<span class="badge bg-secondary">inactive</span>' %>
<form method="post" action="/payment-modes/<%= m.id %>/toggle" class="m-0"><button class="btn btn-sm btn-outline-secondary"><%= m.active ? 'Disable' : 'Enable' %></button></form>
</li>
<% }) %>
</ul></div>
<%- include('../partials/footer') %>
