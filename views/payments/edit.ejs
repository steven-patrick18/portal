<%- include('../partials/header') %>
<h4>Edit Payment <%= p.payment_no %></h4>
<form method="post" action="/payments/<%= p.id %>" class="card p-3" style="max-width:680px">
<div class="row g-3">
<div class="col-md-12"><label class="form-label">Dealer</label><input class="form-control" value="<%= dealer ? dealer.name : '-' %>" readonly></div>
<% if (invoice) { %>
<div class="col-md-12"><label class="form-label">Invoice</label><input class="form-control" value="<%= invoice.invoice_no %> · ₹<%= invoice.total.toFixed(2) %> · paid ₹<%= invoice.paid_amount.toFixed(2) %>" readonly></div>
<% } %>
<div class="col-md-6"><label class="form-label">Date</label><input type="date" name="payment_date" class="form-control" required value="<%= p.payment_date %>"></div>
<div class="col-md-6"><label class="form-label">Amount (₹)</label><input type="number" step="0.01" min="0.01" name="amount" class="form-control" required value="<%= p.amount %>"></div>
<div class="col-md-6"><label class="form-label">Mode</label>
<select name="payment_mode_id" class="form-select"><option value="">-- none --</option>
<% modes.forEach(m => { %><option value="<%= m.id %>" <%= p.payment_mode_id===m.id?'selected':'' %>><%= m.name %></option><% }) %>
</select></div>
<div class="col-md-6"><label class="form-label">Reference No</label><input name="reference_no" class="form-control" value="<%= p.reference_no||'' %>"></div>
<div class="col-md-12"><label class="form-label">Remarks</label><textarea name="remarks" class="form-control" rows="2"><%= p.remarks||'' %></textarea></div>
</div>
<div class="mt-3"><button class="btn btn-primary">Save Changes</button> <a href="/payments/<%= p.id %>" class="btn btn-secondary">Cancel</a></div>
</form>
<%- include('../partials/footer') %>
