<%- include('../partials/header') %>
<h4>Receive Payment</h4>
<form method="post" action="/payments" class="card p-3" style="max-width:780px">
<div class="row g-3">
<div class="col-md-6"><label class="form-label">Dealer *</label>
<select name="dealer_id" id="dealer-select" class="form-select" required>
<option value="">-- select --</option>
<% dealers.forEach(d => { %><option value="<%= d.id %>" <%= preDealer && parseInt(preDealer)===d.id ? 'selected' : '' %>><%= d.code %> · <%= d.name %></option><% }) %>
</select></div>
<div class="col-md-6"><label class="form-label">Invoice (optional - to apply against)</label>
<select name="invoice_id" id="invoice-select" class="form-select">
<option value="">-- on account --</option>
<% invoices.forEach(i => { %><option value="<%= i.id %>" data-balance="<%= i.total - i.paid_amount %>" <%= preInvoice && parseInt(preInvoice)===i.id ? 'selected' : '' %>><%= i.invoice_no %> · ₹<%= (i.total - i.paid_amount).toFixed(2) %> due</option><% }) %>
</select></div>
<div class="col-md-3"><label class="form-label">Date</label><input type="date" name="payment_date" class="form-control" required value="<%= new Date().toISOString().slice(0,10) %>"></div>
<div class="col-md-3"><label class="form-label">Amount *</label><input type="number" step="0.01" name="amount" class="form-control" required></div>
<div class="col-md-3"><label class="form-label">Mode</label>
<select name="payment_mode_id" class="form-select"><option value="">-- select --</option>
<% modes.forEach(m => { %><option value="<%= m.id %>"><%= m.name %></option><% }) %>
</select></div>
<div class="col-md-3"><label class="form-label">Reference No</label><input name="reference_no" class="form-control" placeholder="UPI/Cheque/Txn ID"></div>
<div class="col-md-12"><label class="form-label">Remarks</label><textarea name="remarks" class="form-control" rows="2"></textarea></div>
<input type="hidden" name="lat" id="lat"><input type="hidden" name="lng" id="lng">
</div>
<% if (user.role === 'salesperson') { %>
  <div class="alert alert-info mt-3 mb-0 small"><i class="bi bi-info-circle"></i> Payments collected by salespersons require admin/accountant verification before applying to invoice.</div>
<% } %>
<div class="mt-3"><button class="btn btn-primary">Record Payment</button> <a href="/payments" class="btn btn-secondary">Cancel</a></div>
</form>
<script>
// Reload invoice list when dealer changes
const dealerSel = document.getElementById('dealer-select');
const invSel = document.getElementById('invoice-select');
dealerSel.addEventListener('change', async () => {
  if (!dealerSel.value) { invSel.innerHTML = '<option value="">-- on account --</option>'; return; }
  const r = await fetch('/payments/dealer/' + dealerSel.value + '/invoices');
  const list = await r.json();
  invSel.innerHTML = '<option value="">-- on account --</option>' + list.map(i => `<option value="${i.id}" data-balance="${i.total - i.paid_amount}">${i.invoice_no} · ₹${(i.total - i.paid_amount).toFixed(2)} due</option>`).join('');
});
// Capture geolocation if available
if (navigator.geolocation) {
  navigator.geolocation.getCurrentPosition(p => {
    document.getElementById('lat').value = p.coords.latitude;
    document.getElementById('lng').value = p.coords.longitude;
  }, () => {}, { timeout: 5000 });
}
</script>
<%- include('../partials/footer') %>
