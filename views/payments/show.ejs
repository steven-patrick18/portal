<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div><h4 class="m-0">Payment <%= p.payment_no %></h4>
       <small class="text-muted"><%= p.dealer_name %> · <%= fmtDate(p.payment_date) %></small></div>
  <div class="d-flex gap-2 align-items-center">
    <span class="badge fs-6 bg-<%= p.status==='verified'?'success':p.status==='rejected'?'danger':'warning' %>"><%= p.status %></span>
    <% if (p.status==='verified' && !p.reference_no) { %><span class="badge fs-6 bg-warning text-dark" title="Transaction/reference number not added yet">ref pending</span><% } %>
    <% if (p.status === 'pending') { %><a href="/payments/<%= p.id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a><% } %>
  </div>
</div>
<div class="card p-3 mb-3" style="max-width:680px">
  <dl class="row mb-0">
    <dt class="col-sm-4">Amount</dt><dd class="col-sm-8 fs-5"><%= fmtINR(p.amount) %></dd>
    <dt class="col-sm-4">Mode</dt><dd class="col-sm-8"><%= p.mode || '-' %></dd>
    <dt class="col-sm-4">Reference</dt><dd class="col-sm-8"><%= p.reference_no || '-' %></dd>
    <dt class="col-sm-4">Invoice</dt><dd class="col-sm-8"><% if (p.invoice_no) { %><a href="/invoices/<%= p.invoice_id %>"><%= p.invoice_no %></a><% } else { %>On account<% } %></dd>
    <dt class="col-sm-4">Salesperson</dt><dd class="col-sm-8"><%= p.sp_name || '-' %></dd>
    <% if (p.collected_lat) { %><dt class="col-sm-4">Location</dt><dd class="col-sm-8"><a target="_blank" href="https://maps.google.com/?q=<%= p.collected_lat %>,<%= p.collected_lng %>"><%= p.collected_lat.toFixed(5) %>, <%= p.collected_lng.toFixed(5) %></a></dd><% } %>
    <% if (p.verified_by_name) { %><dt class="col-sm-4">Verified by</dt><dd class="col-sm-8"><%= p.verified_by_name %> · <%= fmtDate(p.verified_at) %></dd><% } %>
    <dt class="col-sm-4">Recorded</dt><dd class="col-sm-8"><%= fmtDate(p.created_at) %></dd>
    <dt class="col-sm-4">IP</dt><dd class="col-sm-8 small text-muted"><%= p.ip || '-' %></dd>
    <% if (p.remarks) { %><dt class="col-sm-4">Remarks</dt><dd class="col-sm-8"><pre class="m-0 small"><%= p.remarks %></pre></dd><% } %>
  </dl>
</div>

<% if (user.role === 'admin' || user.role === 'accountant' || user.role === 'owner') { %>
  <div class="card p-3 mb-3" style="max-width:680px">
    <h6 class="mb-2">Reference / Transaction No.
      <% if (p.status==='verified' && !p.reference_no) { %><span class="badge bg-warning text-dark">pending</span><% } %>
    </h6>
    <form method="post" action="/payments/<%= p.id %>/ref" class="d-flex gap-2">
      <input name="reference_no" class="form-control" value="<%= p.reference_no || '' %>" placeholder="UTR / UPI ref / cheque no / bank txn id" maxlength="80">
      <button class="btn btn-primary"><i class="bi bi-save"></i> Save</button>
    </form>
    <div class="form-text">Add the bank / UPI transaction number here. This works even after the payment is verified — fill it when you get the reference (e.g. the next morning).</div>
  </div>
<% } %>

<% if (p.status === 'pending' && (user.role === 'admin' || user.role === 'accountant' || user.role === 'owner')) { %>
  <div class="card p-3" style="max-width:680px">
    <h6>Verification Actions</h6>
    <form method="post" action="/payments/<%= p.id %>/verify" data-confirm="Verify this payment? It will be applied to the invoice." class="d-inline">
      <button class="btn btn-success">Verify & Apply</button>
    </form>
    <form method="post" action="/payments/<%= p.id %>/reject" class="d-inline ms-2">
      <input name="reason" class="form-control d-inline-block" style="width:280px" placeholder="Reason">
      <button class="btn btn-outline-danger">Reject</button>
    </form>
  </div>
<% } %>
<%- include('../partials/footer') %>
