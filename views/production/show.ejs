<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div><h4 class="m-0">Batch <%= b.batch_no %></h4>
       <small class="text-muted"><%= b.product_code %> · <%= b.product_name %> · Started <%= fmtDate(b.start_date) %></small></div>
  <% if (b.status==='in_progress') { %>
    <form method="post" action="/production/<%= b.id %>/complete" data-confirm="Mark batch as complete?" class="m-0"><button class="btn btn-success btn-sm">Mark Complete</button></form>
  <% } else { %>
    <span class="badge bg-success">Completed <%= fmtDate(b.end_date) %></span>
  <% } %>
</div>

<div class="row g-3 mb-3">
  <div class="col-md-3"><div class="card p-3"><div class="kpi-label">Planned</div><div class="kpi-value"><%= b.qty_planned %></div></div></div>
  <div class="col-md-3"><div class="card p-3"><div class="kpi-label">Completed (Packed)</div><div class="kpi-value"><%= b.qty_completed %></div></div></div>
  <div class="col-md-3"><div class="card p-3"><div class="kpi-label">Current Stage</div><div class="kpi-value text-capitalize"><%= b.current_stage %></div></div></div>
  <div class="col-md-3"><div class="card p-3"><div class="kpi-label">% Complete</div><div class="kpi-value"><%= b.qty_planned ? Math.round(b.qty_completed*100/b.qty_planned) : 0 %>%</div></div></div>
</div>

<div class="card mb-3">
  <div class="card-header">Stage Summary</div>
  <div class="table-responsive">
    <table class="table table-sm m-0"><thead><tr><th>Stage</th><th class="text-end">In</th><th class="text-end">Out</th><th class="text-end">Rejected</th></tr></thead><tbody>
    <% stages.forEach(s => { const t = stageTotals[s] %>
      <tr><td class="text-capitalize"><%= s %></td><td class="text-end"><%= t.in %></td><td class="text-end"><%= t.out %></td><td class="text-end"><%= t.rej %></td></tr>
    <% }) %>
    </tbody></table>
  </div>
</div>

<% if (b.status==='in_progress') { %>
<div class="card mb-3"><div class="card-header">Add Stage Entry</div>
<form method="post" action="/production/<%= b.id %>/stage" class="card-body">
<div class="row g-2">
<div class="col-md-2"><label class="form-label">Stage</label>
<select name="stage" class="form-select" required>
<% stages.forEach(s => { %><option value="<%= s %>" class="text-capitalize"><%= s %></option><% }) %>
</select></div>
<div class="col-md-2"><label class="form-label">Date</label><input type="date" name="entry_date" class="form-control" value="<%= new Date().toISOString().slice(0,10) %>"></div>
<div class="col-md-1"><label class="form-label">Qty In</label><input name="qty_in" type="number" class="form-control" value="0"></div>
<div class="col-md-1"><label class="form-label">Qty Out</label><input name="qty_out" type="number" class="form-control" value="0"></div>
<div class="col-md-1"><label class="form-label">Rejected</label><input name="qty_rejected" type="number" class="form-control" value="0"></div>
<div class="col-md-2"><label class="form-label">Worker</label><input name="worker_name" class="form-control"></div>
<div class="col-md-1"><label class="form-label">Rate/Pc</label><input name="rate_per_piece" type="number" step="0.01" class="form-control" value="0"></div>
<div class="col-md-2"><label class="form-label">Notes</label><input name="notes" class="form-control"></div>
</div>
<button class="btn btn-primary mt-3">Record Entry</button>
<small class="text-muted ms-2">Tip: <strong>packing</strong> stage Qty Out automatically adds to Ready Stock.</small>
</form></div>
<% } %>

<div class="card"><div class="card-header">All Entries</div><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>Date</th><th>Stage</th><th class="text-end">In</th><th class="text-end">Out</th><th class="text-end">Rej</th><th>Worker</th><th class="text-end">Rate/Pc</th><th class="text-end">Total</th><th>By</th><th>Notes</th></tr></thead><tbody>
<% entries.forEach(e => { %>
<tr><td><%= fmtDate(e.entry_date) %></td><td class="text-capitalize"><%= e.stage %></td>
<td class="text-end"><%= e.qty_in %></td><td class="text-end"><%= e.qty_out %></td><td class="text-end"><%= e.qty_rejected %></td>
<td><%= e.worker_name||'-' %></td><td class="text-end"><%= fmtINR(e.rate_per_piece) %></td><td class="text-end"><%= fmtINR(e.total_cost) %></td>
<td><%= e.by_name||'-' %></td><td><%= e.notes||'-' %></td></tr>
<% }) %>
<% if (entries.length===0) { %><tr><td colspan="10" class="text-muted text-center">No entries yet</td></tr><% } %>
</tbody></table></div></div>
<%- include('../partials/footer') %>
