<%- include('../partials/header') %>
<h4><%= p ? 'Edit Product' : 'New Product' %></h4>
<form method="post" action="<%= p ? '/products/' + p.id : '/products' %>" class="card p-3">
  <div class="row g-3">
    <div class="col-md-3"><label class="form-label">Code</label><input name="code" class="form-control" value="<%= p ? p.code : '' %>" <%= p ? 'readonly' : 'placeholder="auto"' %>></div>
    <div class="col-md-5"><label class="form-label">Name *</label><input name="name" class="form-control" required value="<%= p ? p.name : '' %>"></div>
    <div class="col-md-4"><label class="form-label">Category</label>
      <select name="category_id" class="form-select"><option value="">-- none --</option>
        <% cats.forEach(c => { %><option value="<%= c.id %>" <%= p && p.category_id===c.id ? 'selected' : '' %>><%= c.name %></option><% }) %>
      </select>
    </div>
    <div class="col-md-3"><label class="form-label">HSN</label><input name="hsn_code" class="form-control" value="<%= p ? (p.hsn_code||'') : '' %>"></div>
    <div class="col-md-3"><label class="form-label">Size</label><input name="size" class="form-control" value="<%= p ? (p.size||'') : '' %>"></div>
    <div class="col-md-3"><label class="form-label">Color</label><input name="color" class="form-control" value="<%= p ? (p.color||'') : '' %>"></div>
    <div class="col-md-3"><label class="form-label">Unit</label><input name="unit" class="form-control" value="<%= p ? p.unit : 'PCS' %>"></div>
    <div class="col-md-3"><label class="form-label">MRP</label><input name="mrp" type="number" step="0.01" class="form-control" value="<%= p ? p.mrp : 0 %>"></div>
    <div class="col-md-3"><label class="form-label">Sale Price</label><input name="sale_price" type="number" step="0.01" class="form-control" value="<%= p ? p.sale_price : 0 %>"></div>
    <div class="col-md-3"><label class="form-label">Cost Price</label><input name="cost_price" type="number" step="0.01" class="form-control" value="<%= p ? p.cost_price : 0 %>"></div>
    <div class="col-md-3"><label class="form-label">GST %</label><input name="gst_rate" type="number" step="0.01" class="form-control" value="<%= p ? p.gst_rate : 5 %>"></div>
    <div class="col-md-3"><label class="form-label">Reorder Level</label><input name="reorder_level" type="number" class="form-control" value="<%= p ? p.reorder_level : 0 %>"></div>
    <% if (p) { %>
      <div class="col-md-3"><label class="form-label d-block">Active</label>
        <div class="form-check form-switch mt-2"><input class="form-check-input" type="checkbox" name="active" value="1" <%= p.active ? 'checked' : '' %>></div>
      </div>
    <% } %>
  </div>
  <div class="mt-3">
    <button class="btn btn-primary">Save</button>
    <a href="/products" class="btn btn-secondary">Cancel</a>
  </div>
</form>
<%- include('../partials/footer') %>
