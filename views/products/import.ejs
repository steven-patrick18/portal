<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0">Import Products (CSV)</h4>
  <a href="/products" class="btn btn-sm btn-secondary">← Back to Products</a>
</div>

<div class="card mb-3" style="max-width:760px">
  <div class="card-body">
    <p class="text-muted mb-2">Upload a CSV exported from this page. Rows are matched by <code>code</code>:</p>
    <ul class="text-muted small">
      <li><strong>Existing code</strong> → fields are updated</li>
      <li><strong>Blank or new code</strong> → a new product is inserted (auto-numbered if blank)</li>
      <li><strong>Code missing from CSV</strong> → optionally deactivated (checkbox below)</li>
      <li><strong>New category names</strong> → created automatically</li>
    </ul>
    <form method="post" action="/products/import" enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label">CSV file</label>
        <input type="file" name="file" accept=".csv,text/csv" required class="form-control">
      </div>
      <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" id="deactMiss" name="deactivate_missing" value="1">
        <label class="form-check-label" for="deactMiss">Deactivate active products whose code is NOT in this CSV</label>
      </div>
      <button class="btn btn-primary">Import</button>
      <a href="/products/export.csv" class="btn btn-outline-secondary">Download current as CSV</a>
    </form>
  </div>
</div>

<div class="card" style="max-width:760px">
  <div class="card-header">CSV columns</div>
  <div class="card-body small">
    <code>code, name, category, hsn_code, size, color, unit, mrp, sale_price, cost_price, gst_rate, reorder_level, is_bundle_sku, active</code>
    <ul class="mt-2 text-muted">
      <li><code>name</code> is required</li>
      <li><code>category</code> — by name; missing categories are auto-created</li>
      <li>Numbers (mrp, sale_price, cost_price, gst_rate, reorder_level) — no ₹ or commas</li>
      <li><code>is_bundle_sku</code>, <code>active</code> — 1 or 0 (active defaults to 1)</li>
      <li>BOM, photos, and bundle components are NOT touched by import — only the master product fields</li>
    </ul>
  </div>
</div>
<%- include('../partials/footer') %>
