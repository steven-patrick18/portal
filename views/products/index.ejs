<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-bag-heart-fill text-gradient"></i> Products Catalog</h4>
    <small class="text-muted"><%= products.length %> product<%= products.length !== 1 ? 's' : '' %></small>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <div class="btn-group btn-group-sm" role="group">
      <a href="?view=grid<%= q?'&q='+encodeURIComponent(q):'' %><%= categoryId?'&category='+categoryId:'' %><%= sortBy?'&sort='+sortBy:'' %>" class="btn btn-outline-secondary <%= view==='grid'?'active':'' %>" title="Catalog grid"><i class="bi bi-grid-3x3-gap-fill"></i></a>
      <a href="?view=list<%= q?'&q='+encodeURIComponent(q):'' %><%= categoryId?'&category='+categoryId:'' %><%= sortBy?'&sort='+sortBy:'' %>" class="btn btn-outline-secondary <%= view==='list'?'active':'' %>" title="Compact list"><i class="bi bi-list-ul"></i></a>
    </div>
    <% if (canWrite('products')) { %><a href="/products/new" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New Product</a><% } %>
  </div>
</div>

<form method="get" class="card p-3 mb-3" style="background: linear-gradient(135deg, #fafbff 0%, #fff 100%);">
  <input type="hidden" name="view" value="<%= view %>">
  <div class="row g-2 align-items-end">
    <div class="col-md-4">
      <label class="form-label">Search</label>
      <div class="input-group input-group-sm">
        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
        <input name="q" value="<%= q %>" class="form-control form-control-sm" placeholder="Code, name, color...">
      </div>
    </div>
    <div class="col-md-3">
      <label class="form-label">Category</label>
      <select name="category" class="form-select form-select-sm">
        <option value="">All categories</option>
        <% cats.forEach(c => { %><option value="<%= c.id %>" <%= categoryId == c.id ? 'selected' : '' %>><%= c.name %></option><% }) %>
      </select>
    </div>
    <div class="col-md-3">
      <label class="form-label">Sort</label>
      <select name="sort" class="form-select form-select-sm">
        <option value="newest"     <%= sortBy==='newest'?'selected':'' %>>Newest first</option>
        <option value="name"       <%= sortBy==='name'?'selected':'' %>>Name (A→Z)</option>
        <option value="price_low"  <%= sortBy==='price_low'?'selected':'' %>>Price: low to high</option>
        <option value="price_high" <%= sortBy==='price_high'?'selected':'' %>>Price: high to low</option>
        <option value="stock"      <%= sortBy==='stock'?'selected':'' %>>Stock: high to low</option>
      </select>
    </div>
    <div class="col-md-2 d-flex gap-1">
      <button class="btn btn-primary btn-sm flex-grow-1"><i class="bi bi-funnel"></i> Apply</button>
      <a href="/products" class="btn btn-outline-secondary btn-sm" title="Clear filters">×</a>
    </div>
  </div>
</form>

<% if (view === 'grid') { %>
  <% if (products.length === 0) { %>
    <div class="card p-5 text-center text-muted">
      <i class="bi bi-bag-x" style="font-size: 3rem; color: var(--muted)"></i>
      <h5 class="mt-3">No products match your filters</h5>
      <p class="text-muted">Try clearing filters or <a href="/products/new" class="text-decoration-none">add a new product</a></p>
    </div>
  <% } %>
  <div class="row g-3">
    <% products.forEach(p => { %>
      <div class="col-xl-3 col-lg-4 col-md-6">
        <a href="/products/<%= p.id %>" class="prod-card-link">
          <div class="prod-card <%= !p.active ? 'inactive' : '' %>">
            <div class="prod-img">
              <% if (p.image_path) { %>
                <img src="<%= p.image_path %>" alt="<%= p.name %>" loading="lazy">
              <% } else { %>
                <div class="prod-img-placeholder">
                  <i class="bi bi-image" style="font-size: 2.5rem; opacity: .3;"></i>
                  <small class="d-block text-muted mt-2">No photo</small>
                </div>
              <% } %>
              <% if (p.is_bundle_sku) { %><span class="badge-bundle">📦 BUNDLE</span><% } %>
              <% if (p.stock_qty <= 0) { %><span class="badge-stock badge-out">Out of stock</span>
              <% } else if (p.reorder_level && p.stock_qty <= p.reorder_level) { %><span class="badge-stock badge-low"><%= p.stock_qty %> left</span>
              <% } else { %><span class="badge-stock badge-in"><%= p.stock_qty %> in stock</span><% } %>
            </div>
            <div class="prod-body">
              <% if (p.category_name) { %><div class="prod-cat"><%= p.category_name %></div><% } %>
              <h6 class="prod-name"><%= p.name %></h6>
              <div class="prod-attrs">
                <% if (p.size)  { %><span class="prod-chip"><%= p.size %></span><% } %>
                <% if (p.color) { %><span class="prod-chip"><i class="bi bi-circle-fill" style="font-size:.55rem;color:#999"></i> <%= p.color %></span><% } %>
                <span class="prod-chip-code"><%= p.code %></span>
              </div>
              <div class="prod-price-row">
                <div>
                  <span class="prod-mrp">MRP <%= fmtINR(p.mrp) %></span>
                  <div class="prod-sale"><%= fmtINR(p.sale_price) %></div>
                </div>
                <% const discount = p.mrp > p.sale_price ? Math.round((1 - p.sale_price / p.mrp) * 100) : 0; %>
                <% if (discount > 0) { %><span class="prod-discount">-<%= discount %>%</span><% } %>
              </div>
            </div>
            <div class="prod-footer">
              <span class="small text-muted">GST <%= p.gst_rate %>%</span>
              <span class="small text-primary fw-bold">View <i class="bi bi-arrow-right"></i></span>
            </div>
          </div>
        </a>
      </div>
    <% }) %>
  </div>

<% } else { %>
  <!-- List view (compact table) -->
  <div class="card">
    <div class="table-responsive">
      <table class="table table-sm table-hover m-0">
        <thead><tr><th></th><th>Code</th><th>Name</th><th>Category</th><th>Size</th><th>Color</th><th class="text-end">Stock</th><th class="text-end">MRP</th><th class="text-end">Sale</th><th>GST%</th><th></th></tr></thead>
        <tbody>
          <% products.forEach(p => { %>
            <tr class="<%= !p.active ? 'text-muted' : '' %>">
              <td style="width: 50px">
                <% if (p.image_path) { %>
                  <img src="<%= p.image_path %>" alt="" style="width:38px;height:38px;object-fit:cover;border-radius:6px;">
                <% } else { %>
                  <div style="width:38px;height:38px;background:var(--hairline);border-radius:6px;display:flex;align-items:center;justify-content:center"><i class="bi bi-image text-muted"></i></div>
                <% } %>
              </td>
              <td><a href="/products/<%= p.id %>"><%= p.code %></a></td>
              <td>
                <a href="/products/<%= p.id %>"><%= p.name %></a>
                <% if (p.is_bundle_sku) { %><span class="badge bg-info ms-1" style="font-size:.6rem">📦 BUNDLE</span><% } %>
              </td>
              <td><%= p.category_name || '-' %></td>
              <td><%= p.size || '-' %></td>
              <td><%= p.color || '-' %></td>
              <td class="text-end"><%= p.stock_qty %></td>
              <td class="text-end"><%= fmtINR(p.mrp) %></td>
              <td class="text-end"><%= fmtINR(p.sale_price) %></td>
              <td><%= p.gst_rate %>%</td>
              <td>
                <a href="/products/<%= p.id %>" class="btn btn-sm btn-outline-secondary" title="View"><i class="bi bi-eye"></i></a>
                <a href="/products/<%= p.id %>/hangtag" target="_blank" class="btn btn-sm btn-outline-secondary" title="Hangtag"><i class="bi bi-tag"></i></a>
                <% if (canWrite('products')) { %><a href="/products/<%= p.id %>/edit" class="btn btn-sm btn-outline-secondary" title="Edit"><i class="bi bi-pencil"></i></a><% } %>
              </td>
            </tr>
          <% }) %>
          <% if (products.length === 0) { %><tr><td colspan="11" class="text-muted text-center py-4">No products match your filters</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<style>
.prod-card-link { text-decoration: none; color: inherit; display: block; }
.prod-card {
  background: #fff;
  border: 1.5px solid var(--hairline);
  border-radius: 14px;
  overflow: hidden;
  height: 100%;
  display: flex;
  flex-direction: column;
  transition: all .2s ease;
}
.prod-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--denim-200, #c7d2fe); }
.prod-card.inactive { opacity: .6; }
.prod-img {
  position: relative;
  background: linear-gradient(135deg, #f0f4ff 0%, #fdf2f8 100%);
  aspect-ratio: 1 / 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.prod-img img { width: 100%; height: 100%; object-fit: cover; }
.prod-img-placeholder { text-align: center; color: var(--muted); }
.badge-bundle {
  position: absolute; top: 10px; left: 10px;
  background: var(--grad-rose); color: #fff;
  padding: 3px 10px; border-radius: 4px;
  font-size: .65rem; font-weight: 700; letter-spacing: .5px;
  box-shadow: 0 2px 6px rgba(0,0,0,.15);
}
.badge-stock {
  position: absolute; top: 10px; right: 10px;
  padding: 3px 10px; border-radius: 4px;
  font-size: .65rem; font-weight: 700; letter-spacing: .5px;
  box-shadow: 0 2px 6px rgba(0,0,0,.15);
}
.badge-stock.badge-in   { background: var(--grad-emerald); color: #fff; }
.badge-stock.badge-low  { background: var(--grad-marigold); color: #fff; }
.badge-stock.badge-out  { background: var(--grad-coral); color: #fff; }
.prod-body { padding: .9rem 1rem .6rem; flex: 1; }
.prod-cat { font-size: .65rem; text-transform: uppercase; letter-spacing: 1.2px; color: var(--muted); font-weight: 700; margin-bottom: .15rem; }
.prod-name { font-size: .95rem; font-weight: 700; color: var(--ink); margin: 0 0 .4rem; line-height: 1.25; min-height: 2.4em; }
.prod-attrs { display: flex; gap: .25rem; flex-wrap: wrap; margin-bottom: .55rem; }
.prod-chip { background: var(--denim-50); color: var(--denim-700); font-size: .68rem; padding: 1px 8px; border-radius: 4px; font-weight: 600; }
.prod-chip-code { background: #f4f5fa; color: var(--ink-soft); font-size: .65rem; padding: 1px 8px; border-radius: 4px; font-family: 'JetBrains Mono', monospace; margin-left: auto; }
.prod-price-row { display: flex; justify-content: space-between; align-items: flex-end; margin-top: .4rem; }
.prod-mrp { font-size: .7rem; text-decoration: line-through; color: var(--muted); }
.prod-sale { font-size: 1.15rem; font-weight: 800; color: var(--ink); letter-spacing: -0.02em; }
.prod-discount { background: var(--grad-coral); color: #fff; font-size: .7rem; font-weight: 700; padding: 2px 6px; border-radius: 4px; align-self: flex-start; }
.prod-footer { display: flex; justify-content: space-between; align-items: center; padding: .55rem 1rem; border-top: 1px solid var(--hairline); background: #fafbff; }
</style>
<%- include('../partials/footer') %>
