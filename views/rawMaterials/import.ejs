<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0">Import Raw Materials (CSV)</h4>
  <a href="/raw-materials" class="btn btn-sm btn-secondary">← Back to Raw Materials</a>
</div>

<div class="card mb-3" style="max-width:760px">
  <div class="card-body">
    <p class="text-muted mb-2">Upload a CSV exported from this page. Rows are matched by <code>code</code>:</p>
    <ul class="text-muted small">
      <li><strong>Existing code</strong> → fields are updated</li>
      <li><strong>Blank or new code</strong> → a new material is inserted (auto-numbered if blank)</li>
      <li><strong>Code missing from CSV</strong> → optionally deactivated (checkbox below)</li>
    </ul>
    <form method="post" action="/raw-materials/import" enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label">CSV file</label>
        <input type="file" name="file" accept=".csv,text/csv" required class="form-control">
      </div>
      <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" id="deactMiss" name="deactivate_missing" value="1">
        <label class="form-check-label" for="deactMiss">Deactivate active materials whose code is NOT in this CSV</label>
      </div>
      <button class="btn btn-primary">Import</button>
      <a href="/raw-materials/export.csv" class="btn btn-outline-secondary">Download current as CSV</a>
    </form>
  </div>
</div>

<div class="card" style="max-width:760px">
  <div class="card-header">CSV columns</div>
  <div class="card-body small">
    <code>code, name, type, unit, current_stock, reorder_level, cost_per_unit, supplier, active</code>
    <ul class="mt-2 text-muted">
      <li><code>name</code> is required</li>
      <li><code>supplier</code> — must match an existing supplier name exactly, or leave blank</li>
      <li><code>current_stock</code>, <code>reorder_level</code>, <code>cost_per_unit</code> — numbers (no ₹ or commas)</li>
      <li><code>current_stock</code> — set the absolute on-hand quantity. New rows use it as opening stock; existing rows get an <em>adjustment</em> transaction logged whenever the CSV value differs from what's already in the DB. Leave the column blank or empty to skip stock changes for that row.</li>
      <li><code>active</code> — 1 or 0 (defaults to 1)</li>
      <li>Photos are NOT touched by import.</li>
    </ul>
  </div>
</div>
<%- include('../partials/footer') %>
