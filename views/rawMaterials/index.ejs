<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0">Raw Materials</h4>
  <div class="d-flex gap-2">
    <% if (user.role === 'owner') { %>
      <a href="/raw-materials/export.csv" class="btn btn-outline-secondary btn-sm" title="Download all materials as CSV"><i class="bi bi-download"></i> Export</a>
      <a href="/raw-materials/import" class="btn btn-outline-secondary btn-sm" title="Upload CSV to update or insert materials"><i class="bi bi-upload"></i> Import</a>
    <% } %>
    <a href="/raw-materials/new" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New</a>
  </div>
</div>
<div class="card"><div class="table-responsive">
<table class="table table-sm m-0 align-middle"><thead><tr><th style="width:56px"></th><th>Code</th><th>Name</th><th>Type</th><th>Unit</th><th class="text-end">Stock</th><th class="text-end">Reorder</th><th class="text-end">Cost/Unit</th><th>Supplier</th><th></th></tr></thead><tbody>
<% items.forEach(m => { %>
<tr class="<%= m.reorder_level && m.current_stock <= m.reorder_level ? 'table-warning' : '' %>">
<td>
  <% if (m.image_path) { %>
    <img src="<%= m.image_path %>" alt="" style="height:40px;width:40px;object-fit:cover;border-radius:6px;border:1px solid #e5e5e5">
  <% } else { %>
    <div style="height:40px;width:40px;border-radius:6px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;color:#9ca3af"><i class="bi bi-image"></i></div>
  <% } %>
</td>
<td><%= m.code %></td><td><a href="/raw-materials/<%= m.id %>"><%= m.name %></a></td><td><%= m.type||'-' %></td><td><%= m.unit %></td>
<td class="text-end"><%= m.current_stock %></td><td class="text-end"><%= m.reorder_level %></td><td class="text-end"><%= fmtINR(m.cost_per_unit) %></td>
<td><%= m.supplier_name||'-' %></td><td><a href="/raw-materials/<%= m.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a></td>
</tr>
<% }) %>
<% if (items.length===0) { %><tr><td colspan="10" class="text-muted text-center">No raw materials yet</td></tr><% } %>
</tbody></table></div></div>
<%- include('../partials/footer') %>
