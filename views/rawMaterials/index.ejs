<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <h4 class="m-0">Raw Materials</h4>
  <div class="d-flex gap-2 flex-wrap">
    <form class="d-flex gap-1">
      <div class="input-group input-group-sm" style="width:260px">
        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
        <input name="q" value="<%= typeof q !== 'undefined' ? q : '' %>" class="form-control form-control-sm" placeholder="Code, name, type, supplier...">
        <% if (typeof q !== 'undefined' && q) { %>
          <a href="/raw-materials" class="btn btn-outline-secondary" title="Clear">×</a>
        <% } %>
      </div>
    </form>
    <% if (user.role === 'owner') { %>
      <a href="/raw-materials/export.csv" class="btn btn-outline-secondary btn-sm" title="Download all materials as CSV"><i class="bi bi-download"></i> Export</a>
      <a href="/raw-materials/import" class="btn btn-outline-secondary btn-sm" title="Upload CSV to update or insert materials"><i class="bi bi-upload"></i> Import</a>
    <% } %>
    <a href="/raw-materials/new" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New</a>
  </div>
</div>
<%
  function rmChipUrl(stockVal) {
    const p = new URLSearchParams();
    if (typeof q !== 'undefined' && q) p.set('q', q);
    if (stockVal) p.set('stock', stockVal);
    const qs = p.toString();
    return '/raw-materials' + (qs ? '?' + qs : '');
  }
  const sf = (typeof stockFilter !== 'undefined') ? stockFilter : '';
  const cnts = (typeof counts !== 'undefined') ? counts : {total:0,available:0,out:0};
%>
<div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
  <span class="small text-muted me-1">Stock:</span>
  <a href="<%= rmChipUrl('') %>"          class="btn btn-sm <%= !sf ? 'btn-primary' : 'btn-outline-secondary' %>">All <span class="badge bg-light text-dark ms-1"><%= cnts.total || 0 %></span></a>
  <a href="<%= rmChipUrl('available') %>" class="btn btn-sm <%= sf==='available' ? 'btn-success' : 'btn-outline-success' %>"><i class="bi bi-check-circle"></i> Available <span class="badge bg-light text-success ms-1"><%= cnts.available || 0 %></span></a>
  <a href="<%= rmChipUrl('out') %>"       class="btn btn-sm <%= sf==='out' ? 'btn-danger' : 'btn-outline-danger' %>"><i class="bi bi-x-circle"></i> Out of stock <span class="badge bg-light text-danger ms-1"><%= cnts.out || 0 %></span></a>
</div>
<% if (typeof q !== 'undefined' && q) { %>
  <div class="small text-muted mb-2">Searching "<strong><%= q %></strong>" — <%= items.length %> result<%= items.length===1?'':'s' %>.</div>
<% } %>
<div class="card"><div class="table-responsive">
<table class="table table-sm m-0 align-middle"><thead><tr><th style="width:56px"></th><th>Code</th><th>Name</th><th>Type</th><th>Unit</th><th class="text-end">Stock</th><th class="text-end">Reorder</th><th class="text-end">Cost/Unit</th><th>Supplier</th><th></th></tr></thead><tbody>
<% items.forEach(m => { %>
<tr class="<%= m.reorder_level && m.current_stock <= m.reorder_level ? 'table-warning' : '' %>">
<td>
  <% if (m.image_path) { %>
    <img src="<%= m.image_path %>" alt="" style="height:40px;width:40px;object-fit:cover;border-radius:6px;border:1px solid #e5e5e5">
  <% } else { %>
    <div style="height:40px;width:40px;border-radius:6px;background:#f3f4f6;display:flex;align-items:center;justify-content:center;color:#9ca3af"><i class="bi bi-image"></i></div>
  <% } %>
</td>
<td><%= m.code %></td><td><a href="/raw-materials/<%= m.id %>"><%= m.name %></a></td><td><%= m.type||'-' %></td><td><%= m.unit %></td>
<td class="text-end"><%= m.current_stock %></td><td class="text-end"><%= m.reorder_level %></td><td class="text-end"><%= fmtRate(m.cost_per_unit) %></td>
<td><%= m.supplier_name||'-' %></td><td><a href="/raw-materials/<%= m.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a></td>
</tr>
<% }) %>
<% if (items.length===0) { %><tr><td colspan="10" class="text-muted text-center">No raw materials yet</td></tr><% } %>
</tbody></table></div></div>
<%- include('../partials/footer') %>
