<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div><h4 class="m-0"><%= m.name %> <small class="text-muted">(<%= m.code %>)</small></h4>
       <small class="text-muted"><%= m.type||'-' %> · <%= m.unit %> · Supplier: <%= m.supplier_name||'-' %></small></div>
  <a href="/raw-materials/<%= m.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
</div>
<div class="row g-3 mb-3">
  <div class="col-md-3"><div class="card p-3"><div class="kpi-label">Current Stock</div><div class="kpi-value"><%= m.current_stock %> <%= m.unit %></div></div></div>
  <div class="col-md-3"><div class="card p-3"><div class="kpi-label">Reorder Level</div><div class="kpi-value"><%= m.reorder_level %></div></div></div>
  <div class="col-md-3"><div class="card p-3"><div class="kpi-label">Cost / Unit</div><div class="kpi-value"><%= fmtINR(m.cost_per_unit) %></div></div></div>
  <div class="col-md-3"><div class="card p-3"><div class="kpi-label">Stock Value</div><div class="kpi-value"><%= fmtINR(m.current_stock * m.cost_per_unit) %></div></div></div>
</div>

<div class="card mb-3">
<div class="card-header">New Stock Transaction</div>
<form method="post" action="/raw-materials/<%= m.id %>/txn" class="card-body">
<div class="row g-2 align-items-end">
<div class="col-md-2"><label class="form-label">Type</label>
<select name="txn_type" class="form-select" required><option value="purchase">Purchase</option><option value="issue">Issue</option><option value="return">Return</option><option value="adjustment">Adjustment (set to)</option></select>
</div>
<div class="col-md-2"><label class="form-label">Quantity</label><input name="quantity" type="number" step="0.01" class="form-control" required></div>
<div class="col-md-2"><label class="form-label">Rate</label><input name="rate" type="number" step="0.01" class="form-control" value="<%= m.cost_per_unit %>"></div>
<div class="col-md-3"><label class="form-label">Ref No</label><input name="ref_no" class="form-control" placeholder="GRN/Issue voucher"></div>
<div class="col-md-3"><label class="form-label">Notes</label><input name="notes" class="form-control"></div>
</div>
<button class="btn btn-primary mt-3">Record</button>
</form></div>

<div class="card"><div class="card-header">Transactions</div><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>Date</th><th>Type</th><th class="text-end">Qty</th><th class="text-end">Rate</th><th class="text-end">Total</th><th>Ref</th><th>By</th><th>Notes</th></tr></thead><tbody>
<% txns.forEach(t => { %>
<tr><td><%= fmtDate(t.created_at) %></td><td><span class="badge bg-<%= t.txn_type==='purchase'?'success':t.txn_type==='issue'?'danger':'secondary' %>"><%= t.txn_type %></span></td>
<td class="text-end"><%= t.quantity %></td><td class="text-end"><%= fmtINR(t.rate) %></td><td class="text-end"><%= fmtINR(t.total_amount) %></td>
<td><%= t.ref_no||'-' %></td><td><%= t.by_name||'-' %></td><td><%= t.notes||'-' %></td></tr>
<% }) %>
<% if (txns.length===0) { %><tr><td colspan="8" class="text-muted text-center">No transactions yet</td></tr><% } %>
</tbody></table></div></div>
<%- include('../partials/footer') %>
