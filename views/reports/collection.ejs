<%- include('../partials/header') %>
<%
  function dayUrl(d) {
    const p = new URLSearchParams();
    if (from) p.set('from', from);
    if (to)   p.set('to',   to);
    if (d)    p.set('day',  d);
    return '/reports/collection?' + p.toString();
  }
  function clearDayUrl() {
    const p = new URLSearchParams();
    if (from) p.set('from', from);
    if (to)   p.set('to',   to);
    return '/reports/collection?' + p.toString();
  }
  // Pretty "DD-MM-YYYY" for the heading without going through fmtDate (which
  // expects an SQLite UTC string with time).
  function prettyDay(s) {
    const m = String(s).match(/^(\d{4})-(\d{2})-(\d{2})/);
    return m ? `${m[3]}-${m[2]}-${m[1]}` : s;
  }
%>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0">Collection Report</h4>
  <form class="d-flex gap-2">
    <input type="date" name="from" value="<%= from %>" class="form-control form-control-sm">
    <input type="date" name="to" value="<%= to %>" class="form-control form-control-sm">
    <% if (day) { %><input type="hidden" name="day" value="<%= day %>"><% } %>
    <button class="btn btn-sm btn-outline-primary">Filter</button>
  </form>
</div>

<div class="row g-3">
  <div class="col-md-6"><div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
      <span>Daily Collections</span>
      <small class="text-muted">Click a date to see who collected it</small>
    </div>
    <div class="table-responsive">
      <table class="table table-sm m-0">
        <thead><tr><th>Date</th><th class="text-end">Payments</th><th class="text-end">Total</th></tr></thead>
        <tbody>
        <% daily.forEach(d => { %>
          <tr class="<%= day === d.d ? 'table-primary' : '' %>">
            <td>
              <a href="<%= dayUrl(d.d) %>" class="text-decoration-none fw-semibold">
                <%= fmtDate(d.d) %>
                <% if (day === d.d) { %><i class="bi bi-arrow-right-circle-fill text-primary"></i><% } %>
              </a>
            </td>
            <td class="text-end"><%= d.n %></td>
            <td class="text-end"><%= fmtINR(d.total) %></td>
          </tr>
        <% }) %>
        <% if (daily.length === 0) { %><tr><td colspan="3" class="text-muted text-center">No data</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div></div>

  <div class="col-md-6"><div class="card">
    <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
      <span>
        By Salesperson
        <% if (day) { %>
          <span class="badge bg-primary"><%= prettyDay(day) %></span>
        <% } else { %>
          <small class="text-muted">(<%= prettyDay(from) %> → <%= prettyDay(to) %>)</small>
        <% } %>
      </span>
      <% if (day) { %>
        <a href="<%= clearDayUrl() %>" class="btn btn-sm btn-outline-secondary" title="Clear day filter, show full range total">
          <i class="bi bi-x-lg"></i> Clear day
        </a>
      <% } %>
    </div>
    <div class="table-responsive">
      <table class="table table-sm m-0">
        <thead><tr><th>Name</th><th class="text-end">Payments</th><th class="text-end">Total</th></tr></thead>
        <tbody>
        <% bySp.forEach(s => { %>
          <tr class="<%= s.pmts === 0 ? 'text-muted' : '' %>">
            <td><%= s.name %></td>
            <td class="text-end"><%= s.pmts %></td>
            <td class="text-end"><%= fmtINR(s.total) %></td>
          </tr>
        <% }) %>
        <% if (bySp.length === 0) { %><tr><td colspan="3" class="text-muted text-center">No data</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div></div>
</div>
<%- include('../partials/footer') %>
