<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <h4 class="m-0">Dealer-wise Sales</h4>
  <form class="d-flex gap-2"><input type="date" name="from" value="<%= from %>" class="form-control form-control-sm"><input type="date" name="to" value="<%= to %>" class="form-control form-control-sm"><button class="btn btn-sm btn-outline-primary">Filter</button></form>
</div>
<div class="row g-3 mb-3">
  <div class="col-md-4"><div class="kpi-card kpi-denim"><i class="bi bi-people kpi-icon"></i><div class="kpi-label">Dealers Active</div><div class="kpi-value"><%= rows.length %></div></div></div>
  <div class="col-md-4"><div class="kpi-card kpi-emerald"><i class="bi bi-cash-stack kpi-icon"></i><div class="kpi-label">Total Billed</div><div class="kpi-value"><%= fmtINR(totalBilled) %></div></div></div>
  <div class="col-md-4"><div class="kpi-card kpi-teal"><i class="bi bi-cash-coin kpi-icon"></i><div class="kpi-label">Total Collected</div><div class="kpi-value"><%= fmtINR(totalPaid) %></div></div></div>
</div>
<div class="card"><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>#</th><th>Code</th><th>Dealer</th><th>City</th><th>Salesperson</th><th class="text-end">Invoices</th><th class="text-end">Billed</th><th class="text-end">Collected</th><th class="text-end">Balance</th><th>%</th></tr></thead><tbody>
<% rows.forEach((r, idx) => { const pct = r.billed > 0 ? Math.round((r.paid * 100) / r.billed) : 0; %>
<tr><td><%= idx+1 %></td><td><%= r.code %></td><td><a href="/dealers/<%= r.id %>"><%= r.name %></a></td><td><%= r.city || '-' %></td><td><%= r.sp_name || '-' %></td>
<td class="text-end"><%= r.invoices %></td>
<td class="text-end fw-bold"><%= fmtINR(r.billed) %></td>
<td class="text-end" style="color: var(--emerald-600)"><%= fmtINR(r.paid) %></td>
<td class="text-end <%= r.balance > 0 ? 'fw-bold' : '' %>" style="<%= r.balance > 0 ? 'color: var(--coral-600)' : '' %>"><%= fmtINR(r.balance) %></td>
<td style="width: 100px"><div class="progress" style="height: 8px"><div class="progress-bar" style="width: <%= pct %>%; background: <%= pct >= 80 ? 'var(--grad-emerald)' : pct >= 50 ? 'var(--grad-marigold)' : 'var(--grad-coral)' %>"></div></div><small class="text-muted"><%= pct %>%</small></td>
</tr>
<% }) %>
<% if (rows.length===0) { %><tr><td colspan="10" class="text-muted text-center py-3">No sales in this date range</td></tr><% } %>
</tbody></table></div></div>
<%- include('../partials/footer') %>
