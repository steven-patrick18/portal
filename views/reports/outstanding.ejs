<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2 d-print-none">
  <div>
    <h4 class="m-0">Dealer Outstanding Report</h4>
    <% if (officeName) { %><small class="text-muted">Office: <strong><%= officeName %></strong></small><% } %>
  </div>
  <div class="d-flex gap-3 align-items-center">
    <% if (officesList && officesList.length) { %>
      <form method="get" class="d-flex gap-1 align-items-center">
        <select name="office" class="form-select form-select-sm" onchange="this.form.submit()" title="Filter by office">
          <option value="">All offices</option>
          <% officesList.forEach(o => { %>
            <option value="<%= o.id %>" <%= officeFilter === o.id ? 'selected' : '' %>>
              <% if (o.type === 'factory')   { %>🏭<% } %>
              <% if (o.type === 'office')    { %>🏢<% } %>
              <% if (o.type === 'warehouse') { %>📦<% } %>
              <%= o.name %>
            </option>
          <% }) %>
        </select>
      </form>
    <% } %>
    <h6 class="m-0">Total: <strong><%= fmtINR(totalOut) %></strong></h6>
    <button onclick="window.print()" class="btn btn-sm btn-outline-secondary"><i class="bi bi-printer"></i> Print</button>
  </div>
</div>
<%- include('../partials/printHead', { printTitle: 'Dealer Outstanding Report', printSubtitle: (officeName ? 'Office: ' + officeName : 'All offices') }) %>
<div class="card"><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>Code</th><th>Dealer</th><th>City</th><th>Phone</th><th>Salesperson</th><th class="text-end">Credit Limit</th><th class="text-end">Billed</th><th class="text-end">Paid</th><th class="text-end">Outstanding</th></tr></thead><tbody>
<% rows.forEach(r => { %>
<tr class="<%= r.outstanding > r.credit_limit && r.credit_limit > 0 ? 'table-danger' : '' %>">
<td><%= r.code %></td><td><a href="/dealers/<%= r.id %>"><%= r.name %></a></td>
<td><%= r.city||'-' %></td><td><%= r.phone||'-' %></td><td><%= r.sp_name||'-' %></td>
<td class="text-end"><%= fmtINR(r.credit_limit) %></td>
<td class="text-end"><%= fmtINR(r.billed) %></td><td class="text-end"><%= fmtINR(r.paid) %></td>
<td class="text-end fw-bold"><%= fmtINR(r.outstanding) %></td></tr>
<% }) %>
</tbody></table></div></div>
<%- include('../partials/footer') %>
