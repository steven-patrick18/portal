<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0">Product Performance — Last <%= days %> days</h4>
  <form class="d-flex gap-2"><input type="number" name="days" value="<%= days %>" min="1" class="form-control form-control-sm" style="width:90px"><button class="btn btn-sm btn-outline-primary">Apply</button></form>
</div>
<div class="row g-3">
<div class="col-md-6"><div class="card"><div class="card-header bg-success-subtle">Top 20 Fast Movers</div><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>#</th><th>Code</th><th>Product</th><th class="text-end">Sold</th><th class="text-end">Revenue</th><th class="text-end">Stock</th></tr></thead><tbody>
<% top.forEach((r,idx) => { %>
<tr><td><%= idx+1 %></td><td><%= r.code %></td><td><%= r.name %></td>
<td class="text-end"><%= r.sold %></td><td class="text-end"><%= fmtINR(r.revenue) %></td><td class="text-end"><%= r.stock %></td></tr>
<% }) %>
<% if (top.length===0) { %><tr><td colspan="6" class="text-muted text-center">No sales data</td></tr><% } %>
</tbody></table></div></div></div>

<div class="col-md-6"><div class="card"><div class="card-header bg-warning-subtle">Slow Movers (no sales)</div><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>Code</th><th>Product</th><th class="text-end">Stock</th></tr></thead><tbody>
<% slow.forEach(r => { %>
<tr><td><%= r.code %></td><td><%= r.name %></td><td class="text-end"><%= r.stock %></td></tr>
<% }) %>
<% if (slow.length===0) { %><tr><td colspan="3" class="text-muted text-center">All products had sales</td></tr><% } %>
</tbody></table></div></div></div>
</div>
<%- include('../partials/footer') %>
