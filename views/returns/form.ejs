<%- include('../partials/header') %>
<% const editing = ret && ret.id; %>
<h4><%= editing ? 'Edit Return ' + ret.return_no : 'New Return' %></h4>
<form method="post" action="<%= editing ? '/returns/' + ret.id : '/returns' %>" class="card p-3">
<div class="row g-3 mb-3">
  <div class="col-md-4">
    <label class="form-label">Dealer *</label>
    <select name="dealer_id" id="dealer-select" class="form-select" required>
      <option value="">-- select --</option>
      <% dealers.forEach(d => { %>
        <option value="<%= d.id %>" <%= preDealerId == d.id ? 'selected' : '' %>><%= d.code %> · <%= d.name %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label">Linked invoice (optional)</label>
    <select name="invoice_id" id="invoice-select" class="form-select">
      <option value="">— none —</option>
      <!-- populated by JS once a dealer is chosen -->
    </select>
    <div class="small text-muted">Filtered to the selected dealer's invoices.</div>
  </div>
  <div class="col-md-3">
    <label class="form-label">Date</label>
    <input type="date" name="return_date" class="form-control" required value="<%= editing ? ret.return_date : new Date().toISOString().slice(0,10) %>">
  </div>
  <div class="col-md-2">
    <label class="form-label">Reason</label>
    <input name="reason" class="form-control" value="<%= editing ? (ret.reason||'') : '' %>" placeholder="e.g. Wrong size">
  </div>
</div>

<h6 class="section-title">Items</h6>
<div class="table-responsive">
<table class="table table-sm">
<thead><tr>
  <th style="width:35%">Product</th>
  <th style="width:11%">Unit</th>
  <th style="width:10%">Qty</th>
  <th style="width:14%">Rate (per pc)</th>
  <th class="text-end" style="width:14%">Amount</th>
  <th style="width:10%">Restock?</th>
  <th></th>
</tr></thead>
<tbody id="items-body">
  <% const seedItems = items && items.length ? items : [{}]; %>
  <% seedItems.forEach(it => { %>
  <tr class="line-row">
    <td>
      <select name="product_id" class="form-select form-select-sm prod-select" required>
        <option value="">-- select --</option>
        <% products.forEach(p => { %>
          <option value="<%= p.id %>"
                  <%= it.product_id===p.id?'selected':'' %>
                  data-rate="<%= p.sale_price %>"
                  data-bundle="<%= p.is_bundle_sku ? 1 : 0 %>"
                  data-ppb="<%= p.pcs_per_bundle %>">
            <%= p.code %> · <%= p.name %><% if (p.is_bundle_sku && p.pcs_per_bundle > 0) { %> 📦 BUNDLE (<%= p.pcs_per_bundle %> pcs)<% } %>
          </option>
        <% }) %>
      </select>
    </td>
    <td>
      <select name="unit" class="form-select form-select-sm unit-sel">
        <option value="pcs"<%= !it.is_bundle ? ' selected' : '' %>>pcs</option>
        <option value="bdl"<%= it.is_bundle ? ' selected' : '' %>>bundles</option>
      </select>
    </td>
    <td>
      <input name="quantity" type="number" min="1" class="form-control form-control-sm qty"
             value="<%= it.is_bundle ? (it.bundles || 1) : (it.quantity || 1) %>" required>
      <div class="small text-muted pcs-hint" style="display:none"></div>
    </td>
    <td>
      <input name="rate" type="number" step="0.01" class="form-control form-control-sm rate"
             value="<%= it.rate || '' %>" required>
    </td>
    <td class="text-end amount"><%= it.amount ? Number(it.amount).toFixed(2) : '0.00' %></td>
    <td>
      <select name="restock" class="form-select form-select-sm">
        <option value="1" <%= (it.restock === undefined || it.restock === 1) ? 'selected' : '' %>>Yes</option>
        <option value="0" <%= it.restock === 0 ? 'selected' : '' %>>No</option>
      </select>
    </td>
    <td><button type="button" class="btn btn-sm btn-outline-danger del-row">×</button></td>
  </tr>
  <% }) %>
</tbody></table></div>
<button type="button" id="add-row" class="btn btn-sm btn-outline-secondary mb-3">+ Add Row</button>

<div class="d-flex justify-content-between align-items-center">
  <div>
    <strong>Total: ₹<span id="grand-total">0.00</span></strong>
  </div>
  <div>
    <button class="btn btn-primary"><%= editing ? 'Save Changes' : 'Save' %></button>
    <a href="/returns" class="btn btn-secondary">Cancel</a>
  </div>
</div>
</form>

<script>
// Indexed by dealer_id -> [{id, invoice_no, invoice_date, total}, ...].
// Used to populate the invoice dropdown when a dealer is selected.
const INVOICES_BY_DEALER = <%- JSON.stringify(invoicesByDealer || {}) %>;
const PRE_INVOICE_ID = <%- JSON.stringify(preInvoiceId || '') %>;

function fmtINR(v) {
  return '₹' + Number(v||0).toLocaleString('en-IN', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function repopulateInvoices() {
  const dlrId = document.getElementById('dealer-select').value;
  const sel = document.getElementById('invoice-select');
  const list = INVOICES_BY_DEALER[dlrId] || [];
  sel.innerHTML = '<option value="">— none —</option>' + list.map(i =>
    `<option value="${i.id}">${i.invoice_no} · ${i.invoice_date} · ${fmtINR(i.total)}${i.status==='partial' ? ' (partial)' : ''}</option>`
  ).join('');
  if (PRE_INVOICE_ID && list.some(i => String(i.id) === String(PRE_INVOICE_ID))) {
    sel.value = PRE_INVOICE_ID;
  }
}

function recalcRow(row) {
  const sel = row.querySelector('.prod-select');
  const opt = sel.options[sel.selectedIndex];
  const unitSel = row.querySelector('.unit-sel');
  const qty = parseFloat(row.querySelector('.qty').value || 0);
  const rate = parseFloat(row.querySelector('.rate').value || 0);
  const hint = row.querySelector('.pcs-hint');

  let pcs = qty;
  const isBundleSku = opt && opt.dataset.bundle === '1';
  const ppb = opt ? parseFloat(opt.dataset.ppb || 0) : 0;

  // Lock the unit dropdown to "pcs" when the product isn't a bundle SKU.
  if (!isBundleSku) {
    unitSel.value = 'pcs';
    unitSel.disabled = true;
  } else {
    unitSel.disabled = false;
  }

  if (unitSel.value === 'bdl' && ppb > 0) {
    pcs = qty * ppb;
    hint.style.display = 'block';
    hint.textContent = '= ' + pcs + ' pcs';
  } else {
    hint.style.display = 'none';
  }

  const amt = pcs * rate;
  row.querySelector('.amount').textContent = amt.toFixed(2);
  recalcGrand();
}
function recalcGrand() {
  let t = 0;
  document.querySelectorAll('.line-row .amount').forEach(td => { t += parseFloat(td.textContent || 0); });
  document.getElementById('grand-total').textContent = t.toFixed(2);
}

function newRow() {
  const t = document.querySelector('#items-body .line-row').cloneNode(true);
  t.querySelector('select.prod-select').value = '';
  t.querySelector('.unit-sel').value = 'pcs';
  t.querySelector('.qty').value = 1;
  t.querySelector('.rate').value = '';
  t.querySelector('.amount').textContent = '0.00';
  t.querySelector('.pcs-hint').style.display = 'none';
  document.getElementById('items-body').appendChild(t);
}
document.getElementById('add-row').addEventListener('click', newRow);

document.addEventListener('click', e => {
  if (e.target.classList.contains('del-row')) {
    const rows = document.querySelectorAll('.line-row');
    if (rows.length > 1) { e.target.closest('tr').remove(); recalcGrand(); }
  }
});

document.addEventListener('change', e => {
  if (e.target.classList.contains('prod-select')) {
    const o = e.target.options[e.target.selectedIndex];
    const row = e.target.closest('tr');
    if (o && o.value) {
      // Auto-fill per-piece rate from the product master.
      if (o.dataset.rate) row.querySelector('.rate').value = o.dataset.rate;
      // Auto-pick 'bdl' if the product is a bundle SKU (typical case).
      if (o.dataset.bundle === '1') row.querySelector('.unit-sel').value = 'bdl';
    }
    recalcRow(row);
  } else if (e.target.classList.contains('unit-sel')) {
    recalcRow(e.target.closest('tr'));
  } else if (e.target.id === 'dealer-select') {
    repopulateInvoices();
  }
});
document.addEventListener('input', e => {
  if (e.target.classList.contains('qty') || e.target.classList.contains('rate')) {
    recalcRow(e.target.closest('tr'));
  }
});

// Boot: populate invoice list for the preselected dealer + recalc all rows
repopulateInvoices();
document.querySelectorAll('.line-row').forEach(recalcRow);
</script>
<%- include('../partials/footer') %>
