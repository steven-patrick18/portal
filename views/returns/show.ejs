<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2 d-print-none">
  <div>
    <h4 class="m-0">Return <%= r.return_no %></h4>
    <small class="text-muted">
      <%= r.dealer_name %> · <%= fmtDate(r.return_date) %><% if (r.invoice_no) { %> · Invoice <a href="/invoices/<%= r.invoice_id %>"><%= r.invoice_no %></a><% } %>
    </small>
  </div>
  <div class="d-flex gap-2 flex-wrap align-items-center">
    <span class="badge fs-6 bg-<%= r.status==='restocked'||r.status==='approved'?'success':r.status==='rejected'?'danger':'warning' %>"><%= r.status %></span>
    <button onclick="window.print()" class="btn btn-sm btn-outline-primary"><i class="bi bi-printer"></i> Print credit note</button>
    <% if (r.status === 'pending') { %>
      <a href="/returns/<%= r.id %>/edit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
    <% } %>
  </div>
</div>

<%
  // Detect a return that needs GST recompute. Three triggers:
  //   1. subtotal column wasn't populated (pre-migration row)
  //   2. line items have a GST rate > 0 but parent gst_amount is 0
  //   3. NEW — products carry GST in the master but line items don't
  //      reflect it (typical when the auto-backfill failed silently)
  const needsRecompute = (
    (!r.subtotal || r.subtotal === 0) ||
    (items.some(i => (i.gst_rate || 0) > 0) && (!r.gst_amount || r.gst_amount === 0)) ||
    (typeof needsGstBackfill !== 'undefined' && needsGstBackfill)
  );
  const canReapply = ['owner','admin','accountant'].includes(user.role);
%>
<% if (needsRecompute && canReapply) { %>
  <div class="alert alert-warning d-print-none">
    <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap mb-2">
      <div>
        <i class="bi bi-exclamation-triangle-fill"></i>
        <strong>GST not yet applied to this credit note.</strong>
        Total Credit currently shows <strong>₹<%= Number(r.total_amount).toFixed(2) %></strong>
        <% if (typeof needsGstBackfill !== 'undefined' && needsGstBackfill) { %>
          — the line items show 0% GST even though the products' master sale GST is &gt; 0%.
        <% } else { %>
          (subtotal only).
        <% } %>
      </div>
    </div>
    <!-- Two ways to fix it: either pull from product master (when that
         has a GST rate set) or type the rate manually (when the master
         is still at 0%, which is the case the user just hit). -->
    <div class="d-flex flex-wrap gap-3 align-items-end">
      <form method="post" action="/returns/<%= r.id %>/set-gst-rate" class="m-0 d-flex gap-2 align-items-end">
        <div>
          <label class="small fw-bold mb-1 d-block">Apply GST rate to all items</label>
          <div class="input-group input-group-sm" style="width:auto">
            <input type="number" name="gst_rate" step="0.01" min="0" max="28" required
                   class="form-control" style="max-width:90px" placeholder="5"
                   value="<%= items[0] && items[0].product_gst_rate ? items[0].product_gst_rate : 5 %>">
            <span class="input-group-text">%</span>
            <button class="btn btn-warning"><i class="bi bi-check-lg"></i> Apply</button>
          </div>
          <div class="small text-muted mt-1">Types the rate (5, 12, 18, 28…) and applies to every line of this return.</div>
        </div>
        <span class="text-muted small">— or —</span>
        <button type="button" class="btn btn-sm btn-outline-warning"
                onclick="document.getElementById('reapply-form-<%= r.id %>').submit()">
          <i class="bi bi-arrow-clockwise"></i> Pull from product master
        </button>
      </form>
      <form id="reapply-form-<%= r.id %>" method="post" action="/returns/<%= r.id %>/recompute-gst" class="d-none"></form>
    </div>
  </div>
<% } else if (canReapply) { %>
  <!-- Even when the math looks right, give owner/admin/accountant a small
       "Reapply GST" link as an escape hatch — useful if a product's GST
       rate was edited after the return was created and we want to re-pull
       the new figure into this credit note. -->
  <div class="d-flex justify-content-end gap-2 mb-2 d-print-none">
    <form method="post" action="/returns/<%= r.id %>/set-gst-rate" class="m-0 d-flex gap-1 align-items-center">
      <span class="small text-muted">Set GST manually:</span>
      <div class="input-group input-group-sm" style="width:auto">
        <input type="number" name="gst_rate" step="0.01" min="0" max="28" required
               class="form-control" style="max-width:80px" placeholder="5"
               value="<%= items[0] && items[0].gst_rate ? items[0].gst_rate : 5 %>">
        <span class="input-group-text">%</span>
        <button class="btn btn-outline-secondary"><i class="bi bi-check-lg"></i> Apply</button>
      </div>
    </form>
    <form method="post" action="/returns/<%= r.id %>/recompute-gst" class="m-0"
          onsubmit="return confirm('Reapply GST from the current product rates? Adjusts the credit + dealer outstanding.');">
      <button class="btn btn-sm btn-link text-muted" style="text-decoration:none">
        <i class="bi bi-arrow-clockwise"></i> Pull from product master
      </button>
    </form>
  </div>
<% } %>

<!-- ── Print zone: credit-note header + items + signatures ────── -->
<div class="print-zone">
  <div class="print-only">
    <div style="text-align:center;margin-bottom:6px">
      <div style="font-size:20pt;font-weight:800;letter-spacing:.5px"><%= companyName %></div>
      <div style="font-size:14pt;font-weight:700;margin-top:2px">CREDIT NOTE</div>
      <div style="font-size:10pt;color:#444">Return / Sales Return adjustment</div>
      <hr style="margin:6px 0;border-top:2px solid #000">
    </div>
    <table style="width:100%;font-size:10pt;margin-bottom:8px">
      <tr>
        <td style="width:50%;vertical-align:top">
          <strong>Credit Note #:</strong> <%= r.return_no %><br>
          <strong>Date:</strong> <%= fmtDate(r.return_date) %><br>
          <% if (r.invoice_no) { %><strong>Against Invoice:</strong> <%= r.invoice_no %><br><% } %>
          <strong>Status:</strong> <%= r.status %><br>
          <% if (r.created_by_name) { %><strong>Issued by:</strong> <%= r.created_by_name %><% } %>
        </td>
        <td style="vertical-align:top">
          <strong>To:</strong> <%= r.dealer_name %> (<%= r.dealer_code %>)<br>
          <% if (r.dealer_address) { %><%= r.dealer_address %><br><% } %>
          <% if (r.dealer_city || r.dealer_state) { %><%= [r.dealer_city, r.dealer_state].filter(Boolean).join(', ') %><br><% } %>
          <% if (r.dealer_phone) { %>Phone: <%= r.dealer_phone %><br><% } %>
          <% if (r.dealer_gstin) { %>GSTIN: <%= r.dealer_gstin %><% } %>
        </td>
      </tr>
    </table>
  </div>

  <div class="card mb-3"><div class="table-responsive"><table class="table table-sm m-0">
<thead><tr>
  <th>Code</th><th>Product</th>
  <th class="text-end">Qty</th>
  <th class="text-end">Rate</th>
  <th class="text-end">GST %</th>
  <th class="text-end">Amount</th>
  <th class="d-print-none">Restock</th>
</tr></thead>
<tbody>
<% items.forEach(i => { %>
<tr>
  <td><%= i.code %></td>
  <td><%= i.name %></td>
  <td class="text-end">
    <% if (i.is_bundle && i.bundles > 0) { %>
      <strong><%= i.bundles %> bdl</strong>
      <div class="small text-muted">(<%= i.quantity %> pcs · <%= i.pcs_per_bundle %>/bdl)</div>
    <% } else { %>
      <%= i.quantity %> pcs
    <% } %>
  </td>
  <td class="text-end"><%= fmtINR(i.rate) %></td>
  <td class="text-end"><%= (i.gst_rate || 0).toFixed(2) %>%</td>
  <td class="text-end"><%= fmtINR(i.amount) %></td>
  <td class="d-print-none"><% if (i.restock) { %><span class="badge bg-success">Yes</span><% } else { %><span class="text-muted">No</span><% } %></td>
</tr>
<% }) %>
</tbody>
<tfoot>
  <tr><th colspan="5" class="text-end">Subtotal (taxable)</th><th class="text-end"><%= fmtINR(r.subtotal || 0) %></th><th class="d-print-none"></th></tr>
  <% if ((r.igst || 0) > 0) { %>
    <tr><th colspan="5" class="text-end">IGST</th><th class="text-end"><%= fmtINR(r.igst) %></th><th class="d-print-none"></th></tr>
  <% } else { %>
    <tr><th colspan="5" class="text-end">CGST</th><th class="text-end"><%= fmtINR(r.cgst || 0) %></th><th class="d-print-none"></th></tr>
    <tr><th colspan="5" class="text-end">SGST</th><th class="text-end"><%= fmtINR(r.sgst || 0) %></th><th class="d-print-none"></th></tr>
  <% } %>
  <tr class="table-secondary"><th colspan="5" class="text-end">Total Credit Amount (incl. GST)</th><th class="text-end"><strong><%= fmtINR(r.total_amount) %></strong></th><th class="d-print-none"></th></tr>
</tfoot>
</table></div></div>

<% if (r.reason) { %><div class="alert alert-info"><strong>Reason:</strong> <%= r.reason %></div><% } %>

  <!-- Print-only acknowledgement / signature block (inside .print-zone) -->
  <div class="print-only">
    <div style="margin-top:24px;font-size:10pt">
      <div style="margin-bottom:8px"><strong>Notes:</strong> This credit note reduces the dealer's outstanding by ₹<%= fmtINR(r.total_amount).replace('₹','') %>.<% if (r.status === 'pending') { %> <em>Status: pending approval — credit not yet applied.</em><% } %></div>
      <table style="width:100%;margin-top:36px">
        <tr>
          <td style="width:50%;border-top:1px solid #000;padding-top:4px">Authorised Signatory · <%= companyName %></td>
          <td style="width:50%;border-top:1px solid #000;padding-top:4px;text-align:right">Received by · <%= r.dealer_name %></td>
        </tr>
      </table>
      <div style="margin-top:14px;font-size:9pt;color:#666;text-align:center">Generated <%= fmtDateTime(new Date().toISOString().replace('T',' ').slice(0,19)) %></div>
    </div>
  </div>
</div><!-- /.print-zone -->

<% if (r.status === 'pending' && (user.role === 'admin' || user.role === 'accountant' || user.role === 'owner')) { %>
  <div class="d-flex gap-2 d-print-none">
    <form method="post" action="/returns/<%= r.id %>/approve" class="d-inline" data-confirm="Approve, restock items, and apply the credit to the dealer's outstanding?"><button class="btn btn-success">Approve, Restock &amp; Credit Dealer</button></form>
    <form method="post" action="/returns/<%= r.id %>/reject" class="d-inline" data-confirm="Reject? No stock or ledger changes will be made."><button class="btn btn-outline-danger">Reject</button></form>
  </div>
<% } %>
<%- include('../partials/footer') %>
