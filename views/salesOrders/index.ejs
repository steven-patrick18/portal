<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
  <h4 class="m-0">Sales Orders</h4>
  <div class="d-flex gap-2">
    <button onclick="window.print()" class="btn btn-outline-secondary btn-sm" title="Print this list"><i class="bi bi-printer"></i> Print</button>
    <a href="/sales-orders/new" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New Order</a>
  </div>
</div>

<% if (typeof approvals !== 'undefined' && approvals.length) { %>
  <div class="alert alert-warning d-print-none">
    <strong><i class="bi bi-hourglass-split"></i> <%= approvals.length %> invoice<%= approvals.length>1?'s':'' %> need your credit approval</strong> (dealer over limit):
    <div class="mt-2 d-flex flex-wrap gap-2">
      <% approvals.forEach(a => { %>
        <a href="/sales-orders/<%= a.id %>" class="btn btn-sm btn-outline-dark"><%= a.order_no %> · <%= a.dealer_name %> · <%= fmtINR(a.total) %><% if (a.requested_name) { %> <span class="text-muted">(<%= a.requested_name %>)</span><% } %></a>
      <% }) %>
    </div>
  </div>
<% } %>

<form method="get" class="card card-body py-2 mb-3 d-print-none">
  <div class="row g-2 align-items-end">
    <div class="col-auto"><label class="form-label small mb-0">From</label><input type="date" name="from" value="<%= from||'' %>" class="form-control form-control-sm"></div>
    <div class="col-auto"><label class="form-label small mb-0">To</label><input type="date" name="to" value="<%= to||'' %>" class="form-control form-control-sm"></div>
    <div class="col-auto"><button class="btn btn-sm btn-primary"><i class="bi bi-funnel"></i> Apply</button><% if (from||to) { %> <a href="/sales-orders" class="btn btn-sm btn-outline-secondary">Clear</a><% } %></div>
  </div>
</form>

<div class="print-zone">
  <div class="print-only mb-3">
    <div style="font-size:16pt;font-weight:800;border-bottom:2px solid #000;padding-bottom:4px;margin-bottom:6px"><%= companyName %> · Sales Orders</div>
    <div style="font-size:10pt;color:#444">
<% if (from||to) { %><strong>Period:</strong> <%= from||'start' %> to <%= to||'today' %> · <% } %><strong>Total:</strong> <%= orders.length %> order<%= orders.length===1?'':'s' %>
      · Generated <%= fmtDateTime(new Date().toISOString().replace('T',' ').slice(0,19)) %>
    </div>
  </div>
  <div class="card"><div class="table-responsive">
  <table class="table table-sm m-0"><thead><tr><th>Order #</th><th>Date</th><th>Dealer</th><th>Salesperson</th><th class="text-end">Subtotal</th><th class="text-end">GST</th><th class="text-end">Total</th><th>Status</th></tr></thead><tbody>
  <% orders.forEach(o => { %>
  <tr><td><a href="/sales-orders/<%= o.id %>"><%= o.order_no %></a></td><td><%= fmtDate(o.order_date) %></td>
  <td><%= o.dealer_name %></td><td><%= o.sp_name||'-' %></td>
  <td class="text-end"><%= fmtINR(o.subtotal) %></td><td class="text-end"><%= fmtINR(o.gst_amount) %></td>
  <td class="text-end"><%= fmtINR(o.total) %></td>
  <td><span class="badge bg-<%= o.status==='invoiced'?'success':o.status==='cancelled'?'danger':o.status==='confirmed'?'primary':'secondary' %>"><%= o.status %></span></td></tr>
  <% }) %>
  <% if (orders.length===0) { %><tr><td colspan="8" class="text-muted text-center">No sales orders</td></tr><% } %>
  </tbody></table></div></div>
</div>
<%- include('../partials/footer') %>
