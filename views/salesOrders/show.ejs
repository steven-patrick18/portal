<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div><h4 class="m-0">Sales Order <%= o.order_no %></h4>
       <small class="text-muted"><%= o.dealer_name %> · <%= fmtDate(o.order_date) %> · By <%= o.sp_name||'-' %></small></div>
  <div>
    <span class="badge bg-<%= o.status==='invoiced'?'success':o.status==='cancelled'?'danger':o.status==='confirmed'?'primary':'secondary' %>"><%= o.status %></span>
    <% if (o.approval_status === 'pending') { %><span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split"></i> awaiting credit approval</span><% } %>
    <% if (o.approval_status === 'rejected') { %><span class="badge bg-danger"><i class="bi bi-x-octagon"></i> credit rejected</span><% } %>
    <a href="/sales-orders/<%= o.id %>/print" target="_blank" class="btn btn-sm btn-outline-dark"><i class="bi bi-printer"></i> Print</a>
    <% if (o.status === 'pending') { %>
      <a href="/sales-orders/<%= o.id %>/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i> Edit</a>
      <form method="post" action="/sales-orders/<%= o.id %>/confirm" class="d-inline"><button class="btn btn-sm btn-primary">Confirm</button></form>
    <% } %>
    <% if (o.status !== 'invoiced' && o.status !== 'cancelled') { %>
      <% if (o.approval_status === 'pending') { %>
        <% if (canApprove) { %>
          <form method="post" action="/sales-orders/<%= o.id %>/approve" class="d-inline" data-confirm="Approve over-limit billing and generate the invoice?"><button class="btn btn-sm btn-success"><i class="bi bi-check2-circle"></i> Approve &amp; Invoice</button></form>
          <form method="post" action="/sales-orders/<%= o.id %>/reject" class="d-inline" data-confirm="Reject this over-limit invoice request?"><button class="btn btn-sm btn-outline-danger"><i class="bi bi-x-circle"></i> Reject</button></form>
        <% } else { %>
          <button class="btn btn-sm btn-secondary" disabled><i class="bi bi-hourglass-split"></i> Pending approval<%= approver ? ' · ' + approver.name : '' %></button>
        <% } %>
      <% } else { %>
        <form method="post" action="/sales-orders/<%= o.id %>/invoice" class="d-inline" data-confirm="Generate invoice and decrement stock?"><button class="btn btn-sm btn-success">Generate Invoice</button></form>
      <% } %>
      <form method="post" action="/sales-orders/<%= o.id %>/cancel" class="d-inline" data-confirm="Cancel this order?"><button class="btn btn-sm btn-outline-danger">Cancel</button></form>
    <% } %>
  </div>
</div>

<% if (cs) { %>
  <% const tone = cs.kind==='ok' ? 'success' : (cs.kind==='no_limit' ? 'secondary' : 'warning'); %>
  <div class="alert alert-<%= tone %> py-2 d-print-none d-flex flex-wrap gap-3 align-items-center">
    <span><i class="bi bi-shield-<%= cs.kind==='ok'?'check':'exclamation' %>"></i>
      <% if (cs.kind === 'no_limit') { %>
        <strong>No credit limit set for <%= o.dealer_name %>.</strong> An invoice can't be generated until a limit is set — <a href="/credit">set one in Credit Score</a> or on the dealer.
      <% } else if (cs.kind === 'exceeded') { %>
        <strong>Over credit limit.</strong> Limit <%= fmtINR(cs.limit) %> · outstanding <%= fmtINR(cs.outstanding) %> · this invoice <%= fmtINR(cs.total) %> → <strong>over by <%= fmtINR(cs.over) %></strong>.
        <%= (o.approval_status === 'pending') ? 'Awaiting manager approval.' : 'A salesperson must get reporting-manager approval; owner/admin can generate directly.' %>
      <% } else { %>
        Credit OK — limit <%= fmtINR(cs.limit) %>, outstanding <%= fmtINR(cs.outstanding) %>, headroom <strong><%= fmtINR(cs.headroom) %></strong>.
      <% } %>
    </span>
  </div>
<% } %>
<% if (o.approval_status === 'rejected' && o.approval_note) { %>
  <div class="alert alert-danger py-2 d-print-none"><i class="bi bi-x-octagon"></i> <strong>Credit request rejected<%= approver ? ' by ' + approver.name : '' %>:</strong> <%= o.approval_note %></div>
<% } %>
<div class="card mb-3">
<div class="table-responsive"><table class="table table-sm m-0">
<thead><tr><th>Code</th><th>Product</th><th class="text-end">Qty</th><th class="text-end">Rate</th><th class="text-end">GST%</th><th class="text-end">Amount</th></tr></thead><tbody>
<% items.forEach(i => { %>
<tr><td><%= i.code %></td><td><%= i.name %></td><td class="text-end"><%= i.quantity %></td>
<td class="text-end"><%= fmtINR(i.rate) %></td><td class="text-end"><%= i.gst_rate %>%</td><td class="text-end"><%= fmtINR(i.amount) %></td></tr>
<% }) %>
</tbody><tfoot>
<tr><th colspan="5" class="text-end">Subtotal</th><th class="text-end"><%= fmtINR(o.subtotal) %></th></tr>
<% if (o.discount_amount && o.discount_amount > 0) { %>
<tr><th colspan="5" class="text-end text-success">Discount<% if (o.subtotal > 0) { %> (<%= (o.discount_amount * 100 / o.subtotal).toFixed(2) %>%)<% } %></th><th class="text-end text-success">− <%= fmtINR(o.discount_amount) %></th></tr>
<tr><th colspan="5" class="text-end">Taxable</th><th class="text-end"><%= fmtINR(o.subtotal - o.discount_amount) %></th></tr>
<% } %>
<tr><th colspan="5" class="text-end">GST</th><th class="text-end"><%= fmtINR(o.gst_amount) %></th></tr>
<tr class="table-secondary"><th colspan="5" class="text-end">Total</th><th class="text-end"><%= fmtINR(o.total) %></th></tr>
</tfoot></table></div></div>
<% if (o.notes) { %><div class="card p-3 mb-3"><strong>Notes:</strong> <%= o.notes %></div><% } %>
<%- include('../partials/footer') %>
