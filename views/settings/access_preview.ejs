<%- include('../partials/header') %>
<% const lvl = { full:{c:'success',t:'Full'}, limited:{c:'warning',t:'Limited'}, view:{c:'info',t:'View'}, none:{c:'light',t:'— No access'} };
   const accessibleSensitive = []; %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-eye-fill text-gradient"></i> Access Preview</h4>
    <small class="text-muted"><a href="/settings/access">← Access &amp; Roles</a> · exactly what <strong><%= subjectLabel %></strong> can reach (live effective permissions)</small>
  </div>
  <% if (isUser && subjectUser) { %><span class="badge bg-<%= subjectUser.active ? 'success' : 'secondary' %>"><%= subjectUser.active ? 'Active user' : 'Disabled user' %></span><% } %>
</div>

<div class="row g-2 mb-3">
  <div class="col-md-4"><div class="card text-center h-100"><div class="card-body p-2">
    <div class="h4 m-0 text-success"><%= canCount %></div><div class="small text-muted">features they CAN access</div>
  </div></div></div>
  <div class="col-md-4"><div class="card text-center h-100"><div class="card-body p-2">
    <div class="h4 m-0 text-secondary"><%= total - canCount %></div><div class="small text-muted">blocked (no access)</div>
  </div></div></div>
  <div class="col-md-4"><div class="card text-center h-100"><div class="card-body p-2">
    <div class="h4 m-0"><%= role === 'owner' ? '👑' : (subjectLabel||'').toUpperCase() %></div><div class="small text-muted"><%= isUser ? 'role' : 'role preview' %></div>
  </div></div></div>
</div>

<% if (role === 'owner') { %>
  <div class="alert alert-warning"><i class="bi bi-shield-lock"></i> <strong>Owner</strong> always has <strong>Full</strong> access to everything — this is by design and can't be reduced.</div>
<% } %>

<% sections.forEach(s => { %>
  <div class="card mb-2"><div class="card-header bg-white fw-semibold py-2"><%= s.title %></div>
  <div class="table-responsive"><table class="table table-sm align-middle m-0">
    <tbody>
    <% s.features.forEach(f => { const v = perms[f.key] || 'none'; const isSub = !!f.parent; const sens = sensitive.has(f.key) && v !== 'none'; if (sens) accessibleSensitive.push(f.label); %>
      <tr class="<%= v==='none' ? 'opacity-50' : '' %>">
        <td style="<%= isSub ? 'padding-left:1.6rem' : '' %>">
          <% if (isSub) { %><span class="text-muted">↳ </span><% } %><strong><%= f.label %></strong>
          <% if (sens && v!=='none') { %><i class="bi bi-exclamation-triangle-fill text-warning ms-1" title="Sensitive — double-check"></i><% } %>
          <div class="small text-muted"><%= f.desc %></div>
        </td>
        <td class="text-end" style="width:140px">
          <% if (v === 'none') { %>
            <span class="text-muted small"><i class="bi bi-x-circle"></i> No access</span>
          <% } else { %>
            <span class="badge bg-<%= lvl[v].c %><%= v==='none'?' text-dark':'' %>"><i class="bi bi-check-circle"></i> <%= lvl[v].t %></span>
          <% } %>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table></div></div>
<% }) %>

<% if (accessibleSensitive.length) { %>
  <div class="alert alert-info mt-2"><i class="bi bi-eye"></i> <strong>Sensitive areas this <%= isUser ? 'user' : 'role' %> can access:</strong> <%= accessibleSensitive.join(' · ') %>. Make sure that's intended.</div>
<% } else if (role !== 'owner') { %>
  <div class="alert alert-success mt-2"><i class="bi bi-check2-circle"></i> No sensitive areas (payroll, finance reports, funds, GST invoices, settings) are exposed to this <%= isUser ? 'user' : 'role' %>.</div>
<% } %>

<div class="small text-muted mt-2">Levels: <span class="badge bg-info">View</span> see only · <span class="badge bg-warning text-dark">Limited</span> act on own · <span class="badge bg-success">Full</span> full control. This reflects the live matrix + any per-user overrides.</div>
<%- include('../partials/footer') %>
