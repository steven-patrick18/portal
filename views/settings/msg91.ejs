<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="m-0"><i class="bi bi-chat-dots-fill text-gradient"></i> MSG91 Configuration</h4>
    <small class="text-muted">SMS & WhatsApp messaging credentials. Saved to DB and applied immediately.</small>
  </div>
  <span class="badge bg-<%= cfg.enabled === 'true' ? 'success' : 'secondary' %> fs-6"><%= cfg.enabled === 'true' ? 'LIVE' : 'STUB MODE (logged only)' %></span>
</div>

<div class="row g-3">
  <div class="col-md-7">
    <form method="post" action="/settings/msg91" class="card p-3">
      <div class="row g-3">
        <div class="col-md-12">
          <div class="form-check form-switch" style="background: var(--denim-50); padding: .6rem .8rem .6rem 3rem; border-radius: 8px;">
            <input class="form-check-input" type="checkbox" name="enabled" value="1" id="enabled" <%= cfg.enabled === 'true' ? 'checked' : '' %>>
            <label class="form-check-label fw-bold" for="enabled">Enable live MSG91 sending <small class="text-muted fw-normal">(off = stub mode, messages only logged)</small></label>
          </div>
        </div>
        <div class="col-md-8">
          <label class="form-label">Auth Key <span class="text-danger">*</span></label>
          <input name="auth_key" class="form-control" value="<%= cfg.auth_key %>" placeholder="Get from MSG91 dashboard → Settings → API">
          <small class="text-muted">Required when enabled. Find at <a href="https://control.msg91.com/app/" target="_blank" class="text-decoration-none">control.msg91.com</a></small>
        </div>
        <div class="col-md-4">
          <label class="form-label">Sender ID</label>
          <input name="sender_id" class="form-control" value="<%= cfg.sender_id %>" placeholder="PORTAL">
          <small class="text-muted">6-char DLT sender</small>
        </div>
        <div class="col-md-12"><h6 class="section-title m-0">DLT Templates</h6></div>
        <div class="col-md-6">
          <label class="form-label">Payment Confirmation Template ID</label>
          <input name="template_payment" class="form-control" value="<%= cfg.template_payment %>" placeholder="DLT-approved template ID">
        </div>
        <div class="col-md-6">
          <label class="form-label">Outstanding Reminder Template ID</label>
          <input name="template_outstanding" class="form-control" value="<%= cfg.template_outstanding %>" placeholder="DLT-approved template ID">
        </div>
        <div class="col-md-12">
          <label class="form-label">WhatsApp Template Name</label>
          <input name="template_whatsapp" class="form-control" value="<%= cfg.template_whatsapp %>" placeholder="meta_approved_template_name">
        </div>
      </div>
      <div class="mt-3">
        <button class="btn btn-primary"><i class="bi bi-save"></i> Save Settings</button>
      </div>
    </form>
  </div>

  <div class="col-md-5">
    <div class="card p-3 mb-3">
      <h6 class="m-0 mb-2"><i class="bi bi-send-check"></i> Test Message</h6>
      <small class="text-muted d-block mb-2">Send a test SMS to verify the configuration.</small>
      <form method="post" action="/settings/msg91/test" class="d-flex gap-2">
        <input name="test_phone" class="form-control form-control-sm" placeholder="Phone number (10 digit)" required>
        <button class="btn btn-outline-primary btn-sm">Send Test</button>
      </form>
    </div>
    <div class="card">
      <div class="card-header"><i class="bi bi-clock-history"></i> Recent Notifications</div>
      <div class="table-responsive">
        <table class="table table-sm m-0">
          <thead><tr><th>Time</th><th>Channel</th><th>To</th><th>Status</th></tr></thead>
          <tbody>
          <% recent.forEach(r => { %>
            <tr><td class="small"><%= fmtDate(r.created_at) %></td>
                <td><span class="badge bg-<%= r.channel==='sms'?'primary':'success' %>"><%= r.channel %></span></td>
                <td class="small"><%= r.to_phone %></td>
                <td><span class="badge bg-<%= r.status==='sent'?'success':r.status==='failed'?'danger':'secondary' %>"><%= r.status %></span></td></tr>
          <% }) %>
          <% if (recent.length === 0) { %><tr><td colspan="4" class="text-muted text-center small py-3">No messages yet</td></tr><% } %>
          </tbody>
        </table>
      </div>
      <div class="card-footer text-end p-2">
        <a href="/notifications" class="btn btn-sm btn-outline-secondary">View All</a>
      </div>
    </div>
  </div>
</div>

<div class="alert alert-info mt-3 small">
  <strong><i class="bi bi-info-circle"></i> How MSG91 works in this ERP:</strong>
  <ul class="mb-0 mt-1">
    <li><strong>Stub mode</strong> (default) — messages are logged in <a href="/notifications" class="alert-link">Notifications</a> but not actually sent. Safe to use without an API key.</li>
    <li><strong>Live mode</strong> — needs auth key + DLT-approved sender + templates. Real messages go via MSG91's flow API for SMS, and WhatsApp Cloud API for WhatsApp.</li>
    <li>Auto-trigger: payment confirmations and outstanding reminders use the configured templates. Manual messages from <a href="/notifications/send" class="alert-link">Send Notification</a> use plain text.</li>
  </ul>
</div>
<%- include('../partials/footer') %>
