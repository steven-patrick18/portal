<%- include('../partials/header') %>
<h4>SMS Settings</h4>
<small class="text-muted">Pick how the system sends SMS notifications. The Android phone gateway needs no DLT and no sender-ID approval — sender is just your phone's SIM.</small>

<form method="post" action="/settings/sms" class="card p-3 mt-3" style="max-width:840px">

<div class="mb-3">
  <label class="form-label fw-bold">SMS Mode</label>
  <div class="row g-2">
    <div class="col-md-6">
      <label class="card p-3 m-0 h-100" style="cursor:pointer; border:2px solid <%= cfg.provider==='gateway' ? 'var(--denim-500)' : 'var(--hairline)' %>;">
        <div class="d-flex align-items-center gap-2">
          <input type="radio" name="provider" value="gateway" <%= cfg.provider==='gateway'?'checked':'' %>>
          <strong>📱 Android Phone Gateway (live)</strong>
        </div>
        <small class="text-muted mt-1 d-block">Your spare phone sends real SMS via its SIM. No DLT. No sender ID. ₹0 per SMS. Configure credentials below.</small>
      </label>
    </div>
    <div class="col-md-6">
      <label class="card p-3 m-0 h-100" style="cursor:pointer; border:2px solid <%= cfg.provider!=='gateway' ? 'var(--denim-500)' : 'var(--hairline)' %>;">
        <div class="d-flex align-items-center gap-2">
          <input type="radio" name="provider" value="off" <%= cfg.provider!=='gateway'?'checked':'' %>>
          <strong>⏸ Off / Test</strong>
        </div>
        <small class="text-muted mt-1 d-block">No SMS actually sent — every send is logged only. Use this until your gateway phone is set up.</small>
      </label>
    </div>
  </div>
</div>

<hr>

<h6>Android Phone Gateway · Capcom SMS Gateway</h6>
<div class="alert alert-info small">
  <strong>One-time setup:</strong>
  <ol class="mb-0">
    <li>Install <a href="https://sms-gate.app/" target="_blank">SMS Gateway for Android</a> on a spare phone with your business SIM.</li>
    <li>In the app, enable <strong>Cloud server (private API)</strong> → it generates a <strong>username</strong> and <strong>password</strong>.</li>
    <li>Paste them below and save. Done — your portal can now send SMS.</li>
  </ol>
</div>

<div class="row g-3">
  <div class="col-md-12">
    <label class="form-label">Cloud relay URL <small class="text-muted">(default works for the official Capcom relay)</small></label>
    <input name="gateway_url" class="form-control" value="<%= cfg.gateway_url %>" placeholder="https://api.sms-gate.app/3rdparty/v1">
  </div>
  <div class="col-md-6">
    <label class="form-label">Username</label>
    <input name="gateway_user" class="form-control" value="<%= cfg.gateway_user %>" placeholder="from the Cloud server screen in the app">
  </div>
  <div class="col-md-6">
    <label class="form-label">Password</label>
    <input name="gateway_pass" type="password" class="form-control" placeholder="<%= cfg.gateway_pass ? '(saved — leave blank to keep)' : 'paste here' %>">
  </div>
</div>

<hr>

<h6>Auto-send</h6>
<small class="text-muted d-block mb-2">SMS is the default channel for every notification. Toggle off any you don't want auto-firing.</small>

<div class="form-check form-switch mb-2">
  <input class="form-check-input" type="checkbox" name="auto_invoice" value="1" id="auto-invoice" <%= cfg.auto_invoice ? 'checked' : '' %>>
  <label class="form-check-label" for="auto-invoice">
    <strong>Invoice generated</strong>
    <div class="text-muted small">Fires when an invoice is created (direct or from a sales order).</div>
  </label>
</div>

<div class="form-check form-switch mb-2">
  <input class="form-check-input" type="checkbox" name="auto_payment" value="1" id="auto-payment" <%= cfg.auto_payment ? 'checked' : '' %>>
  <label class="form-check-label" for="auto-payment">
    <strong>Payment received</strong>
    <div class="text-muted small">Fires when a payment is verified. Includes outstanding balance + your sales nudge.</div>
  </label>
</div>

<div class="form-check form-switch mb-2">
  <input class="form-check-input" type="checkbox" name="auto_dispatch" value="1" id="auto-dispatch" <%= cfg.auto_dispatch ? 'checked' : '' %>>
  <label class="form-check-label" for="auto-dispatch">
    <strong>Dispatch created</strong>
    <div class="text-muted small">Fires when goods are dispatched, with vehicle + LR no.</div>
  </label>
</div>

<hr>

<h6>Message Templates <small class="text-muted">(placeholders: <code>{dealer}</code>, <code>{amount}</code>, <code>{outstanding}</code>, <code>{invoice_no}</code>, <code>{date}</code>, <code>{ref}</code>, <code>{vehicle}</code>, <code>{lr}</code>, <code>{count}</code>, <code>{company}</code>)</small></h6>
<div class="row g-3">
  <div class="col-md-12">
    <label class="form-label">Invoice generated</label>
    <input name="tpl_invoice" class="form-control" value="<%= cfg.tpl_invoice %>">
  </div>
  <div class="col-md-12">
    <label class="form-label">Payment received</label>
    <input name="tpl_payment" class="form-control" value="<%= cfg.tpl_payment %>">
  </div>
  <div class="col-md-12">
    <label class="form-label">Dispatch created</label>
    <input name="tpl_dispatch" class="form-control" value="<%= cfg.tpl_dispatch %>">
  </div>
  <div class="col-md-12">
    <label class="form-label">Outstanding reminder</label>
    <input name="tpl_outstand" class="form-control" value="<%= cfg.tpl_outstand %>">
  </div>
</div>

<div class="mt-3"><button class="btn btn-primary">Save Settings</button></div>
</form>

<form method="post" action="/settings/sms/test" class="card p-3 mt-3" style="max-width:840px">
  <h6>Send a test SMS</h6>
  <div class="row g-2 align-items-end">
    <div class="col-md-6"><label class="form-label">Phone number</label><input name="test_phone" class="form-control" placeholder="9876543210" required></div>
    <div class="col-md-3"><button class="btn btn-outline-primary w-100">Send Test</button></div>
    <div class="col-md-3"><a href="/notifications" class="btn btn-outline-secondary w-100">View log →</a></div>
  </div>
  <small class="text-muted mt-2">The current provider is <strong><%= cfg.provider %></strong>. Saves the message to the notifications log either way.</small>
</form>

<% if (recent && recent.length) { %>
<div class="card mt-3" style="max-width:840px">
  <div class="card-header">Last 10 SMS attempts</div>
  <div class="table-responsive"><table class="table table-sm m-0">
  <thead><tr><th>Time</th><th>To</th><th>Dealer</th><th>Status</th><th>Message</th></tr></thead><tbody>
  <% recent.forEach(r => { %>
    <tr>
      <td class="small text-muted"><%= r.created_at %></td>
      <td><%= r.to_phone || '-' %></td>
      <td><%= r.dealer_name || '-' %></td>
      <td><span class="badge bg-<%= r.status==='sent'?'success':r.status==='failed'?'danger':'secondary' %>"><%= r.status %></span></td>
      <td class="small"><%= (r.message||'').slice(0,80) %><%= (r.message||'').length > 80 ? '…' : '' %></td>
    </tr>
  <% }) %>
  </tbody></table></div>
</div>
<% } %>
<%- include('../partials/footer') %>
