<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h4 class="m-0"><i class="bi bi-chat-dots"></i> SMS Settings</h4>
    <small class="text-muted">Send transactional SMS to dealers via <strong>Fast2SMS</strong> (DLT route) — invoice, payment &amp; dispatch alerts.</small>
  </div>
  <a href="/notifications" class="btn btn-sm btn-outline-secondary"><i class="bi bi-clock-history"></i> Full SMS log</a>
</div>

<!-- STATUS -->
<div class="card mb-3"><div class="card-body d-flex justify-content-between align-items-center">
  <div><strong><i class="bi bi-broadcast"></i> Provider status</strong>
    <div id="smsStatus" class="small text-muted mt-1">Checking…</div>
  </div>
  <button id="smsStatusRefresh" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
</div></div>

<form method="post" action="/settings/sms" class="card mb-3"><div class="card-body">
  <!-- MODE -->
  <div class="row g-2 mb-3">
    <div class="col-md-6">
      <label class="form-label fw-semibold">SMS Mode</label>
      <select name="provider" class="form-select">
        <option value="fast2sms" <%= cfg.provider==='fast2sms'?'selected':'' %>>Fast2SMS — live (real SMS via DLT)</option>
        <option value="off" <%= cfg.provider!=='fast2sms'?'selected':'' %>>Off / Test (log only, nothing sent)</option>
      </select>
    </div>
  </div>

  <div class="alert alert-light border small">
    <strong>One-time setup:</strong> in your <a href="https://www.fast2sms.com" target="_blank">Fast2SMS</a> account →
    <strong>Dev API</strong> (copy the Authorization key) and <strong>DLT</strong> (your Sender ID + approved templates). Paste them here, then add each template below with its DLT Template ID.
  </div>

  <div class="row g-3">
    <div class="col-md-4">
      <label class="form-label">API Authorization key <% if (cfg.key_saved) { %><span class="badge bg-success">saved</span><% } %></label>
      <input name="api_key" class="form-control" placeholder="<%= cfg.key_saved ? 'leave blank to keep' : 'paste Fast2SMS Authorization key' %>" autocomplete="off">
    </div>
    <div class="col-md-3">
      <label class="form-label">Sender ID (Header)</label>
      <input name="sender_id" class="form-control text-uppercase" value="<%= cfg.sender_id %>" placeholder="SHARVE" maxlength="6">
    </div>
    <div class="col-md-2">
      <label class="form-label">Route</label>
      <select name="route" class="form-select"><option value="dlt" <%= cfg.route==='dlt'?'selected':'' %>>DLT (transactional)</option></select>
    </div>
    <div class="col-md-3">
      <label class="form-label">Entity ID <span class="text-muted">(reference)</span></label>
      <input name="entity_id" class="form-control" value="<%= cfg.entity_id %>" placeholder="DLT entity id">
    </div>
    <div class="col-md-3 d-flex align-items-center">
      <div class="form-check form-switch mt-3"><input class="form-check-input" type="checkbox" name="flash" value="1" id="flash" <%= cfg.flash?'checked':'' %>><label class="form-check-label" for="flash">Flash SMS</label></div>
    </div>
  </div>

  <hr>
  <label class="form-label fw-semibold">Auto-send</label>
  <div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="auto_invoice" value="1" id="ai" <%= cfg.auto_invoice?'checked':'' %>><label class="form-check-label" for="ai"><strong>Invoice generated</strong> — fires when an invoice is created</label></div>
  <div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="auto_payment" value="1" id="ap" <%= cfg.auto_payment?'checked':'' %>><label class="form-check-label" for="ap"><strong>Payment received</strong> — fires when a payment is verified</label></div>
  <div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="auto_dispatch" value="1" id="ad" <%= cfg.auto_dispatch?'checked':'' %>><label class="form-check-label" for="ad"><strong>Dispatch created</strong> — fires when goods are dispatched</label></div>

  <div class="mt-3"><button class="btn btn-primary"><i class="bi bi-save"></i> Save settings</button></div>
</div></form>

<!-- TEMPLATES MANAGER -->
<div class="card mb-3"><div class="card-body">
  <div class="d-flex justify-content-between align-items-center mb-2">
    <strong><i class="bi bi-card-text"></i> Message Templates</strong>
    <button class="btn btn-sm btn-primary" data-bs-toggle="collapse" data-bs-target="#addTpl"><i class="bi bi-plus"></i> Add template</button>
  </div>
  <div class="alert alert-light border small mb-2">
    Each template must match a <strong>DLT-approved</strong> template in Fast2SMS. Put its <strong>DLT Template ID</strong> + the <strong>variable order</strong> (comma-separated) exactly as the DLT template's <code>{#var#}</code> blanks.
    <div class="mt-1">Placeholders for the body &amp; order: <code>{dealer}</code> <code>{invoice_no}</code> <code>{amount}</code> <code>{outstanding}</code> <code>{vehicle}</code> <code>{lr}</code> <code>{count}</code> <code>{date}</code> <code>{ref}</code> <code>{company}</code>. The <strong>active</strong> template for each event is the one auto-send uses.</div>
  </div>

  <div class="collapse mb-3" id="addTpl">
    <form method="post" action="/settings/sms/templates" class="border rounded p-2 bg-light">
      <div class="row g-2">
        <div class="col-md-3"><label class="form-label small mb-0">Event</label>
          <select name="event" class="form-select form-select-sm">
            <% ['invoice','payment','dispatch','outstanding','manual'].forEach(e => { %><option value="<%= e %>"><%= e %></option><% }) %>
          </select></div>
        <div class="col-md-4"><label class="form-label small mb-0">Label</label><input name="label" class="form-control form-control-sm" placeholder="e.g. Invoice generated"></div>
        <div class="col-md-3"><label class="form-label small mb-0">DLT Template ID</label><input name="dlt_template_id" class="form-control form-control-sm" placeholder="from Fast2SMS"></div>
        <div class="col-md-2 d-flex align-items-end"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="active" value="1" checked><label class="form-check-label small">Active</label></div></div>
        <div class="col-md-8"><label class="form-label small mb-0">Message body (for preview/log)</label><textarea name="body" rows="2" class="form-control form-control-sm" placeholder="Dear {dealer}, ..."></textarea></div>
        <div class="col-md-4"><label class="form-label small mb-0">Variable order (comma list)</label><input name="var_order" class="form-control form-control-sm" placeholder="dealer,invoice_no,amount,outstanding"></div>
      </div>
      <div class="mt-2"><button class="btn btn-sm btn-primary">Add</button></div>
    </form>
  </div>

  <div class="table-responsive">
    <table class="table table-sm align-middle">
      <thead><tr><th>Event</th><th>Label</th><th>DLT ID</th><th>Variables</th><th>Active</th><th></th></tr></thead>
      <tbody>
        <% templates.forEach(t => { %>
          <tr>
            <td><span class="badge bg-secondary"><%= t.event %></span></td>
            <td><%= t.label %><div class="small text-muted"><%= (t.body||'').slice(0,60) %></div></td>
            <td class="small"><% if (t.dlt_template_id) { %><%= t.dlt_template_id %><% } else { %><span class="text-danger">— not set —</span><% } %></td>
            <td class="small text-muted"><%= t.var_order || '-' %></td>
            <td><form method="post" action="/settings/sms/templates/<%= t.id %>/toggle"><button class="btn btn-sm btn-<%= t.active?'success':'outline-secondary' %> py-0"><%= t.active?'on':'off' %></button></form></td>
            <td style="white-space:nowrap">
              <button class="btn btn-sm btn-outline-primary py-0" data-bs-toggle="collapse" data-bs-target="#edit<%= t.id %>"><i class="bi bi-pencil"></i></button>
              <form method="post" action="/settings/sms/templates/<%= t.id %>/delete" class="d-inline" data-confirm="Delete this template?"><button class="btn btn-sm btn-outline-danger py-0">×</button></form>
            </td>
          </tr>
          <tr class="collapse" id="edit<%= t.id %>"><td colspan="6">
            <form method="post" action="/settings/sms/templates/<%= t.id %>" class="border rounded p-2 bg-light">
              <div class="row g-2">
                <div class="col-md-3"><label class="form-label small mb-0">Event</label>
                  <select name="event" class="form-select form-select-sm">
                    <% ['invoice','payment','dispatch','outstanding','manual'].forEach(e => { %><option value="<%= e %>" <%= t.event===e?'selected':'' %>><%= e %></option><% }) %>
                  </select></div>
                <div class="col-md-4"><label class="form-label small mb-0">Label</label><input name="label" class="form-control form-control-sm" value="<%= t.label %>"></div>
                <div class="col-md-3"><label class="form-label small mb-0">DLT Template ID</label><input name="dlt_template_id" class="form-control form-control-sm" value="<%= t.dlt_template_id||'' %>"></div>
                <div class="col-md-2 d-flex align-items-end"><div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="active" value="1" <%= t.active?'checked':'' %>><label class="form-check-label small">Active</label></div></div>
                <div class="col-md-8"><label class="form-label small mb-0">Body</label><textarea name="body" rows="2" class="form-control form-control-sm"><%= t.body %></textarea></div>
                <div class="col-md-4"><label class="form-label small mb-0">Variable order</label><input name="var_order" class="form-control form-control-sm" value="<%= t.var_order||'' %>"></div>
              </div>
              <div class="mt-2"><button class="btn btn-sm btn-primary">Save</button></div>
            </form>
          </td></tr>
        <% }) %>
        <% if (templates.length===0) { %><tr><td colspan="6" class="text-muted text-center py-3">No templates — add one above.</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div></div>

<!-- SCHEDULED LEDGER REMINDER -->
<div class="card mb-3"><div class="card-body">
  <div class="d-flex justify-content-between align-items-center mb-1">
    <strong><i class="bi bi-calendar-check"></i> Scheduled ledger / balance reminder</strong>
    <% if (ledger.last_run) { %><span class="small text-muted">Last run: <%= ledger.last_run %></span><% } %>
  </div>
  <div class="small text-muted mb-2">Automatically texts each dealer their <strong>official outstanding balance</strong> on a schedule — so dealers always know the true figure and a salesperson can't mis-state a payment.</div>

  <form method="post" action="/settings/sms/ledger">
    <div class="row g-3 align-items-end">
      <div class="col-md-2">
        <div class="form-check form-switch mt-2"><input class="form-check-input" type="checkbox" name="enabled" value="1" id="ledOn" <%= ledger.enabled?'checked':'' %>><label class="form-check-label" for="ledOn">Enabled</label></div>
      </div>
      <div class="col-md-2"><label class="form-label small mb-0">Frequency</label>
        <select name="frequency" id="ledFreq" class="form-select form-select-sm">
          <% ['daily','weekly','monthly'].forEach(fr => { %><option value="<%= fr %>" <%= ledger.frequency===fr?'selected':'' %>><%= fr %></option><% }) %>
        </select>
      </div>
      <div class="col-md-2" id="wkWrap"><label class="form-label small mb-0">Day of week</label>
        <select name="day" id="dayWeek" class="form-select form-select-sm">
          <% ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'].forEach((dn,i) => { %><option value="<%= i %>" <%= ledger.frequency==='weekly'&&ledger.day===i?'selected':'' %>><%= dn %></option><% }) %>
        </select>
      </div>
      <div class="col-md-2" id="moWrap"><label class="form-label small mb-0">Day of month</label>
        <input type="number" name="day" id="dayMonth" min="1" max="28" class="form-control form-control-sm" value="<%= ledger.frequency==='monthly' ? (ledger.day||1) : 1 %>">
      </div>
      <div class="col-md-2"><label class="form-label small mb-0">Time (IST)</label>
        <input type="time" name="time" class="form-control form-control-sm" value="<%= ledger.time %>">
      </div>
      <div class="col-md-2"><label class="form-label small mb-0">Template</label>
        <select name="template_id" class="form-select form-select-sm">
          <% templates.forEach(t => { %><option value="<%= t.id %>" <%= String(ledger.template_id)===String(t.id)?'selected':'' %>><%= t.label %></option><% }) %>
        </select>
      </div>
    </div>
    <div class="form-check form-switch mt-2"><input class="form-check-input" type="checkbox" name="only_out" value="1" id="ledOut" <%= ledger.only_out?'checked':'' %>><label class="form-check-label small" for="ledOut">Only dealers with outstanding &gt; 0 (recommended)</label></div>
    <div class="mt-2 d-flex align-items-center gap-2">
      <button class="btn btn-sm btn-primary"><i class="bi bi-save"></i> Save schedule</button>
      <span class="small text-muted">Will currently text <strong><%= ledger.targets %></strong> dealer(s) per run.</span>
    </div>
  </form>

  <hr class="my-2">
  <form method="post" action="/settings/sms/ledger/run" data-confirm="Send the ledger balance SMS to all matching dealers now?">
    <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-send"></i> Send now (manual run)</button>
    <span class="small text-muted ms-1">Sends immediately to the <%= ledger.targets %> dealer(s) above. Uses your SMS balance.</span>
  </form>
</div></div>

<script>
(function(){
  var freq=document.getElementById('ledFreq'), wk=document.getElementById('wkWrap'), mo=document.getElementById('moWrap'),
      dayWeek=document.getElementById('dayWeek'), dayMonth=document.getElementById('dayMonth');
  function sync(){
    var f=freq.value;
    wk.style.display = (f==='weekly')?'':'none';
    mo.style.display = (f==='monthly')?'':'none';
    // only the relevant control submits as `day` (disabled inputs don't post)
    dayWeek.disabled = (f!=='weekly');
    dayMonth.disabled = (f!=='monthly');
  }
  freq.addEventListener('change', sync); sync();
})();
</script>

<!-- CAMPAIGN / PROMOTIONAL BROADCAST -->
<div class="card mb-3"><div class="card-body">
  <strong><i class="bi bi-megaphone"></i> Campaign / promotional broadcast</strong>
  <div class="small text-muted mb-2">Send any template (e.g. a festival offer) to many dealers at once — now or scheduled. Promotional sends only fire <strong>9 AM–9 PM</strong> and use your SMS balance.</div>

  <form method="post">
    <div class="row g-2 align-items-end">
      <div class="col-md-4"><label class="form-label small mb-0">Template</label>
        <select name="template_id" class="form-select form-select-sm" required>
          <option value="">— pick a template —</option>
          <% templates.forEach(t => { %><option value="<%= t.id %>"><%= t.label %> (<%= t.event %>)<%= !t.dlt_template_id ? ' — no DLT ID' : '' %></option><% }) %>
        </select>
      </div>
      <div class="col-md-3"><label class="form-label small mb-0">Audience</label>
        <select name="audience" id="bcAud" class="form-select form-select-sm">
          <option value="all">All active dealers (<%= bc.all %>)</option>
          <option value="outstanding">Only with outstanding (<%= bc.outstanding %>)</option>
          <option value="office">By office</option>
        </select>
      </div>
      <div class="col-md-3" id="bcOfficeWrap" style="display:none"><label class="form-label small mb-0">Office</label>
        <select name="office_id" class="form-select form-select-sm">
          <% offices.forEach(o => { %><option value="<%= o.id %>"><%= o.name %></option><% }) %>
        </select>
      </div>
      <div class="col-md-2"><label class="form-label small mb-0">Festival / value <span class="text-muted">(if template uses it)</span></label>
        <input name="festival" class="form-control form-control-sm" placeholder="e.g. Diwali">
      </div>
    </div>
    <div class="d-flex flex-wrap gap-2 align-items-end mt-2">
      <button formaction="/settings/sms/broadcast/run" class="btn btn-sm btn-primary" data-confirm="Send this broadcast to all matching dealers now?"><i class="bi bi-send"></i> Send now</button>
      <span class="text-muted small">or schedule:</span>
      <input type="datetime-local" name="run_at" class="form-control form-control-sm" style="width:auto">
      <button formaction="/settings/sms/broadcast/schedule" class="btn btn-sm btn-outline-primary"><i class="bi bi-calendar-plus"></i> Schedule</button>
    </div>
  </form>

  <% if (broadcasts.length) { %>
    <hr class="my-2">
    <div class="small fw-semibold mb-1">Scheduled broadcasts</div>
    <table class="table table-sm m-0">
      <thead><tr><th>When (IST)</th><th>Template</th><th>Audience</th><th></th></tr></thead>
      <tbody>
        <% broadcasts.forEach(b => { %>
          <tr><td class="small"><%= b.run_at %></td><td class="small"><%= b.tpl_label || ('#'+b.template_id) %></td><td class="small"><%= b.audience %></td>
          <td><form method="post" action="/settings/sms/broadcast/<%= b.id %>/cancel" data-confirm="Cancel this scheduled broadcast?"><button class="btn btn-sm btn-outline-danger py-0">cancel</button></form></td></tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div></div>
<script>
(function(){
  var aud=document.getElementById('bcAud'), ow=document.getElementById('bcOfficeWrap');
  function s(){ ow.style.display = (aud.value==='office')?'':'none'; }
  aud.addEventListener('change', s); s();
})();
</script>

<!-- TEST + RECENT -->
<div class="row g-3">
  <div class="col-md-5"><div class="card h-100"><div class="card-body">
    <strong><i class="bi bi-send"></i> Send a test SMS</strong>
    <form method="post" action="/settings/sms/test" class="mt-2">
      <div class="mb-2"><label class="form-label small mb-0">Phone (10-digit)</label><input name="test_phone" class="form-control form-control-sm" placeholder="9876543210"></div>
      <div class="mb-2"><label class="form-label small mb-0">Using template</label>
        <select name="template_id" class="form-select form-select-sm">
          <option value="">— plain test (stub only) —</option>
          <% templates.forEach(t => { %><option value="<%= t.id %>"><%= t.label %> (<%= t.event %>)</option><% }) %>
        </select></div>
      <button class="btn btn-sm btn-primary">Send test</button>
    </form>
  </div></div></div>
  <div class="col-md-7"><div class="card h-100"><div class="card-body">
    <strong><i class="bi bi-clock-history"></i> Recent SMS</strong>
    <table class="table table-sm m-0 mt-2"><tbody>
      <% recent.forEach(n => { %>
        <tr><td class="small"><%= fmtDateTime(n.created_at) %></td><td class="small"><%= n.dealer_name || n.to_phone %></td>
        <td><span class="badge bg-<%= n.status==='sent'?'success':n.status==='failed'?'danger':'secondary' %>"><%= n.status %></span></td></tr>
      <% }) %>
      <% if (recent.length===0) { %><tr><td class="text-muted">No messages yet.</td></tr><% } %>
    </tbody></table>
  </div></div></div>
</div>

<script>
(function(){
  var box = document.getElementById('smsStatus');
  function paint(d){
    if(!d){ box.textContent='Status unavailable.'; return; }
    if(d.status==='ok'){ box.innerHTML='<span class="text-success">● Connected</span> — Fast2SMS wallet balance: <strong>₹'+(d.balance||'?')+'</strong>'; }
    else if(d.status==='off'){ box.innerHTML='<span class="text-secondary">● Off / Test mode</span> — '+d.message; }
    else if(d.status==='no_key'){ box.innerHTML='<span class="text-warning">● No API key</span> — paste your Fast2SMS Authorization key below.'; }
    else { box.innerHTML='<span class="text-danger">● Not connected</span> — '+(d.message||'check API key'); }
  }
  function load(){ box.textContent='Checking…'; fetch('/settings/sms/health').then(function(r){return r.json();}).then(paint).catch(function(){paint(null);}); }
  document.getElementById('smsStatusRefresh').addEventListener('click', load);
  load();
})();
</script>
<%- include('../partials/footer') %>
