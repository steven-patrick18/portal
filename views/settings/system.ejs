<%- include('../partials/header') %>
<%
function fmtBytes(n) {
  if (!n || n < 1024) return (n||0) + ' B';
  if (n < 1024*1024) return (n/1024).toFixed(1) + ' KB';
  if (n < 1024*1024*1024) return (n/1024/1024).toFixed(1) + ' MB';
  return (n/1024/1024/1024).toFixed(2) + ' GB';
}
function fmtUptime(s) {
  if (!s) return '0s';
  const d = Math.floor(s/86400), h = Math.floor((s%86400)/3600), m = Math.floor((s%3600)/60);
  return (d?d+'d ':'') + (h?h+'h ':'') + m + 'm';
}
%>
<h4>System Health</h4>
<small class="text-muted">Pull updates from git, run a backup, see disk usage — all without SSH.</small>

<div class="row g-3 mt-1">

  <!-- ── Current version + updates ────────────────────────── -->
  <div class="col-md-6">
    <div class="card p-3 h-100">
      <h6 class="mb-2"><i class="bi bi-git"></i> Current version</h6>
      <% if (sys.current && sys.current.hash) { %>
        <div class="small mb-1"><code><%= sys.current.hash %></code> · <%= sys.current.author %></div>
        <div class="small text-muted mb-1"><%= fmtDateTime(sys.current.date) %></div>
        <div class="mb-3"><%= sys.current.subject %></div>
      <% } else { %>
        <div class="alert alert-warning small">Not a git checkout — updates won't work. <%= (sys.current && sys.current.error) || '' %></div>
      <% } %>

      <hr class="my-2">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <strong>Updates available</strong>
        <button class="btn btn-sm btn-outline-secondary" id="btn-check-updates"><i class="bi bi-arrow-clockwise"></i> Check now</button>
      </div>
      <div id="updates-box">
        <% if (sys.updates_available && sys.updates_available.length) { %>
          <span class="badge bg-warning text-dark"><%= sys.updates_available.length %> new commit<%= sys.updates_available.length===1?'':'s' %> available</span>
          <ul class="small mt-2 mb-3">
            <% sys.updates_available.slice(0,5).forEach(c => { %><li><code><%= c.split(' ')[0] %></code> <%= c.split(' ').slice(1).join(' ') %></li><% }) %>
          </ul>
          <button class="btn btn-success" id="btn-update-now"><i class="bi bi-download"></i> Update now</button>
        <% } else { %>
          <span class="badge bg-success">✓ Up to date</span>
        <% } %>
      </div>

      <div id="update-output" class="d-none mt-3">
        <strong class="small">Update log:</strong>
        <pre id="update-log" style="max-height:300px;overflow:auto;background:#0f172a;color:#cbd5e1;padding:.6rem;border-radius:6px;font-size:.78rem;line-height:1.4">Starting…</pre>
        <div class="form-text">The page will lose connection briefly while the app reloads. Refresh after 10 seconds.</div>
      </div>
    </div>
  </div>

  <!-- ── Backups ──────────────────────────────────────────── -->
  <div class="col-md-6">
    <div class="card p-3 h-100">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="m-0"><i class="bi bi-archive-fill"></i> Backups</h6>
        <button class="btn btn-sm btn-success" id="btn-backup-now"><i class="bi bi-cloud-arrow-down-fill"></i> Run backup now</button>
      </div>
      <small class="text-muted d-block mb-2">Daily auto-backup runs via cron at 02:30. Files kept 14 days, then auto-pruned.</small>

      <% if (sys.backups && sys.backups.length) { %>
        <div class="table-responsive" style="max-height:340px">
          <table class="table table-sm m-0">
            <thead><tr><th>File</th><th class="text-end">Size</th><th>When</th></tr></thead>
            <tbody>
              <% sys.backups.forEach(b => { %>
                <tr>
                  <td><code style="font-size:.75rem"><%= b.name %></code></td>
                  <td class="text-end small"><%= fmtBytes(b.size) %></td>
                  <td class="small text-muted"><%= fmtDateTime(b.mtime) %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="alert alert-info small mb-0">No backup files yet. Click <strong>Run backup now</strong> above to create the first one.</div>
      <% } %>

      <div id="backup-output" class="d-none mt-3">
        <strong class="small">Backup output:</strong>
        <pre id="backup-log" style="max-height:200px;overflow:auto;background:#0f172a;color:#cbd5e1;padding:.6rem;border-radius:6px;font-size:.78rem;line-height:1.4"></pre>
      </div>
    </div>
  </div>

  <!-- ── Disk usage ───────────────────────────────────────── -->
  <div class="col-md-6">
    <div class="card p-3">
      <h6 class="mb-2"><i class="bi bi-hdd-fill"></i> Disk usage (this app)</h6>
      <div class="row g-2 small">
        <div class="col-6">Database</div><div class="col-6 text-end fw-bold"><%= fmtBytes(sys.disk.data) %></div>
        <div class="col-6">Uploaded photos</div><div class="col-6 text-end fw-bold"><%= fmtBytes(sys.disk.uploads) %></div>
        <div class="col-6">Backup archive</div><div class="col-6 text-end fw-bold"><%= fmtBytes(sys.disk.backups) %></div>
        <div class="col-12"><hr class="my-1"></div>
        <div class="col-6"><strong>Total</strong></div><div class="col-6 text-end fw-bold"><%= fmtBytes((sys.disk.data||0) + (sys.disk.uploads||0) + (sys.disk.backups||0)) %></div>
      </div>
    </div>
  </div>

  <!-- ── Process ──────────────────────────────────────────── -->
  <div class="col-md-6">
    <div class="card p-3">
      <h6 class="mb-2"><i class="bi bi-cpu-fill"></i> App process</h6>
      <div class="row g-2 small">
        <div class="col-6">Node version</div><div class="col-6 text-end"><code><%= sys.proc.node %></code></div>
        <div class="col-6">Environment</div><div class="col-6 text-end"><span class="badge bg-<%= sys.proc.env==='production'?'success':'secondary' %>"><%= sys.proc.env %></span></div>
        <div class="col-6">Uptime</div><div class="col-6 text-end"><%= fmtUptime(sys.proc.uptime_s) %></div>
        <div class="col-6">Memory (RSS)</div><div class="col-6 text-end"><%= sys.proc.memory_mb %> MB</div>
        <div class="col-6">PID</div><div class="col-6 text-end"><code><%= sys.proc.pid %></code></div>
        <div class="col-6">Install dir</div><div class="col-6 text-end small text-muted"><code style="font-size:.7rem"><%= sys.app_dir %></code></div>
      </div>
    </div>
  </div>

</div>

<!-- ── Live server monitor (auto-refresh every 5s) ─────────────────── -->
<div class="card mt-3">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span><i class="bi bi-activity"></i> Live Server Monitor</span>
    <small class="text-muted">
      <span class="d-inline-block" style="width:8px;height:8px;border-radius:50%;background:#10b981;animation:pulse 2s infinite"></span>
      live · refreshes every 5s · last update <span id="ls-when">—</span>
    </small>
  </div>
  <div class="card-body">

    <div class="row g-3">

      <!-- CPU -->
      <div class="col-md-4">
        <div class="d-flex justify-content-between align-items-baseline mb-1">
          <h6 class="m-0"><i class="bi bi-cpu-fill"></i> CPU</h6>
          <span class="badge bg-secondary" id="ls-cpu-pct">…</span>
        </div>
        <div class="progress" style="height:14px">
          <div id="ls-cpu-bar" class="progress-bar bg-success" role="progressbar" style="width:0%"></div>
        </div>
        <div class="small text-muted mt-2">
          <div><strong>Cores:</strong> <span id="ls-cpu-cores">…</span> · <span id="ls-cpu-speed">…</span></div>
          <div title="Average load — informal score, ~equal to cores is fine"><strong>Load avg:</strong> <span id="ls-load">…</span></div>
          <div style="word-break:break-all" title="CPU model"><span id="ls-cpu-model" class="text-muted small"></span></div>
        </div>
      </div>

      <!-- Memory -->
      <div class="col-md-4">
        <div class="d-flex justify-content-between align-items-baseline mb-1">
          <h6 class="m-0"><i class="bi bi-memory"></i> Memory</h6>
          <span class="badge bg-secondary" id="ls-mem-pct">…</span>
        </div>
        <div class="progress" style="height:14px">
          <div id="ls-mem-bar" class="progress-bar bg-info" role="progressbar" style="width:0%"></div>
        </div>
        <div class="small text-muted mt-2">
          <div><strong>Used:</strong> <span id="ls-mem-used">…</span> / <span id="ls-mem-total">…</span></div>
          <div><strong>Free:</strong> <span id="ls-mem-free">…</span></div>
          <div><strong>App (RSS):</strong> <span id="ls-proc-rss">…</span> · Heap <span id="ls-proc-heap">…</span></div>
        </div>
      </div>

      <!-- Disk -->
      <div class="col-md-4">
        <div class="d-flex justify-content-between align-items-baseline mb-1">
          <h6 class="m-0"><i class="bi bi-hdd-fill"></i> Disk (server-wide)</h6>
          <span class="badge bg-secondary" id="ls-disk-pct">…</span>
        </div>
        <div class="progress" style="height:14px">
          <div id="ls-disk-bar" class="progress-bar bg-warning" role="progressbar" style="width:0%"></div>
        </div>
        <div class="small text-muted mt-2">
          <div><strong>Used:</strong> <span id="ls-disk-used">…</span> / <span id="ls-disk-total">…</span></div>
          <div><strong>Free:</strong> <span id="ls-disk-free">…</span></div>
          <div><strong>Mount:</strong> <code id="ls-disk-target" style="font-size:.7rem">…</code></div>
        </div>
      </div>

    </div>

    <hr class="my-3">

    <div class="row g-2 small">
      <div class="col-md-3 col-6"><strong>Hostname:</strong> <code id="ls-host">…</code></div>
      <div class="col-md-3 col-6"><strong>Platform:</strong> <span id="ls-platform">…</span></div>
      <div class="col-md-3 col-6"><strong>Server uptime:</strong> <span id="ls-sys-uptime">…</span></div>
      <div class="col-md-3 col-6"><strong>App uptime:</strong> <span id="ls-app-uptime">…</span></div>
    </div>

    <div class="alert alert-light border mt-3 mb-0 small py-2">
      <i class="bi bi-info-circle"></i>
      <strong>Reading the gauges:</strong> CPU &lt; 70% green · 70–90% orange · &gt; 90% red.
      Memory and disk follow the same rule. Load average ≈ number of cores is normal — much higher
      and the server is over-committed.
    </div>
  </div>
</div>

<style>
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
</style>

<script>
(function () {
  // ── Format helpers ─────────────────────────────────────
  function fmtBytes(n) {
    if (!n && n !== 0) return '—';
    if (n < 1024) return n + ' B';
    if (n < 1024*1024) return (n/1024).toFixed(1) + ' KB';
    if (n < 1024*1024*1024) return (n/1024/1024).toFixed(1) + ' MB';
    return (n/1024/1024/1024).toFixed(2) + ' GB';
  }
  function fmtUptime(s) {
    if (!s) return '—';
    const d = Math.floor(s/86400), h = Math.floor((s%86400)/3600), m = Math.floor((s%3600)/60);
    return (d?d+'d ':'') + (h?h+'h ':'') + m + 'm';
  }
  function fmtTimeIST(iso) {
    if (!iso) return '—';
    return new Date(iso).toLocaleTimeString('en-IN', {timeZone:'Asia/Kolkata', hour12:false});
  }
  // Threshold → bootstrap color
  function colorFor(pct) {
    if (pct == null) return 'bg-secondary';
    if (pct >= 90) return 'bg-danger';
    if (pct >= 70) return 'bg-warning';
    return 'bg-success';
  }
  function setBar(id, pct, label) {
    const bar = document.getElementById(id);
    bar.className = 'progress-bar ' + colorFor(pct);
    bar.style.width = (pct == null ? 0 : pct) + '%';
    const badge = document.getElementById(id.replace('-bar', '-pct'));
    if (badge) {
      badge.className = 'badge ' + colorFor(pct);
      badge.textContent = pct == null ? '…' : (pct + '%');
    }
  }

  // ── Poll loop ──────────────────────────────────────────
  let timer = null;
  async function tick() {
    try {
      const r = await fetch('/settings/system/stats.json', { headers: { 'Accept': 'application/json' } });
      if (!r.ok) return;
      const d = await r.json();

      // CPU
      setBar('ls-cpu-bar', d.cpu.usage_pct);
      document.getElementById('ls-cpu-cores').textContent = d.cpu.cores;
      document.getElementById('ls-cpu-speed').textContent = d.cpu.speed_mhz ? (d.cpu.speed_mhz + ' MHz') : '';
      document.getElementById('ls-cpu-model').textContent = d.cpu.model;
      document.getElementById('ls-load').textContent =
        d.cpu.load_1m.toFixed(2) + ' / ' + d.cpu.load_5m.toFixed(2) + ' / ' + d.cpu.load_15m.toFixed(2)
        + ' (1m / 5m / 15m)';

      // Memory
      setBar('ls-mem-bar', d.memory.pct);
      document.getElementById('ls-mem-used').textContent  = fmtBytes(d.memory.used_b);
      document.getElementById('ls-mem-total').textContent = fmtBytes(d.memory.total_b);
      document.getElementById('ls-mem-free').textContent  = fmtBytes(d.memory.free_b);
      document.getElementById('ls-proc-rss').textContent  = d.process.rss_mb + ' MB';
      document.getElementById('ls-proc-heap').textContent = d.process.heap_used_mb + ' / ' + d.process.heap_total_mb + ' MB';

      // Disk
      if (d.disk) {
        setBar('ls-disk-bar', d.disk.pct);
        document.getElementById('ls-disk-used').textContent  = fmtBytes(d.disk.usedB);
        document.getElementById('ls-disk-total').textContent = fmtBytes(d.disk.totalB);
        document.getElementById('ls-disk-free').textContent  = fmtBytes(d.disk.freeB);
        document.getElementById('ls-disk-target').textContent = d.disk.target;
      } else {
        document.getElementById('ls-disk-target').textContent = 'unavailable on this OS';
      }

      // System / app
      document.getElementById('ls-host').textContent     = d.system.hostname;
      document.getElementById('ls-platform').textContent = d.system.platform + ' ' + d.system.arch + ' · ' + d.system.release;
      document.getElementById('ls-sys-uptime').textContent = fmtUptime(d.system.uptime_s);
      document.getElementById('ls-app-uptime').textContent = fmtUptime(d.process.uptime_s);
      document.getElementById('ls-when').textContent = fmtTimeIST(d.when);
    } catch (e) {
      // Silently swallow — page might be reloading or net flaked
    }
  }
  tick();                       // immediate first paint
  timer = setInterval(tick, 5000); // every 5s
  // Pause polling when tab is hidden to save VPS CPU.
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      if (timer) { clearInterval(timer); timer = null; }
    } else if (!timer) {
      tick(); timer = setInterval(tick, 5000);
    }
  });
})();
</script>

<script>
(function () {
  const $ = id => document.getElementById(id);

  $('btn-check-updates')?.addEventListener('click', async () => {
    const btn = $('btn-check-updates');
    btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Checking…';
    try {
      const r = await fetch('/settings/system/check-updates', { method: 'POST' }).then(r => r.json());
      if (!r.ok) { alert('Check failed: ' + (r.error || 'unknown')); }
      else { location.reload(); }
    } catch (e) { alert('Error: ' + e.message); }
    btn.disabled = false; btn.innerHTML = '<i class="bi bi-arrow-clockwise"></i> Check now';
  });

  $('btn-update-now')?.addEventListener('click', async () => {
    if (!confirm('Pull the latest code and reload the app? A backup runs automatically just before. The page may briefly disconnect.')) return;
    const btn = $('btn-update-now');
    btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Starting…';
    $('update-output').classList.remove('d-none');
    $('update-log').textContent = 'Starting update…';
    try {
      const r = await fetch('/settings/system/update-now', { method: 'POST' }).then(r => r.json());
      if (!r.ok) { $('update-log').textContent = 'Failed: ' + (r.error || 'unknown'); btn.disabled = false; return; }
      // Poll the log file every 1.5s
      const tick = setInterval(async () => {
        try {
          const log = await fetch('/settings/system/update-log').then(r => r.text());
          $('update-log').textContent = log;
          $('update-log').scrollTop = $('update-log').scrollHeight;
          if (/Update complete|Already at the latest|Rollback:|✗/i.test(log)) {
            clearInterval(tick);
            btn.innerHTML = '<i class="bi bi-check-circle"></i> Done — refresh the page';
            btn.classList.remove('btn-success'); btn.classList.add('btn-outline-success');
          }
        } catch (e) { /* ignore — page might be reloading */ }
      }, 1500);
    } catch (e) { alert('Error: ' + e.message); btn.disabled = false; }
  });

  $('btn-backup-now')?.addEventListener('click', async () => {
    const btn = $('btn-backup-now');
    btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Backing up…';
    $('backup-output').classList.remove('d-none');
    $('backup-log').textContent = 'Running…';
    try {
      const r = await fetch('/settings/system/backup-now', { method: 'POST' }).then(r => r.json());
      $('backup-log').textContent = r.output || (r.ok ? 'Done.' : 'Failed.');
      if (r.ok) { setTimeout(() => location.reload(), 800); }
    } catch (e) { $('backup-log').textContent = 'Error: ' + e.message; }
    btn.disabled = false; btn.innerHTML = '<i class="bi bi-cloud-arrow-down-fill"></i> Run backup now';
  });
})();
</script>
<%- include('../partials/footer') %>
