<footer><div class="wrap">
  <div class="fgrid">
    <div>
      <div class="brand" style="color:#fff;font-size:1.2rem">
        <% if (logo) { %><img src="<%= logo %>" alt="<%= c.company_name %> logo" style="height:34px"><% } else { %><span class="mark"><%= (c.company_name||'S')[0] %></span><% } %>
        <span><%= c.company_name %></span>
      </div>
      <p style="margin-top:12px;color:#94a3b8;max-width:38ch;font-size:.9rem"><%= c.tagline %></p>
      <div class="social">
        <% if (c.instagram) { %><a href="<%= c.instagram %>" aria-label="Instagram" target="_blank" rel="noopener">📸</a><% } %>
        <% if (c.linkedin)  { %><a href="<%= c.linkedin %>"  aria-label="LinkedIn"  target="_blank" rel="noopener">in</a><% } %>
        <% if (c.facebook)  { %><a href="<%= c.facebook %>"  aria-label="Facebook"  target="_blank" rel="noopener">f</a><% } %>
        <% if (c.youtube)   { %><a href="<%= c.youtube %>"   aria-label="YouTube"   target="_blank" rel="noopener">▶</a><% } %>
      </div>
    </div>
    <div>
      <h4>Explore</h4>
      <a href="/#products">Products</a><a href="/#why">Why Us</a><a href="/#process">Process</a><a href="/blog">Blog</a><a href="/about">About</a><a href="/careers">Careers</a><a href="/contact">Contact</a><a href="https://portal.sharvexports.com" rel="nofollow">Staff Login</a>
    </div>
    <div>
      <h4>Contact</h4>
      <% if (c.address) { %><a href="/contact" style="cursor:pointer"><%= c.address %></a><% } %>
      <% if (c.phone) { %><a href="tel:<%= c.phone %>"><%= c.phone %></a><% } %>
      <% if (c.email) { %><a href="mailto:<%= c.email %>"><%= c.email %></a><% } %>
    </div>
  </div>
  <div class="copyr">© <%= new Date().getFullYear() %> <%= c.company_name %>. All rights reserved.</div>
</div></footer>

<% if (c.whatsapp) {
     const waNum = c.whatsapp.replace(/[^0-9]/g, '');
     const waMsg = (c.wa_greeting && c.wa_greeting.trim())
       ? c.wa_greeting.trim()
       : ('Hi ' + (c.company_name || 'there') + ', I am interested in your garments. Please share details.');
     const waUrl = 'https://wa.me/' + waNum + '?text=' + encodeURIComponent(waMsg);
%>
<a class="wa" href="<%= waUrl %>" aria-label="Chat on WhatsApp" target="_blank" rel="noopener">
  <svg viewBox="0 0 32 32" width="30" height="30" fill="#fff" aria-hidden="true">
    <path d="M16 .4C7.4.4.4 7.4.4 16c0 2.8.7 5.5 2.1 7.9L.3 31.7l8-2.1c2.3 1.3 4.9 1.9 7.6 1.9 8.6 0 15.6-7 15.6-15.6S24.6.4 16 .4zm0 28.5c-2.4 0-4.7-.6-6.7-1.8l-.5-.3-4.8 1.3 1.3-4.6-.3-.5c-1.3-2.1-2-4.5-2-7 0-7.2 5.9-13.1 13.1-13.1S29.1 8.8 29.1 16 23.2 28.9 16 28.9z"/>
    <path d="M23.2 19.3c-.4-.2-2.3-1.1-2.7-1.3-.4-.1-.6-.2-.9.2-.3.4-1 1.3-1.2 1.5-.2.2-.4.3-.8.1-.4-.2-1.7-.6-3.2-2-1.2-1.1-2-2.4-2.2-2.8-.2-.4 0-.6.2-.8.2-.2.4-.4.5-.7.2-.2.2-.4.4-.6.1-.3.1-.5 0-.7-.1-.2-.9-2.1-1.2-2.9-.3-.8-.6-.7-.9-.7h-.7c-.2 0-.6.1-1 .5-.3.4-1.3 1.3-1.3 3.1s1.3 3.6 1.5 3.9c.2.2 2.6 4 6.3 5.5.9.4 1.6.6 2.1.8.9.3 1.7.2 2.3.1.7-.1 2.3-.9 2.6-1.8.3-.9.3-1.7.2-1.8-.1-.2-.3-.3-.7-.5z"/>
  </svg>
</a>
<% } %>

</body>
</html>
