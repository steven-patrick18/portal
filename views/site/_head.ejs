<%
  const _title  = (typeof pageTitle !== 'undefined' && pageTitle) ? pageTitle : (c.meta_title || c.company_name || 'Sharv Enterprises');
  const _desc   = (typeof pageDesc  !== 'undefined' && pageDesc)  ? pageDesc  : (c.meta_desc || c.tagline || '');
  const _path   = (typeof canonical !== 'undefined' && canonical) ? canonical : '/';
  const _canon  = baseUrl + _path;
  const _ogtype = (typeof ogType !== 'undefined' && ogType) ? ogType : 'website';
  const _ogimg  = (typeof ogImage !== 'undefined' && ogImage) ? ogImage : (c.og_image || logo || '');
  // Be forgiving: the owner may paste the whole <meta ... content="X"> tag
  // OR just the token X. Extract the content value either way so Google's
  // verification never breaks on a double-wrapped tag.
  function _verifyToken(v) {
    if (!v) return '';
    const m = String(v).match(/content\s*=\s*["']([^"']+)["']/i);
    return (m ? m[1] : String(v)).trim();
  }
  const _gsc  = _verifyToken(c.google_verification);
  const _bing = _verifyToken(c.bing_verification);
%><!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<link rel="icon" href="/brand/sharv-icon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/brand/sharv-icon.svg">
<title><%= _title %></title>
<meta name="description" content="<%= _desc %>">
<link rel="canonical" href="<%= _canon %>">
<meta property="og:type" content="<%= _ogtype %>">
<meta property="og:title" content="<%= _title %>">
<meta property="og:description" content="<%= _desc %>">
<meta property="og:url" content="<%= _canon %>">
<% if (_ogimg) { %><meta property="og:image" content="<%= /^https?:/.test(_ogimg) ? _ogimg : baseUrl + _ogimg %>"><% } %>
<meta name="twitter:card" content="summary_large_image">
<% if (_gsc) { %><meta name="google-site-verification" content="<%= _gsc %>"><% } %>
<% if (_bing) { %><meta name="msvalidate.01" content="<%= _bing %>"><% } %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "<%- (c.company_name||'').replace(/"/g,'\\"') %>",
  "url": "<%= baseUrl %>/",
  "description": "<%- (c.meta_desc||c.tagline||'').replace(/"/g,'\\"') %>",
  "address": "<%- (c.address||'').replace(/"/g,'\\"') %>"<% if (c.phone) { %>,
  "telephone": "<%= c.phone %>"<% } %>
}
</script>
<link rel="stylesheet" href="/css/site.css">
<% if (typeof ga4 !== 'undefined' && ga4) { %>
<script async src="https://www.googletagmanager.com/gtag/js?id=<%= ga4 %>"></script>
<script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','<%= ga4 %>');</script>
<% } %>
<% if (typeof metaPixel !== 'undefined' && metaPixel) { %>
<!-- Meta Pixel (Facebook / Instagram ads) -->
<script>!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','<%= metaPixel %>');fbq('track','PageView');</script>
<noscript><img height="1" width="1" style="display:none" src="https://www.facebook.com/tr?id=<%= metaPixel %>&ev=PageView&noscript=1" alt=""/></noscript>
<% } %>
</head>
<body>
