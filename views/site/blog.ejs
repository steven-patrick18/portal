<%- include('_head', { canonical: '/blog', pageTitle: 'Jeans & Garment Manufacturing Blog — ' + c.company_name, pageDesc: 'Guides and insights on wholesale jeans, denim manufacturing, bulk sourcing and private-label apparel from ' + c.company_name + ' (Firelock), Bihar, India.' }) %>
<%- include('_nav') %>

<section class="page-hero"><div class="wrap">
  <div class="crumb"><a href="/">Home</a> / Blog</div>
  <h1>Jeans &amp; Garment Manufacturing Blog</h1>
  <p>Practical guides on wholesale jeans, denim manufacturing, bulk sourcing, MOQs and private-label apparel — from <%= c.company_name %> (Firelock), a jeans &amp; garment manufacturer, wholesaler and exporter in Bettiah, Bihar, India.</p>
</div></section>

<section class="section"><div class="wrap">
  <% if (posts && posts.length) { %>
    <div class="blog-grid">
      <% posts.forEach(po => { %>
        <a class="bcard" href="/blog/<%= po.slug %>">
          <div class="cover"><% if (po.cover_image) { %><img src="<%= po.cover_image %>" alt="<%= po.title %>"><% } else { %>📝<% } %></div>
          <div class="body">
            <div class="date"><%= po.published_at ? fmtDate(po.published_at + ' 00:00:00') : '' %></div>
            <h3><%= po.title %></h3>
            <p><%= po.excerpt || '' %></p>
            <span class="more">Read more →</span>
          </div>
        </a>
      <% }) %>
    </div>
  <% } else { %>
    <div class="center" style="padding:40px 0;color:var(--muted)">
      <div style="font-size:2.5rem">📝</div>
      <p style="margin-top:10px">No posts yet — check back soon.</p>
    </div>
  <% } %>
</div></section>

<%- include('_footer') %>
