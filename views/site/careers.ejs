<%- include('_head', { canonical: '/careers', pageTitle: 'Careers — ' + c.company_name, pageDesc: 'Join ' + c.company_name + ' — denim & garment manufacturing jobs in Bettiah, Bihar. Washing master, pattern master, fashion designer, tailors & more.' }) %>
<%- include('_nav') %>
<style>
  .cv-overlay{position:fixed;inset:0;background:rgba(15,23,42,.55);z-index:200;display:none;align-items:flex-start;justify-content:center;padding:22px;overflow:auto}
  .cv-overlay.open{display:flex}
  .cv-modal{background:#fff;border-radius:16px;max-width:480px;width:100%;padding:24px;box-shadow:0 24px 60px rgba(15,23,42,.3);margin:auto;position:relative}
  .cv-modal h3{margin:0 0 2px;color:var(--ink);font-size:1.3rem}
  .cv-modal .sub{color:var(--muted);font-size:.85rem;margin-bottom:12px}
  .cv-modal label{display:block;font-size:.8rem;font-weight:700;color:var(--ink2);margin:10px 0 4px}
  .cv-modal input,.cv-modal select{width:100%;border:1px solid var(--line);border-radius:9px;padding:11px 12px;font:inherit;font-size:.95rem;background:#fff}
  .cv-modal input:focus,.cv-modal select:focus{outline:none;border-color:var(--accent);box-shadow:0 0 0 3px rgba(217,83,30,.15)}
  .cv-modal .frow{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .cv-modal .hp{position:absolute;left:-9999px;width:1px;height:1px;overflow:hidden}
  .cv-modal .file{padding:10px 12px;border:1px dashed var(--accent);border-radius:9px;background:var(--soft);cursor:pointer}
  .cv-modal button.submit{margin-top:16px;width:100%;border:0;cursor:pointer}
  .cv-x{position:absolute;top:14px;right:16px;cursor:pointer;font-size:1.5rem;line-height:1;color:var(--muted);background:none;border:0}
  @media(max-width:480px){.cv-modal .frow{grid-template-columns:1fr}}
</style>

<section class="page-hero"><div class="wrap">
  <div class="crumb"><a href="/">Home</a> / Careers</div>
  <h1>Build your career with us</h1>
  <p>We're a growing denim &amp; garment manufacturer and exporter in Bettiah, Bihar — looking for skilled, sincere people who take pride in their craft. On-time salary, a clean workplace and room to grow.</p>
  <button type="button" class="btn" onclick="openApply('', '')">Apply Now</button>
</div></section>

<section class="section"><div class="wrap">
  <% if (sent) { %><div class="notice ok" style="max-width:640px;margin:0 auto 22px"><strong>Thank you!</strong> Your application &amp; CV have been received. Our team will call you if your profile fits.</div><% } %>

  <div class="eyebrow" style="text-align:center">Open Positions</div>
  <h2 style="text-align:center;color:var(--ink);font-size:1.7rem;margin:.3rem 0 1.4rem">We're hiring</h2>

  <% if (!jobs.length) { %>
    <div class="wcard center" style="max-width:560px;margin:0 auto">
      No openings are listed right now — but we're always glad to meet good people.
      <button type="button" class="btn" style="margin-top:12px" onclick="openApply('', '')">Send your CV</button>
    </div>
  <% } else { %>
    <div style="display:grid;gap:16px;grid-template-columns:repeat(auto-fit,minmax(300px,1fr))">
      <% jobs.forEach(j => { %>
        <div class="wcard" style="display:flex;flex-direction:column;gap:8px">
          <div style="display:flex;justify-content:space-between;align-items:start;gap:8px">
            <h3 style="margin:0;color:var(--ink);font-size:1.18rem"><%= j.title %></h3>
            <% if (j.type) { %><span style="flex:none;background:var(--accent);color:#fff;font-size:.7rem;font-weight:700;padding:3px 9px;border-radius:20px"><%= j.type %></span><% } %>
          </div>
          <div class="text-muted" style="color:var(--muted);font-size:.85rem">
            <% if (j.dept) { %><%= j.dept %><% } %><% if (j.location) { %> · 📍 <%= j.location %><% } %>
          </div>
          <% if (j.summary) { %><div style="color:var(--ink);font-size:.93rem"><%= j.summary %></div><% } %>
          <% if (j.requirements) { %><div class="text-muted" style="color:var(--muted);font-size:.85rem"><strong>You need:</strong> <%= j.requirements %></div><% } %>
          <div style="margin-top:auto;padding-top:6px">
            <button type="button" class="btn" onclick="openApply('<%= j.title.replace(/'/g, "\\'") %>', '<%= j.id %>')">Apply for this role →</button>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div></section>

<!-- Apply popup — opens only after clicking Apply -->
<div class="cv-overlay <%= (typeof reopen!=='undefined' && reopen) ? 'open' : '' %>" id="applyModal" onclick="if(event.target===this)closeApply()">
  <div class="cv-modal">
    <button type="button" class="cv-x" onclick="closeApply()" aria-label="Close">&times;</button>
    <h3>Apply</h3>
    <div class="sub">Fill a few details and attach your CV. We'll call you back.</div>
    <% if (typeof formError!=='undefined' && formError) { %><div class="notice err"><%= formError %></div><% } %>
    <form method="post" action="/site/careers/apply" enctype="multipart/form-data">
      <div class="hp" aria-hidden="true"><label>Website</label><input name="website" tabindex="-1" autocomplete="off"></div>
      <input type="hidden" name="job_id" id="job_id">
      <div class="frow">
        <div><label>First name *</label><input name="first_name" required maxlength="80"></div>
        <div><label>Last name *</label><input name="last_name" required maxlength="80"></div>
      </div>
      <div class="frow">
        <div><label>City *</label><input name="location" required maxlength="80" placeholder="Your city"></div>
        <div><label>Phone (WhatsApp) *</label><input name="phone" required maxlength="40"></div>
      </div>
      <label>Email *</label>
      <input name="email" type="email" required maxlength="120" placeholder="you@example.com">
      <label>Applying for</label>
      <select name="role_applied" id="role_applied">
        <option value="">— select a role —</option>
        <% jobs.forEach(j => { %><option value="<%= j.title %>" data-job="<%= j.id %>" <%= prefill===j.title?'selected':'' %>><%= j.title %></option><% }) %>
        <option value="Other" <%= (prefill && !jobs.some(j=>j.title===prefill)) ? 'selected' : '' %>>Other</option>
      </select>
      <label>Upload CV / Resume *</label>
      <input class="file" type="file" name="cv" required accept=".pdf,.doc,.docx,.jpg,.jpeg,.png,.webp">
      <div class="text-muted" style="color:var(--muted);font-size:.75rem;margin-top:4px">PDF, DOC or a clear photo · max 5 MB</div>
      <button class="btn submit">Submit Application</button>
    </form>
    <p class="text-muted" style="color:var(--muted);text-align:center;font-size:.82rem;margin:12px 0 0">
      Prefer WhatsApp? <% if (c.whatsapp) { %><a href="https://wa.me/<%= c.whatsapp.replace(/[^0-9]/g,'') %>?text=<%= encodeURIComponent('Hi '+(c.company_name||'')+', I want to apply for a job.') %>" target="_blank" rel="noopener" style="color:var(--accent);font-weight:700">Message us</a><% } else if (c.phone) { %><a href="tel:<%= c.phone %>" style="color:var(--accent);font-weight:700">Call <%= c.phone %></a><% } %>
    </p>
  </div>
</div>

<script>
  var modal = document.getElementById('applyModal');
  function openApply(role, job){
    var sel=document.getElementById('role_applied'), jid=document.getElementById('job_id');
    if (sel && role){ for (var i=0;i<sel.options.length;i++){ if (sel.options[i].value===role){ sel.selectedIndex=i; break; } } }
    if (jid) jid.value = job || '';
    modal.classList.add('open'); document.body.style.overflow='hidden';
  }
  function closeApply(){ modal.classList.remove('open'); document.body.style.overflow=''; }
  document.addEventListener('keydown', function(e){ if(e.key==='Escape') closeApply(); });
  (function(){ var sel=document.getElementById('role_applied'); if(!sel) return;
    sel.addEventListener('change', function(){ var o=sel.options[sel.selectedIndex]; document.getElementById('job_id').value=(o&&o.getAttribute('data-job'))||''; });
  })();
</script>

<%- include('_footer') %>
