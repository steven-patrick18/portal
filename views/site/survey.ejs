<%- include('_head', { canonical: '/survey/' + survey.slug, pageTitle: survey.title + ' — ' + (c.company_name||'Survey'), pageDesc: survey.description || ('Share your feedback with ' + (c.company_name||'us')) }) %>
<%- include('_nav') %>

<section class="page-hero"><div class="wrap">
  <div class="crumb"><a href="/">Home</a> / Survey</div>
  <h1><%= survey.title %></h1>
  <% if (survey.description) { %><p><%= survey.description %></p><% } %>
</div></section>

<section class="section"><div class="wrap" style="max-width:720px;margin:0 auto">
  <% if (done) { %>
    <div class="wcard center" style="padding:48px 24px">
      <div style="font-size:2.4rem">✅</div>
      <h2 style="margin:.4rem 0"><%= survey.thank_you || 'Thank you for your feedback!' %></h2>
      <p class="text-muted" style="color:var(--muted)">We appreciate you taking the time.</p>
      <a class="btn" href="/">Back to home</a>
    </div>
  <% } else { %>
    <% if (error) { %><div class="wcard" style="border-color:#dc3545;color:#dc3545;margin-bottom:16px;padding:12px 16px"><%= error %></div><% } %>
    <form method="post" action="/survey/<%= survey.slug %>" class="wcard" style="padding:22px 24px">
      <input type="hidden" name="source" value="<%= source %>">
      <div style="position:absolute;left:-9999px"><label>Website<input name="website" tabindex="-1" autocomplete="off"></label></div>

      <div class="row" style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:18px">
        <div style="flex:1;min-width:200px"><label class="fld-label">Your name <span class="text-muted" style="color:var(--muted)">(optional)</span></label>
          <input name="resp_name" class="fld" placeholder="Shop / your name"></div>
        <div style="flex:1;min-width:200px"><label class="fld-label">Phone <span class="text-muted" style="color:var(--muted)">(optional)</span></label>
          <input name="resp_phone" class="fld" placeholder="10-digit mobile"></div>
      </div>

      <% questions.forEach((q, i) => { %>
        <div style="margin-bottom:20px">
          <label class="fld-label" style="font-weight:600"><%= i+1 %>. <%= q.qtext %><% if (q.required) { %> <span style="color:#dc3545">*</span><% } %></label>

          <% if (q.qtype === 'rating') { %>
            <div style="display:flex;gap:14px;margin-top:6px">
              <% [1,2,3,4,5].forEach(n => { %><label style="cursor:pointer"><input type="radio" name="q_<%= q.id %>" value="<%= n %>" <%= q.required?'required':'' %>> <%= n %>★</label><% }) %>
            </div>
          <% } else if (q.qtype === 'nps') { %>
            <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:6px">
              <% for (let n=0;n<=10;n++) { %><label style="cursor:pointer;border:1px solid var(--line,#ddd);border-radius:6px;padding:4px 9px"><input type="radio" name="q_<%= q.id %>" value="<%= n %>" <%= q.required?'required':'' %> style="display:none" onclick="this.closest('label').style.background='var(--accent)';this.closest('label').style.color='#fff'"><%= n %></label><% } %>
            </div>
            <div class="text-muted" style="color:var(--muted);font-size:.8rem;margin-top:4px">0 = not likely · 10 = very likely</div>
          <% } else if (q.qtype === 'yesno') { %>
            <div style="display:flex;gap:18px;margin-top:6px">
              <label style="cursor:pointer"><input type="radio" name="q_<%= q.id %>" value="Yes" <%= q.required?'required':'' %>> Yes</label>
              <label style="cursor:pointer"><input type="radio" name="q_<%= q.id %>" value="No"> No</label>
            </div>
          <% } else if (q.qtype === 'single') { %>
            <div style="margin-top:6px">
              <% q.options.forEach(o => { %><label style="display:block;cursor:pointer;margin:4px 0"><input type="radio" name="q_<%= q.id %>" value="<%= o %>" <%= q.required?'required':'' %>> <%= o %></label><% }) %>
            </div>
          <% } else if (q.qtype === 'multi') { %>
            <div style="margin-top:6px">
              <% q.options.forEach(o => { %><label style="display:block;cursor:pointer;margin:4px 0"><input type="checkbox" name="q_<%= q.id %>" value="<%= o %>"> <%= o %></label><% }) %>
            </div>
          <% } else { %>
            <textarea name="q_<%= q.id %>" class="fld" rows="3" <%= q.required?'required':'' %> placeholder="Type your answer…"></textarea>
          <% } %>
        </div>
      <% }) %>

      <button class="btn" type="submit" style="width:100%">Submit feedback</button>
      <p class="text-muted" style="color:var(--muted);font-size:.78rem;text-align:center;margin-top:10px">Your response goes directly to <%= c.company_name || 'us' %>.</p>
    </form>
  <% } %>
</div></section>

<style>
  .fld-label{display:block;font-size:.9rem;margin-bottom:4px}
  .fld{width:100%;padding:10px 12px;border:1px solid var(--line,#ddd);border-radius:8px;font-size:.95rem;font-family:inherit}
</style>
<%- include('_footer') %>
