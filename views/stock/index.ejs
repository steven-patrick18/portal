<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <h4 class="m-0">Ready Stock</h4>
  <div class="d-flex gap-2 flex-wrap">
    <% if (user.role === 'owner') { %>
      <a href="/stock/export.csv" class="btn btn-sm btn-outline-secondary" title="Download current stock as CSV"><i class="bi bi-download"></i> Export</a>
      <a href="/stock/import" class="btn btn-sm btn-outline-secondary" title="Upload CSV to bulk-update stock quantities"><i class="bi bi-upload"></i> Import</a>
    <% } %>
    <a href="/stock/movements" class="btn btn-sm btn-outline-secondary"><i class="bi bi-clock-history"></i> Movements</a>
    <button onclick="window.print()" class="btn btn-sm btn-outline-secondary" title="Print this stock list"><i class="bi bi-printer"></i> Print</button>
  </div>
</div>

<div class="print-only mb-3">
  <div style="font-size:16pt;font-weight:800;border-bottom:2px solid #000;padding-bottom:4px;margin-bottom:6px"><%= companyName %> · Ready Stock</div>
  <div style="font-size:10pt;color:#444">
    <strong>SKUs:</strong> <%= items.length %> · <strong>Total quantity:</strong> <%= totalQty %> pcs · <strong>Stock value:</strong> <%= fmtINR(totalValue) %>
    · Generated <%= fmtDateTime(new Date().toISOString().replace('T',' ').slice(0,19)) %>
  </div>
</div>
<div class="row g-3 mb-3">
  <div class="col-md-3 col-6"><a class="card-link" href="/products"><div class="kpi-card kpi-denim">
    <i class="bi bi-box-seam kpi-icon"></i>
    <div class="kpi-label">Total SKUs</div><div class="kpi-value"><%= items.length %></div>
    <i class="bi bi-arrow-right kpi-arrow"></i>
  </div></a></div>
  <div class="col-md-3 col-6"><a class="card-link" href="/reports/stock"><div class="kpi-card kpi-emerald">
    <i class="bi bi-archive kpi-icon"></i>
    <div class="kpi-label">Total Quantity (pcs)</div><div class="kpi-value"><%= totalQty %></div>
    <small style="font-size:.7rem;opacity:.8">Bundles excluded — variants count once</small>
    <i class="bi bi-arrow-right kpi-arrow"></i>
  </div></a></div>
  <div class="col-md-3 col-6"><a class="card-link" href="/reports/stock"><div class="kpi-card kpi-teal">
    <i class="bi bi-currency-rupee kpi-icon"></i>
    <div class="kpi-label">Stock Value (cost)</div><div class="kpi-value"><%= fmtINR(totalValue) %></div>
    <small style="font-size:.7rem;opacity:.8">Bundles excluded (no double-count)</small>
    <i class="bi bi-arrow-right kpi-arrow"></i>
  </div></a></div>
  <div class="col-md-3 col-6"><a class="card-link" href="/stock/movements"><div class="kpi-card kpi-coral">
    <i class="bi bi-exclamation-octagon kpi-icon"></i>
    <div class="kpi-label">Low Stock Items</div><div class="kpi-value"><%= items.filter(i => i.reorder_level && i.quantity <= i.reorder_level).length %></div>
    <i class="bi bi-arrow-right kpi-arrow"></i>
  </div></a></div>
</div>
<%
  function stChipUrl(stockVal) {
    return '/stock' + (stockVal ? '?stock=' + stockVal : '');
  }
%>
<div class="d-flex flex-wrap gap-2 mb-3 align-items-center">
  <span class="small text-muted me-1">Stock:</span>
  <a href="<%= stChipUrl('') %>"          class="btn btn-sm <%= !stockFilter ? 'btn-primary' : 'btn-outline-secondary' %>">All <span class="badge bg-light text-dark ms-1"><%= counts.total || 0 %></span></a>
  <a href="<%= stChipUrl('available') %>" class="btn btn-sm <%= stockFilter==='available' ? 'btn-success' : 'btn-outline-success' %>"><i class="bi bi-check-circle"></i> Available <span class="badge bg-light text-success ms-1"><%= counts.available || 0 %></span></a>
  <a href="<%= stChipUrl('out') %>"       class="btn btn-sm <%= stockFilter==='out' ? 'btn-danger' : 'btn-outline-danger' %>"><i class="bi bi-x-circle"></i> Out of stock <span class="badge bg-light text-danger ms-1"><%= counts.out || 0 %></span></a>
</div>

<div class="card"><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>Code</th><th>Product</th><th>Size</th><th>Color</th><th class="text-end">Qty</th><th class="text-end" title="For bundles: qty × pieces-per-bundle">Total Pcs</th><th class="text-end">Reorder</th><th class="text-end">Cost</th><th class="text-end" title="For bundles: bundle qty × pieces-per-bundle × cost">Value</th><th></th></tr></thead><tbody>
<% items.forEach(i => { %>
<tr class="<%= i.reorder_level && i.quantity <= i.reorder_level ? 'table-warning' : '' %> <%= i.is_bundle_sku ? 'table-info' : '' %>">
<td>
  <a href="/stock/product/<%= i.id %>" class="text-decoration-none"><%= i.code %></a>
  <% if (i.is_bundle_sku) { %><span class="badge bg-info text-dark" style="font-size:.6rem">BUNDLE × <%= i.pieces_per_bundle %></span><% } %>
</td>
<td><a href="/stock/product/<%= i.id %>" class="text-decoration-none"><%= i.name %></a></td>
<td><%= i.size||'-' %></td><td><%= i.color||'-' %></td>
<td class="text-end">
  <%= i.quantity %>
  <% if (i.is_bundle_sku) { %><small class="text-muted">bdl</small><% } %>
</td>
<td class="text-end fw-semibold"><%= i.total_pieces %><% if (i.is_bundle_sku) { %> <small class="text-muted">pcs</small><% } %></td>
<td class="text-end"><%= i.reorder_level %></td>
<td class="text-end"><%= fmtINR(i.cost_price) %></td>
<td class="text-end"><%= fmtINR(i.value) %></td>
<td>
  <a href="/stock/product/<%= i.id %>" class="btn btn-sm btn-primary" title="View pieces"><i class="bi bi-arrow-right"></i></a>
  <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#adj-<%= i.id %>">Adjust</button>
</td>
</tr>
<div class="modal fade" id="adj-<%= i.id %>"><div class="modal-dialog"><div class="modal-content"><form method="post" action="/stock/adjust">
<div class="modal-header"><h5 class="modal-title">Adjust Stock - <%= i.name %></h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
<div class="modal-body">
<input type="hidden" name="product_id" value="<%= i.id %>">
<div class="mb-2"><label class="form-label">Set Quantity To</label><input name="quantity" type="number" class="form-control" required value="<%= i.quantity %>"></div>
<div class="mb-2"><label class="form-label">Reason / Notes</label><input name="notes" class="form-control" required></div>
</div>
<div class="modal-footer"><button class="btn btn-primary">Save</button></div>
</form></div></div></div>
<% }) %>
<% if (items.length===0) { %><tr><td colspan="10" class="text-muted text-center">No products yet</td></tr><% } %>
</tbody></table></div></div>
<%- include('../partials/footer') %>
