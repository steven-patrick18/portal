<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0">Stock Movements</h4>
  <a href="/stock" class="btn btn-sm btn-outline-secondary">← Back to Stock</a>
</div>
<div class="card"><div class="table-responsive">
<table class="table table-sm m-0"><thead><tr><th>Date</th><th>Product</th><th>Type</th><th class="text-end">Qty</th><th>Ref</th><th>By</th><th>Notes</th></tr></thead><tbody>
<% items.forEach(i => { %>
<tr><td><%= fmtDate(i.created_at) %></td><td><%= i.product_code %> · <%= i.product_name %></td>
<td><span class="badge bg-<%= i.movement_type==='production_in'||i.movement_type==='return_in'?'success':'danger' %>"><%= i.movement_type %></span></td>
<td class="text-end"><%= i.quantity %></td><td><%= (i.ref_table||'') + (i.ref_id?' #'+i.ref_id:'') %></td>
<td><%= i.by_name||'-' %></td><td><%= i.notes||'-' %></td></tr>
<% }) %>
<% if (items.length===0) { %><tr><td colspan="7" class="text-muted text-center">No movements yet</td></tr><% } %>
</tbody></table></div></div>
<%- include('../partials/footer') %>
