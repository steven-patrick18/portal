<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <a href="/stock/product/<%= p.id %>" class="text-decoration-none small text-muted">← Batches for <%= p.name %></a>
    <h4 class="m-0 mt-1">
      <%= batch ? batch.batch_no : 'Legacy Stock' %> · <%= p.name %>
    </h4>
    <small class="text-muted">
      Size: <%= p.size || '-' %> · Color: <%= p.color || '-' %>
      <% if (batch) { %> · Started <%= fmtDate(batch.start_date) %><% } %>
    </small>
  </div>
  <div class="btn-group btn-group-sm">
    <a class="btn btn-outline-secondary <%= status==='all'?'active':'' %>" href="?status=all">All (<%= pieces.length %>)</a>
    <a class="btn btn-outline-secondary <%= status==='in_stock'?'active':'' %>" href="?status=in_stock">In Stock</a>
    <a class="btn btn-outline-secondary <%= status==='sold'?'active':'' %>" href="?status=sold">Sold</a>
    <a class="btn btn-outline-secondary <%= status==='returned'?'active':'' %>" href="?status=returned">Returned</a>
  </div>
</div>

<div class="card">
  <div class="card-header"><i class="bi bi-collection"></i> Individual Pieces (each with unique code)</div>
  <div class="table-responsive">
    <table class="table table-sm m-0">
      <thead><tr><th>Piece Code</th><th>Status</th><th>Cost / Piece</th><th>Sold To</th><th>Invoice</th><th>Created</th><th>Sold On</th><th>Notes</th></tr></thead>
      <tbody>
        <% pieces.forEach(p => { %>
          <tr>
            <td><code style="font-size:.85rem; background: var(--denim-50); color: var(--denim-700); padding: 3px 8px; border-radius: 4px;"><%= p.piece_code %></code></td>
            <td>
              <% if (p.status === 'in_stock')   { %><span class="badge bg-success">In Stock</span>
              <% } else if (p.status === 'sold') { %><span class="badge bg-primary">Sold</span>
              <% } else if (p.status === 'returned') { %><span class="badge bg-warning">Returned</span>
              <% } else if (p.status === 'dispatched') { %><span class="badge bg-info">Dispatched</span>
              <% } else { %><span class="badge bg-secondary"><%= p.status %></span><% } %>
            </td>
            <td><%= fmtINR(p.cost_per_piece || 0) %></td>
            <td><%= p.dealer_name || '-' %></td>
            <td><% if (p.invoice_no) { %><a href="/invoices/<%= p.invoice_id %>"><%= p.invoice_no %></a><% } else { %>-<% } %></td>
            <td class="small text-muted"><%= fmtDate(p.created_at) %></td>
            <td class="small text-muted"><%= p.sold_at ? fmtDate(p.sold_at) : '-' %></td>
            <td class="small text-muted"><%= p.notes || '-' %></td>
          </tr>
        <% }) %>
        <% if (pieces.length === 0) { %><tr><td colspan="8" class="text-muted text-center py-4">No pieces match this filter</td></tr><% } %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
