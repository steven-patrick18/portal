<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <h4 class="m-0">Suppliers</h4>
  <div class="d-flex gap-2 flex-wrap">
    <form class="d-flex gap-1">
      <div class="input-group input-group-sm" style="width:260px">
        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
        <input name="q" value="<%= typeof q !== 'undefined' ? q : '' %>" class="form-control form-control-sm" placeholder="Name, contact, phone, GSTIN...">
        <% if (typeof q !== 'undefined' && q) { %>
          <a href="/suppliers" class="btn btn-outline-secondary" title="Clear">×</a>
        <% } %>
      </div>
    </form>
    <a href="/suppliers/new" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New</a>
  </div>
</div>
<% if (typeof q !== 'undefined' && q) { %>
  <div class="small text-muted mb-2">Searching "<strong><%= q %></strong>" — <%= items.length %> result<%= items.length===1?'':'s' %>.</div>
<% } %>
<div class="card"><div class="table-responsive">
<table class="table table-sm m-0">
<thead><tr><th>#</th><th>Name</th><th>Contact</th><th>Phone</th><th>GSTIN</th><th>City</th><th></th></tr></thead><tbody>
<% items.forEach(s => { %>
<tr><td><%= s.id %></td><td><%= s.name %></td><td><%= s.contact_person||'-' %></td><td><%= s.phone||'-' %></td><td><%= s.gstin||'-' %></td><td><%= s.address||'-' %></td><td><a href="/suppliers/<%= s.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a></td></tr>
<% }) %>
<% if (items.length===0) { %><tr><td colspan="7" class="text-muted text-center">No suppliers yet</td></tr><% } %>
</tbody></table>
</div></div>
<%- include('../partials/footer') %>
