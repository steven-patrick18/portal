<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h4 class="m-0">Users</h4>
  <a href="/users/new" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> New User</a>
</div>
<div class="card">
  <div class="table-responsive">
    <table class="table table-sm m-0">
      <thead><tr><th>#</th><th>Name</th><th>Email</th><th>Phone</th><th>Role</th><th>Reports To</th><th>Home Office</th><th>Active</th><th></th></tr></thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr>
            <td><%= u.id %></td>
            <td><%= u.name %></td>
            <td><%= u.email %></td>
            <td><%= u.phone || '-' %></td>
            <td><span class="badge bg-secondary badge-role"><%= u.role %></span></td>
            <td class="text-muted"><%= u.manager_name || '—' %></td>
            <td class="text-muted small">
              <% if (u.home_office_name) { %><%= u.home_office_name %><% if (u.home_office_city) { %> <span class="text-muted">· <%= u.home_office_city %></span><% } %><% } else { %>—<% } %>
            </td>
            <td><%= u.active ? 'Yes' : 'No' %></td>
            <td>
              <% if (u.role === 'owner' && user && user.role !== 'owner') { %>
                <span class="text-muted small" title="Only the owner can edit owner accounts">🔒 Owner-only</span>
              <% } else { %>
                <a href="/users/<%= u.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>
