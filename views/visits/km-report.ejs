<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2 d-print-none">
  <div>
    <h4 class="m-0">KM Report</h4>
    <small class="text-muted">Auto-calculated from each salesperson's geo-tagged visits. Sum of straight-line distance between consecutive stops, per day.</small>
  </div>
  <div class="d-flex gap-2 align-items-center">
    <form class="d-flex gap-2 align-items-center flex-wrap">
      <label class="small text-muted m-0">From</label>
      <input type="date" name="from" value="<%= from %>" class="form-control form-control-sm" style="width:150px">
      <label class="small text-muted m-0">To</label>
      <input type="date" name="to" value="<%= to %>" class="form-control form-control-sm" style="width:150px">
      <% if (visibleOffices && visibleOffices.length) { %>
        <select name="office" class="form-select form-select-sm" title="Filter by salesperson's home office">
          <option value="">All offices</option>
          <% visibleOffices.forEach(o => { %>
            <option value="<%= o.id %>" <%= officeFilter === o.id ? 'selected' : '' %>>
              <% if (o.type === 'factory')   { %>🏭<% } %>
              <% if (o.type === 'office')    { %>🏢<% } %>
              <% if (o.type === 'warehouse') { %>📦<% } %>
              <%= o.name %>
            </option>
          <% }) %>
        </select>
      <% } %>
      <button class="btn btn-sm btn-outline-primary">Filter</button>
      <!-- Quick range chips: tap to set common ranges without typing -->
      <div class="btn-group btn-group-sm" role="group">
        <button type="button" class="btn btn-outline-secondary" data-range="today">Today</button>
        <button type="button" class="btn btn-outline-secondary" data-range="week">This week</button>
        <button type="button" class="btn btn-outline-secondary" data-range="month">This month</button>
        <button type="button" class="btn btn-outline-secondary" data-range="last7">Last 7d</button>
        <button type="button" class="btn btn-outline-secondary" data-range="last30">Last 30d</button>
      </div>
    </form>
    <a href="/visits" class="btn btn-sm btn-outline-secondary">All visits</a>
    <a href="/hr/km" class="btn btn-sm btn-outline-secondary">HR Mileage log</a>
    <button onclick="window.print()" class="btn btn-sm btn-outline-secondary" title="Print this KM report"><i class="bi bi-printer"></i> Print</button>
  </div>
</div>

<div class="print-zone">
<div class="print-only mb-3">
  <div style="font-size:16pt;font-weight:800;border-bottom:2px solid #000;padding-bottom:4px;margin-bottom:6px"><%= companyName %> · KM Report</div>
  <div style="font-size:10pt;color:#444">
    <strong>Period:</strong> <%= from %> → <%= to %>
    <% if (officeName) { %> · <strong>Office:</strong> <%= officeName %><% } %>
    · <strong>Rows:</strong> <%= rows.length %>
    · Generated <%= fmtDateTime(new Date().toISOString().replace('T',' ').slice(0,19)) %>
  </div>
</div>

<% if (Object.keys(totals).length > 0) { %>
<div class="row g-3 mb-3">
  <% Object.keys(totals).forEach(sp => { %>
    <div class="col-md-3 col-6"><div class="kpi-card kpi-denim" style="padding:.9rem 1.1rem !important">
      <i class="bi bi-person-walking kpi-icon"></i>
      <div class="kpi-label" style="font-size:.7rem"><%= sp %></div>
      <div class="kpi-value" style="font-size:1.4rem"><%= totals[sp].km.toFixed(2) %> km</div>
      <div style="font-size:.78rem;opacity:.85"><%= totals[sp].days %> day<%= totals[sp].days===1?'':'s' %> · <%= totals[sp].visits %> visit<%= totals[sp].visits===1?'':'s' %></div>
    </div></div>
  <% }) %>
</div>
<% } %>

<div class="card"><div class="table-responsive">
<table class="table table-sm m-0">
<thead><tr>
  <th>Date</th><th>Salesperson</th><th class="text-end">Visits</th>
  <th class="text-center" title="Factory In photo logged">F-In</th>
  <th class="text-center" title="Factory Out photo logged">F-Out</th>
  <th class="text-end">KM</th>
  <th>First → Last</th>
  <th>Status</th>
  <th class="d-print-none"></th>
</tr></thead>
<tbody>
<% rows.forEach(r => { %>
<tr>
  <td><%= r.date %></td>
  <td><%= r.sp_name %></td>
  <td class="text-end"><%= r.visits %></td>
  <td class="text-center"><% if (r.factory_in)  { %><span class="text-success">✓</span><% } else { %><span class="text-muted">—</span><% } %></td>
  <td class="text-center"><% if (r.factory_out) { %><span class="text-success">✓</span><% } else { %><span class="text-muted">—</span><% } %></td>
  <td class="text-end">
    <a href="/visits/km/path/<%= r.salesperson_id %>/<%= r.date %>" target="_blank"
       class="text-decoration-none" title="Open the day's route on a map (new tab)">
      <strong><%= r.km %></strong> km <i class="bi bi-box-arrow-up-right small text-muted"></i>
    </a>
  </td>
  <td class="small text-muted"><%= r.first_where %><% if (r.first_where !== r.last_where) { %> → <%= r.last_where %><% } %></td>
  <td>
    <% if (r.already_synced) { %>
      <span class="badge bg-success">✓ in HR (₹<%= r.synced_amount.toFixed(2) %>)</span>
    <% } else if (!r.employee_id) { %>
      <span class="badge bg-secondary" title="No employee record linked to this salesperson">no employee</span>
    <% } else if (!r.km_rate) { %>
      <span class="badge bg-warning text-dark" title="Set km_rate in HR → Employees">no rate</span>
    <% } else if (parseFloat(r.km) === 0) { %>
      <span class="badge bg-light text-muted">0 km — only 1 visit</span>
    <% } else { %>
      <span class="badge bg-secondary">pending</span>
    <% } %>
  </td>
  <td class="d-print-none">
    <% if (!r.already_synced && r.employee_id && r.km_rate && parseFloat(r.km) > 0) { %>
      <form method="post" action="/visits/km/sync" class="m-0" data-confirm="Add <%= r.km %> km × ₹<%= r.km_rate %> = ₹<%= (parseFloat(r.km) * r.km_rate).toFixed(2) %> to HR Mileage log for <%= r.sp_name %> on <%= r.date %>?">
        <input type="hidden" name="salesperson_id" value="<%= r.salesperson_id %>">
        <input type="hidden" name="date" value="<%= r.date %>">
        <input type="hidden" name="km" value="<%= r.km %>">
        <button class="btn btn-sm btn-outline-success"><i class="bi bi-arrow-up-right"></i> Save to HR</button>
      </form>
    <% } %>
  </td>
</tr>
<% }) %>
<% if (rows.length === 0) { %><tr><td colspan="9" class="text-muted text-center">No visits in this date range.</td></tr><% } %>
</tbody></table></div></div>

<div class="card p-3 mt-3 d-print-none" style="max-width:840px">
  <h6 class="mb-2"><i class="bi bi-info-circle text-info"></i> How this works</h6>
  <ul class="small mb-0">
    <li>For each salesperson, all their geo-tagged visits on a given day are sorted by time.</li>
    <li>If the salesperson tapped <strong>Factory In</strong> in the morning, that's prepended; if they tapped <strong>Factory Out</strong>, it's appended. So km = factory → visit 1 → … → visit N → factory.</li>
    <li>Distance for the day = sum of straight-line distances between consecutive stops (Haversine).</li>
    <li>This <strong>under-counts</strong> the actual road distance (because roads aren't straight) — it's a conservative floor, not an exact odometer reading.</li>
    <li><strong>"Save to HR"</strong> creates an entry in HR → Mileage with <code>km × km_rate = amount</code>, tagged <code>[auto from visits]</code> so duplicates can't sneak in.</li>
    <li>The salesperson must have an employee record (HR → Employees) linked to their user account, with a <strong>per-km rate</strong> set, before "Save to HR" appears.</li>
  </ul>
</div>
</div><!-- /.print-zone -->

<script>
// ── Quick-range chips ─────────────────────────────────────────
// Tap "Today" / "This week" / "This month" / "Last 7d" / "Last 30d"
// to populate from + to with sensible defaults, then auto-submit
// the filter form so the report reloads.
(function () {
  function ymd(d) {
    const y = d.getFullYear(), m = String(d.getMonth()+1).padStart(2,'0'), day = String(d.getDate()).padStart(2,'0');
    return y + '-' + m + '-' + day;
  }
  document.querySelectorAll('button[data-range]').forEach(btn => {
    btn.addEventListener('click', () => {
      const today = new Date();
      let from = new Date(today), to = new Date(today);
      switch (btn.dataset.range) {
        case 'today':  /* both = today */ break;
        case 'week': {
          // ISO-ish "this week" = Monday → today
          const dow = (today.getDay() + 6) % 7;     // 0 = Mon ... 6 = Sun
          from.setDate(today.getDate() - dow);
          break;
        }
        case 'month':  from = new Date(today.getFullYear(), today.getMonth(), 1); break;
        case 'last7':  from.setDate(today.getDate() - 6); break;
        case 'last30': from.setDate(today.getDate() - 29); break;
      }
      const form = btn.closest('form');
      form.querySelector('input[name="from"]').value = ymd(from);
      form.querySelector('input[name="to"]').value   = ymd(to);
      form.submit();
    });
  });
})();
</script>

<%- include('../partials/footer') %>
