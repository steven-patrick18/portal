<%- include('../partials/header') %>
<style>
  .map-stage { display: grid; grid-template-columns: 1fr 320px; gap: 1rem; }
  @media (max-width: 992px) { .map-stage { grid-template-columns: 1fr; } }
  #visits-map { height: calc(100vh - 240px); min-height: 460px; border-radius: var(--radius); border: 1px solid var(--hairline); }
  .legend-dot { display:inline-block; width:12px; height:12px; border-radius:50%; vertical-align:middle; margin-right:6px; box-shadow: 0 0 0 1px rgba(0,0,0,.1); }
  .map-side { display: flex; flex-direction: column; gap: 1rem; }
  .map-side .card { margin: 0; }
  .legend-row { padding: 4px 0; border-bottom: 1px dashed var(--hairline); display: flex; justify-content: space-between; align-items: center; gap: 8px; }
  .legend-row:last-child { border-bottom: none; }
  .legend-row .count { font-size: .75rem; color: var(--ink-soft); }
  .coverage-row { display: flex; justify-content: space-between; align-items: baseline; padding: 4px 0; border-bottom: 1px dashed var(--hairline); }
  .coverage-row:last-child { border-bottom: none; }
  .coverage-row .bar { height: 4px; background: linear-gradient(90deg, #1e3a8a, #b45309); border-radius: 2px; }
</style>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-geo-alt-fill"></i> Visit Map · Coverage</h4>
    <small class="text-muted"><%= from %> → <%= to %> · <%= items.length %> visit<%= items.length===1?'':'s' %> across <%= coverageRows.length %> cit<%= coverageRows.length===1?'y':'ies' %> · <strong><%= stores.length %></strong> store<%= stores.length===1?'':'s' %> located</small>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <a href="/visits" class="btn btn-sm btn-outline-secondary">List view</a>
    <a href="/visits/new" class="btn btn-sm btn-primary"><i class="bi bi-plus"></i> New Visit</a>
  </div>
</div>

<!-- Filters bar -->
<form method="get" class="card p-2 mb-3">
  <div class="row g-2 align-items-end">
    <div class="col-md-2">
      <label class="form-label small mb-1">From</label>
      <input type="date" name="from" value="<%= from %>" class="form-control form-control-sm">
    </div>
    <div class="col-md-2">
      <label class="form-label small mb-1">To</label>
      <input type="date" name="to" value="<%= to %>" class="form-control form-control-sm">
    </div>
    <div class="col-md-3">
      <label class="form-label small mb-1">Salesperson</label>
      <select name="sp" class="form-select form-select-sm">
        <option value="">All salespersons</option>
        <% salespersons.forEach(s => { %>
          <option value="<%= s.id %>" <%= spFilter && parseInt(spFilter) === s.id ? 'selected' : '' %>>
            <%= s.name %> · <%= s.visit_count %> visit<%= s.visit_count===1?'':'s' %>
          </option>
        <% }) %>
      </select>
    </div>
    <% if (visibleOfficeList && visibleOfficeList.length) { %>
    <div class="col-md-3">
      <label class="form-label small mb-1">Office</label>
      <select name="office" class="form-select form-select-sm">
        <option value="">All offices</option>
        <% visibleOfficeList.forEach(o => { %>
          <option value="<%= o.id %>" <%= officeFilter === o.id ? 'selected' : '' %>>
            <% if (o.type === 'factory')   { %>🏭<% } %>
            <% if (o.type === 'office')    { %>🏢<% } %>
            <% if (o.type === 'warehouse') { %>📦<% } %>
            <%= o.name %><% if (o.city) { %> · <%= o.city %><% } %>
          </option>
        <% }) %>
      </select>
    </div>
    <% } %>
    <div class="col-md-2 d-flex gap-1">
      <button class="btn btn-primary btn-sm flex-grow-1"><i class="bi bi-funnel"></i> Apply</button>
      <a href="/visits/map/recent" class="btn btn-outline-secondary btn-sm" title="Reset to last 7 days">×</a>
    </div>
    <div class="col-md-3 d-flex gap-1 justify-content-end">
      <a href="?from=<%= new Date(Date.now()-7*86400000).toISOString().slice(0,10) %>&to=<%= to %><%= spFilter ? '&sp=' + spFilter : '' %>" class="btn btn-outline-secondary btn-sm">7d</a>
      <a href="?from=<%= new Date(Date.now()-30*86400000).toISOString().slice(0,10) %>&to=<%= to %><%= spFilter ? '&sp=' + spFilter : '' %>" class="btn btn-outline-secondary btn-sm">30d</a>
      <a href="?from=<%= new Date(Date.now()-90*86400000).toISOString().slice(0,10) %>&to=<%= to %><%= spFilter ? '&sp=' + spFilter : '' %>" class="btn btn-outline-secondary btn-sm">90d</a>
      <a href="?from=<%= new Date(new Date().getFullYear(), 0, 1).toISOString().slice(0,10) %>&to=<%= to %><%= spFilter ? '&sp=' + spFilter : '' %>" class="btn btn-outline-secondary btn-sm">YTD</a>
    </div>
  </div>
</form>

<% if (items.length === 0 && stores.length === 0) { %>
  <div class="card p-5 text-center text-muted">
    <i class="bi bi-geo" style="font-size:2.4rem"></i>
    <div class="mt-2">No visits in the selected range / filter. <a href="/visits/new">Log one</a>.</div>
  </div>
<% } else { %>
<!-- Map layer toggles. Visits = activity-this-period. Stores = "where dealer
     shops are physically located" (captured from the most-recent visit per
     dealer). Stores don't change with the date range; they're persistent. -->
<div class="d-flex flex-wrap gap-2 mb-2 align-items-center">
  <span class="small text-muted me-1">Layers:</span>
  <button type="button" id="layer-visits" class="btn btn-sm btn-primary" data-on="1">
    <i class="bi bi-geo-fill"></i> Visits <span class="badge bg-light text-dark ms-1"><%= items.length %></span>
  </button>
  <button type="button" id="layer-stores" class="btn btn-sm btn-outline-info" data-on="0">
    <i class="bi bi-shop"></i> Stores <span class="badge bg-light text-dark ms-1"><%= stores.length %></span>
  </button>
  <% if (offices && offices.length) { %>
  <button type="button" id="layer-offices" class="btn btn-sm btn-success" data-on="1">
    <i class="bi bi-building"></i> Offices <span class="badge bg-light text-dark ms-1"><%= offices.length %></span>
  </button>
  <% } %>
  <span class="small text-muted ms-2">
    <%= dealerCoverage.located %> / <%= dealerCoverage.total_dealers %> dealer<%= dealerCoverage.total_dealers===1?'':'s' %> physically located<% if (dealerCoverage.total_dealers > 0) { %>
      (<%= Math.round(dealerCoverage.located * 100 / Math.max(dealerCoverage.total_dealers, 1)) %>%)
    <% } %>
  </span>
</div>
<div class="map-stage">
  <div id="visits-map"></div>
  <aside class="map-side">
    <!-- Salesperson legend -->
    <div class="card">
      <div class="card-header"><i class="bi bi-people"></i> Salespersons in view</div>
      <div class="card-body py-2" id="sp-legend">
        <!-- filled by JS -->
      </div>
    </div>

    <!-- Coverage / expansion -->
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-map"></i> Coverage by city</span>
        <span class="badge bg-info text-dark"><%= coverageRows.length %> cit<%= coverageRows.length===1?'y':'ies' %></span>
      </div>
      <div class="card-body py-2" style="max-height:260px;overflow-y:auto">
        <%
          // Use the largest non-missing-city row as the scale baseline so
          // the bars compare real geographies, not the "City not set" bucket.
          const realRows = coverageRows.filter(c => !c.missing);
          const maxVisits = realRows.length ? realRows[0].visits : (coverageRows[0] ? coverageRows[0].visits : 1);
          coverageRows.forEach(c => {
            const pct = Math.round((c.visits * 100) / Math.max(maxVisits, 1));
        %>
          <div class="coverage-row">
            <div style="flex:1;min-width:0">
              <div style="font-weight:600;color: <%= c.missing ? 'var(--coral-600)' : 'var(--ink)' %>">
                <% if (c.missing) { %><i class="bi bi-exclamation-triangle-fill"></i> <% } %><%= c.city %>
              </div>
              <div class="bar" style="width: <%= pct %>%; max-width: 100%; margin-top:3px; <%= c.missing ? 'background: linear-gradient(90deg, #be123c, #f59e0b)' : '' %>"></div>
              <div class="small text-muted"><%= c.visits %> visits · <%= c.dealers %> existing · <%= c.prospects %> prospect<%= c.prospects===1?'':'s' %></div>
            </div>
          </div>
        <% }) %>
        <% if (coverageRows.length === 0) { %>
          <div class="small text-muted text-center py-2">No coverage data.</div>
        <% } %>
      </div>
      <% if (missingCityCount > 0) { %>
        <div class="card-footer py-2 small" style="background:#fef2f2;border-top:1px solid #fecaca">
          <i class="bi bi-info-circle"></i>
          <strong><%= missingCityCount %> visit<%= missingCityCount===1?'':'s' %></strong> in <strong>City not set</strong> — those dealers don't have a city filled in.
          <a href="/dealers" class="ms-1">Edit dealers</a> and add their city to put them on the right line.
        </div>
      <% } %>
    </div>

    <!-- Expansion hint -->
    <div class="card" style="background:linear-gradient(135deg,#fffbeb,#fff)">
      <div class="card-body py-2 small">
        <strong><i class="bi bi-stars"></i> Expansion tip</strong>
        <div class="mt-1 text-muted">
          Clusters of pins = strong presence. Sparse / isolated pins = exploration zones.
          Switch the salesperson dropdown to see who's covering which corridor.
        </div>
      </div>
    </div>
  </aside>
</div>
<% } %>

<!-- Leaflet from jsdelivr (only CDN allowed by our CSP, see src/app.js) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css">
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
  const visits = <%- JSON.stringify(items.map(i => ({
    id: i.id, no: i.visit_no, lat: i.lat, lng: i.lng,
    sp_id: i.salesperson_id, sp: i.sp_name,
    when: i.when_ist, dealer: i.dealer_name, city: i.dealer_city || i.prospect_city,
    prospect_name: i.prospect_name, prospect_shop: i.prospect_shop,
    type: i.visit_type, photo: i.photo_path
  }))) %>;
  const stores = <%- JSON.stringify(stores.map(s => ({
    id: s.id, code: s.code, name: s.name, city: s.city, phone: s.phone,
    lat: s.lat, lng: s.lng, sp_id: s.salesperson_id, sp: s.sp_name,
    when: s.last_visit_ist, visit_count: s.visit_count,
  }))) %>;
  // Office markers — head office / regional offices / warehouses.
  const offices = <%- JSON.stringify(offices || []) %>;
  if (visits.length === 0 && stores.length === 0 && offices.length === 0) return;

  // Distinct salesperson palette — deterministic from the salesperson id so
  // a given rep always gets the same colour across page loads.
  const palette = ['#1e3a8a','#b45309','#047857','#be123c','#7c3aed','#0e7490','#c2410c','#15803d','#9333ea','#e11d48','#0891b2','#65a30d'];
  function colorFor(spId) { return palette[Math.abs(spId|0) % palette.length]; }

  const map = L.map('visits-map');
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap', maxZoom: 19,
  }).addTo(map);

  // Custom coloured circle markers — looks cleaner than default Leaflet pins.
  function makeMarker(v) {
    return L.circleMarker([v.lat, v.lng], {
      radius: 8,
      color: '#ffffff',
      weight: 2,
      fillColor: colorFor(v.sp_id),
      fillOpacity: 0.92,
    });
  }

  // ── Visits layer (default on) ──────────────────────────────────
  const visitsLayer = L.layerGroup();
  visits.forEach(v => {
    const label = v.type === 'existing' ? (v.dealer || 'dealer') : (v.prospect_shop || v.prospect_name || 'prospect');
    const typeBadge = v.type === 'existing'
      ? '<span style="background:#1e3a8a;color:#fff;padding:1px 6px;font-size:10px;border-radius:3px">existing</span>'
      : '<span style="background:#b45309;color:#fff;padding:1px 6px;font-size:10px;border-radius:3px">prospect</span>';
    const m = makeMarker(v);
    m.bindPopup(`
      <div style="min-width:200px">
        <a href="/visits/${v.id}" style="font-size:13px"><strong>${v.no}</strong></a> ${typeBadge}<br>
        <small style="color:#6b7280">${escapeHtml(v.sp)} · ${v.when}</small><br>
        <div style="margin:4px 0 0"><strong>${escapeHtml(label)}</strong>${v.city ? ' · ' + escapeHtml(v.city) : ''}</div>
        ${v.photo ? `<img src="${v.photo}" style="max-width:170px;border-radius:6px;margin-top:6px">` : ''}
      </div>
    `);
    visitsLayer.addLayer(m);
  });

  // ── Stores layer (default off) ─────────────────────────────────
  // Custom shop-shaped marker so it's visually distinct from visit circles.
  const storesLayer = L.layerGroup();
  function makeStoreMarker(s) {
    const c = colorFor(s.sp_id);
    const icon = L.divIcon({
      className: 'store-marker',
      html: `<div style="position:relative">
               <div style="background:${c};color:#fff;border:2px solid #fff;border-radius:50% 50% 50% 0;transform:rotate(-45deg);width:32px;height:32px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 6px rgba(0,0,0,.35)">
                 <span style="transform:rotate(45deg);font-size:15px">🏪</span>
               </div>
             </div>`,
      iconSize: [32, 32], iconAnchor: [16, 32], popupAnchor: [0, -28],
    });
    return L.marker([s.lat, s.lng], { icon });
  }
  stores.forEach(s => {
    const m = makeStoreMarker(s);
    m.bindPopup(`
      <div style="min-width:210px">
        <a href="/dealers/${s.id}" style="font-size:13px"><strong>${escapeHtml(s.name)}</strong></a>
        <span style="color:#9ca3af;font-size:11px"> · ${escapeHtml(s.code)}</span><br>
        <small style="color:#6b7280">${escapeHtml(s.sp)}${s.city ? ' · ' + escapeHtml(s.city) : ''}</small><br>
        <div style="margin:4px 0;font-size:11px;color:#374151">
          ${s.visit_count} visit${s.visit_count===1?'':'s'}${s.when ? ' · last: ' + s.when : ''}
        </div>
        <a href="/dealers/${s.id}" style="font-size:11px">Open dealer →</a>
      </div>
    `);
    storesLayer.addLayer(m);
  });

  // Default state: visits ON, stores OFF (cleaner first impression).
  visitsLayer.addTo(map);

  // ── Offices layer (default on) ─────────────────────────────────
  // Big green-tinted markers at each registered office / warehouse /
  // factory so the viewer sees the org's physical footprint at a glance.
  const officesLayer = L.layerGroup();
  function officeEmoji(t) { return t === 'factory' ? '🏭' : t === 'warehouse' ? '📦' : '🏢'; }
  offices.forEach(o => {
    const icon = L.divIcon({
      className: 'office-marker',
      html: `<div style="background:#047857;color:#fff;border:2px solid #fff;border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 7px rgba(0,0,0,.35);font-size:17px">${officeEmoji(o.type)}</div>`,
      iconSize: [36, 36], iconAnchor: [18, 18], popupAnchor: [0, -16],
    });
    const m = L.marker([o.lat, o.lng], { icon });
    m.bindPopup(`
      <div style="min-width:200px">
        <strong>${escapeHtml(o.name)}</strong> <span style="color:#9ca3af;font-size:11px">· ${escapeHtml(o.code)}</span><br>
        <small style="color:#6b7280">${o.type}${o.city ? ' · ' + escapeHtml(o.city) : ''}</small><br>
        <a href="/locations/${o.id}/edit" style="font-size:11px">Edit office →</a>
      </div>
    `);
    officesLayer.addLayer(m);
  });
  officesLayer.addTo(map);

  // Fit bounds to whichever layer has data (prefer visits when available,
  // fall back to stores, then offices).
  const fitFeatures = visits.length ? visits : (stores.length ? stores : offices);
  if (fitFeatures.length === 1) {
    map.setView([fitFeatures[0].lat, fitFeatures[0].lng], 14);
  } else if (fitFeatures.length > 1) {
    map.fitBounds(L.latLngBounds(fitFeatures.map(f => [f.lat, f.lng])).pad(0.2));
  }

  // Wire the three toggle buttons.
  function setLayer(btn, layer, onClass, offClass) {
    if (!btn) return;
    btn.addEventListener('click', () => {
      const on = btn.dataset.on === '1';
      if (on) { map.removeLayer(layer); btn.dataset.on = '0'; btn.className = 'btn btn-sm ' + offClass; }
      else    { layer.addTo(map);      btn.dataset.on = '1'; btn.className = 'btn btn-sm ' + onClass;  }
    });
  }
  setLayer(document.getElementById('layer-visits'), visitsLayer, 'btn-primary',           'btn-outline-primary');
  setLayer(document.getElementById('layer-stores'), storesLayer, 'btn-info text-dark',    'btn-outline-info');
  setLayer(document.getElementById('layer-offices'),officesLayer,'btn-success',           'btn-outline-success');

  // Build the salesperson legend with counts (sorted desc). Counts visits
  // first; if there are no visits in range (e.g. user opened the map purely
  // to inspect stores), fall back to counting stores so the legend isn't
  // empty.
  const counts = {};
  const legendSource = visits.length ? visits : stores;
  legendSource.forEach(v => { counts[v.sp_id] = (counts[v.sp_id] || 0) + 1; if (!counts[v.sp_id + '_name']) counts[v.sp_id + '_name'] = v.sp; });
  const legendBox = document.getElementById('sp-legend');
  if (legendBox) {
    const entries = Object.keys(counts).filter(k => !k.endsWith('_name')).map(spId => ({
      id: spId,
      name: counts[spId + '_name'],
      count: counts[spId],
    })).sort((a, b) => b.count - a.count);
    legendBox.innerHTML = entries.map(e =>
      `<div class="legend-row">
         <span><span class="legend-dot" style="background:${colorFor(e.id)}"></span>${escapeHtml(e.name)}</span>
         <span class="count">${e.count}</span>
       </div>`
    ).join('') || '<div class="small text-muted">No salespersons in view.</div>';
  }

  function escapeHtml(s) { return String(s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]); }
})();
</script>
<%- include('../partials/footer') %>
