<%- include('../partials/header') %>
<style>
  .plan-stage { display: grid; grid-template-columns: 380px 1fr; gap: 1rem; }
  @media (max-width: 992px) { .plan-stage { grid-template-columns: 1fr; } }
  #plan-map { height: calc(100vh - 320px); min-height: 460px; border-radius: var(--radius); border: 1px solid var(--hairline); }
  .dealer-pick { display: flex; align-items: flex-start; gap: 8px; padding: 6px 8px; border-radius: 6px; cursor: pointer; border-bottom: 1px dashed var(--hairline); }
  .dealer-pick:hover { background: #f4f5fa; }
  .dealer-pick:last-child { border-bottom: none; }
  .dealer-pick.selected { background: #dbeafe; }
  .city-card { margin-bottom: .55rem; }
  .city-card .card-header { font-size: .8rem; padding: .35rem .55rem; }
  .picker-side { max-height: calc(100vh - 320px); overflow-y: auto; padding-right: 4px; }
  .picker-bar { position: sticky; top: 0; background: var(--bg, #fff); padding-bottom: .5rem; z-index: 2; }
  .leg-tag { background: #fef3c7; color: #92400e; padding: 0 6px; border-radius: 8px; font-size: .68rem; font-weight: 700; }
</style>

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-2 d-print-none">
  <div>
    <h4 class="m-0"><i class="bi bi-signpost-2"></i> Route Plan<% if (routeLabel) { %> · <%= routeLabel %><% } %></h4>
    <small class="text-muted">
      <% if (mode === 'dispatch') { %>
        Build a <strong>delivery / dispatch run</strong> — pick any dealers (across all salespersons) and the system orders them by nearest-neighbour
      <% } else { %>
        Pick which assigned dealers to visit today — system orders them by nearest-neighbour
      <% } %>
      <% if (factoryLoc) { %>starting and ending at <strong><%= homeOfficeName || 'the factory' %></strong><% } else { %>(no home office or factory location captured yet — order will start from the first selected dealer)<% } %>.
    </small>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <a href="/visits" class="btn btn-sm btn-outline-secondary">← Visits</a>
    <% if (plan) { %>
      <button onclick="window.print()" class="btn btn-sm btn-outline-primary print-btn"><i class="bi bi-printer"></i> Print route</button>
    <% } %>
  </div>
</div>

<!-- Mode switch: per-salesperson · area sweep (pool everyone) · delivery run -->
<div class="btn-group btn-group-sm mb-3 d-print-none">
  <a href="/visits/plan" class="btn <%= mode==='sp' ? 'btn-primary' : 'btn-outline-primary' %>"><i class="bi bi-person-badge"></i> By Salesperson</a>
  <a href="/visits/plan?mode=area" class="btn <%= mode==='area' ? 'btn-success' : 'btn-outline-success' %>"><i class="bi bi-bullseye"></i> Area Sweep</a>
  <a href="/visits/plan?mode=dispatch" class="btn <%= mode==='dispatch' ? 'btn-primary' : 'btn-outline-primary' %>"><i class="bi bi-truck"></i> Dispatch run</a>
</div>

<% if (mode === 'area') { %>
  <form method="get" class="card p-2 mb-3 d-print-none" style="background:linear-gradient(135deg,#f0fdf4,#fff)">
    <input type="hidden" name="mode" value="area">
    <div class="row g-2 align-items-end">
      <div class="col-md-3"><label class="form-label small mb-0">City / town</label>
        <select name="city" class="form-select form-select-sm"><option value="">— any city —</option>
          <% cityList.forEach(c => { %><option value="<%= c %>" <%= areaCity===c?'selected':'' %>><%= c %></option><% }) %></select></div>
      <div class="col-md-3"><label class="form-label small mb-0">Within radius of</label>
        <select name="near" class="form-select form-select-sm"><option value="">— no centre —</option>
          <% officeCenters.forEach(o => { %><option value="office:<%= o.id %>" <%= areaNear==='office:'+o.id?'selected':'' %>><%= o.name %><% if(o.city){ %> · <%= o.city %><% } %></option><% }) %></select></div>
      <div class="col-md-2"><label class="form-label small mb-0">Radius (km)</label>
        <input type="number" name="radius" min="0" step="1" value="<%= areaRadius||'' %>" class="form-control form-control-sm" placeholder="e.g. 15"></div>
      <div class="col-md-2"><button class="btn btn-success btn-sm w-100"><i class="bi bi-funnel"></i> Show area</button></div>
      <% if (areaSummary) { %><div class="col-md-2 small text-muted"><strong><%= areaSummary.dealers %></strong> dealers · <strong><%= areaSummary.prospects %></strong> prospects<br>across <%= areaSummary.owners %> salesperson<%= areaSummary.owners===1?'':'s' %></div><% } %>
    </div>
    <div class="small text-muted mt-1"><i class="bi bi-info-circle"></i> Pools <strong>everyone's</strong> dealers + prospects in the area — one person sweeps it all in one trip (less petrol). Pick a city, a radius around an office, or both.</div>
  </form>
<% } %>

<% if (mode === 'dispatch') { %>
  <!-- Dispatch source: pick dealers, or auto-pull dealers with goods to ship -->
  <div class="d-flex flex-wrap gap-2 align-items-center mb-3 d-print-none">
    <span class="small text-muted">Build from:</span>
    <div class="btn-group btn-group-sm">
      <a href="/visits/plan?mode=dispatch" class="btn <%= source==='manual' ? 'btn-secondary' : 'btn-outline-secondary' %>"><i class="bi bi-hand-index"></i> By dealer</a>
      <a href="/visits/plan?mode=dispatch&source=pending" class="btn <%= source==='pending' ? 'btn-warning' : 'btn-outline-warning' %>"><i class="bi bi-box-seam"></i> Available for dispatch</a>
      <a href="/visits/plan?mode=dispatch&source=transit" class="btn <%= source==='transit' ? 'btn-info' : 'btn-outline-info' %>"><i class="bi bi-truck"></i> Out for delivery</a>
    </div>
    <% if (dispatchSummary) { %>
      <span class="badge bg-dark"><i class="bi bi-shop"></i> <%= dispatchSummary.dealerCount %> dealer<%= dispatchSummary.dealerCount===1?'':'s' %> · <%= fmtINR(dispatchSummary.amount) %></span>
      <% if (dispatchSummary.unlocatedCount) { %><span class="small text-warning"><i class="bi bi-exclamation-triangle-fill"></i> <%= dispatchSummary.unlocatedCount %> can't be mapped (no shop location)</span><% } %>
      <span class="small text-muted">auto-selected &amp; routed — uncheck any, then re-plan</span>
    <% } else { %>
      <span class="small text-muted"><i class="bi bi-info-circle"></i> <strong>Available</strong> = invoiced, not yet sent · <strong>Out for delivery</strong> = sent, not yet delivered</span>
    <% } %>
  </div>
<% } %>

<% if (mode === 'sp' && !isOwn) { %>
  <!-- Salesperson picker (owner/admin only) -->
  <form method="get" class="card p-2 mb-3 d-print-none" style="background:linear-gradient(135deg,#fafbff,#fff)">
    <div class="row g-2 align-items-end">
      <div class="col-md-5">
        <label class="form-label small mb-1">Plan a route for</label>
        <select name="sp" class="form-select form-select-sm" onchange="this.form.submit()">
          <option value="">— Choose salesperson —</option>
          <% salespersons.forEach(s => { %>
            <option value="<%= s.id %>" <%= spId === s.id ? 'selected' : '' %>><%= s.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <!-- Explicit submit button so the user has a clear path even if
             onchange auto-submit doesn't fire (browser quirks, re-selecting
             the same option, etc.). -->
        <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-arrow-right-circle"></i> Show</button>
      </div>
      <% if (sp) { %>
        <div class="col-md-5"><small class="text-muted"><%= dealers.length %> dealer<%= dealers.length===1?'':'s' %> ready to plot · <%= unlocated.length %> still need a first visit</small></div>
      <% } %>
    </div>
  </form>
<% } %>

<% if (mode === 'sp' && !spId) { %>
  <div class="card p-5 text-center text-muted">
    <i class="bi bi-signpost" style="font-size:2.4rem"></i>
    <h6 class="mt-3">Pick a salesperson above and click <strong>Show</strong></h6>
    <small>Their assigned dealers with stored shop coords will appear on the map.</small>
  </div>
<% } else if (dealers.length === 0) { %>
  <div class="card p-5 text-center text-muted">
    <i class="bi bi-geo" style="font-size:2.4rem"></i>
    <h6 class="mt-3">No dealers have a stored shop location yet<% if (sp) { %> for <%= sp.name %><% } %>.</h6>
    <small>The route planner only shows <strong>active</strong> dealers that have been visited at least once
      (so the system has GPS coordinates to plot).
      Log a visit on each dealer in Field Visits → New Visit, and they'll appear here.</small>
    <% if (unlocated.length) { %>
      <div class="mt-3"><strong><%= unlocated.length %></strong> active dealer<%= unlocated.length===1?'':'s' %> still need a first visit:</div>
      <div class="mt-2">
        <% unlocated.slice(0, 20).forEach(d => { %>
          <a href="/visits/new?dealer_id=<%= d.id %>" class="badge bg-light text-dark text-decoration-none me-1 mb-1" style="font-weight:500"><%= d.name %><% if (d.city) { %> <span class="text-muted">· <%= d.city %></span><% } %></a>
        <% }) %>
        <% if (unlocated.length > 20) { %><span class="small text-muted">+ <%= unlocated.length - 20 %> more</span><% } %>
      </div>
    <% } %>
  </div>
<% } else { %>
<div class="plan-stage">
  <!-- LEFT: dealer picker (hidden on print — only the route table is printable) -->
  <div class="d-print-none">
    <form id="plan-form" method="get" action="/visits/plan">
      <% if (mode === 'dispatch') { %><input type="hidden" name="mode" value="dispatch"><% if (source && source !== 'manual') { %><input type="hidden" name="source" value="<%= source %>"><% } %>
      <% } else if (mode === 'area') { %><input type="hidden" name="mode" value="area"><% if (areaCity) { %><input type="hidden" name="city" value="<%= areaCity %>"><% } %><% if (areaNear) { %><input type="hidden" name="near" value="<%= areaNear %>"><% } %><% if (areaRadius) { %><input type="hidden" name="radius" value="<%= areaRadius %>"><% } %>
      <% } else { %><input type="hidden" name="sp" value="<%= spId %>"><% } %>
      <input type="hidden" id="ids-input" name="ids" value="<%= idsCsv %>">
      <div class="picker-bar">
        <div class="d-flex gap-1">
          <button type="submit" class="btn btn-primary btn-sm flex-grow-1" id="plan-submit">
            <i class="bi bi-magic"></i> Plan route (<span id="picked-count">0</span>)
          </button>
          <button type="button" class="btn btn-outline-secondary btn-sm" id="clear-pick" title="Clear all picks"><i class="bi bi-x-lg"></i></button>
        </div>
        <input type="search" id="dealer-search" class="form-control form-control-sm mt-1" placeholder="🔍 Filter dealers by name, city<%= mode==='dispatch' ? ', salesperson' : '' %>…">
      </div>
      <div class="picker-side mt-2">
        <% if (mode==='sp' && typeof topSuggestions!=='undefined' && topSuggestions.length) { %>
          <div class="card city-card" style="border-color:#16a34a">
            <div class="card-header d-flex justify-content-between align-items-center" style="background:#f0fdf4">
              <strong><i class="bi bi-stars text-success"></i> Suggested stops</strong>
              <button type="button" class="btn btn-sm btn-success py-0" id="add-suggested">+ Add all</button>
            </div>
            <div class="card-body p-0">
              <% topSuggestions.forEach(s => { %>
                <div class="dealer-pick suggested-row" data-id="<%= s.id %>" style="cursor:pointer" title="Add to route">
                  <div class="flex-grow-1" style="min-width:0">
                    <div style="font-weight:600"><%= s.name %></div>
                    <div class="small text-muted">
                      <% if (s.outstanding > 0) { %><span class="text-danger">due <%= fmtINR(s.outstanding) %></span> · <% } %><%= s.days_since!=null ? s.days_since + 'd since visit' : 'not visited' %><% if (s.city) { %> · <%= s.city %><% } %>
                    </div>
                  </div>
                  <i class="bi bi-plus-circle text-success"></i>
                </div>
              <% }) %>
            </div>
          </div>
        <% } %>
        <% cityNames.forEach(city => { %>
          <div class="card city-card">
            <div class="card-header d-flex justify-content-between align-items-center">
              <strong><%= city %></strong>
              <a href="#" class="small text-muted city-toggle" data-city="<%= city %>" title="Select all in this city">pick all</a>
            </div>
            <div class="card-body p-0">
              <% byCity[city].forEach(d => { %>
                <label class="dealer-pick" data-city="<%= city %>" data-search="<%= (d.name + ' ' + d.code + ' ' + (d.city||'') + ' ' + (d.sp_name||'')).toLowerCase() %>">
                  <input type="checkbox" class="dealer-cb" value="<%= d.id %>" data-name="<%= d.name %>" data-lat="<%= d.lat %>" data-lng="<%= d.lng %>" <%= (',' + idsCsv + ',').includes(',' + d.id + ',') ? 'checked' : '' %>>
                  <div class="flex-grow-1" style="min-width:0">
                    <div style="font-weight:600"><%= d.name %></div>
                    <div class="small text-muted"><%= d.code %><% if (d.phone) { %> · <%= d.phone %><% } %><% if (mode==='dispatch' && d.sp_name) { %> · <span class="text-primary"><i class="bi bi-person"></i> <%= d.sp_name %></span><% } %><% if (d.pending) { %> · <span class="badge bg-warning text-dark"><i class="bi bi-box-seam"></i> <%= fmtINR(d.pending.amt) %> · <%= d.pending.n %></span><% } %><% if (mode==='area') { %><% if (d.kind==='prospect') { %> · <span class="badge bg-warning text-dark">prospect</span><% } %> · <span class="text-primary"><i class="bi bi-person"></i> <%= d.sp_name %></span><% if (d.kind!=='prospect' && d.outstanding>0) { %> · <span class="text-danger">due <%= fmtINR(d.outstanding) %></span><% } %><% if (d.kind!=='prospect' && d.days_since!=null && d.days_since>30) { %> · <span><%= d.days_since %>d</span><% } %><% } %></div>
                  </div>
                </label>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    </form>
  </div>

  <!-- RIGHT: map + computed route -->
  <div>
    <% if (plan) { %>
      <div class="card p-2 mb-2 d-flex flex-row gap-3 align-items-center flex-wrap d-print-none" style="background:linear-gradient(135deg,#fef3c7,#fff)">
        <div>
          <div class="small text-muted">Total straight-line distance</div>
          <div style="font-size:1.4rem;font-weight:800;color:var(--denim)"><%= plan.totalKm.toFixed(2) %> km</div>
        </div>
        <div class="small text-muted">
          <%= plan.picked.length %> stop<%= plan.picked.length===1?'':'s' %>
          <% if (plan.hasFactory) { %> · round-trip from <strong><%= plan.homeOfficeName || 'factory' %></strong><% } %>
          <br>Real road distance will be longer (typically 20–40% more).
        </div>
      </div>
    <% } %>
    <div id="plan-map" class="d-print-none"></div>

    <% if (plan) { %>
      <!-- Print zone: the banner + the route table both render on paper.
           Everything outside this <div class="print-zone"> is hidden by
           the global @media print rule in app.css. -->
      <div class="print-zone">
      <div class="print-only" style="margin-bottom:8px">
        <div style="text-align:center;border-bottom:2px solid #000;padding-bottom:4px;margin-bottom:6px">
          <div style="font-size:18pt;font-weight:800;letter-spacing:.3px"><%= companyName %></div>
          <div style="font-size:13pt;font-weight:600">Route Plan · <%= routeLabel %></div>
          <div style="font-size:10pt;color:#444">
            <%= plan.picked.length %> stops · <strong><%= plan.totalKm.toFixed(2) %> km</strong> straight-line<% if (plan.hasFactory) { %> · round-trip from <%= plan.homeOfficeName || 'factory' %><% } %>
            · Generated <%= fmtDateTime(new Date().toISOString().replace('T',' ').slice(0,19)) %>
          </div>
        </div>
      </div>

      <!-- Printable route sheet -->
      <% const pickedIds = plan.picked.map(p => p.id).join(',');
         const dispatchBack = '/visits/plan?mode=dispatch&source=' + (source||'manual') + '&ids=' + encodeURIComponent(idsCsv);
         const showDispatch = (mode === 'dispatch' && canDispatch && (source === 'pending' || source === 'transit')); %>
      <div class="card mt-3" id="route-print">
        <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2 d-print-none">
          <div>
            <strong>Today's Route</strong> · <%= routeLabel %> · <%= plan.picked.length %> stops · <strong><%= plan.totalKm.toFixed(2) %> km</strong>
          </div>
          <% if (showDispatch && source === 'pending') { %>
            <form method="post" action="/dispatch/route/dispatched" class="d-flex flex-wrap gap-1 align-items-center" data-confirm="Mark all <%= plan.picked.length %> stops dispatched? This creates dispatch entries for their pending invoices.">
              <input type="hidden" name="dealer_ids" value="<%= pickedIds %>">
              <input type="hidden" name="back" value="<%= dispatchBack %>">
              <input name="transport_name" id="tt-transport" class="form-control form-control-sm" style="max-width:140px" placeholder="Transport (optional)">
              <input name="vehicle_no" id="tt-vehicle" class="form-control form-control-sm" style="max-width:115px" placeholder="Vehicle no.">
              <button class="btn btn-sm btn-success"><i class="bi bi-truck"></i> Mark all <%= plan.picked.length %> dispatched</button>
            </form>
          <% } else if (showDispatch && source === 'transit') { %>
            <form method="post" action="/dispatch/route/delivered" data-confirm="Mark all <%= plan.picked.length %> stops delivered?">
              <input type="hidden" name="dealer_ids" value="<%= pickedIds %>">
              <input type="hidden" name="back" value="<%= dispatchBack %>">
              <button class="btn btn-sm btn-info"><i class="bi bi-check2-all"></i> Mark all <%= plan.picked.length %> delivered</button>
            </form>
          <% } %>
        </div>
        <div class="table-responsive">
          <table class="table table-sm m-0">
            <thead class="table-light">
              <tr><th style="width:48px">#</th><th>Dealer</th><th>City</th><th>Phone</th><th class="text-end" style="width:120px">KM from prev</th><th class="d-print-none" style="width:100px">Action</th></tr>
            </thead>
            <tbody>
              <% if (plan.hasFactory) { %>
                <tr style="background:#f0fdf4">
                  <td><i class="bi bi-building text-success"></i></td>
                  <td colspan="3"><strong>Start: <%= plan.homeOfficeName || 'Factory' %></strong></td>
                  <td class="text-end">—</td>
                  <td class="d-print-none">—</td>
                </tr>
              <% } %>
              <% plan.picked.forEach((p, i) => {
                   const legIdx = plan.hasFactory ? i : (i === 0 ? -1 : i - 1);
                   const leg = legIdx >= 0 ? plan.legs[legIdx] : null;
              %>
                <tr>
                  <td><strong style="font-size:1.05rem"><%= i + 1 %></strong></td>
                  <td>
                    <strong><%= p.name %></strong>
                    <div class="small text-muted"><%= p.code %><% if (p.address) { %> · <%= p.address %><% } %></div>
                  </td>
                  <td><%= p.city || '-' %></td>
                  <td><%= p.phone || '-' %></td>
                  <td class="text-end"><% if (leg) { %><span class="leg-tag"><%= leg.km.toFixed(2) %> km</span><% } else { %>—<% } %></td>
                  <td class="d-print-none">
                    <div class="d-flex gap-1">
                      <% if (p.id > 0) { %>
                        <a href="/visits/new?dealer_id=<%= p.id %>" class="btn btn-sm btn-outline-primary" title="Log a visit"><i class="bi bi-camera"></i></a>
                      <% } else { %>
                        <a href="/visits/<%= -p.id %>" class="btn btn-sm btn-outline-warning" title="Open prospect"><i class="bi bi-person"></i></a>
                      <% } %>
                      <% if (showDispatch && source === 'pending') { %>
                        <form method="post" action="/dispatch/route/dispatched" class="d-inline" title="Mark this stop dispatched">
                          <input type="hidden" name="dealer_ids" value="<%= p.id %>">
                          <input type="hidden" name="back" value="<%= dispatchBack %>">
                          <input type="hidden" name="transport_name" class="row-transport">
                          <input type="hidden" name="vehicle_no" class="row-vehicle">
                          <button class="btn btn-sm btn-outline-success" title="Mark dispatched"><i class="bi bi-truck"></i></button>
                        </form>
                      <% } else if (showDispatch && source === 'transit') { %>
                        <form method="post" action="/dispatch/route/delivered" class="d-inline">
                          <input type="hidden" name="dealer_ids" value="<%= p.id %>">
                          <input type="hidden" name="back" value="<%= dispatchBack %>">
                          <button class="btn btn-sm btn-outline-info" title="Mark delivered"><i class="bi bi-check2"></i></button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
              <% if (plan.hasFactory) {
                   const lastLeg = plan.legs[plan.legs.length - 1]; %>
                <tr style="background:#f0fdf4">
                  <td><i class="bi bi-building text-success"></i></td>
                  <td colspan="3"><strong>Return: <%= plan.homeOfficeName || 'Factory' %></strong></td>
                  <td class="text-end"><span class="leg-tag"><%= lastLeg.km.toFixed(2) %> km</span></td>
                  <td class="d-print-none">—</td>
                </tr>
              <% } %>
            </tbody>
            <tfoot>
              <tr style="border-top:2px solid #333">
                <th colspan="4" class="text-end">Total straight-line distance</th>
                <th class="text-end"><strong><%= plan.totalKm.toFixed(2) %> km</strong></th>
                <th class="d-print-none"></th>
              </tr>
            </tfoot>
          </table>
        </div>
        <div class="card-footer small text-muted">
          <i class="bi bi-info-circle"></i> Order optimised by nearest-neighbour. Distances are straight-line (Haversine) — actual driven distance will be higher because roads aren't straight.
        </div>
      </div>
      </div><!-- /.print-zone -->
    <% } %>

    <% if (unlocated.length) { %>
      <div class="card mt-3 d-print-none">
        <div class="card-header d-flex justify-content-between"><strong>Dealers still needing a first visit</strong><span class="badge bg-warning text-dark"><%= unlocated.length %></span></div>
        <div class="card-body py-2">
          <% unlocated.slice(0, 30).forEach(d => { %>
            <span class="badge bg-light text-dark me-1 mb-1" style="font-weight:500"><a href="/dealers/<%= d.id %>" class="text-decoration-none text-dark"><%= d.name %><% if (d.city) { %> <small class="text-muted">· <%= d.city %></small><% } %></a></span>
          <% }) %>
          <% if (unlocated.length > 30) { %><span class="small text-muted">+ <%= unlocated.length - 30 %> more</span><% } %>
          <div class="small text-muted mt-2">Once these dealers get a first visit, they'll show up here for route planning.</div>
        </div>
      </div>
    <% } %>
  </div>
</div>
<% } %>

<!-- Leaflet from jsdelivr (CSP) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css">
<script src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
  const dealers = <%- JSON.stringify(dealers.map(d => ({id:d.id, name:d.name, code:d.code, city:d.city, phone:d.phone, lat:d.lat, lng:d.lng}))) %>;
  const factory = <%- JSON.stringify(factoryLoc) %>;
  const homeOfficeName = <%- JSON.stringify(homeOfficeName || 'Factory') %>;
  const plan = <%- JSON.stringify(plan ? {
    picked: plan.picked.map(p => ({id:p.id, name:p.name, code:p.code, city:p.city, phone:p.phone, lat:p.lat, lng:p.lng})),
    hasFactory: plan.hasFactory,
  } : null) %>;
  if (dealers.length === 0) return;

  const map = L.map('plan-map');
  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '&copy; OpenStreetMap', maxZoom: 19,
  }).addTo(map);

  const pickedSet = new Set(plan ? plan.picked.map(p => p.id) : []);

  // All available dealers as faint store icons. Picked ones turn solid orange.
  const baseMarkers = {};
  dealers.forEach(d => {
    const isPicked = pickedSet.has(d.id);
    const color = isPicked ? '#b45309' : '#94a3b8';
    const icon = L.divIcon({
      className: 'plan-marker',
      html: `<div style="background:${color};color:#fff;border:2px solid #fff;border-radius:50% 50% 50% 0;transform:rotate(-45deg);width:26px;height:26px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 6px rgba(0,0,0,.3);opacity:${isPicked ? 1 : 0.55}">
                <span style="transform:rotate(45deg);font-size:12px">🏪</span>
              </div>`,
      iconSize: [26, 26], iconAnchor: [13, 26], popupAnchor: [0, -22],
    });
    const m = L.marker([d.lat, d.lng], { icon }).addTo(map);
    m.bindPopup(`<strong>${escapeHtml(d.name)}</strong><br><small>${escapeHtml(d.code)}${d.city ? ' · ' + escapeHtml(d.city) : ''}</small>`);
    baseMarkers[d.id] = m;
  });

  // Home-office marker (green building) — labelled with the office name
  // so a route plan for a Muzaffarpur salesperson clearly shows
  // "Muzaffarpur Regional Office" instead of the literal word "Factory".
  if (factory) {
    const icon = L.divIcon({
      className: 'factory-marker',
      html: `<div style="background:#047857;color:#fff;border:2px solid #fff;border-radius:50%;width:34px;height:34px;display:flex;align-items:center;justify-content:center;box-shadow:0 2px 6px rgba(0,0,0,.35);font-size:16px">🏭</div>`,
      iconSize: [34, 34], iconAnchor: [17, 17],
    });
    L.marker([factory.lat, factory.lng], { icon }).addTo(map).bindPopup('<strong>' + escapeHtml(homeOfficeName) + '</strong>');
  }

  // Computed route — polyline + numbered overlay markers
  if (plan && plan.picked.length) {
    const seq = [];
    if (plan.hasFactory && factory) seq.push([factory.lat, factory.lng]);
    plan.picked.forEach(p => seq.push([p.lat, p.lng]));
    if (plan.hasFactory && factory) seq.push([factory.lat, factory.lng]);

    L.polyline(seq, { color: '#1e3a8a', weight: 4, opacity: 0.85 }).addTo(map);
    L.polyline(seq, { color: '#ffffff', weight: 2, opacity: 0.6, dashArray: '6, 10' }).addTo(map);

    // Stop numbers — keep the store icon's position, overlay the number badge.
    plan.picked.forEach((p, i) => {
      const numIcon = L.divIcon({
        className: 'plan-num',
        html: `<div style="background:#1e3a8a;color:#fff;border:2px solid #fff;border-radius:50%;width:24px;height:24px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:12px;box-shadow:0 2px 5px rgba(0,0,0,.35)">${i+1}</div>`,
        iconSize: [24, 24], iconAnchor: [12, -10],
      });
      L.marker([p.lat, p.lng], { icon: numIcon, interactive: false }).addTo(map);
    });

    map.fitBounds(L.latLngBounds(seq).pad(0.2));
  } else {
    const bounds = L.latLngBounds(dealers.map(d => [d.lat, d.lng]));
    if (factory) bounds.extend([factory.lat, factory.lng]);
    if (dealers.length === 1) map.setView([dealers[0].lat, dealers[0].lng], 13);
    else map.fitBounds(bounds.pad(0.2));
  }

  // ── Pick UI plumbing ─────────────────────────────────────────
  function refreshCounts() {
    const checked = Array.from(document.querySelectorAll('.dealer-cb:checked'));
    document.getElementById('ids-input').value = checked.map(cb => cb.value).join(',');
    document.getElementById('picked-count').textContent = checked.length;
    document.querySelectorAll('.dealer-pick').forEach(row => {
      const cb = row.querySelector('.dealer-cb');
      row.classList.toggle('selected', cb && cb.checked);
    });
  }
  document.querySelectorAll('.dealer-cb').forEach(cb => cb.addEventListener('change', refreshCounts));
  const clearBtn = document.getElementById('clear-pick');
  if (clearBtn) clearBtn.addEventListener('click', () => {
    document.querySelectorAll('.dealer-cb').forEach(cb => cb.checked = false);
    refreshCounts();
  });
  document.querySelectorAll('.city-toggle').forEach(a => a.addEventListener('click', (e) => {
    e.preventDefault();
    const city = a.dataset.city;
    const rows = document.querySelectorAll('.dealer-pick[data-city="' + CSS.escape(city) + '"] .dealer-cb');
    const allChecked = Array.from(rows).every(cb => cb.checked);
    rows.forEach(cb => cb.checked = !allChecked);
    a.textContent = allChecked ? 'pick all' : 'unpick all';
    refreshCounts();
  }));

  // Suggested stops — tick the matching dealer checkbox in the city groups.
  function pickDealer(id) { const cb = document.querySelector('.dealer-cb[value="' + id + '"]'); if (cb) { cb.checked = true; } }
  document.querySelectorAll('.suggested-row').forEach(row => row.addEventListener('click', () => { pickDealer(row.dataset.id); refreshCounts(); }));
  const addAll = document.getElementById('add-suggested');
  if (addAll) addAll.addEventListener('click', () => { document.querySelectorAll('.suggested-row').forEach(r => pickDealer(r.dataset.id)); refreshCounts(); });

  // Live filter — name / code / city / salesperson. Empty city cards hide.
  const search = document.getElementById('dealer-search');
  if (search) search.addEventListener('input', () => {
    const q = search.value.trim().toLowerCase();
    document.querySelectorAll('.dealer-pick').forEach(row => {
      row.style.display = (!q || (row.dataset.search || '').includes(q)) ? '' : 'none';
    });
    document.querySelectorAll('.city-card').forEach(card => {
      const anyVisible = Array.from(card.querySelectorAll('.dealer-pick')).some(r => r.style.display !== 'none');
      card.style.display = anyVisible ? '' : 'none';
    });
  });
  refreshCounts();

  function escapeHtml(s) { return String(s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'})[c]); }

  // Keep each row's "Mark dispatched" transport/vehicle in sync with the toolbar.
  const ttT = document.getElementById('tt-transport'), ttV = document.getElementById('tt-vehicle');
  function syncRowDispatch() {
    document.querySelectorAll('.row-transport').forEach(el => el.value = ttT ? ttT.value : '');
    document.querySelectorAll('.row-vehicle').forEach(el => el.value = ttV ? ttV.value : '');
  }
  if (ttT) ttT.addEventListener('input', syncRowDispatch);
  if (ttV) ttV.addEventListener('input', syncRowDispatch);
  syncRowDispatch();
})();
</script>

<!-- Route-plan print tweak: kill the leg-tag pill background so the
     km figure prints as plain bold text (no light-yellow chip on paper). -->
<style>
@media print {
  .print-zone .leg-tag {
    background: transparent !important;
    color: #000 !important;
    padding: 0 !important;
    font-weight: 700 !important;
  }
}
</style>

