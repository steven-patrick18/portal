<%- include('../partials/header') %>
<% const medal = i => i===0?'🥇':i===1?'🥈':i===2?'🥉':(i+1)+'.';
   const rb = s => s==null?'secondary':(s>=90?'success':s>=75?'primary':s>=60?'warning text-dark':'danger');
   const pb = p => p==null?'#e5e7eb':(p>=100?'#16a34a':p>=60?'#f59e0b':'#ef4444');
   const pm = (label) => label; %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-people-fill text-primary"></i> Team Performance</h4>
    <small class="text-muted">Targets · collection · outstanding · auto-incentive — per salesperson. <a href="/visits">← Field</a></small>
  </div>
  <div class="d-flex gap-2">
    <form method="get" class="d-flex gap-1">
      <select name="period" class="form-select form-select-sm" onchange="this.form.submit()">
        <% periods.forEach(p => { %><option value="<%= p %>" <%= p===period?'selected':'' %>><%= p %><%= p===curPeriod ? ' · this month' : (p > curPeriod ? ' · upcoming' : '') %></option><% }) %>
      </select>
    </form>
    <% if (canManage) { %><a href="/visits/team/schemes" class="btn btn-sm btn-outline-primary"><i class="bi bi-gear"></i> Incentive Schemes</a><% } %>
  </div>
</div>

<% if (canManage) { %>
<form method="post" action="/visits/team/team-scheme" class="card mb-3" style="background:linear-gradient(135deg,#eff6ff,#fff)">
  <div class="card-body py-2 d-flex flex-wrap align-items-center gap-2">
    <span class="fw-semibold"><i class="bi bi-calendar2-check text-primary"></i> Whole-team scheme for <%= period %>:</span>
    <input type="hidden" name="period" value="<%= period %>">
    <select name="scheme_id" class="form-select form-select-sm" style="width:auto;min-width:220px">
      <option value="">— not set (use employee / default) —</option>
      <% schemes.forEach(s => { %><option value="<%= s.id %>" <%= teamSchemeId===s.id?'selected':'' %>><%= s.name %></option><% }) %>
    </select>
    <button class="btn btn-sm btn-primary">Apply to whole team</button>
    <% if (teamSchemeId) { const ts = schemes.find(s => s.id===teamSchemeId); %>
      <span class="small text-success"><i class="bi bi-check-circle-fill"></i> Everyone is on <strong><%= ts ? ts.name : 'a scheme' %></strong> for <%= period %> — set a different month from the dropdown above to change another month. (A per-person override still wins.)</span>
    <% } %>
  </div>
</form>
<% } %>
<% const lk = (typeof links !== 'undefined' && links) ? links : {};
   const tOpen = h => h ? `<a href="${h}" class="card text-center h-100 text-reset text-decoration-none tile-link">` : '<div class="card text-center h-100">';
   const tClose = h => h ? '</a>' : '</div>';
   const arr = h => h ? ' <i class="bi bi-box-arrow-up-right arr" style="font-size:.65rem"></i>' : ''; %>
<style>.tile-link{transition:.15s;cursor:pointer}.tile-link:hover{border-color:#0d6efd;box-shadow:0 3px 12px rgba(13,110,253,.12)}.arr{opacity:.45}.tile-link:hover .arr{opacity:1}</style>
<!-- Month totals — click a tile to drill into the detail -->
<div class="row g-2 mb-3">
  <div class="col-6 col-lg"><%- tOpen(lk.sales) %><div class="card-body p-2"><div class="small text-muted">Sales (billed)<%- arr(lk.sales) %></div><div class="h5 m-0"><%= fmtINR(totals.sales) %></div><% if (totals.tSales) { %><div class="small text-muted">of <%= fmtINR(totals.tSales) %></div><% } %></div><%- tClose(lk.sales) %></div>
  <div class="col-6 col-lg"><%- tOpen(lk.collection) %><div class="card-body p-2"><div class="small text-muted">Collection<%- arr(lk.collection) %></div><div class="h5 m-0 text-success"><%= fmtINR(totals.collection) %></div><% if (totals.tColl) { %><div class="small text-muted">of <%= fmtINR(totals.tColl) %></div><% } %></div><%- tClose(lk.collection) %></div>
  <div class="col-6 col-lg"><%- tOpen(lk.outstanding) %><div class="card-body p-2"><div class="small text-muted">Outstanding (live)<%- arr(lk.outstanding) %></div><div class="h5 m-0 text-danger"><%= fmtINR(totals.outstanding) %></div></div><%- tClose(lk.outstanding) %></div>
  <div class="col-6 col-lg"><%- tOpen(lk.dealers) %><div class="card-body p-2"><div class="small text-muted">New dealers<%- arr(lk.dealers) %></div><div class="h5 m-0"><%= totals.newDealers %></div></div><%- tClose(lk.dealers) %></div>
  <div class="col-6 col-lg"><%- tOpen(lk.incentive) %><div class="card-body p-2"><div class="small text-muted">Incentive payable<%- arr(lk.incentive) %></div><div class="h5 m-0 text-primary"><%= fmtINR(totals.incentive) %></div></div><%- tClose(lk.incentive) %></div>
</div>

<!-- Leaderboard -->
<div class="card mb-3"><div class="table-responsive">
  <table class="table table-sm table-hover align-middle m-0">
    <thead><tr>
      <th>#</th><th>Salesperson</th>
      <th class="text-end">Collection / Target</th>
      <th style="min-width:120px">Achieved</th>
      <th class="text-end">Sales</th>
      <th class="text-center">New</th>
      <th class="text-end">Outstanding</th>
      <th class="text-end">Incentive</th>
      <th class="text-center">Score</th>
    </tr></thead>
    <tbody>
      <% rows.forEach((r, i) => { const ca = r.ach.collection; %>
        <tr>
          <td class="fs-6"><%= medal(i) %></td>
          <td>
            <a href="/visits/team/<%= r.sp.id %>?period=<%= period %>" class="fw-semibold text-decoration-none"><%= r.sp.name %></a>
            <div class="small text-muted"><%= r.sp.role === 'area_manager' ? 'Area Manager' : 'Salesperson' %><% if (r.sp.manager_name) { %> · ↳ <%= r.sp.manager_name %><% } %> · <%= r.dealers %> dealers<% if (r.team) { %> <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle" title="This row is the TEAM's combined figures — own + every direct report's collection, sales, targets and outstanding">team of <%= r.team %> · combined</span><% } %></div>
          </td>
          <td class="text-end"><%= fmtINR(r.actual.collection) %><% if (r.target) { %><div class="small text-muted">of <%= fmtINR(r.target.collection_target) %></div><% } %></td>
          <td>
            <% if (ca==null) { %><span class="small text-muted">no target</span><% } else { %>
              <div class="d-flex align-items-center gap-1"><div class="flex-grow-1" style="height:7px;background:#eee;border-radius:4px;overflow:hidden"><span style="display:block;height:100%;width:<%= Math.min(ca,100) %>%;background:<%= pb(ca) %>"></span></div><span class="small fw-semibold"><%= ca %>%</span></div>
            <% } %>
          </td>
          <td class="text-end"><%= fmtINR(r.actual.sales) %></td>
          <td class="text-center"><%= r.actual.newDealers %><% if (r.target && r.target.new_dealer_target) { %><span class="small text-muted">/<%= r.target.new_dealer_target %></span><% } %></td>
          <td class="text-end <%= r.outstanding>0?'text-danger':'' %>"><%= fmtINR(r.outstanding) %></td>
          <td class="text-end text-primary"><%= fmtINR(r.incentive) %><% if (r.penalty) { %><div class="small text-danger fw-semibold" title="Below the scheme's minimum gate — salary penalty">−<%= fmtINR(r.penalty) %> penalty</div><% } %></td>
          <td class="text-center"><span class="badge bg-<%= rb(r.score) %>"><%= r.score==null?'—':r.score %><% if (r.score!=null) { %> · <%= r.rating %><% } %></span></td>
        </tr>
      <% }) %>
      <% if (!rows.length) { %><tr><td colspan="9" class="text-center text-muted py-4">No salespersons in your view for <%= period %>.</td></tr><% } %>
    </tbody>
  </table>
</div></div>

<% if (canManage && rows.length) { %>
<!-- Auto-grow targets into future months -->
<form method="post" action="/visits/team/autogrow" class="card mb-3" data-confirm="Generate growing targets for everyone in view? This overwrites targets for those future months.">
  <input type="hidden" name="period" value="<%= period %>">
  <div class="card-header bg-white fw-semibold"><i class="bi bi-graph-up-arrow text-success"></i> Auto-grow targets</div>
  <div class="card-body py-2">
    <div class="row g-2 align-items-end">
      <div class="col-6 col-md-3"><label class="form-label small mb-0">Growth % / month</label><input name="growth" type="number" step="1" min="0" class="form-control form-control-sm" value="10"></div>
      <div class="col-6 col-md-3"><label class="form-label small mb-0">Project months</label><input name="months" type="number" min="1" max="12" class="form-control form-control-sm" value="3"></div>
      <div class="col-8 col-md-4"><label class="form-label small mb-0">Base on</label>
        <select name="base" class="form-select form-select-sm">
          <option value="actual">Last 3-month average (actual)</option>
          <option value="target">This month's target</option>
        </select></div>
      <div class="col-4 col-md-2"><button class="btn btn-sm btn-success w-100"><i class="bi bi-magic"></i> Generate</button></div>
    </div>
    <div class="form-text">Compounds each month from <%= period %> — e.g. ₹1,00,000 at +10% → ₹1,10,000 · ₹1,21,000 · ₹1,33,100… Overwrites those future months' targets.</div>
  </div>
</form>

<!-- Set monthly targets -->
<div class="card">
  <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
    <span class="fw-semibold"><i class="bi bi-bullseye"></i> Set targets for <%= period %><% if (period > curPeriod) { %> <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle">upcoming</span><% } %></span>
    <label class="small text-muted mb-0">Also apply to next
      <input type="number" id="repeat-n" min="0" max="11" value="0" style="width:58px" class="form-control form-control-sm d-inline-block"> month(s)
    </label>
  </div>
  <div class="card-body py-2">
    <div class="row g-3">
      <% rows.forEach(r => { %>
        <div class="col-md-6 col-lg-4">
          <form method="post" action="/visits/team/targets" class="border rounded p-2">
            <input type="hidden" name="salesperson_id" value="<%= r.sp.id %>">
            <input type="hidden" name="period" value="<%= period %>">
            <input type="hidden" name="repeat" class="repeat-field" value="0">
            <div class="fw-semibold small mb-1"><%= r.sp.name %></div>
            <div class="row g-1">
              <div class="col-12"><div class="input-group input-group-sm"><span class="input-group-text">₹ Coll.</span><input name="collection_target" type="number" step="1000" class="form-control" value="<%= r.target ? r.target.collection_target : '' %>" placeholder="collection target"></div></div>
              <div class="col-12"><div class="input-group input-group-sm"><span class="input-group-text">₹ Sales</span><input name="sales_target" type="number" step="1000" class="form-control" value="<%= r.target ? r.target.sales_target : '' %>" placeholder="sales target"></div></div>
              <div class="col-12"><div class="input-group input-group-sm"><span class="input-group-text">Scheme</span>
                <select name="scheme_id" class="form-select" title="Incentive scheme for this month only">
                  <option value="">default / employee</option>
                  <% schemes.forEach(s => { %><option value="<%= s.id %>" <%= (r.target && r.target.scheme_id===s.id)?'selected':'' %>><%= s.name %></option><% }) %>
                </select></div></div>
              <div class="col-7"><div class="input-group input-group-sm"><span class="input-group-text">New</span><input name="new_dealer_target" type="number" class="form-control" value="<%= r.target ? r.target.new_dealer_target : '' %>" placeholder="dealers"></div></div>
              <div class="col-5"><button class="btn btn-sm btn-primary w-100">Save</button></div>
            </div>
          </form>
        </div>
      <% }) %>
    </div>
  </div>
</div>
<% } %>
<script>
  // One "apply to next N months" control governs every target form.
  (function(){
    var n = document.getElementById('repeat-n');
    if (!n) return;
    function sync(){ document.querySelectorAll('.repeat-field').forEach(function(f){ f.value = n.value || 0; }); }
    n.addEventListener('input', sync); sync();
  })();
</script>
<%- include('../partials/footer') %>
