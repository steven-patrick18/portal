<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-cash-stack text-primary"></i> Incentive Schemes</h4>
    <small class="text-muted">Pay salespeople on collection (default) or sales. <a href="/visits/team">← Team</a></small>
  </div>
</div>

<div class="row g-3">
  <div class="col-lg-7">
    <div class="card"><div class="table-responsive">
      <table class="table table-sm align-middle m-0">
        <thead><tr><th>Scheme</th><th>Paid on</th><th>Rate</th><th>Gate</th><th></th></tr></thead>
        <tbody>
          <% schemes.forEach(s => { %>
            <tr>
              <td class="fw-semibold"><%= s.name %> <% if (!s.active) { %><span class="badge bg-secondary">inactive</span><% } %></td>
              <td class="text-capitalize"><%= s.basis %></td>
              <td><% if (s.slabs_json) { %><span title='<%= s.slabs_json %>'>slabs</span><% } else { %><%= s.pct %>%<% } %></td>
              <td><%= s.min_achievement_pct ? (s.min_achievement_pct + '%') : '—' %></td>
              <td class="text-end" style="white-space:nowrap">
                <% if (canManage) { %>
                  <button class="btn btn-sm btn-outline-primary py-0" onclick='editScheme(<%- JSON.stringify(s) %>)'><i class="bi bi-pencil"></i></button>
                  <form method="post" action="/visits/team/schemes/<%= s.id %>/delete" class="d-inline" data-confirm="Delete this scheme?"><button class="btn btn-sm btn-outline-danger py-0">×</button></form>
                <% } %>
              </td>
            </tr>
          <% }) %>
          <% if (!schemes.length) { %><tr><td colspan="5" class="text-muted text-center py-3">No schemes yet.</td></tr><% } %>
        </tbody>
      </table>
    </div></div>
  </div>

  <% if (canManage) { %>
  <div class="col-lg-5">
    <form method="post" action="/visits/team/schemes" class="card p-3" id="schemeForm">
      <input type="hidden" name="id" id="f_id">
      <h6 class="mb-2"><i class="bi bi-plus-circle"></i> <span id="f_title">Add scheme</span></h6>
      <div class="mb-2"><label class="form-label small mb-0">Name</label><input name="name" id="f_name" class="form-control form-control-sm" required placeholder="e.g. Senior — 1.5% on collection"></div>
      <div class="row g-2">
        <div class="col-6"><label class="form-label small mb-0">Paid on</label>
          <select name="basis" id="f_basis" class="form-select form-select-sm"><option value="collection">Collection</option><option value="sales">Sales</option></select></div>
        <div class="col-6"><label class="form-label small mb-0">Flat rate %</label><input name="pct" id="f_pct" type="number" step="0.1" class="form-control form-control-sm" placeholder="1.0"></div>
      </div>
      <div class="mt-2"><label class="form-label small mb-0">Slabs <span class="text-muted">(optional, overrides flat)</span></label>
        <input name="slabs" id="f_slabs" class="form-control form-control-sm" placeholder="0:0.5, 200000:1, 500000:1.5">
        <div class="form-text">Format <code>min:pct</code> pairs — the highest slab whose amount is reached applies. Example above: ₹0–2L = 0.5%, ₹2L+ = 1%, ₹5L+ = 1.5%.</div>
      </div>
      <div class="mt-2"><label class="form-label small mb-0">Min. achievement gate %</label><input name="min_achievement_pct" id="f_gate" type="number" step="1" class="form-control form-control-sm" placeholder="0 = always pay">
        <div class="form-text">Pay only if the salesperson reaches this % of target. 0 = no gate.</div></div>
      <div class="form-check form-switch mt-2"><input class="form-check-input" type="checkbox" name="active" id="f_active" value="1" checked><label class="form-check-label small">Active</label></div>
      <div class="mt-3 d-flex gap-2"><button class="btn btn-sm btn-primary">Save scheme</button><button type="button" class="btn btn-sm btn-light" onclick="resetScheme()">Clear</button></div>
    </form>
  </div>
  <% } %>
</div>

<script>
function editScheme(s){
  document.getElementById('f_id').value = s.id;
  document.getElementById('f_title').textContent = 'Edit scheme';
  document.getElementById('f_name').value = s.name || '';
  document.getElementById('f_basis').value = s.basis || 'collection';
  document.getElementById('f_pct').value = s.pct || '';
  document.getElementById('f_gate').value = s.min_achievement_pct || '';
  document.getElementById('f_active').checked = !!s.active;
  var slabs = '';
  try { (JSON.parse(s.slabs_json||'[]')||[]).forEach(function(x,i){ slabs += (i?', ':'')+x.min+':'+x.pct; }); } catch(e){}
  document.getElementById('f_slabs').value = slabs;
  document.getElementById('schemeForm').scrollIntoView({behavior:'smooth'});
}
function resetScheme(){ document.getElementById('schemeForm').reset(); document.getElementById('f_id').value=''; document.getElementById('f_title').textContent='Add scheme'; }
</script>
<%- include('../partials/footer') %>
