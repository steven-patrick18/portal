<%- include('../partials/header') %>
<% const palette = ['#1e3a8a','#b45309','#047857','#be123c','#7c3aed','#0e7490','#c2410c','#15803d','#9333ea','#e11d48','#0891b2','#65a30d'];
   const dot = id => palette[Math.abs(id|0) % palette.length]; %>
<style>
  .zcard .city-chip { display:inline-flex; align-items:center; gap:4px; background:#f1f5f9; border:1px solid #e2e8f0; border-radius:14px; padding:2px 4px 2px 9px; margin:0 4px 4px 0; font-size:.8rem; }
  .zcard .city-chip .x { border:none; background:none; color:#94a3b8; line-height:1; padding:0 3px; cursor:pointer; }
  .zcard .city-chip .x:hover { color:#dc2626; }
  .zbar { height:6px; border-radius:3px; background:#e5e7eb; overflow:hidden; }
</style>

<div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-bullseye text-gradient"></i> Focus Areas</h4>
    <small class="text-muted">Who covers which towns. Stable territories — moving a city is one click; no dealer is ever reassigned.</small>
  </div>
  <div class="d-flex gap-2">
    <a href="/visits/plan?mode=area" class="btn btn-sm btn-outline-success"><i class="bi bi-signpost-2"></i> Plan an area sweep</a>
    <form method="post" action="/visits/zones/rebuild" class="d-inline" data-confirm="Rebuild every territory from current dealer coverage? Overwrites manual changes.">
      <button class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-repeat"></i> Auto-rebuild</button>
    </form>
  </div>
</div>

<!-- Summary -->
<div class="row g-2 mb-3">
  <div class="col"><div class="card text-center h-100"><div class="card-body p-2"><div class="h4 m-0"><%= summary.zones %></div><div class="small text-muted">salespersons</div></div></div></div>
  <div class="col"><div class="card text-center h-100"><div class="card-body p-2"><div class="h4 m-0"><%= summary.assigned %></div><div class="small text-muted">towns covered</div></div></div></div>
  <div class="col"><div class="card text-center h-100 <%= summary.unassigned ? 'border-danger' : '' %>"><div class="card-body p-2"><div class="h4 m-0 <%= summary.unassigned ? 'text-danger' : 'text-success' %>"><%= summary.unassigned %></div><div class="small text-muted">unassigned</div></div></div></div>
  <div class="col"><div class="card text-center h-100 <%= summary.conflicts ? 'border-warning' : '' %>"><div class="card-body p-2"><div class="h4 m-0 <%= summary.conflicts ? 'text-warning' : '' %>"><%= summary.conflicts %></div><div class="small text-muted">to tidy ⚠</div></div></div></div>
  <div class="col"><div class="card text-center h-100"><div class="card-body p-2"><div class="h4 m-0"><%= summary.dealers %></div><div class="small text-muted">dealers</div></div></div></div>
</div>

<!-- GPS city — accurate town from the captured location -->
<div class="card mb-3" style="background:linear-gradient(135deg,#eff6ff,#fff)">
  <div class="card-body py-2 d-flex flex-wrap align-items-center gap-2">
    <span><i class="bi bi-geo-alt-fill text-primary"></i> <strong>GPS city</strong> — town read from each dealer's captured location (typed city is kept too).</span>
    <% if (summary.geoMismatch) { %><a href="/visits/geo-mismatch" class="badge bg-warning text-dark text-decoration-none"><%= summary.geoMismatch %> typed ≠ GPS</a><% } %>
    <% if (summary.geoPending) { %><span class="badge bg-secondary"><%= summary.geoPending %> not yet read</span><% } %>
    <form method="post" action="/visits/zones/geocode" class="ms-auto" data-confirm="Read the GPS city for located dealers from OpenStreetMap? Runs in the background.">
      <button class="btn btn-sm btn-outline-primary"><i class="bi bi-cloud-download"></i> Update cities from GPS<% if (summary.geoPending) { %> (<%= summary.geoPending %>)<% } %></button>
    </form>
  </div>
</div>

<!-- Unassigned towns — the only thing that needs action -->
<% if (unassigned.length) { %>
  <div class="card mb-3 border-danger">
    <div class="card-header bg-white fw-semibold text-danger"><i class="bi bi-exclamation-triangle"></i> <%= unassigned.length %> town<%= unassigned.length===1?'':'s' %> have no owner — assign them</div>
    <div class="card-body py-2">
      <form method="post" action="/visits/zones/bulk" class="row g-2 align-items-end">
        <div class="col-md-6">
          <label class="form-label small mb-0">Pick towns (Ctrl/⌘-click for many)</label>
          <select name="cities" class="form-select form-select-sm" multiple size="5">
            <% unassigned.forEach(c => { %><option value="<%= c.city %>"><%= c.city %> · <%= c.dealers %> dealer<%= c.dealers===1?'':'s' %></option><% }) %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label small mb-0">Assign to</label>
          <select name="salesperson_id" class="form-select form-select-sm" required>
            <option value="">— choose salesperson —</option>
            <% salespersons.forEach(s => { %><option value="<%= s.id %>"><%= s.name %></option><% }) %>
          </select>
        </div>
        <div class="col-md-2"><button class="btn btn-primary btn-sm w-100"><i class="bi bi-check-lg"></i> Assign</button></div>
      </form>
    </div>
  </div>
<% } %>

<!-- One card per salesperson's territory -->
<div class="row g-3">
  <% zonesBySp.forEach(z => { %>
    <div class="col-md-6 col-lg-4">
      <div class="card h-100 zcard">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <span class="fw-semibold"><span style="display:inline-block;width:11px;height:11px;border-radius:50%;background:<%= dot(z.id) %>;margin-right:6px"></span><%= z.name %></span>
          <span class="badge bg-secondary"><%= z.nCities %> town<%= z.nCities===1?'':'s' %></span>
        </div>
        <div class="card-body py-2">
          <!-- business value -->
          <div class="d-flex justify-content-between small mb-1">
            <span>🏬 <strong><%= z.dealers %></strong> dealers</span>
            <span>🌱 <strong><%= z.prospects %></strong> prospects</span>
            <span>💰 <strong><%= fmtINR(z.outstanding) %></strong></span>
          </div>
          <!-- coverage health -->
          <div class="small text-muted d-flex justify-content-between"><span>Visited last 30 days</span><span><%= z.coverage %>%</span></div>
          <div class="zbar mb-2"><span style="display:block;height:100%;width:<%= z.coverage %>%;background:<%= z.coverage>=60?'#16a34a':(z.coverage>=30?'#f59e0b':'#ef4444') %>"></span></div>
          <% if (z.conflicts) { %><div class="small text-warning mb-1"><i class="bi bi-exclamation-triangle-fill"></i> <%= z.conflicts %> dealer<%= z.conflicts===1?'':'s' %> here belong to someone else</div><% } %>
          <!-- city chips -->
          <div class="mb-2">
            <% z.cityRows.forEach(c => { %>
              <span class="city-chip"><%= c.city %> <span class="text-muted" style="font-size:.7rem">(<%= c.dealers %>)</span>
                <form method="post" action="/visits/zones/assign" class="d-inline"><input type="hidden" name="city" value="<%= c.city %>"><button class="x" title="Remove from <%= z.name %>">&times;</button></form>
              </span>
            <% }) %>
          </div>
          <!-- add a town -->
          <% if (unassigned.length) { %>
            <form method="post" action="/visits/zones/assign" class="d-flex gap-1">
              <input type="hidden" name="salesperson_id" value="<%= z.id %>">
              <select name="city" class="form-select form-select-sm" onchange="this.form.submit()">
                <option value="">+ add a town…</option>
                <% unassigned.forEach(c => { %><option value="<%= c.city %>"><%= c.city %> (<%= c.dealers %>)</option><% }) %>
              </select>
            </form>
          <% } %>
        </div>
        <div class="card-footer py-1 bg-white">
          <a href="/visits/plan?mode=area&zone=<%= z.id %>" class="small"><i class="bi bi-signpost-2"></i> Plan a sweep of this territory →</a>
        </div>
      </div>
    </div>
  <% }) %>
  <% if (!zonesBySp.length) { %><div class="col-12"><div class="card p-4 text-center text-muted">No territories yet. Click <strong>Auto-rebuild</strong> to build them from current coverage.</div></div><% } %>
</div>
<%- include('../partials/footer') %>
