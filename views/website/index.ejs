<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-globe2"></i> Website <span class="badge bg-<%= c.published ? 'success' : 'secondary' %>"><%= c.published ? 'published' : 'hidden' %></span></h4>
    <small class="text-muted">Manage the public marketing site (sharvexport.com) — content, products, certifications, SEO &amp; social links.</small>
  </div>
  <div class="d-flex gap-2">
    <a href="/website/insights" class="btn btn-sm btn-outline-primary"><i class="bi bi-graph-up-arrow"></i> Insights</a>
    <a href="/website/brand" class="btn btn-sm btn-outline-primary"><i class="bi bi-palette"></i> Logo &amp; Brand Kit</a>
    <a href="/site" target="_blank" class="btn btn-sm btn-primary"><i class="bi bi-box-arrow-up-right"></i> View Public Site</a>
  </div>
</div>

<ul class="nav nav-tabs mb-3" role="tablist">
  <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-status" type="button"><i class="bi bi-speedometer2"></i> Status</button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-content" type="button">Content &amp; SEO</button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-products" type="button">Products (<%= products.length %>)</button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-certs" type="button">Certifications (<%= certs.length %>)</button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-blog" type="button">Blog (<%= posts.length %>)</button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-enquiries" type="button">Enquiries <% if (newCount) { %><span class="badge bg-danger"><%= newCount %></span><% } else { %>(<%= enquiries.length %>)<% } %></button></li>
  <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-instagram" type="button">Instagram (<%= instagram.length %>)</button></li>
</ul>

<div class="tab-content">
  <!-- STATUS -->
  <div class="tab-pane fade show active" id="tab-status">
    <div class="row g-3">
      <!-- SEO readiness score -->
      <div class="col-lg-5">
        <div class="card h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <h6 class="m-0"><i class="bi bi-clipboard-check"></i> SEO Readiness</h6>
              <span class="badge bg-<%= status.score===status.total ? 'success' : (status.score>=status.total-3 ? 'warning text-dark' : 'secondary') %> fs-6"><%= status.score %>/<%= status.total %></span>
            </div>
            <div class="progress mb-3" style="height:8px"><div class="progress-bar bg-<%= status.score===status.total ? 'success':'primary' %>" style="width:<%= Math.round(status.score/status.total*100) %>%"></div></div>
            <ul class="list-group list-group-flush small">
              <% status.checklist.forEach(item => { %>
                <li class="list-group-item d-flex align-items-start gap-2 px-0 py-1 border-0">
                  <% if (item.ok) { %><i class="bi bi-check-circle-fill text-success"></i><% } else { %><i class="bi bi-circle text-muted"></i><% } %>
                  <div>
                    <span class="<%= item.ok ? '' : 'fw-semibold' %>"><%= item.label %></span>
                    <% if (!item.ok) { %><div class="text-muted" style="font-size:.78rem"><%= item.hint %></div><% } %>
                  </div>
                </li>
              <% }) %>
            </ul>
          </div>
        </div>
      </div>

      <div class="col-lg-7">
        <!-- Content snapshot -->
        <div class="card mb-3"><div class="card-body">
          <h6 class="mb-3"><i class="bi bi-bar-chart"></i> Content Snapshot</h6>
          <div class="row text-center g-2">
            <div class="col"><div class="border rounded py-2"><div class="fs-4 fw-bold"><%= status.liveProducts %></div><div class="small text-muted">Products</div></div></div>
            <div class="col"><div class="border rounded py-2"><div class="fs-4 fw-bold"><%= status.liveCerts %></div><div class="small text-muted">Certificates</div></div></div>
            <div class="col"><div class="border rounded py-2"><div class="fs-4 fw-bold"><%= status.publishedPosts %><% if (status.draftPosts) { %><span class="small text-muted">+<%= status.draftPosts %>d</span><% } %></div><div class="small text-muted">Blog posts</div></div></div>
            <div class="col"><div class="border rounded py-2"><div class="fs-4 fw-bold"><%= status.instagram %></div><div class="small text-muted">Instagram</div></div></div>
            <div class="col"><div class="border rounded py-2 <%= status.enquiriesNew ? 'bg-danger-subtle' : '' %>"><div class="fs-4 fw-bold"><%= status.enquiriesTotal %><% if (status.enquiriesNew) { %> <span class="badge bg-danger align-middle"><%= status.enquiriesNew %> new</span><% } %></div><div class="small text-muted">Enquiries</div></div></div>
          </div>
        </div></div>

        <!-- Live pages / sitemap -->
        <div class="card mb-3"><div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <h6 class="m-0"><i class="bi bi-diagram-3"></i> Live Pages &amp; Sitemap <span class="badge bg-light text-dark"><%= status.sitemapUrls.length %> URLs</span></h6>
            <div>
              <a href="https://sharvexports.com/sitemap.xml" target="_blank" class="btn btn-sm btn-outline-secondary py-0">sitemap.xml</a>
              <a href="https://sharvexports.com/robots.txt" target="_blank" class="btn btn-sm btn-outline-secondary py-0">robots.txt</a>
            </div>
          </div>
          <div class="d-flex flex-wrap gap-1">
            <% status.sitemapUrls.forEach(u => { %>
              <a href="https://sharvexports.com<%= u %>" target="_blank" class="badge bg-light text-primary border text-decoration-none"><%= u %> <i class="bi bi-box-arrow-up-right" style="font-size:.7rem"></i></a>
            <% }) %>
          </div>
          <div class="small text-muted mt-2">Published blog posts auto-add here. Submit the sitemap once in Search Console; new posts are picked up automatically.</div>
        </div></div>

        <!-- Search engine tools -->
        <div class="card"><div class="card-body">
          <h6 class="mb-2"><i class="bi bi-search"></i> Search Engine Dashboards</h6>
          <p class="small text-muted mb-2">Live crawl stats, indexed-page counts and search-query data live inside each search engine's own console (Google updates a few days after verifying). Open them here:</p>
          <div class="d-flex flex-wrap gap-2">
            <a href="https://search.google.com/search-console?resource_id=sc-domain:sharvexports.com" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-google"></i> Google Search Console <span class="badge bg-<%= c.google_verification ? 'success':'secondary' %>"><%= c.google_verification ? 'verified' : 'not set' %></span></a>
            <a href="https://www.bing.com/webmasters/home" target="_blank" class="btn btn-sm btn-outline-primary"><i class="bi bi-microsoft"></i> Bing Webmaster <span class="badge bg-<%= c.bing_verification ? 'success':'secondary' %>"><%= c.bing_verification ? 'verified' : 'not set' %></span></a>
          </div>
          <div class="alert alert-light border small mt-2 mb-0"><i class="bi bi-graph-up-arrow"></i> See your <strong>visitors &amp; Google ranking inside the portal</strong> on the <a href="/website/insights">Insights page</a> — connect Google Analytics + Search Console once to pull clicks, impressions, average position and top search terms here.</div>
        </div></div>
      </div>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="tab-pane fade" id="tab-content">
    <form method="post" action="/website/content" class="card p-3">
      <div class="row g-3">
        <div class="col-md-6"><label class="form-label">Company Name</label><input name="company_name" class="form-control" value="<%= c.company_name||'' %>"></div>
        <div class="col-md-6"><label class="form-label">Tagline</label><input name="tagline" class="form-control" value="<%= c.tagline||'' %>"></div>
        <div class="col-12"><hr class="my-1"><strong class="small text-muted">HERO (top banner)</strong></div>
        <div class="col-md-6"><label class="form-label">Hero Headline</label><input name="hero_title" class="form-control" value="<%= c.hero_title||'' %>"></div>
        <div class="col-md-3"><label class="form-label">CTA Button Text</label><input name="hero_cta_text" class="form-control" value="<%= c.hero_cta_text||'' %>"></div>
        <div class="col-md-3"><label class="form-label">Factory Video (YouTube link)</label><input name="hero_video_url" class="form-control" value="<%= c.hero_video_url||'' %>" placeholder="https://youtu.be/..."></div>
        <div class="col-12"><label class="form-label">Hero Sub-text</label><textarea name="hero_subtitle" rows="2" class="form-control"><%= c.hero_subtitle||'' %></textarea></div>

        <div class="col-12"><hr class="my-1"><strong class="small text-muted">ABOUT</strong></div>
        <div class="col-md-12"><label class="form-label">About Title</label><input name="about_title" class="form-control" value="<%= c.about_title||'' %>"></div>
        <div class="col-12"><label class="form-label">About Text</label>
          <%- include('../partials/richEditor', { reName: 'about_html', reHtml: c.about_html, reRows: 8 }) %>
        </div>

        <div class="col-12"><hr class="my-1"><strong class="small text-muted">CONTACT</strong></div>
        <div class="col-md-3"><label class="form-label">Phone</label><input name="phone" class="form-control" value="<%= c.phone||'' %>"></div>
        <div class="col-md-3"><label class="form-label">Email</label><input name="email" class="form-control" value="<%= c.email||'' %>"></div>
        <div class="col-md-3"><label class="form-label">WhatsApp (with country code)</label><input name="whatsapp" class="form-control" value="<%= c.whatsapp||'' %>" placeholder="91XXXXXXXXXX"></div>
        <div class="col-md-3"><label class="form-label">Address</label><input name="address" class="form-control" value="<%= c.address||'' %>"></div>

        <div class="col-12"><hr class="my-1"><strong class="small text-muted">SOCIAL LINKS</strong></div>
        <div class="col-md-3"><label class="form-label">Instagram URL</label><input name="instagram" class="form-control" value="<%= c.instagram||'' %>"></div>
        <div class="col-md-3"><label class="form-label">LinkedIn URL</label><input name="linkedin" class="form-control" value="<%= c.linkedin||'' %>"></div>
        <div class="col-md-3"><label class="form-label">Facebook URL</label><input name="facebook" class="form-control" value="<%= c.facebook||'' %>"></div>
        <div class="col-md-3"><label class="form-label">YouTube URL</label><input name="youtube" class="form-control" value="<%= c.youtube||'' %>"></div>

        <div class="col-12"><hr class="my-1"><strong class="small text-muted">SEO / META</strong></div>
        <div class="col-md-6"><label class="form-label">Meta Title (Google tab title)</label><input name="meta_title" class="form-control" maxlength="70" value="<%= c.meta_title||'' %>"></div>
        <div class="col-md-6"><label class="form-label">Meta Description (Google snippet)</label><input name="meta_desc" class="form-control" maxlength="170" value="<%= c.meta_desc||'' %>"></div>
        <div class="col-md-6"><label class="form-label">Google Search Console verification <span class="text-muted">(content value of the meta tag)</span></label><input name="google_verification" class="form-control" value="<%= c.google_verification||'' %>" placeholder="e.g. abcd1234… (from Search Console → HTML tag method)"></div>
        <div class="col-md-6"><label class="form-label">Bing verification <span class="text-muted">(msvalidate.01)</span></label><input name="bing_verification" class="form-control" value="<%= c.bing_verification||'' %>" placeholder="optional"></div>
        <div class="col-12"><div class="alert alert-light border small mb-0"><i class="bi bi-google"></i> <strong>To verify on Google:</strong> Search Console → add property <code>sharvexports.com</code> → choose <em>HTML tag</em> → copy just the <code>content="…"</code> value here → Save → click Verify. Then submit <code>https://sharvexports.com/sitemap.xml</code> under Sitemaps.</div></div>

        <div class="col-12"><hr class="my-1"><strong class="small text-muted">ADVANCED — section data (JSON: stats / why-us / process). Edit carefully.</strong></div>
        <div class="col-md-4"><label class="form-label small">Stats <span class="text-muted">[{"value","label"}]</span></label><textarea name="stats_json" rows="5" class="form-control form-control-sm" style="font-family:monospace;font-size:.72rem"><%= c.stats_json||'' %></textarea></div>
        <div class="col-md-4"><label class="form-label small">Why-Us <span class="text-muted">[{"icon","title","text"}]</span></label><textarea name="why_json" rows="5" class="form-control form-control-sm" style="font-family:monospace;font-size:.72rem"><%= c.why_json||'' %></textarea></div>
        <div class="col-md-4"><label class="form-label small">Process <span class="text-muted">[{"step","title","text"}]</span></label><textarea name="process_json" rows="5" class="form-control form-control-sm" style="font-family:monospace;font-size:.72rem"><%= c.process_json||'' %></textarea></div>

        <div class="col-12">
          <div class="form-check form-switch"><input class="form-check-input" type="checkbox" name="published" value="1" <%= c.published ? 'checked' : '' %>><label class="form-check-label">Site published (visible to public)</label></div>
        </div>
      </div>
      <div class="mt-3"><button class="btn btn-primary"><i class="bi bi-save"></i> Save Content</button> <a href="/site" target="_blank" class="btn btn-outline-secondary">Preview</a></div>
    </form>
  </div>

  <!-- PRODUCTS -->
  <div class="tab-pane fade" id="tab-products">
    <div class="card p-3 mb-3">
      <h6 class="mb-2"><i class="bi bi-plus-circle"></i> Add Product / Category</h6>
      <form method="post" action="/website/products" enctype="multipart/form-data" class="row g-2 align-items-end">
        <div class="col-md-3"><label class="form-label small">Name</label><input name="name" class="form-control form-control-sm" required></div>
        <div class="col-md-4"><label class="form-label small">Tagline</label><input name="tagline" class="form-control form-control-sm"></div>
        <div class="col-md-3"><label class="form-label small">Photo (optional)</label><input type="file" name="image" accept="image/*" class="form-control form-control-sm"></div>
        <div class="col-md-2"><button class="btn btn-primary btn-sm w-100">Add</button></div>
      </form>
    </div>
    <div class="row g-2">
      <% products.forEach(p => { %>
      <div class="col-md-6">
        <form method="post" action="/website/products/<%= p.id %>" enctype="multipart/form-data" class="card p-2 d-flex flex-row gap-2 align-items-center">
          <div style="width:54px;height:54px;border-radius:8px;overflow:hidden;background:#f1f5f9;display:flex;align-items:center;justify-content:center;flex:0 0 auto">
            <% if (p.image_path) { %><img src="<%= p.image_path %>" style="width:54px;height:54px;object-fit:cover"><% } else { %>👕<% } %>
          </div>
          <div class="flex-grow-1">
            <input name="name" class="form-control form-control-sm mb-1" value="<%= p.name %>">
            <input name="tagline" class="form-control form-control-sm" value="<%= p.tagline||'' %>" placeholder="tagline">
          </div>
          <div class="d-flex flex-column gap-1" style="flex:0 0 auto">
            <input type="file" name="image" accept="image/*" class="form-control form-control-sm" style="width:130px">
            <div class="form-check form-switch m-0"><input class="form-check-input" type="checkbox" name="active" value="1" <%= p.active?'checked':'' %>><label class="form-check-label small">live</label></div>
          </div>
          <div class="d-flex flex-column gap-1" style="flex:0 0 auto">
            <button class="btn btn-sm btn-outline-primary" title="Save"><i class="bi bi-check-lg"></i></button>
            <button formaction="/website/products/<%= p.id %>/delete" class="btn btn-sm btn-outline-danger" data-confirm="Remove this product?" title="Delete">×</button>
          </div>
        </form>
      </div>
      <% }) %>
      <% if (products.length===0) { %><div class="col-12 text-muted text-center py-3">No products yet — add some above.</div><% } %>
    </div>
  </div>

  <!-- CERTIFICATIONS -->
  <div class="tab-pane fade" id="tab-certs">
    <div class="card p-3 mb-3">
      <h6 class="mb-2"><i class="bi bi-patch-check"></i> Add Certification</h6>
      <form method="post" action="/website/certifications" enctype="multipart/form-data" class="row g-2 align-items-end">
        <div class="col-md-5"><label class="form-label small">Certification Name</label><input name="name" class="form-control form-control-sm" required placeholder="e.g. ISO 9001:2015"></div>
        <div class="col-md-4"><label class="form-label small">Certificate image / logo (upload when obtained)</label><input type="file" name="image" accept="image/*" class="form-control form-control-sm"></div>
        <div class="col-md-3"><button class="btn btn-primary btn-sm w-100">Add</button></div>
      </form>
    </div>
    <div class="row g-2">
      <% certs.forEach(ct => { %>
      <div class="col-md-6">
        <form method="post" action="/website/certifications/<%= ct.id %>" enctype="multipart/form-data" class="card p-2 d-flex flex-row gap-2 align-items-center">
          <div style="width:54px;height:54px;border-radius:8px;overflow:hidden;background:#f1f5f9;display:flex;align-items:center;justify-content:center;flex:0 0 auto">
            <% if (ct.image_path) { %><img src="<%= ct.image_path %>" style="max-width:54px;max-height:54px;object-fit:contain"><% } else { %>🏅<% } %>
          </div>
          <div class="flex-grow-1"><input name="name" class="form-control form-control-sm" value="<%= ct.name %>"></div>
          <input type="file" name="image" accept="image/*" class="form-control form-control-sm" style="width:130px;flex:0 0 auto">
          <div class="form-check form-switch m-0" style="flex:0 0 auto"><input class="form-check-input" type="checkbox" name="active" value="1" <%= ct.active?'checked':'' %>><label class="form-check-label small">show</label></div>
          <div class="d-flex flex-column gap-1" style="flex:0 0 auto">
            <button class="btn btn-sm btn-outline-primary"><i class="bi bi-check-lg"></i></button>
            <button formaction="/website/certifications/<%= ct.id %>/delete" class="btn btn-sm btn-outline-danger" data-confirm="Remove?">×</button>
          </div>
        </form>
      </div>
      <% }) %>
    </div>
    <div class="alert alert-info small mt-2"><i class="bi bi-info-circle"></i> Names are pre-filled as your target standards. Upload each certificate image once obtained — until then the name shows as a clean badge on the site.</div>
  </div>

  <!-- BLOG -->
  <div class="tab-pane fade" id="tab-blog">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <span class="small text-muted">Posts published here appear at <code>/blog</code> on the website and auto-add to the sitemap.</span>
      <a href="/website/posts/new" class="btn btn-sm btn-primary"><i class="bi bi-plus"></i> New Post</a>
    </div>
    <div class="card"><div class="table-responsive">
      <table class="table table-sm m-0 align-middle">
        <thead><tr><th>Title</th><th>Status</th><th>Published</th><th>URL</th><th></th></tr></thead>
        <tbody>
          <% posts.forEach(po => { %>
            <tr>
              <td><strong><%= po.title %></strong><% if (po.excerpt) { %><div class="small text-muted"><%= po.excerpt.slice(0,70) %></div><% } %></td>
              <td><span class="badge bg-<%= po.status==='published'?'success':'secondary' %>"><%= po.status %></span></td>
              <td class="small"><%= po.published_at ? fmtDate(po.published_at + ' 00:00:00') : '—' %></td>
              <td class="small"><% if (po.status==='published') { %><a href="/blog/<%= po.slug %>" target="_blank">/blog/<%= po.slug %></a><% } else { %><span class="text-muted">/blog/<%= po.slug %></span><% } %></td>
              <td style="white-space:nowrap">
                <a href="/website/posts/<%= po.id %>/edit" class="btn btn-sm btn-outline-primary py-0"><i class="bi bi-pencil"></i></a>
                <form method="post" action="/website/posts/<%= po.id %>/delete" class="d-inline" data-confirm="Delete this post?"><button class="btn btn-sm btn-outline-danger py-0">×</button></form>
              </td>
            </tr>
          <% }) %>
          <% if (posts.length===0) { %><tr><td colspan="5" class="text-muted text-center py-3">No posts yet. Click "New Post" to write your first — great for SEO.</td></tr><% } %>
        </tbody>
      </table>
    </div></div>
  </div>

  <!-- ENQUIRIES -->
  <div class="tab-pane fade" id="tab-enquiries">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span><i class="bi bi-inbox"></i> Buyer Enquiries from the website</span>
        <span class="small text-muted"><%= newCount %> new · <%= enquiries.length %> total</span>
      </div>
      <div class="table-responsive">
        <table class="table table-sm m-0 align-middle">
          <thead><tr><th>When</th><th>Name / Company</th><th>Contact</th><th>Interest</th><th>Message</th><th>Status</th><th></th></tr></thead>
          <tbody>
            <% enquiries.forEach(e => { %>
              <tr class="<%= e.status==='new' ? 'table-warning' : '' %>">
                <td class="small text-muted" style="white-space:nowrap"><%= fmtDate(e.created_at) %></td>
                <td><strong><%= e.name %></strong><% if (e.company) { %><div class="small text-muted"><%= e.company %></div><% } %></td>
                <td class="small"><% if (e.phone) { %><a href="tel:<%= e.phone %>"><%= e.phone %></a><br><% } %><% if (e.email) { %><a href="mailto:<%= e.email %>"><%= e.email %></a><% } %></td>
                <td class="small"><%= e.product_interest || '—' %></td>
                <td class="small" style="max-width:240px"><%= e.message || '' %></td>
                <td>
                  <% if (e.status==='converted' && e.converted_dealer_id) { %>
                    <a href="/dealers/<%= e.converted_dealer_id %>"><span class="badge bg-success">→ <%= e.dealer_name || 'dealer' %></span></a>
                  <% } else { %>
                    <form method="post" action="/website/enquiries/<%= e.id %>/status" class="d-flex gap-1">
                      <select name="status" class="form-select form-select-sm" style="width:120px" onchange="this.form.submit()">
                        <% ['new','contacted','spam','archived'].forEach(s => { %><option value="<%= s %>" <%= e.status===s?'selected':'' %>><%= s %></option><% }) %>
                      </select>
                    </form>
                  <% } %>
                </td>
                <td style="white-space:nowrap">
                  <% if (e.status!=='converted') { %>
                    <form method="post" action="/website/enquiries/<%= e.id %>/convert" class="d-inline" data-confirm="Create a dealer from this enquiry?"><button class="btn btn-sm btn-outline-success py-0" title="Convert to dealer"><i class="bi bi-person-plus"></i></button></form>
                  <% } %>
                  <form method="post" action="/website/enquiries/<%= e.id %>/delete" class="d-inline" data-confirm="Delete this enquiry?"><button class="btn btn-sm btn-outline-danger py-0">×</button></form>
                </td>
              </tr>
            <% }) %>
            <% if (enquiries.length===0) { %><tr><td colspan="7" class="text-muted text-center py-4">No enquiries yet. They'll arrive here when buyers submit the form on your website.</td></tr><% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- INSTAGRAM -->
  <div class="tab-pane fade" id="tab-instagram">
    <div class="card p-3 mb-3">
      <h6 class="mb-2"><i class="bi bi-instagram"></i> Add a post to the feed</h6>
      <p class="small text-muted mb-2">Upload a square image and (optionally) link it to the actual Instagram post. These show as a grid on the website's "Latest from our feed" section.</p>
      <form method="post" action="/website/instagram" enctype="multipart/form-data" class="row g-2 align-items-end">
        <div class="col-md-3"><label class="form-label small">Image (square)</label><input type="file" name="image" accept="image/*" class="form-control form-control-sm" required></div>
        <div class="col-md-4"><label class="form-label small">Caption</label><input name="caption" class="form-control form-control-sm"></div>
        <div class="col-md-3"><label class="form-label small">Link to IG post (optional)</label><input name="link" class="form-control form-control-sm" placeholder="https://instagram.com/p/..."></div>
        <div class="col-md-2"><button class="btn btn-primary btn-sm w-100">Add</button></div>
      </form>
    </div>
    <div class="row g-2">
      <% instagram.forEach(ig => { %>
      <div class="col-md-4">
        <form method="post" action="/website/instagram/<%= ig.id %>" enctype="multipart/form-data" class="card p-2 d-flex flex-row gap-2 align-items-center">
          <div style="width:60px;height:60px;border-radius:8px;overflow:hidden;background:#f1f5f9;flex:0 0 auto"><% if (ig.image_path) { %><img src="<%= ig.image_path %>" style="width:60px;height:60px;object-fit:cover"><% } %></div>
          <div class="flex-grow-1">
            <input name="caption" class="form-control form-control-sm mb-1" value="<%= ig.caption||'' %>" placeholder="caption">
            <input name="link" class="form-control form-control-sm" value="<%= ig.link||'' %>" placeholder="IG link">
          </div>
          <input type="file" name="image" accept="image/*" class="form-control form-control-sm" style="width:120px;flex:0 0 auto">
          <div class="form-check form-switch m-0" style="flex:0 0 auto"><input class="form-check-input" type="checkbox" name="active" value="1" <%= ig.active?'checked':'' %>><label class="form-check-label small">show</label></div>
          <div class="d-flex flex-column gap-1" style="flex:0 0 auto">
            <button class="btn btn-sm btn-outline-primary"><i class="bi bi-check-lg"></i></button>
            <button formaction="/website/instagram/<%= ig.id %>/delete" class="btn btn-sm btn-outline-danger" data-confirm="Remove?">×</button>
          </div>
        </form>
      </div>
      <% }) %>
      <% if (instagram.length===0) { %><div class="col-12 text-muted text-center py-3">No Instagram posts yet — add a few above to show a feed on the site.</div><% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
