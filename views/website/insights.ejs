<%- include('../partials/header') %>
<%
  const nf  = n => Number(n||0).toLocaleString('en-IN');
  const pct = n => (Number(n||0)*100).toFixed(1)+'%';
  const pos = n => Number(n||0).toFixed(1);
  const dur = s => { s=Math.round(Number(s||0)); return Math.floor(s/60)+'m '+(s%60)+'s'; };
  const seoIcon = s => s==='pass'?'<i class="bi bi-check-circle-fill text-success"></i>':(s==='warn'?'<i class="bi bi-exclamation-triangle-fill text-warning"></i>':'<i class="bi bi-x-circle-fill text-danger"></i>');
  const scoreColor = v => v>=80?'success':(v>=50?'warning':'danger');
  const sevBadge = s => s==='fail'?'<span class="badge bg-danger">Fix now</span>':(s==='warn'?'<span class="badge bg-warning text-dark">Improve</span>':'<span class="badge bg-info text-dark">Grow</span>');
  // ▲/▼ vs previous period. invert=true → lower is better (e.g. rank position).
  const deltaBadge = (cur, prev, invert) => {
    cur=Number(cur||0); prev=Number(prev||0);
    if(!prev) return '';
    const ch=(cur-prev)/prev*100;
    if(Math.abs(ch)<0.5) return '<span class="text-muted" style="font-size:11px">±0%</span>';
    const up=ch>0, good = invert ? !up : up;
    return '<span style="font-size:11px;font-weight:600" class="text-'+(good?'success':'danger')+'">'+(up?'▲':'▼')+' '+Math.abs(ch).toFixed(0)+'% <span class="text-muted fw-normal">vs prev</span></span>';
  };
  const rankColor = p => { p=Number(p||0); return p>0&&p<=3?'success':(p<=10?'warning':'danger'); };
  const pathOf = u => { try { return new URL(u).pathname || u; } catch(e){ return u; } };
  const fmtD = s => { const t=String(s||'').replace(/[^0-9]/g,''); return t.length>=8 ? t.slice(6,8)+'/'+t.slice(4,6) : s; };
  function barChart(series, valKey, color){
    const n = series ? series.length : 0; if(!n) return '';
    const W=1000, H=80, max = Math.max(1, ...series.map(s=>Number(s[valKey])||0)), bw = Math.max(2, (W/n)-2);
    let bars='';
    series.forEach((s,i)=>{ const v=Number(s[valKey])||0; const h=Math.round(v/max*(H-6)); const x=i*(W/n);
      bars += '<rect x="'+x.toFixed(1)+'" y="'+(H-Math.max(h,1))+'" width="'+bw.toFixed(1)+'" height="'+Math.max(h,1)+'" rx="1" fill="'+color+'"/>'; });
    return '<svg viewBox="0 0 '+W+' '+H+'" width="100%" height="80" preserveAspectRatio="none" style="display:block">'+bars+'</svg>';
  }
%>
<style>
  .tile{background:var(--bs-light,#f7f7f5);border-radius:12px;padding:14px 16px}
  .tile .v{font-size:24px;font-weight:700;line-height:1.1}
  .tile .l{font-size:12px;color:#6c757d}
  .ins-table td,.ins-table th{padding:.35rem .5rem;font-size:13px}
  .ins-table td.num{text-align:right;font-variant-numeric:tabular-nums}
</style>

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <div>
    <h4 class="m-0"><i class="bi bi-graph-up-arrow"></i> Website Insights</h4>
    <small class="text-muted"><a href="/website#tab-status">← Back to Website</a> · Visitors &amp; Google ranking, inside the portal.</small>
  </div>
  <div class="d-flex gap-2 align-items-center">
    <div class="btn-group btn-group-sm" role="group">
      <% [7,28,90].forEach(d => { %>
        <a href="/website/insights?days=<%= d %>" class="btn btn-outline-secondary <%= days===d?'active':'' %>"><%= d %>d</a>
      <% }) %>
    </div>
    <a href="/website/insights?days=<%= days %>&refresh=1" class="btn btn-sm btn-outline-primary" title="Refresh from Google"><i class="bi bi-arrow-clockwise"></i></a>
  </div>
</div>

<% if (data.errors && data.errors.length) { %>
  <div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> <strong>Couldn't load some data:</strong>
    <ul class="mb-0 small"><% data.errors.forEach(e => { %><li><%= e %></li><% }) %></ul>
    <div class="small mt-1 text-muted">Usually means the service account hasn't been granted access yet, or the site/property ID is wrong — check the Connection settings below.</div>
  </div>
<% } %>

<!-- ===== ALERTS (#11) ===== -->
<% if (typeof alerts !== 'undefined' && alerts && alerts.length) { %>
  <% alerts.forEach(a => { %><div class="alert alert-<%= a.level %> py-2 small mb-2"><i class="bi bi-bell-fill"></i> <%= a.msg %></div><% }) %>
<% } %>

<!-- ===== MONTHLY GOALS (#2) ===== -->
<div class="card mb-3 shadow-sm"><div class="card-body py-2">
  <div class="d-flex justify-content-between align-items-center">
    <strong class="small"><i class="bi bi-bullseye"></i> This month's goals</strong>
    <button class="btn btn-sm btn-link p-0 text-decoration-none" data-bs-toggle="collapse" data-bs-target="#goalCfg">set targets</button>
  </div>
  <% if (typeof goals !== 'undefined' && goals) { %>
    <div class="row g-3 mt-0">
      <% if (goals.visitors.target) { %>
      <div class="col-md-6">
        <div class="d-flex justify-content-between small"><span>Visitors</span><span><%= nf(goals.visitors.current) %> / <%= nf(goals.visitors.target) %> (<%= goals.visitors.pct %>%)</span></div>
        <div class="progress" style="height:8px"><div class="progress-bar bg-primary" style="width:<%= goals.visitors.pct %>%"></div></div>
      </div><% } %>
      <% if (goals.enquiries.target) { %>
      <div class="col-md-6">
        <div class="d-flex justify-content-between small"><span>Website enquiries</span><span><%= nf(goals.enquiries.current) %> / <%= nf(goals.enquiries.target) %> (<%= goals.enquiries.pct %>%)</span></div>
        <div class="progress" style="height:8px"><div class="progress-bar bg-success" style="width:<%= goals.enquiries.pct %>%"></div></div>
      </div><% } %>
    </div>
  <% } else { %>
    <div class="small text-muted mt-1">No targets set yet — click <strong>set targets</strong> to track monthly progress.</div>
  <% } %>
  <div class="collapse mt-2" id="goalCfg">
    <form method="post" action="/website/insights/goals" class="row g-2 align-items-end">
      <div class="col-auto"><label class="form-label small mb-0">Monthly visitors target</label><input name="goal_visitors" type="number" min="0" class="form-control form-control-sm" value="<%= (goals && goals.visitors.target) || '' %>" style="width:150px"></div>
      <div class="col-auto"><label class="form-label small mb-0">Monthly enquiries target</label><input name="goal_enquiries" type="number" min="0" class="form-control form-control-sm" value="<%= (goals && goals.enquiries.target) || '' %>" style="width:150px"></div>
      <div class="col-auto"><button class="btn btn-sm btn-primary">Save goals</button></div>
    </form>
  </div>
</div></div>

<!-- ===== SEO HEALTH & BOOST ===== -->
<% if (audit && audit.score != null) { %>
<div class="card mb-3 shadow-sm">
  <div class="card-body">
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
      <div>
        <h6 class="m-0"><i class="bi bi-rocket-takeoff"></i> SEO Health &amp; Boost</h6>
        <small class="text-muted">Live check of <%= audit.origin %> · <%= audit.reachable ? 'homepage fetched' : 'homepage not reachable' %></small>
      </div>
      <a href="/website/insights?days=<%= days %>&refresh=1" class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-repeat"></i> Re-run check</a>
    </div>
    <% if (audit.fetchError) { %><div class="alert alert-warning small py-1 mb-2">Couldn’t fetch the homepage (<%= audit.fetchError %>) — on-page checks skipped; account checks still shown.</div><% } %>
    <div class="row g-3 align-items-center">
      <div class="col-md-3 text-center border-end">
        <div class="display-3 fw-bold text-<%= scoreColor(audit.score) %>"><%= audit.score %></div>
        <div class="small text-muted">SEO score / 100</div>
        <div class="progress mt-2" style="height:8px"><div class="progress-bar bg-<%= scoreColor(audit.score) %>" style="width:<%= audit.score %>%"></div></div>
        <div class="small mt-2">
          <span class="text-success fw-semibold"><%= audit.counts.pass %> passed</span> ·
          <span class="text-warning fw-semibold"><%= audit.counts.warn %> warn</span> ·
          <span class="text-danger fw-semibold"><%= audit.counts.fail %> fail</span>
        </div>
      </div>
      <div class="col-md-9">
        <div class="row">
          <% audit.checks.forEach(c => { %>
            <div class="col-md-6 d-flex gap-2 py-1 small">
              <span class="pt-1"><%- seoIcon(c.status) %></span>
              <div>
                <strong><%= c.label %></strong>
                <div class="text-muted"><%= c.detail %><% if (c.status!=='pass' && c.fix) { %><span class="d-block text-body-secondary">→ <%= c.fix %></span><% } %></div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Boost action plan -->
<div class="card mb-4 shadow-sm">
  <div class="card-header bg-white"><strong><i class="bi bi-lightning-charge-fill text-warning"></i> Boost plan — do these to climb Google</strong></div>
  <div class="card-body">
    <% if (audit.actions && audit.actions.length) { %>
      <div class="small fw-semibold mb-1">1. Fix what’s holding you back</div>
      <ol class="small">
        <% audit.actions.forEach(a => { %><li class="mb-1"><%- sevBadge(a.severity) %> <strong><%= a.label %></strong> — <%= a.fix %></li><% }) %>
      </ol>
    <% } else { %>
      <div class="small text-success mb-2"><i class="bi bi-check-circle"></i> No technical issues found — focus on growth below.</div>
    <% } %>
    <div class="small fw-semibold mb-1 mt-2">2. Grow your reach (high impact for a B2B exporter)</div>
    <ol class="small mb-0">
      <% (audit.growth||[]).forEach(a => { %><li class="mb-1"><strong><%= a.label %></strong> — <%= a.fix %></li><% }) %>
    </ol>
  </div>
</div>
<% } %>

<!-- ===== SITE-WIDE SEO AUDIT (#6) ===== -->
<% if (typeof siteAudit !== 'undefined' && siteAudit && siteAudit.pages && siteAudit.pages.length) { %>
<div class="card mb-4 shadow-sm"><div class="card-body">
  <strong class="small"><i class="bi bi-files"></i> Page-by-page SEO score</strong>
  <div class="table-responsive"><table class="table table-sm ins-table m-0 mt-2">
    <thead><tr><th>Page</th><th class="num">Score</th><th>Needs work</th></tr></thead>
    <tbody>
      <% siteAudit.pages.forEach(p => { %>
        <tr>
          <td><%= p.path %></td>
          <td class="num"><% if (p.score == null) { %><span class="text-muted">—</span><% } else { %><span class="fw-semibold text-<%= scoreColor(p.score) %>"><%= p.score %></span><% } %></td>
          <td class="small text-muted"><% if (!p.reachable) { %>not reachable<% } else if (!p.issues.length) { %><span class="text-success">all good</span><% } else { %><%= p.issues.join(', ') %><% } %></td>
        </tr>
      <% }) %>
    </tbody>
  </table></div>
</div></div>
<% } %>

<!-- ===== PAGE SPEED / CORE WEB VITALS (#8) ===== -->
<div class="card mb-4 shadow-sm"><div class="card-body">
  <div class="d-flex justify-content-between align-items-center mb-1">
    <strong class="small"><i class="bi bi-speedometer2"></i> Page speed &amp; Core Web Vitals</strong>
    <a href="/website/insights?days=<%= days %>&pagespeed=1" class="btn btn-sm btn-outline-primary">Check speed</a>
  </div>
  <% if (typeof pagespeed !== 'undefined' && pagespeed && (pagespeed.mobile || pagespeed.desktop)) { %>
    <div class="row g-3">
      <% ['mobile','desktop'].forEach(function(k){ var m = pagespeed[k]; if(!m) return; %>
        <div class="col-md-6">
          <div class="small fw-semibold text-capitalize"><i class="bi bi-<%= k==='mobile'?'phone':'display' %>"></i> <%= k %>
            <% if (m.score != null) { %><span class="badge bg-<%= scoreColor(m.score) %> ms-1"><%= m.score %></span><% } %>
          </div>
          <% if (m.error) { %><div class="small text-danger"><%= m.error %></div><% } else { %>
          <table class="table table-sm ins-table m-0"><tbody>
            <tr><td>Largest Contentful Paint</td><td class="num"><%= m.lcp %></td></tr>
            <tr><td>Cumulative Layout Shift</td><td class="num"><%= m.cls %></td></tr>
            <tr><td>Total Blocking Time</td><td class="num"><%= m.tbt %></td></tr>
            <tr><td>First Contentful Paint</td><td class="num"><%= m.fcp %></td></tr>
          </tbody></table>
          <% } %>
        </div>
      <% }); %>
    </div>
    <div class="small text-muted mt-1">By Google PageSpeed Insights · aim for 90+ (green) · checked <%= pagespeed.fetchedAt ? pagespeed.fetchedAt.slice(0,10) : '' %>.</div>
  <% } else if (pagespeed && pagespeed.error) { %>
    <div class="small text-danger mt-1"><%= pagespeed.error %></div>
  <% } else { %>
    <div class="small text-muted mt-1">Click <strong>Check speed</strong> to measure your homepage's mobile &amp; desktop performance (~15 seconds).</div>
  <% } %>
</div></div>

<% if (!data.configured) { %>
  <div class="alert alert-info"><i class="bi bi-plug"></i> Connect your Google account once to see live visitor &amp; ranking data here. Follow the steps below.</div>
<% } else { %>

  <!-- ===== GA4 VISITORS ===== -->
  <h6 class="text-muted mt-1"><i class="bi bi-people"></i> Visitors <span class="fw-normal small">· last <%= days %> days · Google Analytics</span>
    <% if (data.configured) { %><span id="liveBox" class="badge bg-success-subtle text-success border border-success-subtle ms-2" style="display:none"><span class="spinner-grow spinner-grow-sm" style="width:.5rem;height:.5rem"></span> <strong id="liveN">0</strong> active now</span><% } %>
  </h6>
  <% if (data.ga4) { %>
    <div class="row g-2 mb-2">
      <div class="col-6 col-md-3"><div class="tile"><div class="v"><%= nf(data.ga4.totals.users) %></div><div class="l">Visitors</div><% if (data.ga4.prev) { %><%- deltaBadge(data.ga4.totals.users, data.ga4.prev.users) %><% } %></div></div>
      <div class="col-6 col-md-3"><div class="tile"><div class="v"><%= nf(data.ga4.totals.sessions) %></div><div class="l">Sessions</div><% if (data.ga4.prev) { %><%- deltaBadge(data.ga4.totals.sessions, data.ga4.prev.sessions) %><% } %></div></div>
      <div class="col-6 col-md-3"><div class="tile"><div class="v"><%= nf(data.ga4.totals.views) %></div><div class="l">Page views</div><% if (data.ga4.prev) { %><%- deltaBadge(data.ga4.totals.views, data.ga4.prev.views) %><% } %></div></div>
      <div class="col-6 col-md-3"><div class="tile"><div class="v"><%= dur(data.ga4.totals.avgDuration) %></div><div class="l">Avg. time on site</div><% if (data.ga4.prev) { %><%- deltaBadge(data.ga4.totals.avgDuration, data.ga4.prev.avgDuration) %><% } %></div></div>
    </div>
    <% if (data.ga4.trend && data.ga4.trend.length) { %>
      <div class="card mb-3"><div class="card-body p-2">
        <div class="small fw-semibold mb-1">Visitors over time</div>
        <%- barChart(data.ga4.trend, 'users', '#4f46e5') %>
        <div class="d-flex justify-content-between small text-muted px-1"><span><%= fmtD(data.ga4.trend[0].date) %></span><span><%= fmtD(data.ga4.trend[data.ga4.trend.length-1].date) %></span></div>
      </div></div>
    <% } %>
    <div class="row g-3 mb-4">
      <div class="col-md-4"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1">Top pages</div>
        <table class="table table-sm ins-table m-0"><tbody>
          <% (data.ga4.pages||[]).forEach(r => { %><tr><td><%= r.key %></td><td class="num"><%= nf(r.value) %></td></tr><% }) %>
          <% if(!data.ga4.pages.length){ %><tr><td class="text-muted">No data yet</td></tr><% } %>
        </tbody></table>
      </div></div></div>
      <div class="col-md-4"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1">Top countries</div>
        <table class="table table-sm ins-table m-0"><tbody>
          <% (data.ga4.countries||[]).forEach(r => { %><tr><td><%= r.key %></td><td class="num"><%= nf(r.value) %></td></tr><% }) %>
          <% if(!data.ga4.countries.length){ %><tr><td class="text-muted">No data yet</td></tr><% } %>
        </tbody></table>
      </div></div></div>
      <div class="col-md-4"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1">How they found you</div>
        <table class="table table-sm ins-table m-0"><tbody>
          <% (data.ga4.channels||[]).forEach(r => { %><tr><td><%= r.key %></td><td class="num"><%= nf(r.value) %></td></tr><% }) %>
          <% if(!data.ga4.channels.length){ %><tr><td class="text-muted">No data yet</td></tr><% } %>
        </tbody></table>
      </div></div></div>
    </div>
    <div class="row g-3 mb-4">
      <div class="col-md-6"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1">Devices</div>
        <table class="table table-sm ins-table m-0"><tbody>
          <% (data.ga4.devices||[]).forEach(r => { %><tr><td><i class="bi bi-<%= r.key==='mobile'?'phone':(r.key==='tablet'?'tablet':'display') %>"></i> <%= r.key %></td><td class="num"><%= nf(r.value) %></td></tr><% }) %>
          <% if(!data.ga4.devices.length){ %><tr><td class="text-muted">No data yet</td></tr><% } %>
        </tbody></table>
      </div></div></div>
      <div class="col-md-6"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1">New vs returning visitors</div>
        <table class="table table-sm ins-table m-0"><tbody>
          <% (data.ga4.newReturning||[]).forEach(r => { %><tr><td><%= r.key %></td><td class="num"><%= nf(r.value) %></td></tr><% }) %>
          <% if(!data.ga4.newReturning.length){ %><tr><td class="text-muted">No data yet</td></tr><% } %>
        </tbody></table>
      </div></div></div>
    </div>
    <div class="row g-3 mb-4">
      <div class="col-md-6"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1"><i class="bi bi-geo-alt"></i> Top cities</div>
        <table class="table table-sm ins-table m-0"><tbody>
          <% (data.ga4.cities||[]).forEach(r => { %><tr><td><%= r.key %></td><td class="num"><%= nf(r.value) %></td></tr><% }) %>
          <% if(!(data.ga4.cities&&data.ga4.cities.length)){ %><tr><td class="text-muted">No data yet</td></tr><% } %>
        </tbody></table>
      </div></div></div>
      <div class="col-md-6"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1"><i class="bi bi-geo"></i> Top states / regions</div>
        <table class="table table-sm ins-table m-0"><tbody>
          <% (data.ga4.regions||[]).forEach(r => { %><tr><td><%= r.key %></td><td class="num"><%= nf(r.value) %></td></tr><% }) %>
          <% if(!(data.ga4.regions&&data.ga4.regions.length)){ %><tr><td class="text-muted">No data yet</td></tr><% } %>
        </tbody></table>
      </div></div></div>
    </div>
  <% } else if (data.hasGA4) { %>
    <div class="alert alert-light border small">Connected — no visitor data yet. New sites take a day or two to start collecting, and the GA4 tag must be live on the site (deploy after setting the Measurement ID).</div>
  <% } else { %>
    <div class="alert alert-light border small">Analytics not connected yet — add your GA4 Property ID in Connection settings below.</div>
  <% } %>

  <!-- ===== WHAT CHANGED (#3) ===== -->
  <% if (typeof events !== 'undefined' && events && events.length) { %>
    <div class="card mb-4"><div class="card-body p-2">
      <div class="small fw-semibold mb-1"><i class="bi bi-clock-history"></i> What changed <span class="fw-normal text-muted">· recent website activity</span></div>
      <table class="table table-sm ins-table m-0"><tbody>
        <% events.forEach(e => { var ic = e.type==='blog'?'pencil-square':(e.type==='campaign'?'megaphone':'gear'); %>
          <tr><td style="width:95px" class="text-muted"><%= (e.at||'').slice(0,10) %></td><td><i class="bi bi-<%= ic %> text-secondary"></i> <%= e.label || e.type %></td></tr>
        <% }) %>
      </tbody></table>
      <div class="small text-muted px-1 pt-1">Connect a traffic change to what you did — published a post, ran a campaign or edited SEO.</div>
    </div></div>
  <% } %>

  <!-- ===== SEARCH RANKING ===== -->
  <h6 class="text-muted"><i class="bi bi-search"></i> Search ranking <span class="fw-normal small">· last <%= days %> days · Google Search Console</span></h6>
  <% if (data.gsc) { %>
    <div class="row g-2 mb-2">
      <div class="col-6 col-md-3"><div class="tile"><div class="v"><%= nf(data.gsc.totals.clicks) %></div><div class="l">Clicks from Google</div><% if (data.gsc.prev) { %><%- deltaBadge(data.gsc.totals.clicks, data.gsc.prev.clicks) %><% } %></div></div>
      <div class="col-6 col-md-3"><div class="tile"><div class="v"><%= nf(data.gsc.totals.impressions) %></div><div class="l">Times shown</div><% if (data.gsc.prev) { %><%- deltaBadge(data.gsc.totals.impressions, data.gsc.prev.impressions) %><% } %></div></div>
      <div class="col-6 col-md-3"><div class="tile"><div class="v"><%= pct(data.gsc.totals.ctr) %></div><div class="l">Click rate</div><% if (data.gsc.prev) { %><%- deltaBadge(data.gsc.totals.ctr, data.gsc.prev.ctr) %><% } %></div></div>
      <div class="col-6 col-md-3"><div class="tile"><div class="v"><%= pos(data.gsc.totals.position) %></div><div class="l">Avg. position (rank)</div><% if (data.gsc.prev) { %><%- deltaBadge(data.gsc.totals.position, data.gsc.prev.position, true) %><% } %></div></div>
    </div>
    <% if (data.gsc.trend && data.gsc.trend.length) { %>
      <div class="card mb-3"><div class="card-body p-2">
        <div class="small fw-semibold mb-1">Impressions over time <span class="text-muted">(how often you appeared in Google)</span></div>
        <%- barChart(data.gsc.trend, 'impressions', '#0ea5e9') %>
        <div class="d-flex justify-content-between small text-muted px-1"><span><%= fmtD(data.gsc.trend[0].date) %></span><span><%= fmtD(data.gsc.trend[data.gsc.trend.length-1].date) %></span></div>
      </div></div>
    <% } %>
    <div class="row g-3 mb-3">
      <div class="col-md-7"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1">Top search terms (what people typed)</div>
        <table class="table table-sm ins-table m-0">
          <thead><tr><th>Query</th><th class="num">Clicks</th><th class="num">Shown</th><th class="num">Rank</th></tr></thead>
          <tbody>
            <% (data.gsc.queries||[]).slice(0,15).forEach(r => { %><tr><td><%= r.key %></td><td class="num"><%= nf(r.clicks) %></td><td class="num"><%= nf(r.impressions) %></td><td class="num"><%= pos(r.position) %></td></tr><% }) %>
            <% if(!data.gsc.queries.length){ %><tr><td colspan="4" class="text-muted">No queries yet — Google is still indexing.</td></tr><% } %>
          </tbody>
        </table>
      </div></div></div>
      <div class="col-md-5"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1">Top pages in search</div>
        <table class="table table-sm ins-table m-0">
          <thead><tr><th>Page</th><th class="num">Clicks</th><th class="num">Rank</th></tr></thead>
          <tbody>
            <% (data.gsc.pages||[]).forEach(r => { %><tr><td><%= pathOf(r.key) %></td><td class="num"><%= nf(r.clicks) %></td><td class="num"><%= pos(r.position) %></td></tr><% }) %>
            <% if(!data.gsc.pages.length){ %><tr><td colspan="3" class="text-muted">No data yet</td></tr><% } %>
          </tbody>
        </table>
      </div></div></div>
    </div>
  <% } else if (data.hasGSC) { %>
    <div class="alert alert-light border small">Connected — no ranking data yet. Brand-new sites usually show data after a few days to 2 weeks.</div>
  <% } else { %>
    <div class="alert alert-light border small">Search Console not connected yet — add your site URL in Connection settings below.</div>
  <% } %>

  <!-- ===== KEYWORD OPPORTUNITIES ===== -->
  <% if (data.gsc && opportunities) { %>
    <h6 class="text-muted mt-2"><i class="bi bi-bullseye"></i> Keyword opportunities <span class="fw-normal small">· quick wins from your search data</span></h6>
    <div class="row g-3 mb-4">
      <div class="col-md-6"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1"><i class="bi bi-arrow-up-circle text-success"></i> Almost on page 1 — push these up</div>
        <table class="table table-sm ins-table m-0">
          <thead><tr><th>Search term</th><th class="num">Rank</th><th class="num">Shown</th></tr></thead>
          <tbody>
            <% opportunities.striking.forEach(r => { %><tr><td><%= r.key %></td><td class="num"><%= pos(r.position) %></td><td class="num"><%= nf(r.impressions) %></td></tr><% }) %>
            <% if(!opportunities.striking.length){ %><tr><td colspan="3" class="text-muted">Nothing in striking distance yet — more appear as Google indexes you.</td></tr><% } %>
          </tbody>
        </table>
        <div class="small text-muted px-1 pt-1">Put these phrases in your page titles, headings and blog posts to climb from page 2 → page 1.</div>
      </div></div></div>
      <div class="col-md-6"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1"><i class="bi bi-cursor text-primary"></i> Shown a lot, few clicks — rewrite the title</div>
        <table class="table table-sm ins-table m-0">
          <thead><tr><th>Search term</th><th class="num">Shown</th><th class="num">Click rate</th></tr></thead>
          <tbody>
            <% opportunities.lowCtr.forEach(r => { %><tr><td><%= r.key %></td><td class="num"><%= nf(r.impressions) %></td><td class="num"><%= pct(r.ctr) %></td></tr><% }) %>
            <% if(!opportunities.lowCtr.length){ %><tr><td colspan="3" class="text-muted">No low-click terms yet.</td></tr><% } %>
          </tbody>
        </table>
        <div class="small text-muted px-1 pt-1">These appear in Google but few people click — make the title &amp; description more tempting.</div>
      </div></div></div>
    </div>
  <% } %>

  <!-- ===== KEYWORD RANK TRACKING (#7) ===== -->
  <% if (typeof rankHistory !== 'undefined' && rankHistory && rankHistory.hasData) { %>
    <h6 class="text-muted mt-2"><i class="bi bi-graph-down-arrow"></i> Keyword rank tracking <span class="fw-normal small">· lower position = better · builds one snapshot a day</span></h6>
    <div class="row g-3 mb-4">
      <div class="col-md-5"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1">Average Google position over time</div>
        <%- barChart(rankHistory.byDay.map(d => ({ k: d.day, inv: (d.pos > 0 ? (101 - d.pos) : 0) })), 'inv', '#16a34a') %>
        <div class="d-flex justify-content-between small text-muted px-1"><span><%= rankHistory.byDay[0].day %></span><span>now: avg rank <%= rankHistory.byDay[rankHistory.byDay.length-1].pos %></span></div>
      </div></div></div>
      <div class="col-md-7"><div class="card h-100"><div class="card-body p-2">
        <div class="small fw-semibold mb-1">Tracked keywords — movement</div>
        <table class="table table-sm ins-table m-0">
          <thead><tr><th>Search term</th><th class="num">First</th><th class="num">Now</th><th class="num">Change</th></tr></thead>
          <tbody>
            <% rankHistory.top.forEach(t => { var ch = (t.firstPos && t.lastPos) ? (t.firstPos - t.lastPos) : 0; %>
              <tr><td><%= t.query %></td><td class="num"><%= pos(t.firstPos) %></td><td class="num"><%= pos(t.lastPos) %></td>
                <td class="num"><% if (Math.abs(ch) < 0.1) { %><span class="text-muted">—</span><% } else if (ch > 0) { %><span class="text-success">▲ <%= ch.toFixed(1) %></span><% } else { %><span class="text-danger">▼ <%= Math.abs(ch).toFixed(1) %></span><% } %></td></tr>
            <% }) %>
          </tbody>
        </table>
        <div class="small text-muted px-1 pt-1">▲ = climbed (better). History grows daily, so this fills in over the coming weeks.</div>
      </div></div></div>
    </div>
  <% } %>

  <!-- ===== BLOG IDEAS (#9) ===== -->
  <% if (typeof suggestions !== 'undefined' && suggestions && suggestions.length) { %>
    <h6 class="text-muted mt-2"><i class="bi bi-lightbulb"></i> Blog &amp; page ideas <span class="fw-normal small">· searches you have no page for yet</span></h6>
    <div class="card mb-4"><div class="card-body p-2">
      <table class="table table-sm ins-table m-0">
        <thead><tr><th>People search this — write a page for it</th><th class="num">Shown</th><th class="num">Rank</th></tr></thead>
        <tbody>
          <% suggestions.forEach(s => { %><tr><td><%= s.query %></td><td class="num"><%= nf(s.impressions) %></td><td class="num"><%= pos(s.position) %></td></tr><% }) %>
        </tbody>
      </table>
      <div class="small text-muted px-1 pt-1">Google already shows you for these but you have no dedicated page. A blog post or product page for each captures that traffic.</div>
    </div></div>
  <% } %>
<% } %>

<!-- ===== CONNECTION SETTINGS / SETUP ===== -->
<div class="card mt-2">
  <div class="card-header bg-white d-flex justify-content-between align-items-center" style="cursor:pointer" data-bs-toggle="collapse" data-bs-target="#cfgBody">
    <span><i class="bi bi-gear"></i> Connection settings
      <% if (data.configured) { %><span class="badge bg-success ms-1">connected</span><% } else { %><span class="badge bg-secondary ms-1">not connected</span><% } %>
    </span>
    <i class="bi bi-chevron-down"></i>
  </div>
  <div class="collapse <%= data.configured ? '' : 'show' %>" id="cfgBody"><div class="card-body">

    <div class="alert alert-light border small">
      <strong>One-time Google setup</strong> (about 10 minutes):
      <ol class="mb-0 mt-1">
        <li>Go to <a href="https://console.cloud.google.com/" target="_blank">console.cloud.google.com</a> → create a project (e.g. <em>Sharv Website</em>).</li>
        <li><strong>APIs &amp; Services → Library</strong> → enable both: <em>Google Search Console API</em> and <em>Google Analytics Data API</em>.</li>
        <li><strong>APIs &amp; Services → Credentials → Create credentials → Service account</strong> → name it → Done.</li>
        <li>Open that service account → <strong>Keys → Add key → Create new key → JSON</strong>. A <code>.json</code> file downloads.</li>
        <li>Open the file, copy <strong>everything</strong>, and paste it into the box below. Save.</li>
        <li>Grant the service account access to your data using its email <% if (cfg.sa_email) { %>(<code><%= cfg.sa_email %></code>)<% } else { %>(shown here after you save the JSON)<% } %>:
          <ul>
            <li><strong>Search Console</strong> → Settings → Users and permissions → Add user → that email → <em>Full</em>.</li>
            <li><strong>Analytics</strong> → Admin → Property access management → + → that email → <em>Viewer</em>.</li>
          </ul>
        </li>
      </ol>
    </div>

    <form method="post" action="/website/insights/config">
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">GA4 Measurement ID <span class="text-muted">(public tag)</span></label>
          <input name="ga4_measurement_id" class="form-control" placeholder="G-XXXXXXXXXX" value="<%= cfg.ga4_measurement_id %>">
          <div class="form-text">Analytics → Admin → Data Streams → your web stream.</div>
        </div>
        <div class="col-md-4">
          <label class="form-label">GA4 Property ID <span class="text-muted">(numeric)</span></label>
          <input name="ga4_property_id" class="form-control" placeholder="123456789" value="<%= cfg.ga4_property_id %>">
          <div class="form-text">Analytics → Admin → Property settings.</div>
        </div>
        <div class="col-md-4">
          <label class="form-label">Search Console site URL</label>
          <input name="gsc_site_url" class="form-control" placeholder="https://sharvexports.com/" value="<%= cfg.gsc_site_url %>">
          <div class="form-text">Exactly as shown in Search Console.</div>
        </div>
        <div class="col-12">
          <label class="form-label">Service account key (JSON)
            <% if (cfg.sa_configured) { %><span class="badge bg-success">saved</span><% } %>
          </label>
          <textarea name="sa_json" rows="4" class="form-control" style="font-family:monospace;font-size:.72rem" placeholder='<%= cfg.sa_configured ? "Already saved — paste a new key only to replace it." : "{ \"type\": \"service_account\", \"client_email\": \"...\", \"private_key\": \"...\" }" %>'></textarea>
          <% if (cfg.sa_configured) { %>
            <div class="form-check mt-1"><input class="form-check-input" type="checkbox" name="clear_sa" value="1" id="clearSa"><label class="form-check-label small" for="clearSa">Disconnect (remove the saved key)</label></div>
          <% } %>
        </div>
      </div>
      <div class="mt-3"><button class="btn btn-primary"><i class="bi bi-save"></i> Save &amp; connect</button></div>
    </form>
  </div></div>
</div>
<script>
(function(){
  var box=document.getElementById('liveBox'), n=document.getElementById('liveN');
  if(!box) return;
  function tick(){
    fetch('/website/insights/realtime').then(function(r){return r.json();}).then(function(d){
      if(d && d.users!=null){ box.style.display=''; n.textContent=d.users; }
    }).catch(function(){});
  }
  tick(); setInterval(tick, 30000);
})();
</script>
<%- include('../partials/footer') %>
